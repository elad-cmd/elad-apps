<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Foreground service is required to hold a MediaProjection session -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_tile_scan"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Transparent">

        <!-- Optional launcher entry: explains the app and lets the user add the tile -->
        <activity
            android:name=".InfoActivity"
            android:exported="true"
            android:theme="@style/Theme.Transparent">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Quick Settings tile -->
        <service
            android:name=".ScanTileService"
            android:exported="true"
            android:icon="@drawable/ic_tile_scan"
            android:label="@string/tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Transparent activity that requests the screen-capture consent -->
        <activity
            android:name=".CaptureActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:theme="@style/Theme.Transparent" />

        <!-- Foreground service that performs the single-frame capture + decode -->
        <service
            android:name=".ScreenCaptureService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <!-- Shows the decoded text when it is not a URL -->
        <activity
            android:name=".ResultActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.Dialog" />

    </application>
</manifest>
