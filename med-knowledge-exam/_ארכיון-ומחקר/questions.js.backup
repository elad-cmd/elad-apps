/* בנק שאלות התרגול — מבחן הידע לרפואה. נבנה אוטומטית מקובצי JSON. */

const SUBJ = {"biochem":"ביוכימיה","mol":"מולקולרית","cell":"ביולוגיה של התא","physio":"פיזיולוגיה"};

const PRACTICE = {
  biochem: [
    {"topic":"מבנה חלבונים וחומצות אמינו","q":"חלבון קטן עבר דנטורציה מלאה באמצעות אוריאה (urea) 8M ו-בטא-מרקפטואתנול (beta-mercaptoethanol). לאחר הסרה איטית של שני הריאגנטים בדיאליזה החלבון חזר באופן ספונטני לפעילותו המלאה. מה ניתן להסיק מכך?","o":["המידע הדרוש לקיפול התלת-ממדי הסופי מקודד כולו ברצף חומצות האמינו","קיפול החלבון מצריך בהכרח שפרונים (chaperones) ייעודיים","קשרי הדיסולפיד שנוצרו מחדש נקבעים אקראית ולכן הפעילות נשמרת במקרה","הקיפול הסופי נקבע על ידי הקצה ה-N-טרמינלי בלבד"],"a":0,"e":"העיקרון: בניסוי הקלאסי של אנפינסן (Anfinsen) על ריבונוקלאז, החלבון עבר דנטורציה ב-אוריאה (urea) ובחומר מחזר, ואז התקפל מחדש באופן ספונטני לאחר הסרת הריאגנטים. מכאן המסקנה: המבנה התלת-ממדי הפעיל הוא המצב היציב תרמודינמית, וכל המידע לקיפול טמון ברצף חומצות האמינו (המבנה הראשוני). מדוע המסיחים שגויים: ב' — דווקא היעדר הצורך בעזרה חיצונית הוא העיקר; שפרונים (chaperones) מזרזים קיפול בתא אך אינם קובעים את המבנה הסופי. ג' — חזרה אקראית של קשרי הדיסולפיד הייתה נותנת תערובת לא-פעילה; ההתאוששות מוכיחה שהקיפול מכוון את חיבורם הנכון. ד' — כל הרצף תורם, לא רק הקצה ה-N. טיפ: 'הרצף קובע את המבנה' — דוגמה ב, ג ו-ד מנוגדים ישירות למסקנה."},
    {"topic":"מבנה חלבונים וחומצות אמינו","q":"פפטיד מכיל את הרצף Glu-His-Lys. בעבודה ב-pH 7.0, מה הטעינה הנקייה (net charge) המשוערת של הפפטיד כולו, בהתחשב גם בקצוות? (pKa מקורבים: alpha-COOH כ-3.1, alpha-NH3+ כ-8.0, שרשרת צד Glu כ-4.25, His כ-6.0, Lys כ-10.5)","o":["0","1+","1-","2+"],"a":0,"e":"העיקרון: כדי לחשב מטען נקי (net charge) ב-pH נתון בודקים כל קבוצה מתפרקת — אם ה-pH מעל ה-pKa היא מאבדת פרוטון (קבוצות חומציות נטענות שלילית, בסיסיות הופכות ניטרליות). ב-pH 7: קצה קרבוקסילי (pKa 3.1) שלילי, שרשרת Glu (4.25) שלילית, His (6.0) כמעט ניטרלי כי ה-pH מעל ה-pKa, Lys (10.5) חיובי, קצה אמיני (8.0) חיובי. הסיכום: (1+)+(1+)+(1-)+(1-)=0. מדוע המסיחים שגויים: התשובות 1+/1-/2+ נובעות משכחת אחד מהקצוות או ממתן מטען חיובי מלא ל-His. Pitfall נפוץ: לזכור לכלול תמיד את שני הקצוות (alpha-COOH ו-alpha-NH3+), ולא להניח ש-His טעון מלא ב-pH פיזיולוגי — הוא קרוב לחצי-פרוטונציה ותרומתו זניחה."},
    {"topic":"מבנה חלבונים וחומצות אמינו","q":"מדוע הקשר הפפטידי מציג אופי חלקי של קשר כפול והוא בעל מישוריות (planarity)?","o":["רזוננס שבו זוג האלקטרונים הלא-קושר של חנקן האמיד מתחלק עם קשר הקרבוניל C=O","היווצרות קשר מימן בין החנקן לחמצן הקרבוניל באותו קשר פפטידי","דחיות סטריות בין שרשראות הצד הצמודות המקבעות את המישור","יוניזציה של החנקן ההופך לחיובי ומקבע את הזווית"],"a":0,"e":"העיקרון: לקשר הפפטידי אופי חלקי של קשר כפול בגלל רזוננס — זוג האלקטרונים הלא-קושר של חנקן האמיד נדחק אל קשר הקרבוניל (C=O), כך שקשר ה-C-N מקבל כ-40% אופי קשר כפול. תוצאת הרזוננס: סיבוב סביב הקשר חסום, וששת האטומים סביבו (Calpha-CO-NH-Calpha) שוכבים במישור אחד. מכאן שהשלד הפפטידי מורכב מסדרה של מישורים נוקשים המחוברים בקשרי Calpha, וגמישותו מתבטאת בעיקר בזוויות פי (phi) ו-פסי (psi). מדוע המסיחים שגויים: ב' — אין קשר מימן פנימי בתוך הקשר עצמו. ג' — דחיות סטריות משפיעות על זוויות פי ופסי, לא על מישוריות הקשר. ד' — אין יוניזציה של חנקן האמיד בתנאים פיזיולוגיים. טיפ: מישוריות = רזוננס, וזו הסיבה שהקשר טראנס מועדף."},
    {"topic":"תפקוד חלבונים","q":"בהשוואה בין מיוגלובין (myoglobin) להמוגלובין (hemoglobin), מדוע עקומת קשירת החמצן של המוגלובין סיגמואידלית בעוד של מיוגלובין היפרבולית?","o":["המוגלובין הוא רב-תת-יחידתי ומפגין קואופרטיביות בין אתרי הקשירה, ואילו מיוגלובין מונומרי","למיוגלובין זיקה נמוכה יותר לחמצן ולכן עקומתו היפרבולית","המוגלובין קושר חמצן רק במצב T ולכן הקשירה הדרגתית","מיוגלובין מכיל ברזל תלת-ערכי שאינו קושר חמצן באופן שיתופי"],"a":0,"e":"העיקרון: ההבדל בצורת העקומות נובע ממבנה החלבונים. המוגלובין (hemoglobin) רב-תת-יחידתי (ארבע תת-יחידות), והוא מפגין קואופרטיביות — קשירת חמצן בתת-יחידה אחת מסיטה את כל המבנה ממצב T (זיקה נמוכה) למצב R (זיקה גבוהה), ומגבירה את זיקת השאר. אינטראקציה זו יוצרת את העקומה הסיגמואידלית, המתאימה לחלבון הסעת חמצן שצריך לקשור ברֵאות ולשחרר ברקמות. מיוגלובין (myoglobin) מונומרי, אין בו אינטראקציה בין אתרים, ולכן עקומתו היפרבולית — מתאים לאחסון חמצן בשריר. מדוע המסיחים שגויים: ב' — זיקה נמוכה לבדה אינה יוצרת סיגמואידיות; דווקא למיוגלובין זיקה גבוהה. ג' — הקשירה גוררת מעבר T ל-R ואינה נשארת ב-T. ד' — הברזל הפעיל הוא דו-ערכי (Fe2+) בשני החלבונים. טיפ: סיגמואידי = קואופרטיביות = רב-תת-יחידתי."},
    {"topic":"תפקוד חלבונים","q":"עלייה בריכוז ה-CO2 וירידת pH ברקמה פעילה מורידות את זיקת ההמוגלובין לחמצן ומקדמות שחרורו (אפקט בוהר). מהו ההסבר המולקולרי המרכזי?","o":["פרוטונים ו-CO2 מייצבים את מצב T באמצעות קשירה לשאריות מסוימות וקרבמט, ומפחיתים זיקה","פרוטונים נקשרים ישירות לברזל ההם ומגרשים את החמצן","CO2 מתחרה עם החמצן על אותו אתר קשירה בדיוק על הברזל","ירידת ה-pH גורמת לדנטורציה הפיכה המפחיתה זיקה"],"a":0,"e":"העיקרון: אפקט בוהר (Bohr effect) — עלייה בריכוז ה-CO2 וירידת pH ברקמה פעילה מקדמות שחרור חמצן מהמוגלובין בדיוק היכן שצריך. מולקולרית: פרוטונים מתייצבים על שאריות מסוימות (כגון His146 בשרשרת בטא), ו-CO2 נקשר לקצוות האמיניים ויוצר קרבמט; שניהם מייצבים את מצב T בעל הזיקה הנמוכה, ולכן החמצן משתחרר. מדוע המסיחים שגויים: ב' — הפרוטונים נקשרים לשאריות חומצות אמינו ולא ישירות לברזל ההֵם. ג' — CO2 אינו מתחרה על אתר הברזל אלא נקשר כקרבמט לקצוות האמיניים. ד' — אין דנטורציה; זהו ויסות אלוסטרי הפיך לחלוטין. טיפ: רקמה פעילה = הרבה CO2 וחומצה = T יציב = שחרור חמצן — בדיוק כשהרקמה זקוקה לו."},
    {"topic":"תפקוד חלבונים","q":"2,3-ביספוספוגליצרט (2,3-BPG) הוא מווסת חשוב של המוגלובין. כיצד הוא משפיע על קשירת חמצן ומדוע הדבר חיוני?","o":["נקשר בחלל המרכזי של מצב T ומייצב אותו, מוריד זיקה ומאפשר פריקת חמצן יעילה ברקמות","נקשר לאתר ההם ומגביר את זיקת החמצן בריאות","נקשר רק לאוקסי-המוגלובין (מצב R) ומקבע אותו","מפרק את המוגלובין לתת-יחידות ומגביר שחרור חמצן"],"a":0,"e":"העיקרון: 2,3-ביספוספוגליצרט (2,3-BPG) הוא מאפנן אלוסטרי שלילי של המוגלובין. הוא נקשר בחלל המרכזי הטעון חיובי של דאוקסי-המוגלובין (מצב T), מייצב אותו ומוריד את זיקת ההמוגלובין לחמצן. בלעדיו ההמוגלובין היה קושר חמצן חזק מדי ולא משחרר אותו ברקמות. רמת 2,3-BPG עולה בהסתגלות לגובה רב או באנמיה כרונית, ומשפרת את אספקת החמצן לרקמות. מדוע המסיחים שגויים: ב' — הוא מוריד זיקה ולא מעלה, ואינו נקשר לאתר ההֵם. ג' — הוא נקשר דווקא למצב T (דאוקסי) ולא ל-R. ד' — הוא אינו מפרק את החלבון. טיפ: 2,3-BPG נקשר רק לדאוקסי (T) — לכן 'ממתין' לרקמה שבה צריך לשחרר חמצן."},
    {"topic":"אנזימים וקינטיקה","q":"שני אנזימים פועלים על אותו סובסטרט. לאנזים A יש Km=0.1 mM ו-kcat=100 s-1; לאנזים B יש Km=2 mM ו-kcat=1000 s-1. בריכוז סובסטרט נמוך מאוד (הרבה מתחת ל-Km של שניהם), איזה אנזים יעיל יותר?","o":["אנזים A, כי kcat/Km שלו גבוה יותר","אנזים B, כי kcat שלו גבוה יותר","שניהם זהים ביעילות כי המכפלה kcat כפול Km שווה","אנזים B, כי Km שלו גבוה יותר ולכן הוא קושר טוב יותר"],"a":0,"e":"העיקרון: בריכוז סובסטרט נמוך מאוד (הרבה מתחת ל-Km) היעילות הקטליטית נשלטת על ידי קבוע היעילות kcat/Km, ולא על ידי kcat לבדו. נחשב: אנזים A — 100/0.1 = 1000 mM-1 s-1; אנזים B — 1000/2 = 500. לכן A יעיל פי שניים, אף שה-kcat שלו נמוך פי 10. הסיבה: כשהסובסטרט נדיר, מה שקובע הוא כמה טוב האנזים תופס וקושר אותו (Km נמוך = זיקה גבוהה), לא כמה מהר הוא עובד כשהוא רווי. מדוע המסיחים שגויים: ב' — kcat גבוה מכריע רק בריווי (סובסטרט עודף). ג' — הפרמטר הוא היחס kcat/Km, לא מכפלה. ד' — Km גבוה משמעו זיקה נמוכה (קשירה חלשה), לא טובה יותר. טיפ: kcat/Km הוא 'מדד שלמות קטליטית' — שלוט בו לשאלות השוואת אנזימים."},
    {"topic":"אנזימים וקינטיקה","q":"מעכב נבדק בניסוי קינטי. בנוכחותו ה-Vmax הנמדד נשאר ללא שינוי, אך ה-Km האפקטיבי עולה. מאיזה סוג עיכוב מדובר ומה הבסיס המולקולרי?","o":["עיכוב תחרותי - המעכב נקשר לאתר הפעיל ומתחרה בסובסטרט, וניתן להתגבר בריכוז סובסטרט גבוה","עיכוב לא-תחרותי - המעכב נקשר לאתר נפרד ומשנה את ה-Vmax","עיכוב א-תחרותי - המעכב נקשר רק לקומפלקס ES ומוריד גם Km וגם Vmax","עיכוב מעורב - המעכב משנה גם זיקה וגם קצב מקסימלי באופן בלתי תלוי"],"a":0,"e":"העיקרון: סוג העיכוב נקבע לפי השפעתו על Vmax ועל Km. כאן Vmax לא משתנה אך Km האפקטיבי עולה — חתימה מובהקת של עיכוב תחרותי (competitive). מולקולרית: המעכב דומה לסובסטרט ונקשר לאתר הפעיל עצמו, ולכן מתחרה בו; בריכוז סובסטרט גבוה אפשר 'להציף' את המעכב ולהגיע לאותו Vmax, אך נדרש יותר סובסטרט (Km נראה גבוה יותר). מדוע המסיחים שגויים: ב' — בעיכוב לא-תחרותי Vmax יורד. ג' — בא-תחרותי גם Km וגם Vmax יורדים. ד' — במעורב לרוב Vmax כן יורד. הנתון של Vmax ללא שינוי מצביע חד-משמעית על תחרותי. טיפ: 'תחרותי = Vmax שמור, Km עולה, וניתן להתגבר בעודף סובסטרט'."},
    {"topic":"אנזימים וקינטיקה","q":"בתרשים Lineweaver-Burk (1/V מול 1/[S]) של אנזים בנוכחות מעכב, הקווים בנוכחות ובהיעדר המעכב נחתכים על ציר ה-y (אותו חיתוך, כלומר אותו 1/Vmax) אך בעלי שיפועים שונים. איזה סוג עיכוב זה?","o":["תחרותי","א-תחרותי","לא-תחרותי טהור","מעורב"],"a":0,"e":"העיקרון: בתרשים Lineweaver-Burk מציירים 1/V מול 1/[S]; החיתוך עם ציר ה-y שווה ל-1/Vmax והשיפוע פרופורציוני ל-Km/Vmax. כאשר הקווים עם וללא מעכב נחתכים באותה נקודה על ציר ה-y (אותו 1/Vmax, כלומר Vmax זהה) אך שיפועיהם שונים — זהו עיכוב תחרותי: Vmax נשמר, Km הנראה עולה (השיפוע גדל). מדוע המסיחים שגויים: ב' — בעיכוב א-תחרותי הקווים מקבילים (אותו שיפוע). ג' — בלא-תחרותי טהור החיתוך המשותף הוא על ציר ה-x (אותו Km) וה-1/Vmax שונה. ד' — במעורב משתנים גם החיתוך וגם השיפוע. טיפ לזכירה: 'חיתוך משותף על y' = Vmax זהה = תחרותי; 'קווים מקבילים' = א-תחרותי; 'חיתוך משותף על x' = לא-תחרותי."},
    {"topic":"אנזימים וקינטיקה","q":"זימוגנים (zymogens) כגון טריפסינוגן וכימוטריפסינוגן מופרשים בצורה לא-פעילה. מהי המשמעות הפונקציונלית העיקרית של הפעלה על ידי חיתוך פרוטאוליטי?","o":["הפעלה היא בלתי-הפיכה ומאפשרת בקרה מרחבית-זמנית על אנזים הרסני, ומונעת עיכול עצמי מוקדם","ההפעלה הפיכה ומאפשרת לתא לכבות את האנזים בעת הצורך","החיתוך משנה את רצף חומצות האמינו של האתר הפעיל ויוצר שאריות קטליטיות חדשות","הזימוגן פעיל חלקית והחיתוך רק מגביר במעט את הקצב"],"a":0,"e":"העיקרון: זימוגנים (zymogens) כגון טריפסינוגן וכימוטריפסינוגן מופרשים בצורה לא-פעילה, ומופעלים על ידי חיתוך פרוטאוליטי ספציפי שמשנה את הקונפורמציה ומרכיב את האתר הפעיל. המשמעות הפונקציונלית: ההפעלה היא שינוי קוולנטי בלתי-הפיך, המאפשר בקרה מרחבית-זמנית מדויקת על אנזימים הרסניים (אנזימי עיכול, גורמי קרישה) ומונע 'עיכול עצמי' מוקדם של הרקמה. מדוע המסיחים שגויים: ב' — בניגוד לזרחון, חיתוך פרוטאוליטי אינו הפיך, ולכן אינו מנגנון כיבוי. ג' — שאריות האתר הפעיל כבר קיימות ברצף; החיתוך גורם לסידור מחדש קונפורמציוני, לא יוצר שאריות חדשות. ד' — הזימוגן בלתי-פעיל ממשית, לא 'פעיל חלקית'. טיפ: זרחון = הפיך (מתג); חיתוך פרוטאוליטי = חד-כיווני (גזירת חוט בלון)."},
    {"topic":"אנזימים וקינטיקה","q":"אנזים אלוסטרי המפגין קינטיקה סיגמואידלית מעובד על ידי מאפנן שלילי (אפקטור שלילי). מה צפוי לקרות לעקומת הקצב מול ריכוז הסובסטרט?","o":["העקומה תיסוג ימינה (יידרש ריכוז סובסטרט גבוה יותר לחצי-ריווי), כלומר זיקה נראית פוחתת","העקומה הופכת היפרבולית כי המאפנן מבטל את הקואופרטיביות","Vmax עולה משמעותית בעוד K0.5 ללא שינוי","העקומה תיסוג שמאלה כי המאפנן השלילי מגביר זיקה"],"a":0,"e":"העיקרון: אנזים אלוסטרי מפגין עקומת קצב סיגמואידלית. מאפנן שלילי (אפקטור שלילי) מייצב את הקונפורמציה בעלת הזיקה הנמוכה (מצב T), ולכן נדרש ריכוז סובסטרט גבוה יותר כדי להגיע לחצי-ריווי — העקומה נסוגה ימינה ו-K0.5 עולה (זיקה נראית פוחתת). מדוע המסיחים שגויים: ב' — הקואופרטיביות נשמרת ואף מתחזקת; העקומה אינה הופכת היפרבולית. ג' — לרוב Vmax אינו עולה; ההשפעה העיקרית של אנזימים מסוג K היא על K0.5. ד' — הסטה שמאלה (הגברת זיקה) מאפיינת מאפנן חיובי, ההפך מהנשאל. טיפ לזכירה: מאפנן שלילי = ייצוב T = העקומה 'בורחת ימינה' = צריך יותר סובסטרט. השווה למאפנן חיובי שמסיט שמאלה."},
    {"topic":"ביו-אנרגטיקה ותרמודינמיקה","q":"תגובה בתא יש לה ΔG°' של +7.5 kJ/mol. בתנאי התא ריכוז התוצרים נמוך מאוד וריכוז המגיבים גבוה. מה ניתן לומר על מהלך התגובה בפועל?","o":["התגובה עשויה להתקדם קדימה (ΔG שלילי) אם יחס המגיבים לתוצרים גבוה מספיק, למרות ΔG°' חיובי","התגובה לעולם לא תתקדם קדימה כי ΔG°' חיובי","ΔG°' חיובי קובע שהתגובה איטית מאוד אך ספונטנית","רק קטליזה אנזימטית יכולה להפוך את ΔG לשלילי"],"a":0,"e":"העיקרון: ΔG°' (ההפרש הסטנדרטי) אינו קובע לבדו את כיוון התגובה בתא — ה-ΔG הממשי תלוי גם בריכוזים, לפי ΔG = ΔG°' + RT·ln([תוצרים]/[מגיבים]). כאשר ריכוז המגיבים גבוה והתוצרים נמוכים, האיבר הלוגריתמי שלילי מאוד ויכול להפוך את ה-ΔG הכולל לשלילי, כך שהתגובה מתקדמת קדימה למרות ΔG°' חיובי (+7.5 kJ/mol). זה עיקרון מפתח שמסביר כיצד שלבים 'לא נוחים' במסלולים מתבצעים — סילוק מתמיד של התוצר 'מושך' אותם קדימה. מדוע המסיחים שגויים: ב' — ΔG°' חיובי אינו מונע ספונטניות בתנאים תאיים. ג' — ΔG°' אינו קובע קצב (זה תפקיד אנרגיית האקטיבציה). ד' — קטליזה משפיעה על קצב בלבד ולא על ΔG. טיפ: ΔG אמיתי = ΔG°' פלוס תיקון ריכוזים."},
    {"topic":"ביו-אנרגטיקה ותרמודינמיקה","q":"מדוע ATP מכונה \"מטבע אנרגיה\" בעל קשרי פוספט עתירי אנרגיה, וההידרוליזה שלו ל-ADP ו-Pi משחררת אנרגיה רבה?","o":["התוצרים (ADP ו-Pi) יציבים יותר בזכות הקלת דחיית מטענים, ייצוב רזוננס וטוב יותר בסולבטציה","הקשר הפוספואנהידרידי עצמו מכיל אנרגיה כימית רבה הכלואה פיזית בתוכו","הברזל הקשור ל-ATP משחרר אלקטרונים בעת ההידרוליזה","ATP הוא היחיד שיכול לעבור הידרוליזה אקסרגונית בתא"],"a":0,"e":"העיקרון: ATP מכונה 'מטבע אנרגיה' מפני שהידרוליזה שלו ל-ADP ו-Pi משחררת אנרגיה חופשית רבה — אך מקור האנרגיה אינו 'כלוא בקשר'. הסיבה האמיתית היא יציבות גבוהה יותר של התוצרים: הקלת דחייה אלקטרוסטטית בין המטענים השליליים הסמוכים בשרשרת הפוספטים, ייצוב רזוננס רב יותר של Pi ו-ADP, וסולבטציה (מעטפת מים) טובה יותר. מדוע המסיחים שגויים: ב' — תפיסה שגויה נפוצה; האנרגיה אינה 'כלואה פיזית' בקשר אלא נובעת מהפרש היציבות בין מגיבים לתוצרים. ג' — אין ברזל ב-ATP. ד' — מולקולות אחרות (כגון פוספואנול-פירובט, PEP, ו-1,3-ביספוספוגליצרט) הן עתירות אנרגיה אף יותר. טיפ: 'קשר עתיר אנרגיה' = תוצרים יציבים יותר ממגיבים, לא אנרגיה אצורה בקשר."},
    {"topic":"ביו-אנרגטיקה ותרמודינמיקה","q":"בשרשרת ההעברה של אלקטרונים, האלקטרונים זורמים בכיוון של פוטנציאל חיזור סטנדרטי (E°') הולך וגדל (חיובי יותר). אם זוג A בעל E°'=-0.32V וזוג B בעל E°'=+0.82V, מה נכון?","o":["אלקטרונים יזרמו ספונטנית מ-A ל-B, והתהליך הכולל אקסרגוני (ΔG שלילי)","אלקטרונים יזרמו ספונטנית מ-B ל-A כי B הוא מחזר חזק","הזרימה ספונטנית מ-A ל-B אך התהליך אנדרגוני","אין זרימה ספונטנית כי הפרש הפוטנציאלים חיובי"],"a":0,"e":"העיקרון: בשרשרת מעבר האלקטרונים האלקטרונים זורמים ספונטנית מזוג בעל פוטנציאל חיזור סטנדרטי (E°') נמוך (מחזר חזק, נותן אלקטרונים בקלות) לזוג בעל E°' גבוה (מחמצן חזק, 'רעב' לאלקטרונים). כאן A (E°'=-0.32V) הוא הנותן ו-B (E°'=+0.82V) הוא המקבל, ולכן זרימה מ-A ל-B. ההפרש ΔE°' חיובי (+1.14V), ולפי ΔG°'=-nF·ΔE°' התהליך אקסרגוני (ΔG שלילי). מדוע המסיחים שגויים: ב' — B בעל E°' גבוה הוא מחמצן, לא מחזר. ג' — הכיוון נכון אך התהליך אקסרגוני (ΔG שלילי), לא אנדרגוני. ד' — דווקא ΔE°' חיובי מאפשר זרימה ספונטנית. טיפ לזכירה: אלקטרונים 'נופלים' לכיוון E°' חיובי יותר, כמו מים שיורדים במדרון — וזה משחרר אנרגיה לשאיבת פרוטונים."},
    {"topic":"פחמימות","q":"מולקולת לקטוז (lactose) בנויה מגלקטוז וגלוקוז בקשר beta-1,4. בבדיקה היא מפגינה תכונה של סוכר מחזר (reducing sugar), בעוד סוכרוז (sucrose) אינו מחזר. מה ההסבר?","o":["ללקטוז יש קצה מחזר חופשי (פחמן אנומרי חופשי ביחידת הגלוקוז), ואילו בסוכרוז שני הפחמנים האנומריים קשורים זה לזה","הקשר beta תמיד מחזר והקשר alpha לעולם אינו מחזר","לקטוז מכיל גלקטוז שהוא מחזר חזק יותר מפרוקטוז","סוכרוז גדול מדי מכדי להגיב בבדיקת החיזור"],"a":0,"e":"העיקרון: 'סוכר מחזר' (reducing sugar) הוא סוכר בעל פחמן אנומרי חופשי — קבוצת הֶמיאצטל שיכולה להיפתח בשיווי משקל לצורת אלדהיד/קטו ולחזר. בלקטוז (lactose), הקשר הוא beta-1,4 בין הפחמן האנומרי של הגלקטוז לפחמן 4 של הגלוקוז, כך שהפחמן האנומרי של הגלוקוז נשאר חופשי — ולכן לקטוז מחזר. בסוכרוז (sucrose) הקשר הוא בין שני הפחמנים האנומריים (glc alpha-1 ל-fru beta-2), שניהם 'נעולים', ולכן אין קצה מחזר. מדוע המסיחים שגויים: ב' — אופי הקשר alpha/beta אינו קובע יכולת חיזור. ג' — היכולת תלויה בפחמן אנומרי חופשי, לא בזהות הסוכר. ד' — הגודל אינו הגורם. טיפ: בדוק אם פחמן אנומרי כלשהו פנוי — אם כן, הסוכר מחזר."},
    {"topic":"גליקוליזה","q":"תא שריר במאמץ מבצע גליקוליזה מגלוקוז ללקטט. מהי התפוקה הנטו של ATP ו-NADH לכל מולקולת גלוקוז במצב זה?","o":["2 ATP ו-2 NADH","2 ATP ו-0 NADH","4 ATP ו-2 NADH","2 ATP ו-2 FADH2"],"a":1,"e":"העיקרון: בגליקוליזה התפוקה הגולמית היא 4 ATP, אך 2 הושקעו בשלב ההכנה, כך שהנטו 2 ATP ו-2 NADH לכל גלוקוז. אולם כאשר הגורל הוא לקטט (תנאים אנאירוביים), ה-NADH שנוצר בשלב גליצראלדהיד-3-פוספט דהידרוגנאז מנוצל מיד על ידי לקטט דהידרוגנאז כדי לחדש NAD+. לכן בתהליך הכולל מגלוקוז ללקטט אין צבירה נטו של NADH — הנטו הוא 2 ATP ו-0 NADH. זהו 'מאזן סגור' המאפשר לגליקוליזה להמשיך גם בלי חמצן. מדוע המסיחים שגויים: א' — מתעלם מחידוש ה-NAD+ על ידי LDH. ג' — מתעלם מההשקעה של 2 ATP. ד' — גליקוליזה מייצרת NADH ולא FADH2. טיפ: 'גלוקוז ללקטט = 2 ATP, אפס NADH נטו' כי ה-NADH ממוחזר במקום."},
    {"topic":"גליקוליזה","q":"תרכובת מעכבת באופן ספציפי את אנולאז (enolase). באיזה מטבוליט תיווצר הצטברות מיידית במעלה הזרם (upstream) של החסם?","o":["פוספואנולפירובט (PEP)","2-פוספוגליצרט","פירובט","פרוקטוז-1,6-ביספוספט"],"a":1,"e":"העיקרון: אנולאז (enolase) מזרז את ההמרה של 2-פוספוגליצרט לפוספואנולפירובט (PEP) תוך סילוק מולקולת מים (דהידרציה). כשמעכבים אנזים, המטבוליט שמצטבר מיד הוא המצע (סובסטרט) שלו — כאן 2-פוספוגליצרט, שכן הוא נכנס לאנזים החסום ולא יכול להפוך לתוצר. זהו עיקרון כללי לכל שאלות 'חסם במסלול': מצטבר מה שנמצא מיד במעלה הזרם. מדוע המסיחים שגויים: א' — PEP הוא התוצר (downstream), ודווקא ריכוזו ירד. ג' — פירובט נמצא במורד הזרם הרחוק יותר (אחרי פירובט קינאז). ד' — פרוקטוז-1,6-ביספוספט אמנם במעלה הזרם, אך רחוק מהחסם; ההצטברות המיידית היא של המצע הישיר. טיפ: בחסם אנזימטי 'מתמלא הדלי' ישירות לפני האנזים החסום."},
    {"topic":"גליקוליזה","q":"מהו ההבדל המרכזי בין הקסוקינאז (hexokinase) לגלוקוקינאז (glucokinase) שבכבד מבחינת תכונותיהם הקינטיות והוויסות?","o":["לגלוקוקינאז יש Km נמוך לגלוקוז והיא מעוכבת על ידי גלוקוז-6-פוספט","לגלוקוקינאז יש Km גבוה לגלוקוז ואינה מעוכבת ישירות על ידי גלוקוז-6-פוספט","להקסוקינאז יש Km גבוה לגלוקוז והיא אינה רוויה בריכוזי גלוקוז פיזיולוגיים","שני האנזימים מעוכבים בעוצמה זהה על ידי תוצרם גלוקוז-6-פוספט"],"a":1,"e":"העיקרון: הקסוקינאז (hexokinase) וגלוקוקינאז (glucokinase, הקסוקינאז IV בכבד) נבדלים בקינטיקה ובוויסות בהתאם לתפקידם. לגלוקוקינאז Km גבוה (כ-10 mM), כך שפעילותה עולה רק כשרמת הגלוקוז גבוהה (אחרי ארוחה), ובכך הכבד 'תופס' עודפי גלוקוז; היא אינה מעוכבת ישירות על ידי גלוקוז-6-פוספט (אלא מווסתת דרך חלבון מווסת ופרוקטוז-6-פוספט). להקסוקינאז I-III Km נמוך — היא רוויה ופעילה כבר בריכוזים נמוכים, ומעוכבת על ידי תוצרה גלוקוז-6-פוספט כדי למנוע צבירת יתר. מדוע המסיחים שגויים: א' ו-ג' מחליפים בין התכונות (Km נמוך/גבוה). ד' — רק הקסוקינאז I-III מעוכבת בבירור על ידי גלוקוז-6-פוספט, לא שתיהן. טיפ: 'גלוקוקינאז = Km גבוה = חיישן גלוקוז של הכבד'."},
    {"topic":"גליקוליזה","q":"באיזה משלבי הגליקוליזה מתרחשת זרחון ברמת המצע (substrate-level phosphorylation) שמייצר ATP ישירות, מתרכובת בעלת אנרגיית ההידרוליזה הגבוהה ביותר בגליקוליזה?","o":["השלב המזורז על ידי פוספוגליצרט מוטאז, דרך 2,3-ביספוספוגליצרט","השלב המזורז על ידי פירובט קינאז, דרך פוספואנולפירובט (PEP)","השלב המזורז על ידי הקסוקינאז, דרך גלוקוז-6-פוספט","השלב המזורז על ידי אלדולאז, דרך פרוקטוז-1,6-ביספוספט"],"a":1,"e":"העיקרון: זרחון ברמת המצע (substrate-level phosphorylation) הוא ייצור ATP ישיר מהעברת קבוצת פוספט מתרכובת עתירת-אנרגיה ל-ADP, ללא מעורבות שרשרת הנשימה. בגליקוליזה זה קורה בשלב פירובט קינאז: העברת פוספט מפוספואנולפירובט (PEP) ל-ADP. ל-PEP אנרגיית הידרוליזה גבוהה במיוחד (כ-61.9 kJ/mol), והמעבר הספונטני מצורת אנול לא-יציבה לקטו של פירובט 'מושך' את התגובה ומניע את הזרחון. השלב השני מסוג זה בגליקוליזה הוא פוספוגליצרט קינאז (לא מוטאז). מדוע המסיחים שגויים: א' — פוספוגליצרט מוטאז מבצע איזומריזציה בלבד, ללא ייצור ATP. ג' — הקסוקינאז מ-משקיע ATP. ד' — אלדולאז מפצל ללא ייצור ATP. טיפ: שני שלבי SLP בגליקוליזה — PGK ו-פירובט קינאז."},
    {"topic":"גורלות הפירובט","q":"בתסיסה אלכוהולית בשמרים, מהו התפקיד המטבולי המרכזי של השלב המזורז על ידי פירובט דקרבוקסילאז (pyruvate decarboxylase) המייצר אצטאלדהיד?","o":["חידוש NAD+ הנדרש להמשך הגליקוליזה","סילוק CO2 כשלב מכין המאפשר לאלכוהול דהידרוגנאז לחדש NAD+ בשלב העוקב","ייצור ישיר של ATP ברמת המצע","החזרת NADH מהמיטוכונדריה אל הציטוזול"],"a":1,"e":"העיקרון: בתסיסה אלכוהולית בשמרים, פירובט דקרבוקסילאז (pyruvate decarboxylase) מסלק CO2 מפירובט ויוצר אצטאלדהיד — שלב מכין שאינו מחדש NAD+ בעצמו. חידוש ה-NAD+ הציטוזולי, החיוני להמשך הגליקוליזה (לשלב גליצראלדהיד-3-פוספט דהידרוגנאז), מתבצע בשלב העוקב על ידי אלכוהול דהידרוגנאז, המחזר אצטאלדהיד לאתנול תוך חמצון NADH ל-NAD+. לכן תפקיד הדקרבוקסילציה הוא להכין את המצע לשלב המחדש NAD+. מדוע המסיחים שגויים: א' — מייחס את חידוש ה-NAD+ לאנזים הלא-נכון (הדקרבוקסילאז אינו עושה זאת). ג' — אין ייצור ATP בשלב זה. ד' — אין כאן העברת NADH מהמיטוכונדריה; התסיסה ציטוזולית. טיפ: בתסיסה (אלכוהולית או לקטית) המטרה הכוללת היא תמיד חידוש NAD+ להמשך הגליקוליזה."},
    {"topic":"גורלות הפירובט","q":"מתחם פירובט דהידרוגנאז (pyruvate dehydrogenase complex) ממיר פירובט לאצטיל-CoA. איזה היגד נכון לגבי תגובה זו?","o":["זוהי דקרבוקסילציה מחמצנת הפיכה המייצרת NADH ו-CO2","זוהי דקרבוקסילציה מחמצנת בלתי הפיכה בפועל, המייצרת NADH ו-CO2 ומהווה גשר בין גליקוליזה למעגל החומצה הציטרית","התגובה מתרחשת בציטוזול ומחדשת NAD+","התגובה צורכת ATP ומייצרת לקטט כתוצר לוואי"],"a":1,"e":"העיקרון: מתחם פירובט דהידרוגנאז (pyruvate dehydrogenase complex) מבצע דקרבוקסילציה מחמצנת — ממיר פירובט לאצטיל-CoA תוך שחרור CO2 וייצור NADH. בתנאים תאיים התגובה בלתי-הפיכה בפועל (אקסרגונית מאוד), ולכן פחמן שנכנס לאצטיל-CoA אינו יכול לחזור לגלוקוז. המתחם ממוקם במטריקס המיטוכונדריאלי ומשמש כ'גשר' המחבר את הגליקוליזה הציטוזולית למעגל החומצה הציטרית. מדוע המסיחים שגויים: א' — טועה בהפיכות; התגובה אינה הפיכה. ג' — היא במיטוכונדריה (לא בציטוזול) ומייצרת NADH, אינה מחדשת NAD+. ד' — אינה צורכת ATP ואינה מייצרת לקטט. טיפ: PDH = שער חד-כיווני לתוך המיטוכונדריה; משם אין דרך חזרה לגלוקוז — לכן שומן אינו הופך לגלוקוז."},
    {"topic":"גלוקונאוגנזה","q":"אדם בצום ממושך מבצע גלוקונאוגנזה. מהי הסיבה לכך שהמרת פירובט לפוספואנולפירובט (PEP) דורשת מעקף (bypass) דו-שלבי ולא היפוך פשוט של פירובט קינאז?","o":["כי פירובט קינאז פעיל רק בנוכחות אינסולין","כי תגובת פירובט קינאז היא בלתי הפיכה בפועל בשל ירידה גדולה באנרגיה החופשית, ולכן נדרש מסלול חלופי דרך אוקסלואצטט","כי PEP אינו יכול להיווצר במיטוכונדריה","כי המעקף נדרש כדי לייצר NADPH למסלול"],"a":1,"e":"העיקרון: בגלוקונאוגנזה (gluconeogenesis) לא ניתן פשוט להפוך את כל שלבי הגליקוליזה, כי שלושה שלבים בלתי-הפיכים בפועל (בעלי ΔG שלילי גדול) חוסמים את הדרך אחורה — אחד מהם הוא פירובט קינאז. כדי לעקוף אותו, ממירים פירובט ל-PEP בשני שלבים: (1) פירובט קרבוקסילאז ממיר פירובט לאוקסלואצטט (צורך ATP, במיטוכונדריה), ו-(2) PEP קרבוקסיקינאז (PEPCK) ממיר אוקסלואצטט ל-PEP (צורך GTP). המעקף 'משלם' אנרגיה כדי לטפס במעלה המדרון התרמודינמי. מדוע המסיחים שגויים: א' — פירובט קינאז אינו תלוי-אינסולין בדרך זו. ג' — PEP אכן יכול להיווצר במיטוכונדריה. ד' — NADPH שייך למסלול הפנטוז פוספט, לא רלוונטי כאן. טיפ: שלושת המעקפים בגלוקונאוגנזה תואמים לשלושת השלבים הבלתי-הפיכים של הגליקוליזה."},
    {"topic":"גלוקונאוגנזה","q":"פרוקטוז-2,6-ביספוספט (F2,6BP) הוא מווסת מרכזי. כיצד הוא משפיע בו-זמנית על פוספופרוקטוקינאז-1 (PFK-1) ועל פרוקטוז-1,6-ביספוספטאז (FBPase-1)?","o":["מפעיל את PFK-1 ומפעיל את FBPase-1, ומאיץ את שני המסלולים","מפעיל את PFK-1 ומעכב את FBPase-1, ובכך מקדם גליקוליזה ומדכא גלוקונאוגנזה","מעכב את PFK-1 ומפעיל את FBPase-1, ובכך מקדם גלוקונאוגנזה","אין לו השפעה על FBPase-1 והוא פועל רק על PFK-1"],"a":1,"e":"העיקרון: פרוקטוז-2,6-ביספוספט (F2,6BP) הוא 'מתג ראשי' המתאם בין גליקוליזה לגלוקונאוגנזה. הוא מפעיל אלוסטרית את פוספופרוקטוקינאז-1 (PFK-1) — מגביר את זיקתו לפרוקטוז-6-פוספט — ובו-זמנית מעכב את פרוקטוז-1,6-ביספוספטאז (FBPase-1). כך, כאשר רמתו עולה (שליטת אינסולין, מצב שובע), הוא מקדם גליקוליזה ומדכא גלוקונאוגנזה בו-זמנית, ומונע 'מעגל סרק' שבו שני המסלולים רצים יחד ומבזבזים ATP. מדוע המסיחים שגויים: א' ו-ג' הופכים את כיוון הוויסות (הפעלה/עיכוב). ד' — ההשפעה ההדדית על FBPase-1 היא בדיוק לב הוויסות, ולא ניתן להתעלם ממנה. טיפ: F2,6BP נבדל מ-F1,6BP (תוצר PFK-1) — הוא מולקולת אות בלבד, לא מטבוליט מסלולי."},
    {"topic":"גלוקונאוגנזה","q":"רמת גלוקגון בדם עולה בצום. דרך מפל הסיגנל בכבד, כיצד ישתנו פעילויות PFK-2/FBPase-2 וריכוז פרוקטוז-2,6-ביספוספט?","o":["PKA מזרחן את החלבון הדו-תפקודי, מפעיל את פעילות PFK-2 ומעלה את F2,6BP","PKA מזרחן את החלבון הדו-תפקודי, מפעיל את פעילות FBPase-2 ומוריד את F2,6BP, ובכך מקדם גלוקונאוגנזה","פוספטאז מסלק זרחונים, מפעיל PFK-2 ומעלה את F2,6BP","גלוקגון מוריד cAMP ולכן מעלה את F2,6BP"],"a":1,"e":"העיקרון: בצום גלוקגון מפעיל בכבד מפל סיגנל שמדכא גליקוליזה ומקדם גלוקונאוגנזה דרך פרוקטוז-2,6-ביספוספט. גלוקגון מעלה cAMP, המפעיל חלבון קינאז A (PKA). PKA מזרחן את האנזים הדו-תפקודי PFK-2/FBPase-2: הזרחון מדכא את פעילות הקינאז (PFK-2) ומפעיל את פעילות הפוספטאז (FBPase-2). התוצאה — ירידה ב-F2,6BP, מה שמשחרר את העיכוב מ-FBPase-1 ומסיר את ההפעלה מ-PFK-1, וכך מקדם גלוקונאוגנזה. מדוע המסיחים שגויים: א' — הופך את התוצאה (הזרחון מדכא PFK-2, לא מפעיל). ג' — בצום פוספטאז אינו השחקן; דווקא הזרחון על ידי PKA הוא הקובע. ד' — גלוקגון מעלה cAMP, לא מוריד. טיפ: 'זרחון בצום = פחות F2,6BP = פחות גליקוליזה'."},
    {"topic":"מסלול הפנטוז פוספט","q":"תא בעל דרישה גבוהה ל-NADPH (למשל לסינתזת חומצות שומן) אך דרישה נמוכה לריבוז-5-פוספט. כיצד מתאזן מסלול הפנטוז פוספט במצב זה?","o":["החלק הלא-חמצוני ממיר ריבולוז-5-פוספט חזרה לפרוקטוז-6-פוספט וגליצראלדהיד-3-פוספט, המוחזרים לגליקוליזה","כל הפחמן מופנה ליצירת ריבוז-5-פוספט בלבד","החלק החמצוני מושבת לחלוטין כדי למנוע עודף NADPH","גליצראלדהיד-3-פוספט מומר חזרה לגלוקוז-6-פוספט דרך טרנסקטולאז בלבד"],"a":0,"e":"העיקרון: מסלול הפנטוז פוספט (pentose phosphate pathway) גמיש ומסתגל לצורכי התא. כאשר נדרש הרבה NADPH (למשל לסינתזת חומצות שומן) אך מעט ריבוז-5-פוספט, החלק החמצוני פעיל ומייצר NADPH, ואת פחמני הפנטוזות 'ממחזרים' תגובות החלק הלא-חמצוני (טרנסקטולאז וטרנסאלדולאז), שממירות ריבולוז-5-פוספט בחזרה לפרוקטוז-6-פוספט ולגליצראלדהיד-3-פוספט. תוצרים אלו חוזרים לגליקוליזה (או נכנסים שוב למסלול), כך שאין הצטברות מיותרת של פנטוזות. מדוע המסיחים שגויים: ב' — מתאר מצב הפוך (דרישה גבוהה לריבוז). ג' — סותר את הצורך ב-NADPH (החמצוני חייב לפעול). ד' — שגוי בכיוון התגובות ובאנזים. טיפ: החלק הלא-חמצוני הוא 'דו-כיווני וגמיש', ומאפשר לתא לאזן בין NADPH לפנטוזות."},
    {"topic":"מסלול הפנטוז פוספט","q":"מהו האנזים מגביל הקצב (rate-limiting) של מסלול הפנטוז פוספט, ומהו המווסת המעכב העיקרי שלו?","o":["טרנסקטולאז, מעוכב על ידי תיאמין","גלוקוז-6-פוספט דהידרוגנאז (G6PD), מעוכב על ידי יחס NADPH/NADP+ גבוה","6-פוספוגלוקונאט דהידרוגנאז, מעוכב על ידי ATP","גלוקוז-6-פוספט דהידרוגנאז, מעוכב על ידי ריבוז-5-פוספט"],"a":1,"e":"העיקרון: גלוקוז-6-פוספט דהידרוגנאז (G6PD) הוא האנזים מגביל הקצב (rate-limiting) של החלק החמצוני במסלול הפנטוז פוספט, והוא קובע את כניסת הגלוקוז-6-פוספט למסלול. הוויסות העיקרי שלו הוא דרך יחס NADPH/NADP+: כשהיחס גבוה (עודף NADPH, התא 'מלא') האנזים מעוכב; כשהיחס יורד ו-NADP+ זמין (צריכת NADPH מואצת), הפעילות עולה. כך נשמרת אספקת NADPH לפי הביקוש. מדוע המסיחים שגויים: א' — טרנסקטולאז שייך לחלק הלא-חמצוני ואינו מגביל הקצב; תיאמין הוא קו-פקטור שלו, לא מעכב. ג' — האנזים והמווסת שגויים. ד' — מזהה נכון את G6PD אך טועה במווסת (זה NADPH/NADP+, לא ריבוז-5-פוספט). טיפ: NADPH הוא גם התוצר וגם המעכב של G6PD — לולאת משוב שלילי קלאסית."},
    {"topic":"מטבוליזם גליקוגן","q":"גליקוגן פוספורילאז מפרק גליקוגן. מהו התוצר הישיר של תגובת הפוספורוליזה ומה מקור הזרחן שבו?","o":["גלוקוז חופשי, כשהזרחן מקורו ב-ATP","גלוקוז-1-פוספט, כשהזרחן מקורו בפוספט אנאורגני (Pi) ולא ב-ATP","גלוקוז-6-פוספט, כשהזרחן מקורו ב-ATP","UDP-גלוקוז, כשהזרחן מקורו ב-UTP"],"a":1,"e":"העיקרון: גליקוגן פוספורילאז מפרק גליקוגן בתהליך פוספורוליזה (phosphorolysis) — הוא משתמש בפוספט אנאורגני (Pi), ולא במים ולא ב-ATP, כדי לנתק יחידת גלוקוז מקצה השרשרת ולשחרר גלוקוז-1-פוספט. היתרון: התוצר כבר מזורחן, כך שהתא חוסך ATP שהיה נדרש לזרחון מחדש. גלוקוז-1-פוספט מומר אחר כך לגלוקוז-6-פוספט על ידי פוספוגלוקומוטאז. מדוע המסיחים שגויים: א' — אין שחרור גלוקוז חופשי בשלב זה, והזרחן אינו מ-ATP. ג' — התוצר הישיר הוא גלוקוז-1-פוספט (לא 6), והזרחן מ-Pi (לא מ-ATP). ד' — UDP-גלוקוז שייך לסינתזת גליקוגן, לא לפירוק. טיפ: 'פוספורוליזה = שבירה עם Pi', לעומת הידרוליזה (שבירה עם מים) — וזה מה שחוסך אנרגיה."},
    {"topic":"מטבוליזם גליקוגן","q":"אדרנלין נקשר לקולטן בטא-אדרנרגי בשריר. סדר את מפל הסיגנל המוביל לפירוק גליקוגן.","o":["אדרנלין מפעיל אדנילט ציקלאז דרך חלבון G, עולה cAMP, מופעל PKA, המזרחן ומפעיל פוספורילאז קינאז, המזרחן ומפעיל גליקוגן פוספורילאז","אדרנלין מוריד cAMP, מפעיל פוספטאז, ומפרק גליקוגן ישירות","אדרנלין מפעיל PKA, המזרחן ישירות את גליקוגן פוספורילאז ללא מתווכים","אדרנלין מפעיל פוספורילאז קינאז דרך עליית ביספוספט, ללא מעורבות cAMP או PKA"],"a":0,"e":"העיקרון: אדרנלין מפעיל פירוק גליקוגן בשריר דרך מפל הגברה (amplification cascade). הוא נקשר לקולטן בטא-אדרנרגי, שדרך חלבון G מעורר מפעיל את אדנילט ציקלאז; נוצר cAMP המפעיל חלבון קינאז A (PKA); PKA מזרחן ומפעיל את פוספורילאז קינאז; וזו מזרחנת את גליקוגן פוספורילאז b והופכת אותו לצורתו הפעילה a. כל שלב מגביר את האות, כך שמעט הורמון מוביל לפירוק מהיר של גליקוגן רב. מדוע המסיחים שגויים: ב' — אדרנלין מעלה cAMP (לא מוריד) ואינו מפעיל פוספטאז. ג' — מדלג על פוספורילאז קינאז, שהוא מתווך הכרחי בין PKA לפוספורילאז. ד' — שולל את מפל ה-cAMP/PKA שהוא הליבה. טיפ: זכור את הסדר — קולטן בטא, Gs, אדנילט ציקלאז, cAMP, PKA, פוספורילאז קינאז, גליקוגן פוספורילאז."},
    {"topic":"מטבוליזם גליקוגן","q":"לאחר ארוחה עולה האינסולין. כיצד משפיע האינסולין בו-זמנית על גליקוגן סינתאז ועל גליקוגן פוספורילאז כדי לקדם אגירת גליקוגן?","o":["מזרחן ומפעיל את גליקוגן סינתאז, ומזרחן ומפעיל את גליקוגן פוספורילאז","מקדם דה-זרחון של גליקוגן סינתאז (הפעלתו) ודה-זרחון של גליקוגן פוספורילאז (השבתתו)","מעכב את שני האנזימים בו-זמנית כדי לעצור את מטבוליזם הגליקוגן","מפעיל את גליקוגן פוספורילאז ומעכב את גליקוגן סינתאז"],"a":1,"e":"העיקרון: אינסולין (אחרי ארוחה) מקדם אגירת גליקוגן על ידי ויסות הופכי של שני אנזימים מרכזיים. הוא מפעיל מסלול המוביל להפעלת פוספטאז (PP1) ולירידה בפעילות PKA, וכך מקדם דה-זרחון של גליקוגן סינתאז ושל גליקוגן פוספורילאז כאחד. הטריק: דה-זרחון משפיע הפוך על השניים — גליקוגן סינתאז בצורתו הלא-מזורחנת פעיל (סינתזה דולקת), ואילו גליקוגן פוספורילאז בצורתו הלא-מזורחנת לא-פעיל (פירוק כבוי). כך הסינתזה והפירוק לעולם אינם רצים יחד. מדוע המסיחים שגויים: א' — שגוי בכיוון (אינסולין מקדם דה-זרחון, לא זרחון). ג' — אינסולין אינו עוצר את שני האנזימים אלא מפעיל סינתזה. ד' — הופך לחלוטין את התגובה לאינסולין. טיפ: 'זרחון אחד, אפקט הפוך' — מתג הדדי המונע מעגל סרק."},
    {"topic":"גליקוליזה","q":"בתסמונת חסר חמצן (היפוקסיה), מדוע חיוני לתא להמיר פירובט ללקטט גם שאין מכך רווח אנרגטי ישיר נוסף?","o":["כדי לייצר ATP נוסף ישירות בתגובת לקטט דהידרוגנאז","כדי לחדש NAD+ ציטוזולי הנדרש לשלב הגליצראלדהיד-3-פוספט דהידרוגנאז ולאפשר המשך גליקוליזה","כדי לייצר NADPH לתהליכי סינתזה","כדי להעביר אלקטרונים ישירות לשרשרת הנשימה המיטוכונדריאלית"],"a":1,"e":"העיקרון: בהיפוקסיה (חוסר חמצן) שרשרת הנשימה אינה יכולה לחדש NAD+, ולכן הגליקוליזה הייתה נעצרת — אלמלא המרת פירובט ללקטט. לקטט דהידרוגנאז (LDH) מחזר פירובט ללקטט תוך חמצון NADH ל-NAD+. חידוש זה של ה-NAD+ הציטוזולי חיוני כדי שגליצראלדהיד-3-פוספט דהידרוגנאז ימשיך לפעול, וכך נשמרת זרימת הגליקוליזה וייצור ה-ATP — אף שהמרת פירובט ללקטט עצמה אינה מניבה ATP. מדוע המסיחים שגויים: א' — התגובה אינה מייצרת ATP. ג' — מבלבל עם NADPH (שייך לפנטוז פוספט/אנבוליזם). ד' — בהיפוקסיה השרשרת אינה פעילה, והלקטט אינו מעביר אליה אלקטרונים. טיפ: 'המטרה היחידה של ייצור הלקטט היא חידוש NAD+' — כך הגליקוליזה ממשיכה לייצר ATP גם בלי חמצן."},
    {"topic":"מעגל קרבס","q":"בסיבוב אחד של מעגל קרבס (Citric acid cycle), המתחיל בעיבוי אצטיל-CoA אחד עם אוקסלואצטט, כמה מולקולות NADH, FADH2 ו-GTP מיוצרות באופן ישיר במעגל?","o":["4 NADH, 1 FADH2, 1 GTP","3 NADH, 1 FADH2, 1 GTP","3 NADH, 2 FADH2, 1 GTP","3 NADH, 1 FADH2, 2 GTP"],"a":1,"e":"העיקרון: בסיבוב אחד של מעגל קרבס (Citric acid cycle), המתחיל בעיבוי אצטיל-CoA עם אוקסלואצטט, נוצרים 3 NADH, 1 FADH2 ו-1 GTP. שלושת ה-NADH מקורם באיזוציטרט דהידרוגנאז, באלפא-קטוגלוטרט דהידרוגנאז ובמלאט דהידרוגנאז; ה-FADH2 מסוקצינאט דהידרוגנאז; וה-GTP (או ATP) מסוקצינאט תיוקינאז (זרחון ברמת המצע). תוצרי החיזור הללו מזינים אחר כך את שרשרת הנשימה. מדוע המסיחים שגויים: התשובה עם 4 NADH היא טעות נפוצה — היא כוללת בטעות גם את ה-NADH מתגובת פירובט דהידרוגנאז, שהיא 'גשר' לפני המעגל ואינה חלק ממנו. שאר המסיחים טועים במספר ה-FADH2 או ה-GTP. טיפ לזכירה: '3-1-1' (NADH-FADH2-GTP), ואל תספרו את שלב PDH בתוך המעגל."},
    {"topic":"מעגל קרבס","q":"מהו האנזים המהווה את נקודת הוויסות האיטית ביותר (rate-limiting) במעגל קרבס, והמופעל בעיקר על ידי ADP ומעוכב על ידי NADH ו-ATP?","o":["ציטראט סינתאז (Citrate synthase)","סוקצינאט דהידרוגנאז (Succinate dehydrogenase)","איזוציטרט דהידרוגנאז (Isocitrate dehydrogenase)","אקוניטאז (Aconitase)"],"a":2,"e":"העיקרון: איזוציטרט דהידרוגנאז (Isocitrate dehydrogenase) הוא נקודת הבקרה המרכזית וקובעת הקצב במעגל קרבס לפי לנינגר. הוא מווסת אלוסטרית באופן שמשקף את מצב האנרגיה של התא: מופעל על ידי ADP (ו-Ca2+), המסמנים מחסור באנרגיה וצורך בהפעלת המעגל, ומעוכב על ידי ATP ו-NADH, המסמנים עודף אנרגיה. כך קצב המעגל מותאם לביקוש. מדוע המסיחים שגויים: ציטראט סינתאז ואלפא-קטוגלוטרט דהידרוגנאז אכן מווסתים גם הם, אך איזוציטרט דהידרוגנאז נחשב לנקודה העיקרית. סוקצינאט דהידרוגנאז ואקוניטאז אינם נקודות ויסות אלוסטריות. טיפ: זכרו ש'NADH ו-ATP מעכבים, ADP מפעיל' — היגיון משותף לכל נקודות הבקרה של הקטבוליזם המחמצן."},
    {"topic":"מעגל קרבס","q":"תגובה אנפלרוטית (anaplerotic) חשובה ביותר ממלאת מחדש את מאגר האוקסלואצטט במעגל קרבס. איזה אנזים מקטלז תגובה זו, ומהו המפעיל האלוסטרי שלו?","o":["פוספואנולפירובט קרבוקסיקינאז (PEPCK), המופעל על ידי אצטיל-CoA","פירובט קרבוקסילאז (Pyruvate carboxylase), המופעל על ידי אצטיל-CoA","פירובט דהידרוגנאז (Pyruvate dehydrogenase), המופעל על ידי NAD+","מלאט דהידרוגנאז (Malate dehydrogenase), המופעל על ידי GTP"],"a":1,"e":"העיקרון: תגובה אנפלרוטית (anaplerotic) 'ממלאת מחדש' את תווכי מעגל קרבס שמתרוקנים כשהם נשאבים לביוסינתזה. החשובה ביותר היא זו של פירובט קרבוקסילאז (Pyruvate carboxylase), הממיר פירובט לאוקסלואצטט (צורך ATP וביוטין). המפעיל האלוסטרי המחויב שלו הוא אצטיל-CoA: כשאצטיל-CoA מצטבר אך חסר אוקסלואצטט לעיבוי איתו, האנזים מופעל וממלא את המאגר — מנגנון משוב הגיוני. מדוע המסיחים שגויים: א' — PEPCK פועל בכיוון ההפוך (מוציא אוקסלואצטט ל-PEP בגלוקונאוגנזה). ג' — פירובט דהידרוגנאז מייצר אצטיל-CoA ולא אוקסלואצטט. ד' — מלאט דהידרוגנאז אינו אנפלרוטי ואינו מופעל על ידי GTP. טיפ: 'אצטיל-CoA גבוה מפעיל את פירובט קרבוקסילאז' — כי צריך שותף (אוקסלואצטט) לעיבוי."},
    {"topic":"זרחון חמצוני","q":"במהלך זרחון חמצוני, אלקטרונים מ-FADH2 (כגון מסוקצינאט דהידרוגנאז) נכנסים לשרשרת מעבר האלקטרונים. דרך כמה קומפלקסים שואבי פרוטונים עוברים אלקטרונים אלו, ומדוע התשואה שלהם נמוכה מזו של NADH?","o":["שני קומפלקסים (III ו-IV), כי הם עוקפים את קומפלקס I","שלושה קומפלקסים (I, III, IV), כמו NADH","שני קומפלקסים (I ו-III), כי הם עוקפים את קומפלקס IV","ארבעה קומפלקסים, אך שואבים פחות פרוטונים בכל אחד"],"a":0,"e":"העיקרון: אלקטרונים מ-FADH2 (כגון אלו מסוקצינאט דהידרוגנאז, קומפלקס II) נכנסים לשרשרת מעבר האלקטרונים דרך אוביקווינון (CoQ) ומדלגים על קומפלקס I. לכן הם עוברים רק דרך שני קומפלקסים שואבי פרוטונים — III ו-IV. לעומתם, NADH מוסר אלקטרונים לקומפלקס I, ולכן עובר דרך שלושה קומפלקסים שואבים (I, III, IV), שואב יותר פרוטונים ומניב יותר ATP. זו הסיבה שיחס P/O של FADH2 נמוך מזה של NADH (כ-1.5 לעומת כ-2.5). מדוע המסיחים שגויים: ב' — שלושה קומפלקסים מתאר את NADH, לא FADH2. ג' — האלקטרונים אינם עוקפים את IV אלא דווקא את I. ד' — מספר הקומפלקסים שגוי. טיפ: 'FADH2 מתחיל מ-CoQ ולכן מדלג על קומפלקס I' — מכאן תשואת האנרגיה הנמוכה יותר."},
    {"topic":"זרחון חמצוני","q":"מטופל נחשף לרעלן הפוגע בזרחון חמצוני. נמדד כי שרשרת מעבר האלקטרונים ממשיכה לצרוך חמצן בקצב מוגבר, אך כמעט ולא מיוצר ATP, וחום הגוף עולה. איזה סוג חומר מסביר תופעה זו?","o":["מעכב של ATP synthase כמו אוליגומיצין (Oligomycin)","מעכב של קומפלקס IV כמו ציאניד (Cyanide)","מפריד (uncoupler) כמו 2,4-דיניטרופנול (DNP)","מעכב של קומפלקס I כמו רוטנון (Rotenone)"],"a":2,"e":"העיקרון: מפריד (uncoupler) כמו 2,4-דיניטרופנול (DNP) הוא חומצה חלשה ליפופילית שנושאת פרוטונים בחזרה אל המטריקס דרך הממברנה הפנימית, ובכך 'מקצרת' את המפל האלקטרוכימי ועוקפת את ATP synthase. התוצאה: שרשרת הנשימה רצה מהר יותר (צריכת חמצן עולה) כדי לנסות לשקם את המפל, אך האנרגיה מתבזבזת כחום במקום להישמר כ-ATP — ומכאן עליית חום הגוף. מדוע המסיחים שגויים: א' — אוליגומיצין חוסם את ATP synthase, ובעקבות ויסות חוזר (respiratory control) דווקא עוצר גם את צריכת החמצן. ב' ו-ד' — ציאניד (קומפלקס IV) ורוטנון (קומפלקס I) עוצרים את צריכת החמצן ולא מעלים אותה. טיפ: 'מפריד = צריכת חמצן גבוהה, ATP נמוך, חום גבוה' — הוא מנתק בין הנשימה לזרחון."},
    {"topic":"זרחון חמצוני","q":"מהו התיאור המדויק ביותר של עקרון הכימיוסמוזה (chemiosmosis) של מיטשל, המסביר כיצד נוצר ATP בזרחון חמצוני?","o":["מעבר האלקטרונים מזרחן ישירות את ADP בכל קומפלקס בשרשרת","אנרגיית מעבר האלקטרונים משמשת לשאיבת פרוטונים, היוצרת מפל אלקטרוכימי, שזרימתו חזרה דרך ATP synthase מניעה סינתזת ATP","הידרוליזה של GTP במטריקס מספקת את האנרגיה לסינתזת ATP","מפל ריכוז של NADH בין המטריקס למרחב הבין-ממברנלי מניע את ATP synthase"],"a":1,"e":"העיקרון: לפי תיאוריית הכימיוסמוזה (chemiosmosis) של פיטר מיטשל, ייצור ה-ATP אינו ישיר אלא דרך מתווך אנרגטי — מפל פרוטונים. האנרגיה ממעבר האלקטרונים בשרשרת משמשת לשאיבת פרוטונים מהמטריקס אל המרחב הבין-ממברנלי, ויוצרת מפל אלקטרוכימי (כוח מניע פרוטונים, proton-motive force). זרימת הפרוטונים בחזרה דרך ATP synthase היא שמניעה את סינתזת ה-ATP — צימוד עקיף בין הזרימה האלקטרונית לזרחון. מדוע המסיחים שגויים: א' — אין זרחון ישיר של ADP בכל קומפלקס; הקומפלקסים שואבים פרוטונים, לא מזרחנים. ג' — GTP אינו מקור האנרגיה לסינתזה זו. ד' — המפל המניע הוא של פרוטונים, לא של NADH. טיפ: 'אלקטרונים מטעינים מצבר פרוטונים, ו-ATP synthase פורק אותו לעבודה'."},
    {"topic":"חמצון חומצות שומן","q":"מעבורת הקרניטין (carnitine shuttle) מעבירה חומצות שומן ארוכות-שרשרת אל המטריקס המיטוכונדריאלי. מהו האנזים קובע הקצב, ומהו המעכב הפיזיולוגי שלו המבטיח שלא יתרחשו במקביל סינתזה ופירוק של שומן?","o":["קרניטין אצילטרנספראז I (CPT I), המעוכב על ידי מלוניל-CoA (Malonyl-CoA)","קרניטין אצילטרנספראז II (CPT II), המעוכב על ידי מלוניל-CoA","אציל-CoA סינתטאז, המעוכב על ידי NADH","קרניטין אצילטרנספראז I (CPT I), המעוכב על ידי ציטראט"],"a":0,"e":"העיקרון: מעבורת הקרניטין (carnitine shuttle) מכניסה חומצות שומן ארוכות-שרשרת אל המטריקס לחמצון, והשלב קובע הקצב שלה הוא קרניטין אצילטרנספראז I (CPT I), הממוקם בממברנה המיטוכונדריאלית החיצונית. CPT I מעוכב על ידי מלוניל-CoA (Malonyl-CoA) — התוצר הראשון של סינתזת חומצות שומן. עיכוב חכם זה מבטיח שכאשר התא בונה שומן (מלוניל-CoA גבוה), הוא לא יפרק אותו במקביל, ומונע 'מעגל סרק'. מדוע המסיחים שגויים: ב' — CPT II נמצא בצד הפנימי של הממברנה ואינו השלב המווסת. ג' — אציל-CoA סינתטאז מפעיל את חומצת השומן בציטוזול ואינו מעוכב כך. ד' — המעכב הוא מלוניל-CoA, לא ציטראט. טיפ: 'מלוניל-CoA מעכב CPT I' — הקשר ההדוק שבין בנייה לפירוק של שומן."},
    {"topic":"חמצון חומצות שומן","q":"כל מחזור של בטא-אוקסידציה (beta-oxidation) מקצר את חומצת השומן בשני פחמנים ומייצר אצטיל-CoA, NADH ו-FADH2. עבור חמצון מלא של פלמיטויל-CoA (16 פחמנים), כמה מחזורים של בטא-אוקסידציה נדרשים, וכמה אצטיל-CoA מתקבלים?","o":["8 מחזורים, 8 מולקולות אצטיל-CoA","7 מחזורים, 8 מולקולות אצטיל-CoA","8 מחזורים, 7 מולקולות אצטיל-CoA","7 מחזורים, 7 מולקולות אצטיל-CoA"],"a":1,"e":"העיקרון: כל מחזור של בטא-אוקסידציה (beta-oxidation) מקצר את חומצת השומן בשני פחמנים, משחרר אצטיל-CoA אחד ומייצר NADH ו-FADH2. עבור פלמיטויל-CoA (16 פחמנים): מתקבלות 8 מולקולות אצטיל-CoA (16 חלקי 2), אך מספר המחזורים הוא n/2 פחות 1, כלומר 7 — כי המחזור האחרון מפצל יחידה בת 4 פחמנים לשתי מולקולות אצטיל-CoA בבת אחת, ואינו דורש מחזור נוסף. בהתאם נוצרים 7 NADH ו-7 FADH2. מדוע המסיחים שגויים: התשובות עם 8 מחזורים נובעות מהטעות הנפוצה לחשוב שמספר המחזורים שווה למספר האצטיל-CoA. התשובות עם 7 אצטיל-CoA טועות בספירת התוצר. טיפ: 'מספר אצטיל-CoA = n/2, מספר מחזורים = n/2 פחות 1' — כי המחזור האחרון נותן שניים."},
    {"topic":"חמצון חומצות שומן","q":"במהלך צום ממושך, הכבד מייצר גופי קטון (ketone bodies). מהו התנאי המטבולי המאיץ ייצור גופי קטון, ומדוע גלוקגון מעודד זאת?","o":["עודף אוקסלואצטט המפנה אצטיל-CoA לקטונים; גלוקגון מעלה אוקסלואצטט","מחסור באוקסלואצטט (המופנה לגלוקונאוגנזה) המוביל להצטברות אצטיל-CoA; גלוקגון מעודד גלוקונאוגנזה וליפוליזה","עיכוב מלא של בטא-אוקסידציה המפנה חומצות שומן לקטונים; גלוקגון מעכב CPT I","עודף מלוניל-CoA המופנה לקטונים; גלוקגון מעלה מלוניל-CoA"],"a":1,"e":"העיקרון: בצום ממושך הכבד מייצר גופי קטון (ketone bodies) כדלק חלופי. הטריגר המטבולי הוא מחסור באוקסלואצטט: בצום הוא נשאב לגלוקונאוגנזה, ולכן פוחת מאגרו ומגביל את כניסת אצטיל-CoA למעגל קרבס. אצטיל-CoA העודף — שמקורו בבטא-אוקסידציה מואצת — מופנה לייצור גופי קטון. גלוקגון מזין את שני הצדדים: הוא מעודד ליפוליזה (אספקת חומצות שומן לבטא-אוקסידציה) ומפחית מלוניל-CoA (מסיר עיכוב מ-CPT I), ובכך מגביר חמצון שומן וקטוגנזה. מדוע המסיחים שגויים: א' — בצום האוקסלואצטט יורד, לא עולה. ג' — בטא-אוקסידציה דווקא מואצת בצום, לא מעוכבת, וגלוקגון מסיר עיכוב מ-CPT I. ד' — גלוקגון מפחית מלוניל-CoA. טיפ: 'שומן בוער באש של פחמימות' — בלי אוקסלואצטט, אצטיל-CoA הופך לקטונים."},
    {"topic":"קטבוליזם חומצות אמינו","q":"בשלב הראשון של קטבוליזם רוב חומצות האמינו, קבוצת האמינו מועברת לאלפא-קטוגלוטרט. מהו שם התהליך, מהו התוצר, ואיזה קו-פקטור נדרש?","o":["דאמינציה מחמצנת; התוצר גלוטמט; הקו-פקטור NAD+","טרנסאמינציה; התוצר גלוטמט; הקו-פקטור פירידוקסל פוספט (PLP)","טרנסאמינציה; התוצר אספרטט; הקו-פקטור ביוטין","דאמינציה מחמצנת; התוצר אמוניה; הקו-פקטור PLP"],"a":1,"e":"העיקרון: בשלב הראשון של קטבוליזם רוב חומצות האמינו מתרחשת טרנסאמינציה (transamination) — העברת קבוצת האמינו מחומצת האמינו אל אלפא-קטוגלוטרט, היוצרת גלוטמט (ואת חומצת האלפא-קטו המתאימה). הקו-פקטור החיוני לכל האמינוטרנספראזות הוא פירידוקסל פוספט (PLP), נגזרת של ויטמין B6, המשמש כ'נשא זמני' של קבוצת האמינו. כך מרוכז החנקן בגלוטמט לקראת סילוקו. מדוע המסיחים שגויים: א' ו-ד' — דאמינציה מחמצנת (על ידי גלוטמט דהידרוגנאז, עם NAD+, המשחררת אמוניה) היא שלב נפרד ומאוחר יותר, לא הראשון. ג' — התוצר הוא גלוטמט (לא אספרטט), והקו-פקטור הוא PLP (לא ביוטין; ביוטין שייך לקרבוקסילציות). טיפ: 'טרנסאמינציה = PLP = גלוטמט' — שלב הריכוז של חנקן לפני מעגל האוריאה."},
    {"topic":"מעגל האוריאה","q":"מעגל האוריאה (urea cycle) מסלק עודף חנקן. שני אטומי החנקן באוריאה מגיעים משני מקורות שונים. מהם המקורות הישירים של שני אטומי החנקן?","o":["שניהם מאמוניה חופשית דרך קרבמואיל פוספט","אחד מקרבמואיל פוספט (אמוניה) ואחד מאספרטט (Aspartate)","אחד מגלוטמט ואחד מגלוטמין ישירות","אחד מאספרטט ואחד מאלנין"],"a":1,"e":"העיקרון: מעגל האוריאה (urea cycle) מסלק עודף חנקן, ושני אטומי החנקן באוריאה מגיעים משני מקורות שונים. האטום הראשון נכנס דרך קרבמואיל פוספט — שנוצר מאמוניה ו-CO2 על ידי קרבמואיל פוספט סינתטאז I. האטום השני מגיע מאספרטט (Aspartate), המתעבה עם ציטרולין ליצירת ארגינינוסוקצינאט. כך משלב המעגל חנקן ממקור 'חופשי' (אמוניה) וחנקן ממקור 'מועבר' (אספרטט, שמקבל את החנקן בטרנסאמינציה). מדוע המסיחים שגויים: א' — לא שני האטומים מגיעים מאמוניה חופשית; זו בדיוק נקודת הבלבול. ג' — גלוטמין וגלוטמט אינם המקורות הישירים בשלבי המעגל. ד' — אלנין אינו מקור ישיר; המקור השני הוא אספרטט. טיפ לזכירה: 'אטום אחד מקרבמואיל פוספט, אטום שני מאספרטט'."},
    {"topic":"מעגל האוריאה","q":"מהו השלב קובע הקצב והמווסת של מעגל האוריאה, ומהו המפעיל האלוסטרי המחויב שלו המסמן עודף חנקן?","o":["ארגינאז (Arginase), המופעל על ידי ארגינין","אורניתין טרנסקרבמואילאז, המופעל על ידי אורניתין","קרבמואיל פוספט סינתטאז I (CPS I), המופעל על ידי N-אצטילגלוטמט (NAG)","ארגינינוסוקצינאט סינתטאז, המופעל על ידי ATP"],"a":2,"e":"העיקרון: קרבמואיל פוספט סינתטאז I (CPS I) הוא השלב קובע הקצב של מעגל האוריאה, וייחודו בכך שהוא דורש מפעיל אלוסטרי מחויב — N-אצטילגלוטמט (NAG). בלי NAG האנזים אינו פעיל כלל. רמת NAG עולה כאשר יש עודף חומצות אמינו וגלוטמט (וארגינין מגביר את סינתזת NAG), כך שה-NAG משמש כ'חיישן' המאותת על עודף חנקן ומדליק את המעגל בדיוק כשצריך לסלק חנקן. מדוע המסיחים שגויים: א' — ארגינאז הוא השלב האחרון (משחרר אוריאה), לא נקודת הבקרה. ב' — אורניתין טרנסקרבמואילאז אינו השלב קובע הקצב. ד' — ארגינינוסוקצינאט סינתטאז אינו נקודת הוויסות העיקרית. טיפ: 'NAG הוא המפסק הראשי של מעגל האוריאה' — חיישן רמת חומצות האמינו."},
    {"topic":"סינתזת שומנים","q":"סינתזת חומצות שומן מתרחשת בציטוזול ודורשת אצטיל-CoA ו-NADPH. אצטיל-CoA נוצר במיטוכונדריה אך אינו יכול לחצות את הממברנה ישירות. כיצד הוא מועבר לציטוזול, ומהו מקור ה-NADPH העיקרי הנלווה למנגנון זה?","o":["דרך מעבורת הקרניטין; ה-NADPH מגיע ממעגל קרבס","דרך מעבורת הציטראט (citrate shuttle); ה-NADPH מגיע מהאנזים מאליק (malic enzyme) וממסלול הפנטוז פוספט","דרך מעבורת האספרטט-מלאט; ה-NADPH מגיע מגליקוליזה","אצטיל-CoA מתפזר חופשית; ה-NADPH מגיע מ-ATP synthase"],"a":1,"e":"העיקרון: סינתזת חומצות שומן מתרחשת בציטוזול ודורשת אצטיל-CoA, אך אצטיל-CoA נוצר במיטוכונדריה ואינו חוצה את הממברנה ישירות. הפתרון הוא מעבורת הציטראט (citrate shuttle): אצטיל-CoA מתעבה עם אוקסלואצטט לציטראט, שיוצא לציטוזול ושם מתפרק על ידי ATP-citrate lyase בחזרה לאצטיל-CoA ואוקסלואצטט. בדרך החזרה, אוקסלואצטט הופך למלאט, והאנזים המאליק (malic enzyme) ממיר אותו לפירובט תוך ייצור NADPH. מקור NADPH מרכזי נוסף לסינתזה הוא מסלול הפנטוז פוספט. מדוע המסיחים שגויים: א' — מעבורת הקרניטין משמשת לפירוק שומן (כניסה למיטוכונדריה), לא לסינתזה, וה-NADPH אינו ממעגל קרבס. ג' — NADPH אינו מגליקוליזה. ד' — אצטיל-CoA אינו מתפזר חופשית. טיפ: 'ציטראט נושא את האצטיל החוצה, והאנזים המאליק מספק NADPH בדרך'."},
    {"topic":"סינתזת שומנים","q":"מהו השלב קובע הקצב והמווסת של סינתזת חומצות שומן, וכיצד הוא מווסת על ידי ציטראט ועל ידי אינסולין מול גלוקגון?","o":["פטי אציד סינתאז (Fatty acid synthase), המופעל על ידי גלוקגון","אצטיל-CoA קרבוקסילאז (ACC), המופעל על ידי ציטראט ועל ידי אינסולין (דה-פוספורילציה) ומעוכב על ידי גלוקגון (פוספורילציה)","אצטיל-CoA קרבוקסילאז (ACC), המעוכב על ידי ציטראט ומופעל על ידי גלוקגון","ATP-citrate lyase, המופעל על ידי גלוקגון ומעוכב על ידי אינסולין"],"a":1,"e":"העיקרון: אצטיל-CoA קרבוקסילאז (ACC) הוא השלב קובע הקצב של סינתזת חומצות שומן — הוא ממיר אצטיל-CoA למלוניל-CoA (השלב המחויב הראשון). ויסותו משלב אותות אלוסטריים והורמונליים: ציטראט מפעיל אותו (מסמן עודף אנרגיה ואספקת חומרי בניין), אינסולין מפעיל אותו דרך דה-פוספורילציה (מצב שובע = בנייה), ואילו גלוקגון/אדרנלין מעכבים אותו דרך פוספורילציה (על ידי AMPK ו-PKA, מצב צום = פירוק). מדוע המסיחים שגויים: א' — פטי אציד סינתאז אינו השלב המווסת, ואינו מופעל על ידי גלוקגון. ג' — ציטראט מפעיל ולא מעכב, וגלוקגון מעכב ולא מפעיל. ד' — ATP-citrate lyase אינו האנזים קובע הקצב כאן. טיפ: 'ציטראט מפעיל ACC' — נקודת בלבול נפוצה, כי בדרך כלל מטבוליטים מעכבים."},
    {"topic":"שילוב מטבולי וויסות הורמונלי","q":"במצב צום ממושך, איזה תיאור מתאר נכון את ההסתגלות המטבולית של המוח ושל הכבד?","o":["המוח עובר לחמצן חומצות שומן ישירות; הכבד מאחסן גליקוגן","המוח מתחיל לנצל גופי קטון כמקור אנרגיה משמעותי; הכבד מבצע גלוקונאוגנזה ומייצר גופי קטון","המוח ממשיך להשתמש רק בגלוקוז מגליקוגן מוחי; הכבד מבצע גליקוליזה","המוח מנצל חומצות אמינו ישירות; הכבד מבצע ליפוגנזה"],"a":1,"e":"העיקרון: בצום ממושך הגוף עובר הסתגלות מטבולית של 'חיסכון בגלוקוז'. המוח, שאינו יכול לנצל חומצות שומן ביעילות כדלק, מסתגל לנצל גופי קטון (ketone bodies) כמקור אנרגיה עיקרי, ובכך מצמצם את צריכת הגלוקוז ושומר עליו לרקמות התלויות בו בלבד. הכבד הוא ה'מפעל': הוא מבצע גלוקונאוגנזה (מלקטט, גליצרול וחומצות אמינו) לאספקת גלוקוז, ובמקביל מייצר גופי קטון מאצטיל-CoA (תוצר בטא-אוקסידציה מואצת). מדוע המסיחים שגויים: א' — המוח אינו מחמצן חומצות שומן ישירות, והכבד מפרק (לא אוגר) גליקוגן בצום. ג' — למוח אין מאגר גליקוגן משמעותי, והכבד אינו מבצע גליקוליזה אלא גלוקונאוגנזה. ד' — הכבד אינו מבצע ליפוגנזה (בניית שומן) בצום אלא להפך. טיפ: 'בצום הכבד מייצר, המוח עובר לקטונים' — חיסכון מרבי בגלוקוז."},
    {"topic":"מבנה חלבונים וחומצות אמינו","q":"מדוע גליצין אינה פעילה אופטית (אכירלית)?","o":["שייר צד קטן שגורם לפעילות אופטית זניחה","גמישות יתר של זוויות פי ו-פסי","הפחמן האלפא שלה קשור לשני אטומי מימן","נמצאת כצוויטריון בתנאים פיזיולוגיים"],"a":2,"e":"פחמן הופך למרכז כירלי (ופעיל אופטית) רק כשהוא קשור לארבע קבוצות שונות. בגליצין שייר הצד הוא אטום מימן, ולכן הפחמן האלפא נושא שני מימנים זהים — רק שלוש קבוצות שונות, אין מרכז כירלי. גליצין היא חומצת האמינו היחידה מבין ה-20 שאינה כירלית. ניתוח מסיחים: (א) לא 'זניחה' אלא היעדר מוחלט של פעילות אופטית; (ב) גמישות פי/פסי נוגעת לקונפורמציית השלד בפפטיד, לא לכיראליות; (ד) כל חומצות האמינו צוויטריונים ב-pH פיזיולוגי — תכונה משותפת שאינה מסבירה דווקא את גליצין."},
    {"topic":"מבנה חלבונים וחומצות אמינו","q":"מדוע סלילי אלפא כמעט אינם מכילים פרולין?","o":["אין לחנקן השלד שלה מימן פנוי לתרום לקשר המימן של הסליל","היא הידרופובית מאוד","מסה מולקולרית גבוהה","קבוצת הצד שלה טבעתית"],"a":0,"e":"שרשרת הצד של פרולין נסגרת בטבעת אל חנקן השלד. לכן לחנקן אין אטום מימן לתרום לקשר המימן הפנימי (i→i+4) המייצב את הסליל, והטבעת גם מקבעת את זווית פי — שתי סיבות לשבירת הסליל (לנינגר). ניתוח מסיחים: (ב) הידרופוביות אינה הסיבה; (ג) המסה אינה רלוונטית ליציבות הסליל; (ד) הטבעת אכן קיימת אך הניסוח אינו מסביר את המנגנון — היעדר המימן על החנקן הוא הסיבה הישירה."},
    {"topic":"מבנה חלבונים וחומצות אמינו","q":"איך משפיעה העלייה ב-2,3-BPG על המוגלובין?","o":["ייצוב מצב T והורדת האפיניות לחמצן","נקשר ישירות לקבוצת ההם","מפריד בין תת-היחידות ומשפיע בעקיפין על קישור החמצן","ייצוב מצב R והעלאת האפיניות לחמצן"],"a":0,"e":"2,3-BPG הוא מאפנן אלוסטרי שלילי. הוא נקשר בחלל המרכזי החיובי של דאוקסי-המוגלובין (מצב T), בין שתי תת-יחידות הבטא, ומייצב מצב זה — מוריד את האפיניות לחמצן ומקדם פריקתו ברקמות. רמתו עולה בגובה ובאנמיה כרונית. ניתוח מסיחים: (ב) אינו נקשר להם (שם נקשר החמצן) אלא לחלל המרכזי; (ג) אינו מפריד בין תת-היחידות — נקשר ביניהן, השפעה ישירה; (ד) הפוך — מייצב T (לא R) ומוריד אפיניות."},
    {"topic":"פחמימות","q":"איזה דו-סוכר מורכב מגלוקוז ופרוקטוז?","o":["לקטוז","סוכרוז","מלטוז","צלוביוז"],"a":1,"e":"סוכרוז בנוי מגלוקוז ופרוקטוז בקשר גליקוזידי בין שני הפחמנים האנומריים (α1→β2); מאחר ששני האנומריים נעולים, סוכרוז אינו סוכר מחזר. ניתוח מסיחים: (א) לקטוז = גלקטוז+גלוקוז; (ג) מלטוז = גלוקוז+גלוקוז (α1→4); (ד) צלוביוז = גלוקוז+גלוקוז (β1→4)."},
    {"topic":"ביו-אנרגטיקה ותרמודינמיקה","q":"מדוע תגובות מטבוליות מאורגנות בדרך כלל במסלולים?","o":["למנוע הגעה לשיווי משקל","כדי להגביר יעילות הבקרה והוויסות","להוריד ספציפיות של אנזימים","להאיץ את קצב התגובות"],"a":1,"e":"ארגון במסלולים (תוצר של שלב = מצע של הבא) יוצר נקודות בקרה רבות: כל שלב מזורז באנזים ייעודי הניתן לוויסות נפרד, יש שלבים 'מחייבים' לבקרת משוב, וניתן לצמד שלבים ולחלקם בין אברונים. ניתוח מסיחים: (א) שמירת שלבים 'הרחק משיווי משקל' היא תיאור תרמודינמי של נקודות בקרה, לא הרציונל לארגון; (ג) הפוך — לכל שלב אנזים ספציפי; (ד) ההאצה היא תפקיד הזרז בכל שלב, לא עצם הארגון."},
    {"topic":"חמצון חומצות שומן","q":"פגיעה בחמצון חומצות שומן בפרוקסיזום גורמת לאיזו מחלה?","o":["מחלת שתן בריח סירופ מייפל","פנילקטונוריה","אלקפטונוריה","תסמונת צֶלְוֶוגֶר"],"a":3,"e":"תסמונת צלווגר היא הפרעה בביוגנזה של הפרוקסיזומים (פגם בגני PEX) — חסרים פרוקסיזומים מתפקדים ולכן נפגעים חמצון בטא של חומצות שומן ארוכות-שרשרת מאוד (VLCFA), סינתזת פלסמלוגנים וחמצון חומצה פיטנית; פגיעה רב-מערכתית כבר בינקות. ניתוח מסיחים: (א) פגם בפירוק BCAA; (ב) חסר פנילאלנין הידרוקסילאז; (ג) חסר הומוגנטיזאט אוקסידאז במסלול הטירוזין — כולם אינם פרוקסיזומליים."},
    {"topic":"זרחון חמצוני","q":"איך יחס ATP/ADP גבוה משפיע על קצב הזרחון החמצוני?","o":["מעבר האלקטרונים בשרשרת מואט","מעבר האלקטרונים בשרשרת מוגבר","מופעלים תהליכי ניתוק (uncoupling)","הקצב אינו משתנה"],"a":0,"e":"בקרת הנשימה: יחס ATP/ADP גבוה = מעט ADP (מצע ATP-סינתאז). זרימת הפרוטונים דרך ה-ATP-סינתאז פוחתת, המפל האלקטרוכימי מצטבר ומפעיל לחץ-נגד, ולכן מעבר האלקטרונים מואט — הנשימה מצומדת לביקוש האנרגטי. ניתוח מסיחים: (ב) הפוך — ADP גבוה מגביר מעבר אלקטרונים; (ג) ניתוק אינו מנגנון פיזיולוגי המופעל ע'י יחס ATP/ADP גבוה; (ד) הקצב רגיש מאוד לזמינות ADP."},
    {"topic":"סינתזת שומנים","q":"איזו מחלה מאופיינת בייצור יתר/הצטברות של טריגליצרידים בכבד?","o":["מחלת אדיסון","פנילקטונוריה","גאוט","כבד שומני לא אלכוהולי"],"a":3,"e":"כבד שומני לא אלכוהולי (NAFLD) מאופיין בהצטברות טריגליצרידים בהפטוציטים, לרוב על רקע תנגודת לאינסולין. ניתוח מסיחים: (א) אדיסון = אי-ספיקת אדרנל; (ב) פנילקטונוריה = הפרעה בפירוק פנילאלנין; (ג) גאוט = הצטברות חומצה אורית — אף אחת אינה מוגדרת בהצטברות TG בכבד."},
    {"topic":"סינתזת שומנים","q":"מה מטרת חומצה ארכידונית בפיזיולוגיה של יונקים?","o":["מקור לסינתזה של איקוסנואידים","מרכיב מרכזי במאגר טריגליצרידים","מרכיב מרכזי בבניית ה-GAGs ובייצוב ממברנות","מטבוליט עיקרי של יונקים"],"a":0,"e":"חומצה ארכידונית (20:4) היא חומצת השומן שממנה נגזרים האיקוסנואידים — פרוסטגלנדינים, תרומבוקסנים ולויקוטריאנים — מתווכי דלקת, כאב וקרישה. ניתוח מסיחים: (ב) אינה מרכיב מרכזי במאגר ה-TG; (ג) GAGs בנויים מסוכרים, לא מחומצה ארכידונית; (ד) אינה 'מטבוליט עיקרי' אלא מבשר ספציפי של מתווכים."},
    {"topic":"קטבוליזם חומצות אמינו","q":"כיצד פגיעה בויטמין B6 תשפיע על מאזן חומצות האמינו?","o":["תעכב את מעגל האוריאה","תפגע במקור/מקורות השלד הפחמני","פגיעה בספיגת חומצות אמינו מהמזון","ירידה בפעילות אנזימי טרנסאמינאז"],"a":3,"e":"ויטמין B6 הוא מבשר PLP — הקו-פקטור החיוני לאמינוטרנספראזות (טרנסאמינאזות). פגיעה ב-B6 פוגעת ישירות בפעילות אנזימים אלה ובכך במאזן חומצות האמינו (טרנסאמינציה היא צעד מרכזי בסינתזה ובפירוק שלהן). ניתוח מסיחים: (א),(ב) השפעות עקיפות/חלקיות לכל היותר; (ג) הספיגה במעי אינה תלויה ישירות ב-PLP באופן שמסביר את מאזן חומצות האמינו."},
    {"topic":"קטבוליזם חומצות אמינו","q":"מה התפקיד של ה-PLP בריאקציית האמינוטרנספראזות?","o":["נושא קבוצות אמין","יוצר קשר קוולנטי (ניסוח לא מדויק)","משמש להעברת פוספט","עוזר ביצירת קשר פוספואסטרי"],"a":0,"e":"PLP (הצורה הפעילה של B6) פועל כ'מעביר' קבוצת אמין: הוא יוצר בסיס שיף (אלדימין) עם חומצת האמינו, מקבל את קבוצת האמין והופך לפירידוקסאמין-פוספט, ואז מעביר אותה לקטו-חומצה מקבלת. ניתוח מסיחים: (ב) אכן נוצר קשר קוולנטי זמני (בסיס שיף) אך הניסוח חלקי ואינו מתאר את התפקיד — נשיאת/העברת קבוצת האמין; (ג),(ד) PLP אינו מעביר פוספט ואינו יוצר קשר פוספואסטרי — זה תפקיד של קו-פקטורים אחרים."},
    {"topic":"ביו-אנרגטיקה ותרמודינמיקה","q":"מה קורה למים שעוברים ממצב מוצק לנוזל (המסה)?","o":["מספר קשרי מימן למולקולה עולה","אנטרופיה של המים יורדת","האנתלפיה של המים עולה","זווית הקשר H–O–H יורדת"],"a":2,"e":"המסת קרח היא תהליך אנדותרמי — האנתלפיה עולה (סופגים חום סמוי). במקביל מספר קשרי המימן הממוצע למולקולה יורד (בקרח ~4, במים נוזליים ~3.4) והאנטרופיה עולה (פירוק הסריג המסודר). ניתוח מסיחים: (א) הפוך — מספר קשרי המימן יורד; (ב) הפוך — האנטרופיה עולה; (ד) זווית הקשר התוך-מולקולרית אינה משתנה משמעותית במעבר הפאזה."},
    {"topic":"אנזימים וקינטיקה","q":"מה ההבדל בין בקרה אלוסטרית לבקרה ע'י זרחון?","o":["רק אלוסטרי משנה קונפורמציה","רק זרחון מגביר פעילות, אלוסטרי יכול גם להגביר וגם להוריד","רק בזרחון נוצר קשר קוולנטי","זרחון יתרחש רק על חלבון במבנה רביעוני"],"a":2,"e":"זרחון הוא מודיפיקציה קוולנטית (הוספת קבוצת פוספט בקשר קוולנטי ע'י קינאז), בעוד בקרה אלוסטרית מבוססת על קשירה לא-קוולנטית של מאפנן. ניתוח מסיחים: (א) שתי הבקרות משנות קונפורמציה; (ב) שגוי בשני הכיוונים — גם זרחון יכול להוריד פעילות, וגם אלוסטרי דו-כיווני; (ד) זרחון מתרחש גם על חלבונים מונומריים."},
    {"topic":"אנזימים וקינטיקה","q":"מה צריך כדי שתתרחש קרישת דם לאחר פציעה?","o":["כמות גדולה של הפרין","חשיפה של TF (Tissue Factor) לזרם הדם","יצירת קשרים קוולנטיים בין יחידות תרומבין","כימוטריפסין"],"a":1,"e":"המסלול החיצוני של הקרישה מתחיל בחשיפת פקטור רקמתי (TF) — הנמצא תת-אנדותליאלית — לזרם הדם בעת פגיעה בכלי; TF מפעיל את פקטור VII ומתניע את מפל הקרישה. ניתוח מסיחים: (א) הפרין הוא נוגד-קרישה — מעכב קרישה; (ג) תרומבין פועל באופן פרוטאוליטי על פיברינוגן, לא ע'י קשרים קוולנטיים בין יחידותיו; (ד) כימוטריפסין הוא אנזים עיכול לבלב, אינו חלק במפל הקרישה."},
    {"topic":"אנזימים וקינטיקה","q":"מה נכון לגבי Keq ו-Q עבור פעילות PFK-1 בכבד בנוכחות אינסולין?","o":["Keq גדול בהרבה מ-Q","Q גדול בהרבה מ-Keq","שניהם דומים וגדולים בהרבה מ-1","שניהם דומים וקטנים בהרבה מ-1"],"a":0,"e":"PFK-1 מזרז שלב בלתי-הפיך (רחוק משיווי משקל) ומהווה נקודת בקרה מרכזית בגליקוליזה; אינסולין מקדם את פעילותה. בתגובה שמתקדמת קדימה הרחק משיווי משקל מתקיים Q << Keq (כלומר Keq גדול בהרבה מ-Q), ולכן ΔG שלילי משמעותית. ניתוח מסיחים: (ב) הפוך; (ג),(ד) דמיון בין Q ל-Keq משמעו קרבה לשיווי משקל — מתאר תגובות הפיכות, לא את PFK-1."},
    {"topic":"גליקוליזה","q":"כמה מולקולות ATP נטו מתקבלות ממולקולת גלוקוז אחת בתסיסה לקטית?","o":["2 בגליקוליזה, 3 מחמצון NADH","2 מגליקוליזה, 5 מחמצון NADH","2 מגליקוליזה, אפס מחמצון NADH","4 בגליקוליזה, אפס מחמצון NADH"],"a":2,"e":"בתסיסה לקטית (אנאירובית) הרווח הוא 2 ATP נטו מהגליקוליזה בלבד. ה-NADH שנוצר בגליקוליזה מתחמצן חזרה ל-NAD+ ע'י לקטט-דהידרוגנאז (הפיכת פירובט ללקטט) — בלי שרשרת נשימה, ולכן 0 ATP מחמצון NADH. ניתוח מסיחים: (א),(ב) חמצון NADH דורש שרשרת נשימה אווירנית שאינה פועלת בתסיסה; (ד) הגליקוליזה נותנת 2 ATP נטו (4 מיוצרים פחות 2 מושקעים), לא 4."},
    {"topic":"גלוקונאוגנזה","q":"איזה תוצר מייצר פירובט-קרבוקסילאז?","o":["אוקסלואצטט","לקטט","אצטיל-CoA","אתנול"],"a":0,"e":"פירובט-קרבוקסילאז (אנזים מיטוכונדריאלי, ביוטין-תלוי) מקרבקסל פירובט לאוקסלואצטט — צעד אנפלרוטי וצעד ראשון בגלוקונאוגנזה; מופעל אלוסטרית ע'י אצטיל-CoA. ניתוח מסיחים: (ב) לקטט נוצר מפירובט ע'י LDH; (ג) אצטיל-CoA נוצר ע'י פירובט-דהידרוגנאז; (ד) אתנול הוא תוצר תסיסה אלכוהולית בשמרים, לא ביונקים."},
    {"topic":"אנזימים וקינטיקה","q":"מדוע יש מגנזיום באתר הפעיל של הקסוקינאז?","o":["לנטרל את המטענים השליליים של ATP","למנוע כניסת מים לאתר הפעיל","לאפשר התקפה נוקלאופילית","למנוע ממים לתקוף נוקלאופילית את הגלוקוז"],"a":0,"e":"המצע האמיתי של קינאזות הוא Mg-ATP: יון ה-Mg²⁺ מנטרל/מסכך את המטענים השליליים של פוספטי ה-ATP, מקטין דחייה אלקטרוסטטית עם הגלוקוז, ומכוון את הפוספט להעברה. ניתוח מסיחים: (ב) הרחקת המים מושגת בעיקר ע'י סגירת האתר ('induced fit'), לא ע'י Mg; (ג),(ד) ה-Mg אינו ה'תוקף' הנוקלאופילי ואינו תפקידו למנוע התקפת מים על הגלוקוז."},
    {"topic":"אנזימים וקינטיקה","q":"מה אומרת הגעה ל-Steady state בקינטיקה אנזימטית?","o":["אין יותר עלייה בריכוז התוצר","ריכוז קומפלקס ES יציב","אין יותר סובסטרט","ריכוז הסובסטרט שבו הקצב שווה למחצית Vmax"],"a":1,"e":"בהנחת המצב היציב (Briggs-Haldane) ריכוז קומפלקס האנזים-מצע (ES) קבוע: קצב היווצרותו שווה לקצב פירוקו (d[ES]/dt≈0). ניתוח מסיחים: (א) התוצר ממשיך להיווצר במצב יציב; (ג) עדיין יש סובסטרט (לרוב בעודף); (ד) מתאר את ההגדרה של Km, לא של מצב יציב."},
    {"topic":"ביו-אנרגטיקה ותרמודינמיקה","q":"מה ניתן לומר על שינוי האנרגיה החופשית (ΔG) בתגובה המזורזת ע'י הקסוקינאז בתא?","o":["ΔG°' חיובי, אך התגובה מתרחשת בתא בזכות ריכוז סובסטרטים גבוה (לה-שטלייה)","ΔG שלילי מאוד, כיוון שהתגובה מצומדת להידרוליזת ATP","ΔG קרוב לאפס, כי האנרגיה מפירוק ATP שווה בדיוק לאנרגיה הנדרשת לזרחון הגלוקוז","התגובה בשיווי משקל תרמודינמי בתנאים פיזיולוגיים"],"a":1,"e":"זרחון הגלוקוז ע'י הקסוקינאז מצומד להידרוליזת ATP ולכן ΔG שלילי משמעותית בתנאים תאיים — תגובה כמעט בלתי-הפיכה ונקודת בקרה. ניתוח מסיחים: (א) גם אם ΔG°' אינו שלילי במיוחד, ההסבר הנכון הוא הצימוד ל-ATP, לא רק לה-שטלייה; (ג) ΔG אינו קרוב לאפס — התגובה רחוקה משיווי משקל; (ד) אינה בשיווי משקל. הערה: הניסוח עוצב מחדש (לא נזכר במדויק בשחזור)."},
    {"topic":"מטבוליזם גליקוגן","q":"מה המעורבות של UDP-glucose בסינתזת גליקוגן?","o":["מעורב גם כסובסטרט ביצירה וגם נוצר כתוצר ביניים בפירוק","תוצר ביניים בתהליך הפירוק","סובסטרט המעורב בבניית הגליקוגן ואינו משתתף בפירוק","משמש רק כאבן בניין לסינתזת הפריימר ע'י גליקוגנין"],"a":2,"e":"UDP-glucose הוא ה'תורם' המופעל של גלוקוז לגליקוגן-סינתאז בבניית הגליקוגן; הוא אינו משתתף בפירוק הגליקוגן (הפירוק ע'י גליקוגן-פוספורילאז מניב גלוקוז-1-פוספט). ניתוח מסיחים: (א) שגוי — אינו תוצר ביניים בפירוק; (ב) שגוי מאותה סיבה; (ד) גליקוגנין אכן משתמש ב-UDP-glucose לתחילת הגרעין, אך זה אינו תפקידו ה'בלעדי' — הוא המצע המרכזי של גליקוגן-סינתאז לאורך כל ההארכה. הערה: באחזור המקורי מסיחים ג'/ד' מוזגו; שוחזרו כאן."},
    {"topic":"שילוב מטבולי וויסות הורמונלי","q":"בנוכחות אינסולין מה יקרה?","o":["עידוד הוצאת וזיקולות GLUT4 לממברנה בתאי השומן והשריר","עיכוב ACC בכבד/בשריר","הפעלת fatty acyl synthetase בכבד ובשריר","הפעלת פעילות גליקוגן-פוספורילאז בשריר ובכבד"],"a":0,"e":"אינסולין מקדם הסעת שלפוחיות המכילות את מוביל הגלוקוז GLUT4 אל קרום התא בשריר ובשומן — ומגביר קליטת גלוקוז. ניתוח מסיחים: (ב) אינסולין מפעיל (לא מעכב) ACC ובכך מקדם סינתזת חומצות שומן; (ג) הניסוח שגוי — אינסולין מקדם ליפוגנזה אך 'fatty acyl synthetase' אינו האנזים המדויק; (ד) אינסולין מעכב (לא מפעיל) גליקוגן-פוספורילאז ומפעיל גליקוגן-סינתאז."},
    {"topic":"קטבוליזם חומצות אמינו","q":"מה מאפיין אספרטט-אמינוטרנספראז (AST)?","o":["פועל רק בציטוזול","אחד התוצרים הוא גלוטמט","דורש ATP","לא דורש קו-פקטור"],"a":1,"e":"AST מזרז את הטרנסאמינציה: אספרטט + α-קטוגלוטרט ⇌ אוקסלואצטט + גלוטמט — כלומר גלוטמט הוא אחד התוצרים. ניתוח מסיחים: (א) קיימים איזואנזימים ציטוזולי ומיטוכונדריאלי; (ג) אינו דורש ATP; (ד) דורש קו-פקטור PLP."},
    {"topic":"קטבוליזם חומצות אמינו","q":"מהו מנגנון הפעולה של PLP באמינוטרנספראזות?","o":["נשיאת קבוצת אמין","קישור Pi להורדת אנרגיית שפעול","נשיאת קבוצת קרבוקסיל","ייצוב המטען החיובי של α-keto acid"],"a":0,"e":"PLP יוצר בסיס שיף עם חומצת האמינו, מקבל ונושא את קבוצת האמין (כפירידוקסאמין-פוספט) ומעבירה לקטו-חומצה מקבלת. ניתוח מסיחים: (ב) אינו עוסק בקישור Pi; (ג) נושא קבוצת אמין, לא קרבוקסיל; (ד) הוא מייצב מטען שלילי בביניים הקרבאניוני, לא 'מטען חיובי'."},
    {"topic":"אנזימים וקינטיקה","q":"מה יקרה מקישור של מעכב מסוג mixed inhibition?","o":["עלייה ב-Vmax","קשירת המעכב מונעת מהאנזים להיקשר לסובסטרט","משנה את ה-Km הנצפה","מעכב רק ע'י קשירה קוולנטית"],"a":2,"e":"מעכב מעורב נקשר גם לאנזים החופשי וגם לקומפלקס ES, ולכן משנה גם את ה-Vmax (מוריד) וגם את ה-Km הנצפה. ניתוח מסיחים: (א) Vmax יורד, לא עולה; (ב) זה מתאר מעכב תחרותי בלבד; (ד) עיכוב מעורב הוא הפיך ולא-קוולנטי."},
    {"topic":"גליקוליזה","q":"מה יקרה בריכוזים גבוהים של ATP וציטראט לאנזים PFK-1?","o":["שניהם מעכבים","שניהם מפעילים","ATP מפעיל וציטראט מעכב","ציטראט מפעיל ו-ATP מעכב"],"a":0,"e":"גם ATP (מצב אנרגטי גבוה) וגם ציטראט (אינדיקטור לעודף ביניימי קרבס/אנרגיה) הם מעכבים אלוסטריים של PFK-1 — נקודת הבקרה המרכזית בגליקוליזה. ניתוח מסיחים: (ב),(ג),(ד) שגויים — שני המאפננים מעכבים, ו-AMP/F2,6BP הם המפעילים."},
    {"topic":"אנזימים וקינטיקה","q":"מה מאפיין מנגנון של general acid-base catalysis?","o":["Substrate desolvation מפריע לקטליזה","המנגנון אינו מושפע מ-pH","האנזים חייב לשבור מולקולת מים לפרוטון ויון הידרוקסיד","מחייב שייר חומצת אמינו עם שרשרת צד שיכולה להתיינן"],"a":3,"e":"קטליזה חומצה-בסיס כללית דורשת שייר חומצת אמינו עם שרשרת צד מתיינת (כמו היסטידין) שיכולה לתרום או לקבל פרוטון בשלב המעבר. ניתוח מסיחים: (א) שגוי — desolvation דווקא מסייעת; (ב) שגוי — המנגנון תלוי-pH (תלוי במצב היינון של השייר); (ג) זו קטליזה ע'י מים, לא חומצה-בסיס כללית."},
    {"topic":"אנזימים וקינטיקה","q":"לליזוזים שני מנגנונים משוערים — SN1 ו-SN2. מה ההבדל ביניהם?","o":["רק באחד נוצר קשר קוולנטי בין האנזים לסובסטרט","רק באחד יש metal ion catalysis","רק באחד יש general acid-base catalysis","רק באחד נעשה שימוש במולקולת מים שעוברת הידרוליזה"],"a":0,"e":"במנגנון מסוג SN2 נוצר ביניים קוולנטי גליקוזיל-אנזים, בעוד במנגנון SN1 נוצר ביניים אוקסוקרבניום יציב (ללא קשר קוולנטי לאנזים). זהו ההבדל המהותי. ניתוח מסיחים: (ב) ליזוזים אינו משתמש ביון מתכת; (ג) קטליזה חומצה-בסיס (Glu35/Asp52) משותפת לשני המנגנונים; (ד) מולקולת מים מעורבת בשלב הסופי בשניהם."},
    {"topic":"אנזימים וקינטיקה","q":"מה משמש פקטור שלילי (נוגד) לקרישת דם?","o":["תרומבין","פיברין","קולגן","Protein C"],"a":3,"e":"חלבון C מופעל הוא נוגד-קרישה — הוא מבקע ומשבית את פקטורים Va ו-VIIIa ובכך מאט את מפל הקרישה. ניתוח מסיחים: (א) תרומבין מקדם קרישה (הופך פיברינוגן לפיברין); (ב) פיברין הוא רשת הקריש; (ג) חשיפת קולגן מתניעה את הקרישה — כולם פרו-קרישתיים."},
    {"topic":"מבנה חלבונים וחומצות אמינו","q":"מי הן חומצות האמינו G, T, F?","o":["Glycine, Threonine, Fructose","Glycine, Threonine, Phenylalanine","Glutamine, Tyrosine, Phenylalanine","Glutamine, Tryptophan, Proline"],"a":1,"e":"בקוד החד-אותי: G=גליצין, T=תראונין, F=פנילאלנין. ניתוח מסיחים: (א) פרוקטוז אינו חומצת אמינו; (ג),(ד) שגויים — Q=גלוטמין, Y=טירוזין, W=טריפטופן, P=פרולין."},
    {"topic":"קטבוליזם חומצות אמינו","q":"מה מאפיין את מחלת הפנילקטונוריה (PKU)?","o":["מוטציה באנזים המייצר טירוזין מפנילאלנין","חוסר יכולת לפרק פנילאלנין שמופרש בשלמותו בשתן","חסר","מחסור בפירובט במח העצם הפוגע במערכת העצבים"],"a":0,"e":"PKU נגרמת ממוטציה באנזים פנילאלנין-הידרוקסילאז (PAH), ההופך פנילאלנין לטירוזין; בהיעדרו מצטבר פנילאלנין ונוצרים פניל-קטונים רעילים. ניתוח מסיחים: (ב) ניסוח חלקי ולא מדויק — הבעיה היא בהמרה לטירוזין, לא 'הפרשה בשלמותו'; (ג) חסר; (ד) שגוי לחלוטין."},
    {"topic":"מבנה חלבונים וחומצות אמינו","q":"מה מאפיין אינטראקציה בין חומצות אמינו שכנות בפפטיד?","o":["קשרי מלח","קשרי מימן","קשרי ון דר ואלס","קשר קוולנטי"],"a":3,"e":"חומצות אמינו שכנות בשרשרת הפפטיד מחוברות בקשר פפטידי — קשר קוולנטי (אמידי). ניתוח מסיחים: (א),(ב),(ג) קשרי מלח, מימן וון-דר-ואלס הם אינטראקציות לא-קוולנטיות המייצבות מבנה מרחבי בין שיירים לא-שכנים, לא את החיבור בין שכנים."},
    {"topic":"חמצון חומצות שומן","q":"מה מתעכב בעקבות קישור מאלוניל-CoA לאנזים CPT1?","o":["ביוסינתזת חומצות שומן","כניסת חומצות שומן למיטוכונדריה","ספיגת חומצות שומן מהמעי","חסר"],"a":1,"e":"מאלוניל-CoA (סמן למצב ליפוגני) מעכב את CPT1, האנזים המעביר אצטיל-קרניטין פנימה — ובכך חוסם את כניסת חומצות השומן למיטוכונדריה ואת חמצון-הבטא, כדי שלא יתרחשו סינתזה ופירוק בו-זמנית. ניתוח מסיחים: (א) הפוך — מאלוניל-CoA הוא דווקא מצע לסינתזה; (ג) אינו קשור לספיגה במעי; (ד) חסר."},
    {"topic":"חמצון חומצות שומן","q":"איזה אנזים קיים בפירוק חומצות שומן אי-זוגיות ולא בזוגיות?","o":["אציל-CoA דהידרוגנאז","אנואיל-CoA הידרטאז","אצטיל-CoA אצילטרנספראז","פרופיוניל-CoA קרבוקסילאז"],"a":3,"e":"חמצון חומצות שומן אי-זוגיות מותיר בסוף פרופיוניל-CoA, שעיבודו (לסוקציניל-CoA) דורש את פרופיוניל-CoA קרבוקסילאז — אנזים שאינו נחוץ בפירוק שרשראות זוגיות. ניתוח מסיחים: (א),(ב),(ג) אנזימים אלה משתתפים במחזור חמצון-הבטא הרגיל של שתי השרשראות."},
    {"topic":"זרחון חמצוני","q":"יון של איזו מתכת מעביר אלקטרונים בזרחון החמצוני?","o":["קווינון","ברזל","ניקל","מגנזיום"],"a":1,"e":"ברזל הוא המתכת המעבירה אלקטרונים בשרשרת הנשימה — בציטוכרומים (heme) ובמרכזי ברזל-גופרית (Fe-S), העוברים בין Fe²⁺ ל-Fe³⁺. ניתוח מסיחים: (א) קווינון (יוביקווינון) אינו מתכת; (ג) ניקל אינו חלק משרשרת הנשימה היונקית; (ד) מגנזיום אינו נושא רדוקס."},
    {"topic":"סינתזת שומנים","q":"מה משותף לפרוגסטרון, קורטיזול ואסטרדיול?","o":["מיוצרים בבלוטת התריס","מיוצרים בלבלב","כולסטרול הוא הפרה-קורסר שלהם","טסטוסטרון הוא הפרה-קורסר שלהם"],"a":2,"e":"כל הורמוני הסטרואידים — כולל פרוגסטרון, קורטיזול ואסטרדיול — נגזרים מכולסטרול דרך פרגננולון. ניתוח מסיחים: (א),(ב) אינם מיוצרים בתריס/לבלב (אלא באדרנל ובגונדות); (ד) טסטוסטרון הוא מבשר לאסטרדיול בלבד, לא לקורטיזול/פרוגסטרון — המשותף לשלושתם הוא הכולסטרול."},
    {"topic":"גורלות הפירובט","q":"מה הסיבה לכך שאין תסיסה אלכוהולית באדם?","o":["אין פירובט-דקרבוקסילאז","אין אלכוהול-דהידרוגנאז","אין אף אחד מהשניים","שני האנזימים קיימים אך התגובה חד-כיוונית"],"a":0,"e":"לאדם חסר פירובט-דקרבוקסילאז — האנזים (השמרי) ההופך פירובט לאצטאלדהיד — ולכן אין תסיסה אלכוהולית. את האלכוהול-דהידרוגנאז דווקא יש (לפירוק אתנול). ניתוח מסיחים: (ב),(ג) שגויים — אלכוהול-דהידרוגנאז קיים; (ד) האנזים הראשון פשוט חסר."},
    {"topic":"שילוב מטבולי וויסות הורמונלי","q":"איזה קשר הוא עתיר-אנרגיה במולקולת אצטיל-CoA?","o":["תיואסטרי","אסתר חמצני","פוספודיאסטרי","פוספואנהידרידי מעורב"],"a":0,"e":"הקשר עתיר-האנרגיה באצטיל-CoA הוא הקשר התיואסטרי בין קבוצת האציל לגופרית של ה-CoA; הידרוליזתו משחררת אנרגיה רבה ומניעה תגובות העברת אציל. ניתוח מסיחים: (ב),(ג),(ד) אינם הקשר עתיר-האנרגיה הרלוונטי באצטיל-CoA."},
    {"topic":"גלוקונאוגנזה","q":"באילו איברים נקבל גלוקוז מפירוק טריאצילגליצרול?","o":["בתאי שומן בהרעבה מפירוק גליצרול","בתאי כבד מפירוק גליצרול","בתאי שומן מפירוק גליצרול וחומצות שומן","בתאי כבד מפירוק חומצות שומן וגליצרול"],"a":1,"e":"פירוק TAG משחרר גליצרול וחומצות שומן. הגליצרול מגיע לכבד ונכנס לגלוקונאוגנזה (דרך גליצרול-3-פוספט → DHAP) — ולכן הגלוקוז נוצר בכבד מהגליצרול. ניתוח מסיחים: (ג),(ד) חומצות שומן מתפרקות לאצטיל-CoA ואינן יכולות לייצר גלוקוז ביונקים; (א) תאי השומן אינם עושים גלוקונאוגנזה."},
    {"topic":"סינתזת שומנים","q":"טיפת שומן (lipid droplet) עטופה ב-?","o":["חד-שכבה של פוספוליפידים","דו-שכבה של פוספוליפידים","חד-שכבה של ליפידים נייטרליים","דו-שכבה של ליפידים נייטרליים"],"a":0,"e":"טיפת השומן הציטופלזמית עטופה בחד-שכבה (מונולייר) של פוספוליפידים, שכן ליבתה (TAG/אסטרי כולסטרול) הידרופובית — בשונה מאברונים העטופים בדו-שכבה. ניתוח מסיחים: (ב) דו-שכבה מאפיינת ממברנות תאיות; (ג),(ד) המעטפת בנויה פוספוליפידים, לא ליפידים נייטרליים."},
    {"topic":"מסלול הפנטוז פוספט","q":"מהם הסובסטרטים של גלוטתיון-רדוקטאז?","o":["NADPH וגלוטתיון מחוזר","NADP+ וגלוטתיון מחומצן","NADPH וגלוטתיון מחומצן","NADH וגלוטתיון מחומצן"],"a":2,"e":"גלוטתיון-רדוקטאז מחזר גלוטתיון מחומצן (GSSG) בעזרת NADPH: GSSG + NADPH → 2GSH + NADP⁺. הסובסטרטים הם NADPH והגלוטתיון המחומצן. ניתוח מסיחים: (א) גלוטתיון מחוזר הוא התוצר; (ב) NADP⁺ הוא התוצר; (ד) האנזים משתמש ב-NADPH ולא ב-NADH."},
    {"topic":"גליקוליזה","q":"מה הסיבה הישירה שגלוקוז נמוך בדם מדכא גליקוליזה בכבד אך לא בשריר?","o":["עלייה ב-cAMP אינה משפיעה על פירובט-קינאז בשריר","בשריר איזואנזים שונה של PFK-2","לשריר טרנספורטר עם רגישות גבוהה יותר לגלוקוז","השריר אינו מכיל רצפטור לגלוקגון"],"a":3,"e":"גלוקוז נמוך → הפרשת גלוקגון → cAMP מדכא גליקוליזה בכבד. השריר אינו מבטא רצפטור לגלוקגון, ולכן אינו 'שומע' את האות והגליקוליזה בו אינה מדוכאת. ניתוח מסיחים: (א),(ב) נכונים חלקית כתוצאה, אך הסיבה הישירה והבסיסית היא היעדר הרצפטור; (ג) אינו הגורם לדיכאון הסלקטיבי."},
    {"topic":"שילוב מטבולי וויסות הורמונלי","q":"איזה תהליך חייב להתרחש בהפרשת אינסולין?","o":["תלוי בתעלות נתרן תלויות-מתח","כניסת סידן לתא דרך תעלות תלויות-מתח","קשירת ATP לתעלות נתרן","הפסקת הפרשת גלוקגון"],"a":1,"e":"בתא הבטא: גלוקוז → ATP → סגירת תעלות K-ATP → דה-פולריזציה → פתיחת תעלות סידן תלויות-מתח → כניסת סידן → אקסוציטוזה של אינסולין. כניסת הסידן היא שלב הכרחי. ניתוח מסיחים: (א),(ג) המעורבות היא של תעלות אשלגן (K-ATP) וסידן, לא נתרן; (ד) אינו תנאי להפרשה."},
    {"topic":"ג'ל אלקטרופורזה","q":"לפי איזו תכונה מפריד SDS-PAGE?","o":["pKa","הידרופיליות","מטען","גודל"],"a":3,"e":"ב-SDS-PAGE ה-SDS מקנה לכל החלבונים מטען שלילי אחיד ומבטל את המבנה והמטען המקוריים, ולכן ההפרדה היא לפי גודל (מסה מולקולרית) בלבד. ניתוח מסיחים: (א),(ב),(ג) בנוכחות SDS תכונות אלה מנוטרלות ואינן בסיס ההפרדה."},
    {"topic":"מבנה חלבונים וחומצות אמינו","q":"מה נכון לגבי חלבון HSP70?","o":["נקשר לחלבונים לא-מקופלים ושולח לפירוק בפרוטאוזום","חלבון מבני ליציבות הממברנה","מסייע לקיפול חלבונים ושומר על מסיסותם","פקטור שעתוק הנקשר ל-DNA"],"a":2,"e":"HSP70 הוא שפרון תלוי-ATP שנקשר לאזורים הידרופוביים חשופים בשרשרת הנולדת/לא-מקופלת, מונע אגרגציה ומסייע לקיפול — שומר על מסיסות החלבון. ניתוח מסיחים: (א) ניתוב לפירוק הוא תפקיד מערכת היוביקוויטין/CHIP, לא תפקידו המרכזי; (ב),(ד) אינם תפקיד HSP70."},
    {"topic":"מבנה חלבונים וחומצות אמינו","q":"מה המנגנון הביוכימי הגורם לאנמיה חרמשית?","o":["אין מידע","מוטציה נקודתית בבטא-גלובין הגורמת למבנה לא תקין של ההמוגלובין","בעיה בברזל","אין מידע"],"a":1,"e":"אנמיה חרמשית נגרמת ממוטציה נקודתית בגן הבטא-גלובין (Glu6Val), היוצרת HbS שמתפלמר בתנאי דה-אוקסיגנציה ומעוות את הכדורית לצורת חרמש. ניתוח מסיחים: (ג) אין בעיה בברזל; (א),(ד) חסרים."},
    {"topic":"אנזימים וקינטיקה","q":"מה ההשפעה של Tamiflu ו-Relenza?","o":["מונע קישור סלקטינים לגליקופרוטאינים","מונע סינתזת גליקופרוטאינים","מונע מווירונים חדשים להיכנס לתא","מעכב את הסיאלידאז (נוירמינידאז) הוויראלי ובכך מונע מווירונים לצאת מהתא"],"a":3,"e":"טמיפלו ורלנזה הם מעכבי נוירמינידאז (סיאלידאז) ויראלי — הם חוסמים את שחרור הווירונים החדשים מפני התא, ובכך עוצרים את ההתפשטות. ניתוח מסיחים: (א),(ב) אינם מנגנון הפעולה; (ג) הם מונעים יציאה ולא כניסה."},
    {"topic":"אנזימים וקינטיקה","q":"מה ההבדל בין פוספורילאז לקינאז?","o":["פוספורילאז מסיר וקינאז מוסיף","פוספורילאז קטבולי וקינאז אנאבולי","פוספורילאז בלתי-הפיך וקינאז הפיך","קינאז לוקח פוספט מ-ATP ופוספורילאז מוסיף Pi (פוספורוליזה)"],"a":3,"e":"קינאז מעביר קבוצת פוספט מ-ATP אל המצע; פוספורילאז מבצע פוספורוליזה — מוסיף פוספט אנאורגני (Pi) תוך שבירת קשר (למשל גליקוגן-פוספורילאז המניב גלוקוז-1-פוספט). ניתוח מסיחים: (א) הסרת פוספט היא תפקיד פוספטאז; (ב),(ג) הבחנות שגויות."},
    {"topic":"קטבוליזם חומצות אמינו","q":"למה נותנים לחולה לוקמיה אספרגינאז?","o":["יצירת יתר של אספרגין","אין מידע","הופך L-אספרגין לרעיל","מפרק אספרגין, ומכיוון שתא סרטני אינו מייצר אספרגין הוא ימות"],"a":3,"e":"L-אספרגינאז מפרק את האספרגין החוץ-תאי. תאי לוקמיה (בעלי אספרגין-סינתטאז נמוך) תלויים באספרגין חיצוני ולכן 'מורעבים' ומתים, בעוד תאים בריאים מייצרים אספרגין בעצמם. ניתוח מסיחים: (ג) האנזים מפרק ולא 'מרעיל'; (א),(ב) שגויים/חסרים."},
    {"topic":"ביו-אנרגטיקה ותרמודינמיקה","q":"מה נכון לגבי חומצה חלשה?","o":["ככל שחזקה יותר היא בופר טוב יותר","pKa שווה לריכוז החומצה ב-pH 7","ככל שה-pKa גבוה יותר, החומצה חלשה יותר","לא ניתן לטטר חומצה חלשה"],"a":2,"e":"ה-pKa מבטא את חוזק החומצה: pKa גבוה יותר = נטייה נמוכה יותר לתרום פרוטון = חומצה חלשה יותר. ניתוח מסיחים: (א) בופר יעיל הוא דווקא חומצה חלשה סביב ה-pKa שלה; (ב) ערבוב מושגים שגוי; (ד) חומצות חלשות בהחלט ניתנות לטיטרציה (משם מקבלים את עקומת הטיטרציה)."},
    {"topic":"ביו-אנרגטיקה ותרמודינמיקה","q":"מה מאפיין תא חי?","o":["ATP ו-ADP אינם בשיווי משקל","מהווה מערכת סגורה","בשיווי משקל עם הסביבה","אנטרופיה בתא גדולה מהסביבה"],"a":0,"e":"תא חי הוא מערכת פתוחה הרחוקה משיווי משקל — יחס ATP/ADP נשמר גבוה ורחוק משיווי משקל באמצעות מטבוליזם מתמשך. ניתוח מסיחים: (ב) התא מערכת פתוחה (מחליפה חומר ואנרגיה); (ג) שיווי משקל עם הסביבה = מוות; (ד) התא מקטין אנטרופיה פנימית על חשבון העלאת אנטרופיית הסביבה."},
    {"topic":"אנזימים וקינטיקה","q":"מה מאפיין את השלב קובע-הקצב (rate-limiting) בריאקציה אנזימטית?","o":["השלב המהיר ביותר","השלב היחיד הדורש אנזים","השלב עם הכי הרבה קשרים חלשים","השלב שבו אנרגיית האקטיבציה היא הגבוהה ביותר"],"a":3,"e":"השלב קובע-הקצב הוא האיטי ביותר — מחסום אנרגיית האקטיבציה שלו הוא הגבוה ביותר, ולכן הוא 'צוואר הבקבוק' של הקצב הכולל. ניתוח מסיחים: (א) הפוך — הוא האיטי; (ב),(ג) אינם נכונים."},
    {"topic":"אנזימים וקינטיקה","q":"מה נכון לגבי קבוע הקצב k1?","o":["קובע את Vmax","קבוע הקצב של חיבור סובסטרט ואנזים (E+S→ES)","מייצג את האפיניות","אין מידע"],"a":1,"e":"בקינטיקת מיכאליס-מנטן, k1 הוא קבוע הקצב של ההתקשרות הקדמית בין האנזים למצע (E+S→ES). ניתוח מסיחים: (א) Vmax נקבע ע'י kcat ([E]total); (ג) האפיניות מבוטאת ע'י Kd/Km (יחס קבועי קצב), לא ע'י k1 לבדו; (ד) חסר."},
    {"topic":"קטבוליזם חומצות אמינו","q":"מה נכון לגבי אמינוטרנספראז?","o":["אחד התוצרים הוא גלוטמט","התגובה אקסרגונית מאוד","אינו מצריך קבוצה פרוסטטית","מצריך ATP"],"a":0,"e":"אמינוטרנספראזות מעבירות קבוצת אמין אל α-קטוגלוטרט ויוצרות גלוטמט כתוצר משותף. ניתוח מסיחים: (ב) התגובה קרובה לשיווי משקל (ΔG≈0), לא אקסרגונית מאוד; (ג) מצריכות קבוצה פרוסטטית — PLP; (ד) אינן דורשות ATP."},
    {"topic":"גלוקונאוגנזה","q":"האם פוספוגליצראט-קינאז (ΔG ≈ −18.5 kJ/mol בגליקוליזה) משתתף בגלוקונאוגנזה?","o":["לא, קיים מעקף","משתתף — התהליך הפיך בתנאים פיזיולוגיים","משתתף — נוצר ATP ו-ΔG שלילי מאוד","לא, יש מעקף בגלל האנזים"],"a":1,"e":"פוספוגליצראט-קינאז הוא אחד מהאנזימים ההפיכים של הגליקוליזה (קרוב לשיווי משקל בתנאים תאיים), ולכן משמש בשני הכיוונים — כולל גלוקונאוגנזה. רק שלושת השלבים הבלתי-הפיכים (הקסוקינאז, PFK-1, פירובט-קינאז) עוקפים בגלוקונאוגנזה. ניתוח מסיחים: (א),(ד) שגויים — אין מעקף לאנזים זה; (ג) הניסוח לא נכון ביחס להפיכות."},
    {"topic":"זרחון חמצוני","q":"מה מנטרל ROS (רדיקלים חופשיים) בתהליכים המתרחשים במיטוכונדריה?","o":["אנזימים כמו SOD (Superoxide Dismutase) או Peroxidase","ניצול ATP בזרחון חמצוני","CO2 המועבר ע'י ציטוכרום C","NADPH באופן ישיר"],"a":0,"e":"מערכות נוגדות-חמצון אנזימטיות — סופראוקסיד-דיסמוטאז (ההופך סופראוקסיד ל-H2O2) ולאחריו קטלאז/פראוקסידאזים — מנטרלות את ה-ROS. ניתוח מסיחים: (ב),(ג) אינם מנגנון ניטרול ROS; (ד) NADPH מספק שווי-ערכי חיזור למערכת הגלוטתיון, אך הניטרול עצמו אנזימטי (לא 'ישיר')."},
    {"topic":"סינתזת שומנים","q":"מה קורה במחלת Familial Hypercholesterolemia?","o":["אין מידע","אין מידע","מוטציה בגן לרצפטור LDL הגורמת להצטברות כולסטרול בעורקים","אין מידע"],"a":2,"e":"במחלה זו יש מוטציה ברצפטור ל-LDL — קליטת ה-LDL מהדם נפגעת, רמת הכולסטרול בפלזמה עולה, והכולסטרול מצטבר בדפנות העורקים (טרשת מואצת). ניתוח מסיחים: (א),(ב),(ד) חסרים."},
    {"topic":"מטבוליזם גליקוגן","q":"למה גורם הורמון הגלוקגון?","o":["חסימת GLUT4 בשריר","הגברת fatty acyl-CoA סינתטאז בכבד","הגברת פעילות גליקוגן-פוספורילאז בכבד","אין מידע"],"a":2,"e":"גלוקגון (במצב צום) מעלה cAMP בכבד, מפעיל PKA, וזה מפעיל את גליקוגן-פוספורילאז ומפרק גליקוגן לשחרור גלוקוז לדם. ניתוח מסיחים: (א) ויסות GLUT4 קשור לאינסולין, לא לגלוקגון; (ב) גלוקגון מקדם פירוק ולא סינתזת שומן; (ד) חסר."},
    {"topic":"תפקוד חלבונים","q":"המוגלובין מפגין קשירת חמצן שיתופית (cooperativity). לפי המודל המתואם (concerted, MWC), מה מתרחש בעת קשירת החמצן הראשון?","o":["כל תת-יחידה עוברת ממצב T ל-R באופן עצמאי ובלתי תלוי בשכנותיה","כל ארבע התת-יחידות במצב קונפורמציוני משותף, והקשירה מסיטה את שיווי המשקל ממצב T למצב R בעל זיקה גבוהה","הקשירה הראשונה דווקא מורידה את זיקת שאר התת-יחידות","התת-יחידות נעולות במצב R קבוע ללא תלות בריכוז החמצן"],"a":1,"e":"במודל המתואם (MWC) כל התת-יחידות יחד במצב T או יחד ב-R; קשירת ליגנד מייצבת את R לכלל המולקולה — מכאן השיתופיות והעקומה הסיגמואידלית. ניתוח מסיחים: (א) מתאר את המודל הרציף (KNF) ולא המתואם; (ג) הפוך — שיתופיות חיובית מעלה זיקה; (ד) שולל ויסות ושיתופיות. טיפ: מתואם = הכול-או-כלום; רציף = צעד-אחר-צעד.","new2026":true},
    {"topic":"תפקוד חלבונים","q":"בקולגן, כל שארית שלישית ברצף החוזר (Gly-X-Y) היא גליצין (glycine), ולעיתים קרובות במיקום Y נמצא הידרוקסיפרולין. מה ההסבר המבני?","o":["גליצין יוצר גשרי דיסולפיד בין שלושת הגדילים","הידרוקסיפרולין נושא מטען חיובי המושך את הגדילים","גליצין הקטן מתאים לליבת הסליל המשולש הצפוף, והידרוקסילציה של פרולין מייצבת את הסליל בקשרי מימן","גליצין מאפשר גמישות כך שהסליל נפתח בקלות"],"a":2,"e":"בסליל הקולגן המשולש שלוש שרשראות שזורות צפוף; רק גליצין, חסר שרשרת צד, נכנס לליבה ולכן חוזר כל שלישית. הידרוקסילציה של פרולין (תלוית ויטמין C) מוסיפה קשרי מימן מייצבים — וחסרונה גורם צפדינה. ניתוח מסיחים: (א) אין דיסולפידים בייצוב הסליל המשולש; (ב) לקבוצת ההידרוקסיל אין מטען חיובי; (ד) הפוך — המבנה נוקשה ויציב. טיפ: Gly-X-Y: גליצין בליבה, הידרוקסיפרולין מייצב.","new2026":true},
    {"topic":"פחמימות","q":"גלוקוז בתמיסה מימית קיים בעיקר בצורה טבעתית. תופעת המוטרוטציה (mutarotation) מתבטאת ב:","o":["התאזנות איטית בין האנומרים alpha ו-beta דרך הצורה הפתוחה בעלת קבוצת האלדהיד","מעבר בין D-גלוקוז ל-L-גלוקוז בתמיסה","חמצון ספונטני של הפחמן האנומרי לחומצה","פילמור של מולקולות גלוקוז לעמילן"],"a":0,"e":"הפחמן האנומרי (C1) יכול להיות alpha או beta; הטבעת נפתחת לצורה פתוחה וחוזרת ונסגרת, וכך מתאזנים שני האנומרים. ניתוח מסיחים: (ב) אלה אננטיומרים שאינם מתחלפים ספונטנית; (ג) זהו חמצון (סוכר מחזר), תהליך אחר; (ד) פילמור אינו קשור למוטרוטציה. טיפ: מוטרוטציה = החלפת alpha/beta דרך הצורה הפתוחה.","new2026":true},
    {"topic":"פחמימות","q":"בפוליסכריד כמו עמילן, מהו 'הקצה המחזר' (reducing end)?","o":["הקצה שבו כל קבוצות ההידרוקסיל עברו זרחון","כל קצה של השרשרת, שכן כולם מחזרים באותה מידה","הקצה הקושר את הפוליסכריד לחלבון נשא","הקצה שבו הפחמן האנומרי חופשי ואינו קשור בקשר גליקוזידי, ולכן יכול להיפתח לצורת אלדהיד מחזר"],"a":3,"e":"קשר גליקוזידי נוצר דרך הפחמן האנומרי; בקצה אחד הוא נשאר חופשי ויכול להיפתח לאלדהיד מחזר. ניתוח מסיחים: (א) אין קשר לזרחון; (ב) בשרשרת לינארית רק קצה אחד מחזר; (ג) מתאר גליקופרוטאין, לא קצה מחזר. טיפ: מחזר = פחמן אנומרי חופשי.","new2026":true},
    {"topic":"פחמימות","q":"מערכת סוגי הדם ABO נקבעת על ידי סוכרים בקצה שרשראות אוליגוסכרידיות על פני כדוריות הדם. מה המשמעות התפקודית של גליקוזילציה כזו?","o":["הסוכרים מספקים לתא את עיקר האנרגיה השוטפת","סוכרים על פני התא משמשים כסמני זהות וכאתרי זיהוי בין-תאיים","הסוכרים אוטמים את הממברנה בפני מים","הגליקוזילציה מפרקת חלבוני ממברנה מיותרים"],"a":1,"e":"גליקוזילציה של חלבונים ושומנים יוצרת 'קוד סוכרים' לזיהוי תאי ולהכרה חיסונית — מערכת ABO היא דוגמה שבה סוכר הקצה קובע את סוג הדם. ניתוח מסיחים: (א) כמויות זעירות, לא מקור אנרגיה; (ג) אינם תפקיד איטום; (ד) גליקוזילציה אינה מנגנון פירוק. טיפ: סוכרי-שטח = תעודת זהות של התא.","new2026":true},
    {"topic":"מסלול הפנטוז פוספט","q":"השלב המזורז על ידי גלוקוז-6-פוספט דהידרוגנאז (G6PD) הוא הצעד המגביל במסלול. מדוע מחסור ב-G6PD פוגע במיוחד בכדוריות דם אדומות בעת עקה חמצונית?","o":["נפגעת אספקת ה-ATP מהזרחון החמצוני בכדורית","מצטבר ריבוז-5-פוספט רעיל בכדורית","נפגעת אספקת ה-NADPH הדרוש לשחזור גלותתיון מחוזר, ולכן הכדוריות חשופות לנזק חמצוני והמוליזה","נחסמת הגליקוליזה ואין ייצור לקטט"],"a":2,"e":"הזרוע המחמצנת מייצרת NADPH — הכוח לשחזור גלותתיון, מגן חמצוני מרכזי; בכדורית אין מקור NADPH חלופי, ולכן מחסור ב-G6PD גורם להמוליזה תחת עקה (תרופות, פול). ניתוח מסיחים: (א) לכדורית הבוגרת אין מיטוכונדריה/זרחון חמצוני; (ב) אין הצטברות רעילה כזו; (ד) G6PD אינו חלק מהגליקוליזה. טיפ: G6PD ← NADPH ← גלותתיון ← הגנה חמצונית.","new2026":true},
    {"topic":"מעגל קרבס","q":"איזה גורם מאיץ את הפעילות של מעגל קרבס ברקמה פעילה מטבולית?","o":["עלייה ביחס NADH/NAD+ וב-ATP","ירידה חדה בריכוז האצטיל-CoA","עיכוב מוחלט של איזוציטרט דהידרוגנאז","עלייה ביחס ADP/ATP וב-Ca2+, וירידה ב-NADH"],"a":3,"e":"המעגל מואץ כשהתא זקוק לאנרגיה: ADP גבוה, ATP נמוך, ו-Ca2+ מפעיל אנזימי מפתח; NADH נמוך מסיר עיכוב. ניתוח מסיחים: (א) הפוך — אלה מעכבים את המעגל; (ב) אצטיל-CoA הוא הדלק הנכנס; ירידתו מאטה; (ג) עיכוב מלא יעצור את המעגל. טיפ: מטען אנרגיה נמוך = מאיץ.","new2026":true},
    {"topic":"מעגל קרבס","q":"מעגל קרבס הוא 'אמפיבולי' — משמש גם לקטבוליזם וגם כמקור לאבני בניין. מהי משמעות תגובה אנפלרוטית (anaplerotic) כמו זו של פירובט קרבוקסילאז?","o":["חידוש (מילוי מחדש) של ביניימי המעגל שנוצלו לביוסינתזה, למשל יצירת אוקסלואצטט מפירובט","פירוק סופי של ביניימי המעגל ל-CO2 ומים","הוצאת אלקטרונים מהמעגל ישירות אל החמצן","המרת אצטיל-CoA חזרה לגלוקוז"],"a":0,"e":"כשביניימי המעגל נשאבים לביוסינתזה, תגובות אנפלרוטיות ממלאות אותם מחדש — פירובט קרבוקסילאז יוצר אוקסלואצטט מפירובט ושומר על רציפות המעגל. ניתוח מסיחים: (ב) זה ההפך — קטבוליזם; (ג) מתאר את שרשרת הנשימה; (ד) אי אפשר נטו ביונקים. טיפ: אנפלרוטי = מילוי מאגר.","new2026":true},
    {"topic":"מעגל האוריאה","q":"קרבמואיל-פוספט סינתטאז I (CPS1), הצעד הראשון במעגל האוריאה, דורש מפעיל אלוסטרי. מהו?","o":["ATP בלבד, ללא צורך במפעיל","N-אצטילגלוטמט (N-acetylglutamate), שריכוזו עולה כשיש עודף חומצות אמינו לפירוק","אוריאה, כמשוב חיובי על תוצר המעגל","ביוטין הקשור קוולנטית לאנזים"],"a":1,"e":"CPS1 פעיל רק בנוכחות N-אצטילגלוטמט (NAG); ריכוזו עולה כשרמת הגלוטמט וחומצות האמינו גבוהה — כך המעגל נדלק כשיש עודף חנקן לסילוק. ניתוח מסיחים: (א) CPS1 דורש מפעיל אלוסטרי; (ג) אין משוב חיובי מאוריאה; (ד) מתבלבל עם אנזימי קרבוקסילציה תלויי ביוטין. טיפ: NAG = מתג ההצתה של מעגל האוריאה.","new2026":true},
    {"topic":"מעגל האוריאה","q":"שני אטומי החנקן במולקולת האוריאה מגיעים ממקורות שונים. מהם?","o":["שניהם מאמוניה חופשית בלבד","שניהם מגלוטמין ישירות","אחד מאמוניה חופשית (דרך קרבמואיל-פוספט) והשני מאספרט","אחד מ-CO2 והשני מ-ATP"],"a":2,"e":"חנקן אחד נכנס כאמוניה (בקרבמואיל-פוספט) והשני מאספרט (ביצירת ארגינינוסוקצינט); פחמן האוריאה מ-CO2. ניתוח מסיחים: (א) המקור השני הוא אספרט; (ב) גלוטמין אינו המקור הישיר לשני האטומים; (ד) CO2 תורם פחמן, ו-ATP אינו מקור אטומי. טיפ: אמוניה + אספרט = שני החנקנים.","new2026":true},
    {"topic":"שילוב מטבולי וויסות הורמונלי","q":"בצום ממושך, המוח מסתגל לנצל גופי קטו (ketone bodies) כמקור אנרגיה. מה היתרון המטבולי המרכזי של הסתגלות זו?","o":["המוח מפסיק לחלוטין לצרוך גלוקוז כבר ביום הראשון","גופי הקטו מסונתזים בשריר השלד","גופי הקטו מונעים כל פירוק שומן","חיסכון בחלבון הגוף — פחות צורך בפירוק שריר לגלוקונאוגנזה"],"a":3,"e":"בצום ממושך הכבד מייצר גופי קטו משומן והמוח עובר לנצלם — כך פוחת הצורך לפרק חלבון שריר לגלוקונאוגנזה והגוף שומר על מסת השריר. ניתוח מסיחים: (א) המוח עדיין צורך מעט גלוקוז; (ב) הם נוצרים בכבד; (ג) הפוך — ייצורם תלוי בפירוק שומן מוגבר. טיפ: קטו = חוסך חלבון בצום.","new2026":true},
    {"topic":"ג'ל אלקטרופורזה","q":"ב-SDS-PAGE, חלבונים מופרדים בעיקר לפי:","o":["מסה מולקולרית, משום ש-SDS מקנה מטען שלילי אחיד פרופורציונלי לאורך השרשרת","המטען החשמלי הטבעי של החלבון בלבד","הנקודה האיזואלקטרית (pI) של החלבון","הפעילות האנזימטית של החלבון"],"a":0,"e":"SDS מפרק את מבנה החלבון ועוטף אותו במטען שלילי אחיד פרופורציונלי למסה; לכן ההפרדה היא לפי מסה, וחלבונים קטנים נודדים מהר יותר. ניתוח מסיחים: (ב) מתאר ריצה לא-מדנטורנטית (native); (ג) מתאר מיקוד איזואלקטרי; (ד) החלבון מדונטר; הפעילות לא רלוונטית. טיפ: SDS = מטען אחיד ← הפרדה לפי גודל.","new2026":true},
    {"topic":"ג'ל אלקטרופורזה","q":"במיקוד איזואלקטרי (isoelectric focusing) חלבון נע בתוך מפל pH עד שהוא נעצר. היכן?","o":["בקצה הקתודה תמיד, ללא תלות ב-pH","ב-pH השווה לנקודה האיזואלקטרית שלו (pI), שבה מטענו הנקי אפס","ב-pH שבו החלבון הכי מסיס","בנקודה שבה מסתו המולקולרית מזערית"],"a":1,"e":"במפל pH החלבון נודד עד ל-pH שבו מטענו הנקי אפס (pI) — שם אין כוח שמזיז אותו והוא ממוקד; הפרדה לפי מטען, משלימה ל-SDS-PAGE לפי מסה. ניתוח מסיחים: (א) אינו העיקרון; (ג) לא קשור למסיסות; (ד) IEF אינו מפריד לפי מסה. טיפ: נעצר ב-pI, מטען אפס.","new2026":true},
    {"topic":"העברת אותות (Signal Transduction)","q":"קולטן מצומד לחלבון G (GPCR) מסוג Gs מופעל על ידי הורמון. מהו רצף האירועים הנכון?","o":["פוספורילציה ישירה של הקולטן את הגליקוגן סינתאז","פתיחת תעלת Ca2+ בקולטן עצמו ושחרור cAMP מהמיטוכונדריה","החלפת GDP ב-GTP על תת-יחידת Gαs ←→ הפעלת אדנילט ציקלאז ←→ עליית cAMP ←→ הפעלת PKA","הפעלת פוספודיאסטראז המעלה את ריכוז ה-cAMP"],"a":2,"e":"קישור ליגנד ל-GPCR מסוג Gs גורם להחלפת GDP ב-GTP על Gαs; Gαs-GTP מפעיל אדנילט ציקלאז שמייצר cAMP; cAMP מפעיל PKA שמזרחן מטרות. ניתוח מסיחים: (א) מדלג על המתווכים; הקולטן עצמו אינו קינאז כאן; (ב) cAMP נוצר בממברנה ע'י אדנילט ציקלאז, לא במיטוכונדריה; (ד) הפוך — פוספודיאסטראז מפרק cAMP. טיפ: ליגנד←G←ציקלאז←cAMP←PKA.","new2026":true},
    {"topic":"העברת אותות (Signal Transduction)","q":"כיצד מסתיים האות שמעביר חלבון G הטרוטרימרי?","o":["Gα מפורק קוולנטית על ידי הקולטן","GTP נקשר באופן קבוע ל-Gα ומשאיר את האות דלוק","ה-cAMP נקשר חזרה ל-Gα ומכבה אותו","הפעילות ה-GTPazit הפנימית של Gα מהדרלת GTP ל-GDP, וה-Gα חוזר להתאחד עם Gβγ במצב כבוי"],"a":3,"e":"ל-Gα פעילות GTPaze מובנית שמהדרלת GTP ל-GDP; במצב GDP ה-Gα מאבד זיקה לאפקטור וחוזר להתאגד עם Gβγ — וכך האות כבה. ניתוח מסיחים: (א) אין פירוק קוולנטי; (ב) מתאר מצב רעלן/מוטנטי, לא סיום תקין; (ג) אינו המנגנון. טיפ: GTP=דלוק, GDP=כבוי.","new2026":true},
    {"topic":"העברת אותות (Signal Transduction)","q":"מסלול פוספוליפאז C (PLC) מפצל PIP2 לשני שליחים משניים. מה תפקידם?","o":["IP3 משחרר Ca2+ מה-ER, ו-DAG מפעיל את פרוטאין קינאז C (PKC)","IP3 מפעיל אדנילט ציקלאז, ו-DAG מפרק cAMP","שניהם פותחים ישירות תעלות נתרן בממברנה","IP3 ו-DAG מעכבים את שחרור הסידן התוך-תאי"],"a":0,"e":"PLC מפצל PIP2 ל-IP3 ול-DAG: IP3 המסיס פותח תעלות Ca2+ ב-ER, ו-DAG הליפופילי נשאר בממברנה ומפעיל PKC. ניתוח מסיחים: (ב) מבלבל עם מסלול cAMP; (ג) אין פתיחת תעלות נתרן ישירה; (ד) הפוך — IP3 מעלה Ca2+. טיפ: IP3=סידן מה-ER, DAG=PKC בממברנה.","new2026":true},
    {"topic":"העברת אותות (Signal Transduction)","q":"קולטן טירוזין קינאז (RTK) נקשר לגורם גדילה. מה הצעד המוקדם בהפעלתו?","o":["חיתוך פרוטאוליטי של הקולטן ושחרור קטע תוך-תאי","דימריזציה של הקולטן ואוטו-פוספורילציה הדדית של שאריות טירוזין בזנב הציטופלזמטי","קישור הקולטן ל-cAMP בצד החוץ-תאי","הפעלת תעלת כלוריד תלוית מתח"],"a":1,"e":"קישור הליגנד מקרב שני מונומרים לדימר; כל קולטן מזרחן את שכנו על טירוזינים, היוצרים אתרי עגינה לחלבונים (GRB2) המובילים למסלול Ras-MAPK. ניתוח מסיחים: (א) מתאר קולטני Notch, לא RTK; (ג) אינו רלוונטי ל-RTK; (ד) אינו רלוונטי ל-RTK. טיפ: RTK = דימר + אוטופוספורילציה על טירוזין.","new2026":true},
    {"topic":"העברת אותות (Signal Transduction)","q":"מדוע מפל סיגנל הורמונלי (למשל אדרנלין ← cAMP ← קסקדת קינאזות) מאפשר 'הגברה' (amplification) עצומה של האות?","o":["כל מולקולת הורמון מפעילה בדיוק מולקולת תוצר אחת","האות נחלש בכל שלב כדי למנוע תגובת יתר","כל אנזים פעיל מזרז יצירת מולקולות תוצר רבות, וכל שלב מכפיל את מספר המולקולות המופעלות","ההגברה נובעת מריבוי קולטנים בלבד, ללא תפקיד לאנזימים"],"a":2,"e":"כל שלב אנזימטי: קולטן בודד מפעיל חלבוני G רבים, כל אדנילט ציקלאז מייצר cAMP רב, כל PKA מזרחן מצעים רבים — וכך אות זעיר הופך לתגובה גדולה. ניתוח מסיחים: (א) הפוך — אין הגברה כזו; (ב) הפוך — האות מתחזק; (ד) הקטליזה האנזימטית היא מקור ההגברה. טיפ: כל שלב אנזים = מכפיל.","new2026":true},
    {"topic":"העברת אותות (Signal Transduction)","q":"רעלן הכולרה (cholera toxin) מבצע שינוי קבוע ב-Gαs כך שפעילות ה-GTPaze שלו נחסמת. מה התוצאה התאית?","o":["Gαs כבוי לצמיתות ו-cAMP יורד לאפס","הקולטן מנותק לחלוטין מהליגנד","ה-PKA מפסיק לפעול בשל עודף cAMP","Gαs נשאר דלוק, אדנילט ציקלאז פעיל ברציפות, ו-cAMP מצטבר — גורם לאיבוד מלחים ומים במעי"],"a":3,"e":"הרעלן מבצע ADP-ריבוזילציה של Gαs ומשבית את ה-GTPaze; לכן Gαs נותר קשור ל-GTP ודלוק, אדנילט ציקלאז פעיל בלי הרף, ו-cAMP מצטבר בתאי המעי — והתוצאה הפרשת מלחים ומים מסיבית. ניתוח מסיחים: (א) הפוך — הרעלן משאיר אותו דלוק; (ב) אינו המנגנון; (ג) PKA דווקא מופעל יתר על המידה. טיפ: כולרה = GTPaze מושבתת = cAMP תקוע גבוה.","new2026":true},
    {"topic":"סינתזת חומצות אמינו","q":"מהי ההגדרה של חומצת אמינו 'חיונית' (essential) בתזונת האדם?","o":["חומצת אמינו שהגוף אינו יכול לסנתז בכמות מספקת ולכן חייבים לקבלה מהמזון","חומצת אמינו החיונית לבניית חלבון, בניגוד לאלו שאינן","חומצת אמינו שהגוף מסנתז ביעילות הגבוהה ביותר","חומצת אמינו הנדרשת רק בילדות ולא בבגרות"],"a":0,"e":"חומצות אמינו חיוניות הן אלו שמסלול הסינתזה שלהן נעדר/לא מספיק באדם, ולכן חייבות להגיע מהמזון; הלא-חיוניות מסונתזות בגוף בטרנסאמינציה. ניתוח מסיחים: (ב) כל חומצות האמינו בונות חלבון; (ג) הפוך — אלו שאינן מסונתזות; (ד) ההגדרה אינה תלוית גיל כך. טיפ: חיונית = חייבים מהמזון.","new2026":true},
    {"topic":"סינתזת חומצות אמינו","q":"מהו המקור העיקרי לקבוצת האמינו ברוב סינתזות חומצות האמינו הלא-חיוניות?","o":["אמוניה חופשית המתווספת ישירות לשלד הפחמני","גלוטמט, שמעביר את קבוצת האמינו בתגובות טרנסאמינציה","אוריאה המפורקת חזרה לאמינו","קבוצת אמינו המשתחררת מפירוק ATP"],"a":1,"e":"גלוטמט הוא צומת החנקן המרכזי: נוצר מקיבוע אמוניה על alpha-קטוגלוטרט, ומעביר את קבוצת האמינו לאלפא-קטו-חומצות בטרנסאמינציה — וכך נוצרות חומצות אמינו לא-חיוניות. ניתוח מסיחים: (א) מסלול ישיר פחות שכיח לרוב חומצות האמינו; (ג) אוריאה היא תוצר סילוק, לא מקור; (ד) ATP אינו מקור חנקן. טיפ: גלוטמט = מחלק החנקן.","new2026":true},
    {"topic":"סינתזת חומצות אמינו","q":"תגובות טרנסאמינציה (transamination) דורשות קו-פקטור. מהו, ומה תפקידו?","o":["ביוטין, הנושא קבוצת קרבוקסיל","תיאמין פירופוספט, הנושא קבוצת אלדהיד","פירידוקסל פוספט (PLP), נגזרת ויטמין B6, שנושאת את קבוצת האמינו בין החומצות","קואנזים A, הנושא קבוצת אצטיל"],"a":2,"e":"כל האמינוטרנספראזות פועלות עם פירידוקסל פוספט (PLP, מוויטמין B6): הוא נקשר זמנית לקבוצת האמינו ומעביר אותה מחומצת אמינו לאלפא-קטו-חומצה. ניתוח מסיחים: (א) ביוטין משמש בקרבוקסילציות; (ב) TPP בדקרבוקסילציות חמצוניות; (ד) CoA בהעברת אצטיל. טיפ: טרנסאמינציה = PLP = B6.","new2026":true},
    {"topic":"סינתזת חומצות אמינו","q":"טטרההידרופולאט (tetrahydrofolate, THF) חשוב במטבוליזם חומצות אמינו ונוקלאוטידים. מה תפקידו?","o":["נשא של אלקטרונים בשרשרת הנשימה","מאגר עיקרי של קבוצות פוספט עתירות אנרגיה","נשא של קבוצות אצטיל לסינתזת שומן","נשא של יחידות פחמן בודד (one-carbon) ברמות חמצון שונות"],"a":3,"e":"THF (מחומצה פולית) הוא הנשא המרכזי של יחידות פחמן בודד (מתיל, מתילן, פורמיל) לסינתזת חומצות אמינו (מתיונין, גליצין/סרין) ונוקלאוטידים. ניתוח מסיחים: (א) מתאר NAD/FAD/קואנזים Q; (ב) מתאר ATP; (ג) מתאר קואנזים A. טיפ: THF = מונית של פחמן-בודד.","new2026":true},
    {"topic":"יסודות: מים, pH ובופרים","q":"לרבות מתכונות המים הביולוגיות (נקודת רתיחה גבוהה, כושר ממס) מקור משותף. מהו?","o":["יכולת המים ליצור קשרי מימן רבים בשל קוטביות המולקולה","המבנה הלא-קוטבי של מולקולת המים","המשקל המולקולרי הגבוה של המים","היעדר אלקטרונים חופשיים בחמצן"],"a":0,"e":"מולקולת המים קוטבית ויוצרת עד ארבעה קשרי מימן עם שכנותיה; רשת זו מסבירה את נקודת הרתיחה הגבוהה, החום הסגולי וכושר ההמסה של חומרים קוטביים. ניתוח מסיחים: (ב) הפוך — המים קוטביים; (ג) מסת המים דווקא נמוכה; (ד) לחמצן יש זוגות אלקטרונים חופשיים. טיפ: הכול נובע מקשרי מימן.","new2026":true},
    {"topic":"יסודות: מים, pH ובופרים","q":"בופר (buffer) פיזיולוגי יעיל ביותר בבלימת שינויי pH כאשר:","o":["ה-pH רחוק ככל האפשר מה-pKa","ה-pH קרוב ל-pKa שלו, כך שיש ריכוזים דומים של החומצה והבסיס המצומד","כל הבופר נמצא בצורתו החומצית בלבד","ריכוז הבופר אפסי"],"a":1,"e":"לפי הנדרסון-הסלבך, קיבול הבופר מרבי כש-pH=pKa — אז יחס בסיס/חומצה כ-1:1 והמערכת בולמת בשני הכיוונים. ניתוח מסיחים: (א) הפוך — שם הקיבול נמוך; (ג) צריך את שתי הצורות; (ד) ללא בופר אין בלימה. טיפ: בופר חזק כש-pH=pKa.","new2026":true},
    {"topic":"יסודות: מים, pH ובופרים","q":"מהו 'האפקט ההידרופובי' (hydrophobic effect) שמניע קיפול חלבונים והרכבת ממברנות?","o":["משיכה חשמלית חזקה בין מולקולות לא-קוטביות","יצירת קשרים קוולנטיים בין שרשראות הידרופוביות","נטיית מולקולות לא-קוטביות להתקבץ יחד כדי למזער את ההפרעה לרשת קשרי המימן של המים","דחייה ישירה של מולקולות לא-קוטביות זו מזו"],"a":2,"e":"קבוצות לא-קוטביות מפריעות לרשת קשרי המימן ומאלצות סידור מים סביבן (ירידת אנטרופיה); התקבצותן ממזערת מגע עם מים ומשחררת אנטרופיה — מה שמניע קיפול וליבת ממברנה. ניתוח מסיחים: (א) אין משיכה חשמלית חזקה כזו; (ב) אינו קוולנטי; (ד) הפוך — הן מתקבצות. טיפ: הידרופובי = בריחה מהמים, רווח אנטרופי.","new2026":true},
    {"topic":"יסודות: מים, pH ובופרים","q":"בעקומת טיטרציה של חומצת אמינו פשוטה, מה מייצגת כל נקודת pKa?","o":["ה-pH שבו החומצה כולה טעונה חיובית","הנקודה שבה החומצה משקעת מהתמיסה","ה-pH שבו אין כלל מולקולות בתמיסה","ה-pH שבו קבוצה מתפרקת חצי — חצי פרוטונית וחצי מפורקת, ושם יכולת הבופר מרבית"],"a":3,"e":"כל pKa בעקומה מתאים לקבוצה מתפרקת (קרבוקסיל, אמינו, שרשרת צד): ב-pH=pKa היא חצי-פרוטונית, השיפוע מתון ויכולת הבופר מרבית; בין שני pKa נמצא ה-pI. ניתוח מסיחים: (א) לא מה ש-pKa מייצג; (ב) pKa אינו נקודת שיקוע; (ג) חסר משמעות. טיפ: pKa = חצי-חצי = שיא בופר.","new2026":true}
  ],
  mol: [
    {"topic":"שכפול DNA — כיווניות","q":"במהלך שכפול DNA, באיזה כיוון מסנתזת DNA פולימראז את הגדיל החדש, ומה מהווה את האתר הכימי שאליו מתווסף הנוקלאוטיד הבא?","o":["סינתזה בכיוון 5 ל-3, כאשר הנוקלאוטיד הנכנס מתווסף לקצה 3'-OH החופשי של הגדיל הגדל","סינתזה בכיוון 3 ל-5, כאשר הנוקלאוטיד הנכנס מתווסף לקצה 5'-פוספט של הגדיל הגדל","סינתזה בכיוון 5 ל-3, כאשר הקצה 5'-טריפוספט של הגדיל הגדל תוקף את הנוקלאוטיד הנכנס","סינתזה בכיוון 3 ל-5, כאשר אנרגיית ההידרוליזה מגיעה מהנוקלאוטיד שכבר משולב בגדיל"],"a":0,"e":"העיקרון: כל ה-DNA פולימראזות מסנתזות אך ורק בכיוון 5'→3'. ההתארכות מתרחשת כשקבוצת ה-3'-OH החופשית שבקצה הגדיל הגדל מבצעת תקיפה נוקלאופילית על אטום הזרחן האלפא של הנוקלאוטיד הנכנס (dNTP), ונוצר קשר פוספודיאסטר תוך שחרור פירופוספט (PPi). פירוק ה-PPi לשני פוספטים מסיע את התגובה קדימה. מדוע המסיחים שגויים: אין סינתזה בכיוון 3'→5' (בלבול כיווניות שכיח); הקצה הגדל הוא 3'-OH ולא 5'-פוספט; אנרגיית הפילמור מגיעה מה-dNTP הנכנס, לא מהנוקלאוטיד שכבר משולב. טיפ לזכירה: 'הפולימראז בונה תמיד מ-5 ל-3, ומוסיף אל ה-3'-OH'."},
    {"topic":"שכפול DNA — גדיל מפגר","q":"מדוע הגדיל המפגר (lagging strand) מסונתז כסדרת מקטעי אוקזאקי קצרים ולא ברצף אחד, בעוד הגדיל המוביל מסונתז ברציפות?","o":["מפני שהפולימראז של הגדיל המפגר איטי יותר ואינו מסוגל לסנתז רצף ארוך","מפני ששני הגדילים מסונתזים בכיוון 5 ל-3, אך הגדיל המפגר מתקדם בכיוון מנוגד לתנועת המזלג, ולכן מסונתז במקטעים","מפני שהגדיל המפגר משמש כתבנית בלבד ואינו מועתק ישירות","מפני שעל הגדיל המפגר אין צורך בפריימר RNA, ולכן הסינתזה נקטעת בכל פעם"],"a":1,"e":"העיקרון: שתי הפולימראזות מסנתזות 5'→3' בלבד, אך שני גדילי התבנית אנטי-מקבילים (antiparallel). הגדיל המוביל יכול להתקדם ברציפות בכיוון תנועת המזלג, ואילו הגדיל המפגר חייב להתקדם בכיוון ההפוך לתנועת המזלג, ולכן מסונתז לאחור במקטעים קצרים — מקטעי אוקזאקי (Okazaki) — שכל אחד דורש פריימר RNA משלו. מדוע המסיחים שגויים: זה אותו אנזים ואותו קצב, לא עניין של 'איטיות'; הגדיל המפגר אכן מועתק לגדיל חדש; דווקא קיים צורך בפריימר RNA לכל מקטע. טיפ: הסיבה היחידה לגדיל המפגר היא אילוץ הכיווניות 5'→3' מול תבנית אנטי-מקבילה."},
    {"topic":"שכפול DNA — פריימאז","q":"מהו תפקידו הייחודי של פריימאז (primase) בשכפול ה-DNA, ומדוע הוא הכרחי?","o":["הוא מסיר פריימרים של RNA כדי לאפשר לליגאז לחבר את המקטעים","הוא מסנתז פריימר קצר של DNA המספק קצה 3'-OH שממנו DNA פולימראז יכול להתחיל","הוא מסנתז פריימר קצר של RNA המספק קצה 3'-OH, מאחר ש-DNA פולימראז אינו יכול להתחיל גדיל מאפס","הוא משמש כהליקאז המפריד את גדילי התבנית לפני תחילת הסינתזה"],"a":2,"e":"העיקרון: פריימאז (primase) הוא למעשה RNA פולימראז המסנתז פריימר RNA קצר, המספק קצה 3'-OH פנוי. DNA פולימראז אינו יכול להתחיל גדיל de novo (מאפס) — הוא רק מאריך קצה 3'-OH קיים — ולכן הפריימר חיוני לכל אתחול. מדוע המסיחים שגויים: הסרת הפריימרים נעשית ע\"י נוקלאז/RNase H ולא ע\"י פריימאז; הפריימר עשוי RNA ולא DNA (וזו בדיוק הסיבה לקיומו — לעקוף את חוסר היכולת של DNA פול להתחיל מאפס); הפרדת גדילי התבנית היא תפקיד ההליקאז. טיפ: 'פריימאז מניח את אבן הפינה — קצה 3'-OH ראשוני שממנו הפולימראז ממשיך'."},
    {"topic":"שכפול DNA — נאמנות","q":"DNA פולימראז משיג נאמנות גבוהה בעיקר בזכות פעילות proofreading. כיצד פועל מנגנון זה?","o":["פעילות אקסונוקלאז 3 ל-5 מסירה נוקלאוטיד שזה עתה שולב באופן שגוי, לפני המשך הסינתזה","פעילות אקסונוקלאז 5 ל-3 מסירה את הנוקלאוטיד השגוי מהקצה הקדמי של הגדיל","הפולימראז מזהה את הטעות ומשלים מולקולת מים כדי לנטרל את הזיווג השגוי","מערכת תיקון ה-mismatch שמבצעת את ה-proofreading תוך כדי הסינתזה עצמה"],"a":0,"e":"העיקרון: נאמנות (fidelity) הפולימראז נשענת על פעילות אקסונוקלאז 3'→5' מתקנת (proofreading). אם שולב נוקלאוטיד מזווג-שגוי, הזיווג הרופף מאט את הסינתזה, הקצה 3' עובר לאתר האקסונוקלאז, הנוקלאוטיד השגוי מוסר, ואז הסינתזה מתחדשת. מדוע המסיחים שגויים: כיוון התיקון הוא 3'→5' ולא 5'→3' (פעילות 5'→3' של DNA פול I קשורה להסרת פריימר, לא ל-proofreading); אין 'נטרול במים' של זיווג שגוי; תיקון אי-התאמה (mismatch repair) הוא מערכת נפרדת הפועלת לאחר השכפול, ולא ה-proofreading של הפולימראז עצמו. טיפ: proofreading = 'מחיקה לאחור' של הטעות האחרונה תוך כדי כתיבה."},
    {"topic":"תיקון DNA — mismatch repair","q":"מערכת תיקון אי-ההתאמה (mismatch repair) מתקנת שגיאות שחמקו מה-proofreading. מהו האתגר המרכזי שמערכת זו חייבת לפתור, וכיצד הוא נפתר בתאי יונקים?","o":["עליה לזהות אילו בסיסים פגומים כימית, ולעשות זאת על פי שינויי מתילציה","עליה להבחין איזה משני הגדילים הוא הגדיל החדש שטעה, ובתאי יונקים היא מזהה זאת לפי שברים/חריצים (nicks) בגדיל החדש","עליה לזהות את כיוון מזלג השכפול, ולעשות זאת לפי מיקום הטלומר","עליה להסיר את כל מקטע אוקזאקי שבו אירעה הטעות ולסנתזו מחדש מהפריימר"],"a":1,"e":"העיקרון: תיקון אי-התאמה (mismatch repair) חייב לזהות איזה משני הגדילים הוא הגדיל החדש שטעה, שכן הזיווג השגוי הוא בין שני בסיסים תקינים כשלעצמם — צריך לדעת את מי לתקן. בתאי יונקים ההבחנה מתבססת על חריצים/שברים (nicks) הקיימים זמנית בגדיל הבת החדש (אזורי אי-רציפות שטרם נסגרו). מדוע המסיחים שגויים: ה-mismatch מתקן זיווגים שגויים בין בסיסים תקינים, לא נזק כימי לבסיס; הבחנת הגדיל ביונקים אינה תלויה במתילציה (מנגנון ה-Dam methylation לזיהוי הגדיל הוא של E. coli בלבד); אין צורך בזיהוי המזלג או הטלומר ואין הסרת מקטע אוקזאקי שלם. טיפ: השאלה המרכזית ב-MMR היא 'איזה גדיל חדש?', והתשובה ביונקים — לפי החריצים."},
    {"topic":"תיקון DNA — excision repair","q":"בתיקון על ידי כריתת בסיס (base excision repair), מהו רצף הפעולות הנכון לתיקון בסיס פגום בודד כגון ציטוזין שעבר דה-אמינציה ל-אורציל?","o":["נוקלאז כריתה מסיר אוליגונוקלאוטיד שלם המכיל את הנזק, ואז פולימראז ממלא את הפער","DNA גליקוזילאז מסיר את הבסיס הפגום ויוצר אתר AP, אנדונוקלאז AP חותך את שלד הסוכר-פוספט, פולימראז ממלא וליגאז סוגר","הליגאז מזהה את הבסיס הפגום וקושר אליו בסיס תקין חדש ישירות","הבסיס הפגום מתוקן על ידי הפיכתו הישירה (direct reversal) באמצעות פוטוליאז ללא הסרה"],"a":1,"e":"העיקרון: בתיקון על-ידי כריתת בסיס (base excision repair, BER) לבסיס פגום בודד הסדר הוא: DNA גליקוזילאז ספציפי מנתק את הבסיס הפגום (כגון אורציל שנוצר מדה-אמינציה של ציטוזין) ויוצר אתר אבסיני (AP site); אנדונוקלאז AP חותך את שלד הסוכר-פוספט באתר; פולימראז ממלא את הפער בנוקלאוטיד תקין; וליגאז סוגר. מדוע המסיחים שגויים: הסרת אוליגונוקלאוטיד שלם מאפיינת nucleotide excision repair (NER) לנגעים גדולים מעוותי-סליל, לא BER; ליגאז אינו מזהה או מוסיף בסיסים, רק סוגר nick; direct reversal (כמו פוטוליאז לדימרי תימין) הוא מסלול נפרד שאינו כולל הסרת בסיס. טיפ: BER = 'גליקוזילאז גוזם בסיס בודד → AP → חיתוך → מילוי → סגירה'."},
    {"topic":"רקומבינציה הומולוגית — RAD51","q":"בתיקון שבר דו-גדילי על ידי רקומבינציה הומולוגית, מהו תפקידו המדויק של RAD51, וכיצד הוא קשור לעיבוד הראשוני של השבר?","o":["RAD51 חותך את שני הגדילים ליצירת קצות בולטים של 3', ואז משמש כתבנית","RAD51 נקשר לקצה 5' החד-גדילי הבולט ומקדם את חיבורו הישיר לגדיל השני (NHEJ)","לאחר עיבוד נוקלאוליטי (resection) שיוצר זנב 3' חד-גדילי, RAD51 מצפה אותו כפילמנט ומקדם פלישת גדיל (strand invasion) לסליל ההומולוגי","RAD51 פותר את צמתי הולידיי (Holliday junctions) בסיום הרקומבינציה"],"a":2,"e":"העיקרון: בתיקון שבר דו-גדילי (DSB) ברקומבינציה הומולוגית, תחילה מתבצע עיבוד נוקלאוליטי (resection) שחושף זנב 3' חד-גדילי. RAD51 מתאסף על הזנב הזה כפילמנט נוקלאופרוטאיני ומקדם חיפוש הומולוגיה ופלישת גדיל (strand invasion) אל הסליל ההומולוגי השלם המשמש כתבנית. מדוע המסיחים שגויים: ה-resection מבוצע ע\"י נוקלאזות ולא ע\"י RAD51, והקצה הפעיל הוא 3' ולא 5'; חיבור ישיר של קצוות ללא תבנית הוא NHEJ — מסלול נפרד ש-RAD51 אינו מעורב בו; פתירת צמתי הולידיי היא תפקיד רזולבאז, לא RAD51. טיפ: זכרו את שלשת ה-R — Resection, RAD51 filament, strand invasion."},
    {"topic":"רקומבינציה — צומת הולידיי","q":"צומת הולידיי (Holliday junction) הוא מבנה ביניים מרכזי ברקומבינציה הומולוגית. כיצד מתרחשת פתירתו (resolution), ומה קובע את התוצאה הגנטית?","o":["רזולבאז (resolvase) חותך את הצומת בזוג גדילים; אופן החיתוך קובע אם נוצרים מוצרי crossover או non-crossover","הליקאז מפריד את הצומת לשניים ללא חיתוך, ותמיד נוצר crossover","הצומת נפתר אך ורק על ידי ליגאז המחבר את ארבעת הגדילים מחדש","הצומת נפתר על ידי פולימראז הממלא את הפער, והתוצאה תמיד non-crossover"],"a":0,"e":"העיקרון: צומת הולידיי (Holliday junction) הוא מבנה ביניים צולב ברקומבינציה. פתירתו (resolution) מתבצעת ע\"י אנזים רזולבאז (resolvase) החותך אנדונוקלאוליטית זוג גדילים בצומת. האופן שבו נחתך הצומת — איזה זוג גדילים נחתך ביחס למישור הצומת — קובע אם המוצרים יהיו crossover (החלפת אגפי כרומוזום) או non-crossover. מדוע המסיחים שגויים: פתירה דורשת חיתוך אנדונוקלאוליטי, לא רק הפרדה ע\"י הליקאז, ואינה 'תמיד crossover'; ליגאז מחבר אך אינו פותר את הצומת; פולימראז ממלא פערים אך אינו פותר, והתוצאה אינה תמיד non-crossover. טיפ: זווית החיתוך של הרזולבאז = הגרלה בין crossover ל-non-crossover."},
    {"topic":"כרומטין — נוקלאוזום","q":"מהו ההרכב המבני של ליבת הנוקלאוזום (nucleosome core particle), ובאיזה אופן ה-DNA קשור אליה?","o":["אוקטמר היסטונים המורכב משני עותקים של H2A, H2B, H3 ו-H4, שסביבו כרוך DNA באורך כ-147 זוגות בסיסים","טטרמר היסטונים הכולל H1 ו-H3, שסביבו כרוך DNA באורך כ-200 זוגות בסיסים","אוקטמר הכולל את היסטון H1 כחלק מליבת האוקטמר, שסביבו כרוך DNA","משושה (hexamer) של היסטונים שאליו ה-DNA נקשר מבפנים, בתוך חלל הליבה"],"a":0,"e":"העיקרון: ליבת הנוקלאוזום (nucleosome core) היא אוקטמר היסטונים — שני עותקים מכל אחד מ-H2A, H2B, H3 ו-H4 — שסביבו כרוך מבחוץ DNA באורך כ-147 זוגות בסיסים (כ-1.7 סיבובי-על). מדוע המסיחים שגויים: H1 הוא היסטון מקשר (linker) חיצוני לאוקטמר, לא חלק מליבתו; הליבה היא אוקטמר ולא טטרמר/הקסמר (אורך ה-DNA 147 bp, לא 200); ה-DNA כרוך מבחוץ סביב גליל ההיסטונים ולא נקשר בחלל פנימי. טיפ לזכירה: '8 היסטונים בליבה (2 מכל אחד מ-4 הליבתיים), 147 bp כרוכים מסביב, H1 בחוץ'."},
    {"topic":"כרומטין — היסטון H1 וכרומטין","q":"מהו ההבדל התפקודי בין היסטון המקשר H1 לבין היסטוני הליבה, וכיצד הוא משפיע על מבנה הכרומטין?","o":["H1 הוא חלק מאוקטמר הליבה ומייצב את כריכת ה-147 זוגות הבסיסים","H1 נקשר ל-DNA המקשר (linker DNA) בין נוקלאוזומים ומסייע לדחיסת השרשרת לסיב בעובי 30 ננומטר","H1 מפרק את הנוקלאוזומים ומאפשר את פתיחת הכרומטין לתעתוק","H1 מחליף את היסטון H3 באזורים פעילים תעתוקית"],"a":1,"e":"העיקרון: היסטון H1 הוא היסטון מקשר (linker) הנקשר ל-DNA המקשר שבין נוקלאוזומים סמוכים ולנקודת הכניסה/יציאה של ה-DNA מהנוקלאוזום. הוא מקדם את כפיפת ודחיסת שרשרת ה'חרוזים על חוט' למבנה מסודר ודחוס יותר (סיב בעובי כ-30 ננומטר במודל הקלאסי). מדוע המסיחים שגויים: H1 אינו חלק מאוקטמר הליבה (8 הליבתיים הם H2A/H2B/H3/H4); הוא מקדם דחיסה ולא מפרק נוקלאוזומים או פותח כרומטין לתעתוק; הוא אינו מחליף את H3 — החלפת וריאנטים כמו H3.3 היא תהליך אחר. טיפ: H1 = 'מהדק' הקושר את ה-linker ומהדק את הסיב לכדי דחיסה."},
    {"topic":"טלומרים וטלומראז","q":"טלומראז פותר את בעיית קצה השכפול (end-replication problem). מהו המנגנון המולקולרי שבאמצעותו הוא מאריך את הטלומר?","o":["הוא משתמש ב-DNA פולימראז רגיל כדי להעתיק את הגדיל המוביל עד הקצה ממש","הוא מכיל רכיב RNA המשמש כתבנית פנימית להוספת חזרות DNA לקצה 3' של הגדיל, באמצעות פעילות שעתוק לאחור","הוא חותך את הקצה הקהה של הכרומוזום ומחבר אליו רצף טלומרי מוכן מראש","הוא ממלא את הפער שנותר מהסרת פריימר ה-RNA האחרון בגדיל המוביל"],"a":1,"e":"העיקרון: טלומראז (telomerase) פותר את בעיית קצה השכפול. הוא reverse transcriptase (תעתקן הפוך) הנושא רכיב RNA פנימי המשמש כתבנית, וכך מוסיף שוב ושוב חזרות DNA טלומריות לקצה ה-3' של הגדיל, מאריך אותו מעבר למה ששכפול רגיל מסוגל, ומאפשר אז סינתזת הגדיל המשלים. מדוע המסיחים שגויים: בעיית קצה השכפול נובעת דווקא מהגדיל המפגר (לא המוביל), ופולימראז רגיל אינו יכול לפתור אותה; טלומראז אינו חותך ומדביק רצף מוכן מראש; הוא אינו 'ממלא פער פריימר' בגדיל המוביל אלא מאריך de novo את גדיל ה-3'. טיפ: טלומראז = אנזים שנושא איתו את התבנית שלו (RNA פנימי)."},
    {"topic":"שכפול DNA — חישוב מזלג","q":"מזלג שכפול בודד מתקדם בקצב של כ-1000 נוקלאוטידים לשנייה (ערך אופייני בחיידק). אם אזור מסוים אורכו 600,000 זוגות בסיסים ומשוכפל על ידי שני מזלגות הנעים בכיוונים מנוגדים ממקור שכפול יחיד במרכזו, כמה זמן ייקח לשכפל את האזור כולו?","o":["כ-600 שניות","כ-300 שניות","כ-150 שניות","כ-1200 שניות"],"a":1,"e":"העיקרון: כששני מזלגות יוצאים ממקור שכפול יחיד במרכז וכל אחד נע לכיוון מנוגד, כל מזלג מכסה רק מחצית מהאזור: 600,000 / 2 = 300,000 זוגות בסיסים. בקצב 1000 נוקלאוטידים לשנייה: 300,000 / 1000 = 300 שניות. מדוע המסיחים שגויים: 600 שניות מתעלם מכך ששני מזלגות פועלים במקביל (כאילו מזלג יחיד עובר את כל האורך); 150 שניות מחלק שוב ב-2 ללא הצדקה; 1200 שניות מכפיל בטעות. טיפ לזכירה: שני מזלגות מ-origin מרכזי = הזמן נחתך לחצי, כי שניהם עובדים במקביל לכיוונים מנוגדים."},
    {"topic":"שכפול DNA — ליגאז ומקטעי אוקזאקי","q":"לאחר סינתזת מקטע אוקזאקי, איזו רצף אירועים נדרש לפני שניתן לחבר אותו למקטע הסמוך באמצעות DNA ליגאז?","o":["הסרת פריימר ה-RNA, מילוי הפער בנוקלאוטידי DNA, ויצירת קצה 3'-OH צמוד לקצה 5'-פוספט של המקטע הסמוך","חיבור ישיר של פריימר ה-RNA למקטע הסמוך, ורק אז החלפתו ב-DNA","הסרת פריימר ה-RNA בלבד, מאחר שליגאז מסוגל לגשר על הפער שנותר","פירוק כל המקטע ומחזורו, מאחר שמקטעי אוקזאקי הם תוצר ביניים זמני שאינו נשמר"],"a":0,"e":"העיקרון: לפני שניתן לאחות מקטע אוקזאקי למקטע השכן ע\"י DNA ליגאז, יש שלושה צעדים: (1) הסרת פריימר ה-RNA (ע\"י נוקלאז/RNase H/אקסונוקלאז 5'→3'), (2) מילוי הפער הנותר בנוקלאוטידי DNA ע\"י פולימראז, וכך נוצר קצה 3'-OH הצמוד לקצה 5'-פוספט של המקטע הסמוך, ורק אז (3) ליגאז סוגר את ה-nick. מדוע המסיחים שגויים: הפריימר חייב להיות מוסר ומוחלף ב-DNA לפני האיחוי, לא אחריו; ליגאז סוגר nick יחיד אך אינו 'מגשר' על פער RNA חסר; מקטעי אוקזאקי נשמרים והופכים לחלק קבוע מהגדיל הסופי. טיפ: 'להסיר RNA → למלא DNA → לחתום ב-ליגאז'."},
    {"topic":"רקומבינציה — תיקון שבר דו-גדילי","q":"שני המסלולים העיקריים לתיקון שבר דו-גדילי הם רקומבינציה הומולוגית (HR) וחיבור קצוות לא-הומולוגי (NHEJ). מהו ההבדל העקרוני ביניהם מבחינת דיוק ותלות בתבנית?","o":["HR מהיר ומועד לטעויות מפני שאינו משתמש בתבנית, ואילו NHEJ מדויק מפני שמשתמש בכרומוזום ההומולוגי כתבנית","HR מדויק ומשתמש ברצף הומולוגי שלם (כגון כרומאטיד אחות) כתבנית, ואילו NHEJ מחבר את הקצוות ישירות, לעיתים תוך אובדן נוקלאוטידים, ללא תבנית","שני המסלולים זהים בדיוקם ונבדלים רק בזהות האנזימים","NHEJ פעיל רק בשלב S/G2 בעוד HR פעיל בכל מחזור התא ללא תלות בתבנית"],"a":1,"e":"העיקרון: שני מסלולי תיקון שבר דו-גדילי נבדלים בדיוק ובתלות בתבנית. רקומבינציה הומולוגית (HR) משתמשת ברצף הומולוגי שלם — לרוב הכרומאטיד האחות — כתבנית לשחזור מדויק, ולכן היא נאמנה; חיבור קצוות לא-הומולוגי (NHEJ) מחבר את שני הקצוות ישירות, לעיתים תוך עיבוד ואובדן נוקלאוטידים, ללא תבנית, ולכן עלול להיות מועד-לטעויות. מדוע המסיחים שגויים: התיאור הופך בין השניים (HR הוא המדויק והתלוי בתבנית, לא NHEJ); המסלולים אינם זהים בדיוקם; HR מוגבל בעיקר ל-S/G2 כשקיימת כרומאטיד אחות, ו-NHEJ פעיל לאורך מחזור התא — וההיגד מערבב זאת. טיפ: HR = העתקה מתבנית = מדויק; NHEJ = הדבקת קצוות = מהיר אך מסוכן."},
    {"topic":"שעתוק - גורמי שעתוק כלליים","q":"במהלך אתחול השעתוק של גן מקודד-חלבון אאוקריוטי, איזה מבין הגורמים הבאים אחראי לזיהוי קופסת ה-TATA וקושר אליה ישירות באמצעות תת-היחידה TBP?","o":["טִי-אֵף-2-בי (TFIIB)","טִי-אֵף-2-די (TFIID)","טִי-אֵף-2-הֵא (TFIIH)","טִי-אֵף-2-אֵף (TFIIF)"],"a":1,"e":"העיקרון: באתחול שעתוק של גן מקודד-חלבון אאוקריוטי, TFIID הוא הגורם הכללי הראשון הנקשר לפרומוטר. הוא מכיל את תת-היחידה TBP (TATA-binding protein), המזהה וקושרת ישירות את קופסת ה-TATA וגורמת לכיפוף חד של ה-DNA, מה שמכין את הקרקע להרכבת קומפלקס היוזם. מדוע המסיחים שגויים: TFIIB נקשר אחרי TFIID ומסייע במיקום הפולימראז (גישור בין TBP לפולימראז), אך אינו מזהה את ה-TATA; TFIIH הוא הליקאז/קינאז הפותח את ה-DNA ומזרחן את הקצה הקרבוקסילי (CTD) של הפולימראז; TFIIF מלווה ומייצב את הפולימראז. טיפ: 'D' של TFIID = הראשון, ובתוכו TBP שמזהה TATA."},
    {"topic":"שעתוק - RNA פולימראזות","q":"חוקר מטפל בתאים אאוקריוטיים ברעלן אלפא-אמניטין (α-amanitin) במינון נמוך. צפוי שייפגע בעיקר ייצור של אילו מולקולות?","o":["רנ\"א ריבוזומלי (rRNA) הגדול, המשועתק על-ידי RNA פולימראז I","רנ\"א שליח (mRNA), המשועתק על-ידי RNA פולימראז II","רנ\"א מעביר (tRNA) ו-rRNA 5S, המשועתקים על-ידי RNA פולימראז III","כל סוגי ה-RNA בתא ייפגעו במידה שווה"],"a":1,"e":"העיקרון: אלפא-אמניטין (α-amanitin) במינון נמוך מעכב באופן סלקטיבי את RNA פולימראז II, המשעתק את הגנים המקודדים לחלבונים (mRNA). לכן ייצור ה-mRNA ייפגע ראשון. מדוע המסיחים שגויים: RNA פולימראז I (המשעתק את ה-rRNA הגדול בגרעינון) חסין יחסית לרעלן; RNA פולימראז III (המשעתק tRNA ו-rRNA 5S) רגיש רק למינונים גבוהים; ולכן הפגיעה אינה שווה בכל סוגי ה-RNA. זוהי הבחנה קלאסית בין שלוש הפולימראזות. טיפ לזכירה: סולם הרגישות לאמניטין — Pol II (רגיש מאוד) > Pol III (רגיש במינון גבוה) > Pol I (חסין)."},
    {"topic":"שעתוק - פרוקריוטים מול אאוקריוטים","q":"מהו ההבדל המהותי באופן שבו RNA פולימראז של חיידק (E. coli) מזהה את הפרומוטר לעומת RNA פולימראז II אאוקריוטי?","o":["בחיידק תת-היחידה סיגמא (sigma) שבהולואנזים מזהה ישירות את רצפי הפרומוטר, ואילו באאוקריוטים נדרשים גורמי שעתוק כלליים נפרדים","בחיידק נדרשים גורמי שעתוק כלליים רבים, ואילו באאוקריוטים הפולימראז מזהה את הפרומוטר לבדו","בשניהם תת-היחידה סיגמא מזהה את הפרומוטר ישירות","בחיידק הפולימראז זקוק ל-TBP, ואילו באאוקריוטים לגורם סיגמא"],"a":0,"e":"העיקרון: בחיידק (E. coli) ההולואנזים של RNA פולימראז כולל תת-יחידת סיגמא (sigma) המזהה ישירות את רצפי הקונצנזוס של הפרומוטר (אזורי -10 ו--35), ולכן הפולימראז 'מוצא' את הפרומוטר בכוחות עצמו. באאוקריוטים RNA פולימראז II אינו מסוגל לזהות את הפרומוטר לבדו, ונדרש מערך של גורמי שעתוק כלליים (TFII) המתאספים סביב נקודת ההתחלה ומגייסים את הפולימראז. מדוע המסיחים שגויים: בחיידק אין צורך בגורמים כלליים מרובים; אין סיגמא באאוקריוטים, ו-TBP אינו רכיב חיידקי. טיפ: 'בחיידק — סיגמא לבד; באאוקריוט — ועדה של TFII'."},
    {"topic":"עיבוד RNA - כיפת 5'","q":"מתי וכיצד מתווספת כיפת ה-5' (5' cap) לתעתיק ה-mRNA האאוקריוטי, ומה ייחודה הכימי?","o":["לאחר סיום השעתוק, בציטופלזמה, באמצעות קשר פוספודיאסטר רגיל","בשלב מוקדם של ההתארכות, כשהתעתיק עדיין באורך כ-25 נוקלאוטידים, על-ידי הוספת 7-מתיל-גואנוזין בקשר 5'-ל-5' טריפוספט בלתי-רגיל","עם הגעת הפולימראז לאתר הסיום, על-ידי הוספת זנב של אדנינים","במקביל לשחבור, באמצעות הספלייסוזום שמוסיף את הכיפה"],"a":1,"e":"העיקרון: כיפת ה-5' (5' cap) מתווספת מוקדם מאוד, כשהתעתיק הגדל מגיע לאורך של כ-25 נוקלאוטידים, ע\"י אנזימים הנקשרים לקצה הקרבוקסילי (CTD) המזורחן של RNA פולימראז II. הכיפה היא 7-מתיל-גואנוזין המחובר בקשר 5'-ל-5' טריפוספט יוצא-דופן (ולא קשר פוספודיאסטר 3'-5' רגיל). מדוע המסיחים שגויים: ההוספה אינה לאחר השעתוק בציטופלזמה ואינה בקשר רגיל; זנב הפולי-A מתווסף בקצה ה-3' בסיום, לא הכיפה; השחבור (ע\"י הספלייסוזום) הוא תהליך נפרד שאינו מוסיף את הכיפה. טיפ: הכיפה היא 'הראשונה שמגיעה' (קו-שעתוקית, מוקדם), ויוצאת דופן בקשר 5'-5'."},
    {"topic":"עיבוד RNA - שחבור וספלייסוזום","q":"בתהליך השחבור (splicing), מהו הרצף בתוך האינטרון התוקף את אתר השחבור ב-5' ביצירת מבנה הלאסו (lariat), ואיזה חיבור כימי נוצר?","o":["אדנוזין באתר ההסתעפות (branch point), היוצר קשר פוספודיאסטר 2'-ל-5' עם הנוקלאוטיד הראשון של האינטרון","הגואנוזין בקצה 3' של האינטרון, היוצר קשר 3'-ל-5' עם האקסון","אתר ה-polypyrimidine, היוצר קשר עם כיפת ה-5'","ה-snRNP מסוג U1, התוקף את אתר ה-3' של האינטרון"],"a":0,"e":"העיקרון: בשלב הראשון של השחבור (splicing), קבוצת ה-2'-OH של אדנוזין מסוים באתר ההסתעפות (branch point) שבתוך האינטרון מבצעת תקיפה נוקלאופילית על אתר השחבור ב-5', ויוצרת קשר פוספודיאסטר בלתי-רגיל מסוג 2'-ל-5'. כך נוצר מבנה הלאסו (lariat). בשלב השני נחתך אתר ה-3' של האינטרון, ושני האקסונים מתחברים. מדוע המסיחים שגויים: לא הגואנוזין בקצה ה-3' הוא התוקף; אתר ה-polypyrimidine מסייע בזיהוי אך אינו יוצר את הלאסו ואינו קושר את הכיפה; U1 snRNP מזהה את אתר ה-5' אך אינו זה שתוקף. טיפ: 'ה-A של ה-branch point תוקף את ה-5' ויוצר קשר 2'-5' = לאסו'."},
    {"topic":"עיבוד RNA - snRNP","q":"איזה זוג של חלקיקי snRNP אחראי בספלייסוזום לזיהוי הראשוני של שני קצות האינטרון - אתר השחבור ב-5' ואתר ההסתעפות בהתאמה?","o":["U1 מזהה את אתר השחבור ב-5', ו-U2 מזהה את אתר ההסתעפות","U2 מזהה את אתר השחבור ב-5', ו-U1 מזהה את אתר ההסתעפות","U4 מזהה את אתר השחבור ב-5', ו-U6 מזהה את אתר ההסתעפות","U5 מזהה את שני האתרים בו-זמנית"],"a":0,"e":"העיקרון: בזיהוי הראשוני של קצות האינטרון בספלייסוזום, U1 snRNP מזווג בסיסים עם אתר השחבור ב-5' של האינטרון, ו-U2 snRNP מזווג בסיסים עם רצף אתר ההסתעפות (branch point). U4/U6 ו-U5 מצטרפים בהמשך, משתתפים בארגון מחדש (rearrangement) של הספלייסוזום ובקטליזה. מדוע המסיחים שגויים: החלפת התפקידים בין U1 ל-U2 היא טעות נפוצה; U4/U6 אינם המזהים הראשוניים של ה-5' וההסתעפות; U5 אינו מזהה את שני האתרים בו-זמנית אלא מגשר בין אקסונים בהמשך. טיפ לזכירה: 'U1 = 5' (אחד, ההתחלה); U2 = branch point (אתר ה-A)'."},
    {"topic":"עיבוד RNA - שחבור חלופי","q":"מהי המשמעות התפקודית של שחבור חלופי (alternative splicing)?","o":["הוא מאפשר תיקון שגיאות שנפלו במהלך השעתוק על-ידי הסרת נוקלאוטידים שגויים","הוא מאפשר לגן יחיד לקודד ליותר מחלבון אחד, על-ידי כלילה או השמטה שונה של אקסונים בתעתיקים שונים","הוא מבטיח שכל אקסון יתורגם בדיוק פעם אחת בכל סבב תרגום","הוא ממיר אינטרונים לאקסונים כדי להאריך את החלבון הסופי"],"a":1,"e":"העיקרון: שחבור חלופי (alternative splicing) מאפשר לגן יחיד לקודד ליותר מחלבון אחד, ע\"י כלילה או השמטה שונה של אקסונים (ולעיתים שימור אינטרונים) בתעתיקים שונים. זהו מנגנון מרכזי להרחבת המגוון החלבוני (proteome) מתוך מספר מוגבל של גנים, ולוויסות ביטוי בהתאם לרקמה או לשלב התפתחותי. מדוע המסיחים שגויים: זה אינו מנגנון תיקון שגיאות שעתוק; הוא אינו מבטיח שכל אקסון יתורגם פעם אחת בכל סבב; הוא אינו 'ממיר אינטרונים לאקסונים' — הוא בוחר אילו אקסונים יישמרו. טיפ: שחבור חלופי = 'מתכון אחד (גן), מנות שונות (חלבונים)' לפי בחירת רכיבים."},
    {"topic":"תרגום - אמינואציל-tRNA סינתטאז","q":"מהו תפקידו של האנזים אמינואציל-tRNA סינתטאז (aminoacyl-tRNA synthetase), ומדוע דיוקו קריטי לנאמנות התרגום?","o":["הוא קורא את הקודון על ה-mRNA ומתאים לו אנטיקודון; טעות תגרום להחלפת קודון","הוא קושר חומצת אמינו ספציפית ל-tRNA המתאים לה; טעות תכניס חומצת אמינו שגויה לחלבון, שכן הריבוזום בודק רק את הזיווג קודון-אנטיקודון","הוא קוטל קודוני עצירה מוקדמים על ה-mRNA","הוא יוצר את הקשר הפפטידי בין חומצות אמינו סמוכות בריבוזום"],"a":1,"e":"העיקרון: אמינואציל-tRNA סינתטאז (aminoacyl-tRNA synthetase) קושר את חומצת האמינו הנכונה ל-tRNA המתאים לה — 'טעינת' ה-tRNA. דיוקו קריטי משום שהריבוזום עצמו אינו בודק את זהות חומצת האמינו המחוברת; הוא מוודא רק את הזיווג בין הקודון לאנטיקודון. לכן טעות בטעינה מתורגמת ישירות לחומצת אמינו שגויה בחלבון. מדוע המסיחים שגויים: לא הסינתטאז 'קורא קודון' — הזיווג קודון-אנטיקודון מתרחש בריבוזום; הוא אינו 'קוטל קודוני עצירה'; יצירת הקשר הפפטידי נעשית ע\"י ה-rRNA (פעילות פפטידיל-טרנספראז) ולא ע\"י הסינתטאז. טיפ: הסינתטאז הוא 'המסגר' הקובע נאמנות מוקדם — הריבוזום סומך עליו בעיניים עצומות."},
    {"topic":"תרגום - ריבוזום ואתרי A/P/E","q":"בריבוזום פעיל, באיזה רצף עוברים ה-tRNA-ים בין שלושת האתרים במהלך מחזור התארכות יחיד?","o":["aminoacyl-tRNA נכנס לאתר A, נע לאתר P לאחר יצירת הקשר הפפטידי, ויוצא דרך אתר E","aminoacyl-tRNA נכנס לאתר P, נע לאתר A, ויוצא דרך אתר E","aminoacyl-tRNA נכנס לאתר E, נע לאתר P, ויוצא דרך אתר A","aminoacyl-tRNA נכנס לאתר A ויוצא ישירות מאתר A ללא מעבר"],"a":0,"e":"העיקרון: במחזור התארכות בריבוזום, ה-aminoacyl-tRNA הנושא את חומצת האמינו הבאה נכנס לאתר A (aminoacyl); לאחר יצירת הקשר הפפטידי וטרנסלוקציה, ה-tRNA הנושא את השרשרת המתארכת עובר לאתר P (peptidyl); וה-tRNA הריק עובר לאתר E (exit) ומשתחרר. כלומר הזרימה היא A→P→E. מדוע המסיחים שגויים: כניסה לאתר P שמורה רק ל-tRNA המאתחל (initiator) בשלב האתחול, לא לכל tRNA; אין כניסה דרך E; tRNA אינו 'יוצא ישירות מ-A' ללא מעבר. טיפ לזכירה: A=Arrival (הגעה), P=Peptide (נשיאת השרשרת), E=Exit (יציאה)."},
    {"topic":"תרגום - קוד גנטי ומניעותו","q":"הקוד הגנטי מתואר כ'מנוון' (degenerate). מה משמעות תכונה זו?","o":["קודון יחיד יכול לקודד למספר חומצות אמינו שונות, בהתאם להקשר","מרבית חומצות האמינו מקודדות על-ידי יותר מקודון אחד, אך כל קודון מציין חומצת אמינו אחת בלבד","שליש מהקודונים אינם מקודדים לדבר","הקוד שונה מאורגניזם לאורגניזם בצורה בלתי-צפויה"],"a":1,"e":"העיקרון: ניוון (degeneracy) הקוד הגנטי פירושו שרוב חומצות האמינו מקודדות על-ידי יותר מקודון אחד (קודונים נרדפים, synonymous). עם זאת הקוד אינו דו-משמעי: כל קודון נתון מציין חומצת אמינו אחת בלבד (או אות עצירה). הניוון נובע בעיקר מגמישות בקריאת המיקום השלישי בקודון — תופעת ה-wobble. מדוע המסיחים שגויים: קודון יחיד אינו מקודד למספר חומצות אמינו 'לפי הקשר' (זה היה הופך את הקוד לדו-משמעי); לא שליש מהקודונים 'אינם מקודדים' (רק 3 מתוך 64 הם קודוני עצירה); הקוד כמעט-אוניברסלי ואינו משתנה בלתי-צפוי בין אורגניזמים. טיפ: ניוון = 'יתירות' (כמה קודונים → אותה חומצה), לא דו-משמעות."},
    {"topic":"תרגום - אתחול אאוקריוטי","q":"כיצד מזהה תת-היחידה הריבוזומלית הקטנה האאוקריוטית את קודון הפתיחה הנכון על ה-mRNA?","o":["היא נקשרת ישירות לרצף שיין-דלגרנו (Shine-Dalgarno) שלפני קודון הפתיחה","היא נקשרת לכיפת ה-5' ביחד עם ה-tRNA המאתחל וגורמי האתחול, ואז סורקת את ה-mRNA עד לקודון AUG הראשון בהקשר מתאים","היא נקשרת לזנב הפולי-A ב-3' וסורקת לאחור","היא מזהה את קודון הפתיחה דרך אתר IRES בכל המקרים"],"a":1,"e":"העיקרון: באתחול תרגום אאוקריוטי, תת-היחידה הריבוזומלית הקטנה, יחד עם ה-tRNA המאתחל הנושא מתיונין וגורמי אתחול (eIFs), נקשרת לכיפת ה-5' ואז סורקת (scanning) לאורך ה-mRNA עד לאיתור קודון ה-AUG הראשון בהקשר רצף מתאים (קונטקסט קוזק). מדוע המסיחים שגויים: רצף שיין-דלגרנו (Shine-Dalgarno) הוא מנגנון חיידקי (פרוקריוטי) המקדם קישור ישיר, ולא קיים באאוקריוטים; אין קישור לזנב הפולי-A ב-3' עם סריקה לאחור; אתרי IRES (כניסה פנימית של הריבוזום) הם מקרה חריג ולא הדרך הכללית. טיפ: 'אאוקריוט = כיפה ב-5' ואז סריקה עד ה-AUG הראשון'."},
    {"topic":"תרגום - סיום","q":"כיצד מסתיים תהליך התרגום כאשר הריבוזום מגיע לקודון עצירה (stop codon) כגון UAA?","o":["tRNA מיוחד הנושא אנטיקודון משלים נכנס לאתר A ועוצר את התהליך","גורם שחרור (release factor) חלבוני נכנס לאתר A, מזהה את קודון העצירה וגורם לפפטידיל-טרנספראז להוסיף מים במקום חומצת אמינו, ובכך משחרר את הפוליפפטיד","קודון העצירה גורם להפסקה מיידית של פעילות הריבוזום ללא גורמים נוספים","ה-snRNP מסוג U6 קוטע את השרשרת הפוליפפטידית"],"a":1,"e":"העיקרון: קודוני העצירה (UAA, UAG, UGA) אינם מזוהים ע\"י tRNA אלא ע\"י גורמי שחרור (release factors) חלבוניים הנכנסים לאתר A. גורם השחרור מנצל את הפעילות הקטליטית של הריבוזום (פפטידיל-טרנספראז) כך שתתווסף מולקולת מים לקצה השרשרת במקום חומצת אמינו, מה שמנתק את הקשר בין הפוליפפטיד ל-tRNA ומשחרר את החלבון המוגמר. מדוע המסיחים שגויים: אין tRNA 'מיוחד' המזהה את קודון העצירה (קודוני עצירה הם דווקא היעדר tRNA תואם); הריבוזום אינו עוצר 'מעצמו' ללא גורם שחרור; snRNP-ים שייכים לשחבור ולא לתרגום. טיפ: 'stop = גורם שחרור מכניס מים במקום חומצת אמינו'."},
    {"topic":"בקרת איכות - NMD","q":"מנגנון ה-NMD (nonsense-mediated mRNA decay) מזהה ומפרק mRNA-ים פגומים. מהו הטריגר העיקרי שמסמן ל-NMD שתעתיק מסוים פגום באאוקריוטים?","o":["נוכחות זנב פולי-A קצר מדי בקצה ה-3' של התעתיק","נוכחות קודון עצירה מוקדם (premature stop codon) במעלה הזרם של גבול אקסון-אקסון, המזוהה ביחס למיקום קומפלקסים שהושארו לאחר שחבור","היעדר כיפת 5' תקינה בלבד","ריבוי קודוני פתיחה AUG באותו תעתיק"],"a":1,"e":"העיקרון: NMD (nonsense-mediated mRNA decay) מזהה ומפרק תעתיקים הנושאים קודון עצירה מוקדם (premature termination codon). באאוקריוטים האינדיקציה המרכזית היא מיקום קודון העצירה ביחס לקומפלקסים החלבוניים — exon junction complexes (EJC) — שמושארים על ה-mRNA בגבולות חיבור האקסונים לאחר השחבור. קודון עצירה במעלה הזרם של גבול אקסון-אקסון מסמן שהתעתיק כנראה פגום, ומפעיל את פירוקו. מדוע המסיחים שגויים: זנב פולי-A קצר וכיפה תקינה קשורים ליציבות כללית של ה-mRNA אך אינם הטריגר הספציפי של NMD; ריבוי קודוני AUG אינו הטריגר. טיפ: NMD שואל 'האם ה-stop הופיע לפני ה-EJC?' — אם כן, פירוק."},
    {"topic":"שילוב - תרחיש מוטציה","q":"מוטציה נקודתית באתר השחבור ב-5' של אינטרון מסוים מונעת את זיהויו על-ידי U1 snRNP. מה התוצאה הצפויה ביותר ברמת התעתיק והחלבון?","o":["השעתוק של הגן ייפסק כליל ולא ייווצר כל תעתיק","האינטרון לא יוסר כראוי וייוותר בתעתיק הבשל, מה שעלול להכניס קודון עצירה מוקדם בקריאה ולהוביל לחלבון קטוע או לפירוק התעתיק ב-NMD","חומצת האמינו במיקום זה תוחלף בחומצת אמינו אחת בלבד, ללא השפעה נוספת","זנב הפולי-A לא יתווסף לתעתיק"],"a":1,"e":"העיקרון: מוטציה באתר השחבור ב-5' מונעת זיהוי ע\"י U1 snRNP, ולכן האינטרון לא יוסר כראוי (אי-שחבור או שחבור חלופי שגוי). אינטרון שנותר בתעתיק הבשל מכניס לרוב רצף שאינו במסגרת הקריאה הנכונה ועלול להכיל קודון עצירה מוקדם, שיוביל לחלבון קטוע ו/או להפעלת NMD ופירוק התעתיק. מדוע המסיחים שגויים: השעתוק עצמו אינו נפסק — נוצר תעתיק (פגום); זו אינה החלפה של 'חומצת אמינו אחת בלבד' אלא שיבוש כולל של המסגרת; הוספת הכיפה והזנב אינן נפגעות מפגם באתר השחבור — אלו תהליכים נפרדים. טיפ: פגם ב-5' splice site → אינטרון נשאר → frameshift/PTC → חלבון קטוע או NMD."},
    {"topic":"אופרון לקטוז","q":"במערכת אופרון הלקטוז (lac operon) של E. coli, מהו התפקיד של החלבון CAP (Catabolite Activator Protein) הקשור ל-cAMP?","o":["הוא מדכא (repressor) שנקשר למפעיל (operator) ומונע שעתוק בנוכחות גלוקוז","הוא משפעל (activator) שנקשר ל-DNA ומסייע ל-RNA פולימראז להיקשר לפרומוטור כאשר רמת הגלוקוז נמוכה","הוא מפרק את הלקטוז למולקולות גלוקוז וגלקטוז","הוא קושר את הלקטוז ובכך מנטרל את המדכא של האופרון"],"a":1,"e":"העיקרון: באופרון הלקטוז (lac operon) של E. coli, חלבון CAP (Catabolite Activator Protein) הוא משפעל (activator) חיובי. כשרמת הגלוקוז נמוכה, רמת ה-cAMP עולה, ה-cAMP נקשר ל-CAP, והקומפלקס CAP-cAMP נקשר ל-DNA סמוך לפרומוטר ומסייע ל-RNA פולימראז להיקשר — ובכך מגביר שעתוק. מדוע המסיחים שגויים: המסיח על דיכוי וקשירה ל-operator מתאר את ה-Lac repressor (מדכא), לא את CAP; פירוק הלקטוז לגלוקוז וגלקטוז הוא תפקיד האנזים בטא-גלקטוזידאז; קשירת אינדוקטור (אלולקטוז) ונטרול המדכא הם תפקיד האלולקטוז, לא CAP. טיפ: 'CAP = חיישן רעב לגלוקוז (דרך cAMP) שמדליק את האופרון'."},
    {"topic":"אופרון טריפטופן","q":"באופרון הטריפטופן (trp operon), כיצד פועל המדכא (Trp repressor) ביחס לחומצת האמינו טריפטופן?","o":["טריפטופן הוא אינדוקטור שמנתק את המדכא מה-DNA ומאפשר שעתוק","המדכא פעיל ונקשר ל-DNA רק כאשר הוא קשור לטריפטופן (קו-מדכא), ואז מעכב שעתוק","המדכא נקשר ל-DNA רק בהיעדר טריפטופן ומונע שעתוק בלי קשר לריכוז","טריפטופן נקשר ל-RNA פולימראז ישירות ומונע ממנו להתחיל שעתוק"],"a":1,"e":"העיקרון: באופרון הטריפטופן (trp operon), טריפטופן הוא קו-מדכא (corepressor). כשרמת הטריפטופן גבוהה, הוא נקשר למדכא (Trp repressor) ומשנה את צורתו כך שיוכל להיקשר למפעיל (operator) ולעכב שעתוק — בקרה שלילית של מסלול ביוסינתזה (אין טעם לייצר טריפטופן כשהוא בשפע). מדוע המסיחים שגויים: טריפטופן אינו אינדוקטור המנתק את המדכא — זו התנהגות הפוכה האופיינית ללקטוז; המדכא אינו נקשר 'תמיד' בהיעדר טריפטופן — להפך, הוא דורש טריפטופן כדי להיקשר; הטריפטופן אינו נקשר ל-RNA פולימראז ישירות. טיפ: 'מוצר סופי בשפע (Trp) מכבה את המסלול שלו' — דיכוי חוזר ע\"י קו-מדכא."},
    {"topic":"גורמי שעתוק ומגבירים","q":"מגביר (enhancer) באאוקריוטים יכול להשפיע על שעתוק של גן גם כשהוא ממוקם אלפי בסיסים מהפרומוטור. מהו ההסבר המקובל למנגנון זה?","o":["המגביר מקודד RNA קטן שמתפזר אל הפרומוטור ומפעיל אותו","ה-DNA יוצר לולאה (looping) כך שגורמי שעתוק הקשורים למגביר באים במגע פיזי עם קומפלקס הפרומוטור","המגביר מזיז את הנוקלאוזומים לאורך ה-DNA עד שהם מגיעים לפרומוטור","RNA פולימראז נקשר תחילה למגביר ואז זוחל לאורך ה-DNA עד הפרומוטור"],"a":1,"e":"העיקרון: מגביר (enhancer) אאוקריוטי יכול להשפיע על שעתוק גם מאלפי בסיסים מהפרומוטר באמצעות לולאת DNA (DNA looping): ה-DNA מתקפל כך שגורמי השעתוק הקשורים למגביר באים במגע פיזי עם קומפלקס היוזם שבפרומוטר, לרוב דרך חלבוני מתווך (Mediator) וקו-אקטיבטורים. מדוע המסיחים שגויים: המגביר אינו 'מקודד RNA קטן' שמתפזר לפרומוטר; הוא אינו 'מזיז נוקלאוזומים' עד הפרומוטר; RNA פולימראז אינו נקשר תחילה למגביר ואינו 'זוחל' לאורך ה-DNA אל הפרומוטר. טיפ: המרחק לא משנה כי ה-DNA מתקפל ומקרב פיזית את המגביר אל הפרומוטר."},
    {"topic":"אפיגנטיקה - מתילציה","q":"בתאי יונקים, מה מקובל לגבי הקשר בין מתילציה של ציטוזין באיים של CpG בפרומוטורים לבין ביטוי הגן?","o":["מתילציה של פרומוטור באיי CpG מקושרת בדרך כלל להשתקה (silencing) של הגן","מתילציה של פרומוטור מגבירה את השעתוק על ידי שיפור קשירת RNA פולימראז","מתילציה מתרחשת רק על אדנין ואינה משפיעה על ציטוזין ביונקים","מתילציה משנה את רצף הבסיסים של ה-DNA ובכך גורמת למוטציה בגן"],"a":0,"e":"העיקרון: בתאי יונקים, מתילציה של ציטוזין באיי CpG בפרומוטרים מקושרת בדרך כלל להשתקת גנים (gene silencing) — בין היתר ע\"י גיוס חלבונים הקושרים מתיל (methyl-CpG-binding proteins) ודחיסת כרומטין לצורה סגורה. זהו סימון אפיגנטי הניתן לתורשה תאית מבלי לשנות את רצף ה-DNA. מדוע המסיחים שגויים: מתילציה אינה מגבירה שעתוק ע\"י שיפור קשירת הפולימראז — ההפך; ביונקים המתילציה היא על ציטוזין (5-מתילציטוזין) ולא על אדנין; מתילציה אינה משנה את רצף הבסיסים ולכן אינה 'מוטציה'. טיפ: 'CpG מתויל בפרומוטר = גן מושתק'; זהו שינוי אפיגנטי הפיך, לא מוטציה."},
    {"topic":"miRNA / RNAi","q":"חוקר מחדיר לתא RNA דו-גדילי קצר כדי לדכא ביטוי של גן מסוים בשיטת RNAi. מהו השלב המרכזי שבו מתבצע הדיכוי לאחר עיבוד ה-RNA הדו-גדילי?","o":["ה-RNA הדו-גדילי נקשר לפרומוטור של הגן ומונע את תחילת השעתוק","גדיל מנחה (guide) משולב בקומפלקס RISC ומכוון אותו אל mRNA משלים שעובר פירוק או עיכוב תרגום","ה-RNA הדו-גדילי משתלב בגנום במקום הגן ומחליף את הרצף המקורי","ה-RNA הדו-גדילי גורם לפוספורילציה של RNA פולימראז ובכך עוצר את השעתוק"],"a":1,"e":"העיקרון: בשיטת RNAi, ה-RNA הדו-גדילי מעובד ע\"י Dicer ל-siRNA קצרים. גדיל מנחה (guide strand) משולב בקומפלקס RISC (המכיל את חלבון Argonaute) ומכוון אותו אל מולקולת mRNA בעלת רצף משלים, מה שמוביל לפירוק ה-mRNA או לעיכוב תרגומו — בקרה פוסט-שעתוקית. מדוע המסיחים שגויים: ה-RNA הדו-גדילי אינו נקשר לפרומוטר ומונע תחילת שעתוק (RNAi פועל על ה-mRNA, לא על ה-DNA/הפרומוטר); הוא אינו משתלב בגנום ומחליף רצף; הוא אינו גורם לזרחון RNA פולימראז. טיפ: 'Dicer חותך → גדיל מנחה ב-RISC → השמדת mRNA משלים' — דיכוי אחרי השעתוק."},
    {"topic":"PCR","q":"בתגובת שרשרת פולימראז (PCR), מהו תפקידם של הפריימרים (primers) ומדוע נדרש שלב חימום (denaturation) בכל מחזור?","o":["הפריימרים מספקים קצה 3'-OH חופשי להתחלת סינתזה, והחימום מפריד את שני גדילי ה-DNA","הפריימרים מפרקים את ה-DNA, והחימום מפעיל את הפולימראז שאינו עמיד בקור","הפריימרים מקודדים את החלבון הרצוי, והחימום גורם לקיפול נכון של המוצר","הפריימרים מסמנים את המוצר בפלואורסצנציה, והחימום נדרש כדי לחבר את הגדילים זה לזה"],"a":0,"e":"העיקרון: ב-PCR הפריימרים הם אוליגונוקלאוטידים קצרים הנקשרים לרצפים משלימים בתבנית ומספקים קצה 3'-OH חופשי שממנו DNA פולימראז עמיד-חום (כגון Taq) מתחיל סינתזה. שלב הדנטורציה (כ-95 מעלות) בכל מחזור מפריד את שני גדילי ה-DNA כדי לאפשר היצמדות (annealing) של הפריימרים במחזור הבא. מדוע המסיחים שגויים: הפריימרים אינם 'מפרקים' DNA, והחימום אינו 'מפעיל' פולימראז שאינו עמיד בקור — דווקא Taq עמיד בחום; הפריימרים אינם מקודדים חלבון; הם אינם 'מסמנים בפלואורסצנציה', והחימום מפריד גדילים ולא מחבר אותם. טיפ: מחזור PCR = 'חימום מפריד (denature) → קירור מצמיד (anneal) → הארכה (extend)'."},
    {"topic":"אנזימי הגבלה ושיבוט","q":"חוקר חותך בווקטור פלסמיד וגם מקטע DNA זר באמצעות אותו אנזים הגבלה (restriction enzyme) שיוצר \"קצוות דביקים\" (sticky ends). מהי המטרה של שימוש באותו אנזים על שניהם?","o":["כדי לוודא שהמקטע הזר יתפרק לחלוטין לפני השיבוט","כדי שייווצרו קצוות חד-גדיליים משלימים שיאפשרו לזוג להיצמד ולהתחבר על ידי DNA ליגאז","כדי שהאנזים יבצע גם את שלב הליגציה וגם את שלב החיתוך","כדי לסמן את שני הקצוות בפלואורסצנציה לזיהוי תחת מיקרוסקופ"],"a":1,"e":"העיקרון: שימוש באותו אנזים הגבלה (restriction enzyme) היוצר 'קצוות דביקים' (sticky ends) על הוקטור ועל המקטע הזר מבטיח שייווצרו בליטות חד-גדיליות בעלות רצף משלים זהה. הקצוות המשלימים נצמדים זה לזה בקשרי מימן (זיווג בסיסים), ואז DNA ליגאז סוגר את שלד הסוכר-פוספט ויוצר מולקולה רקומביננטית יציבה. מדוע המסיחים שגויים: המטרה אינה 'לפרק' את המקטע הזר; אנזים ההגבלה רק חותך — הליגאז הוא שמחבר, ולא שניהם באותו אנזים; אין כאן סימון בפלואורסצנציה לזיהוי מיקרוסקופי. טיפ: 'אותו אנזים = אותם קצוות דביקים משלימים = הוקטור והמקטע נדבקים'."},
    {"topic":"ג'ל אלקטרופורזה","q":"בהפרדת מקטעי DNA בג'ל אלקטרופורזה (gel electrophoresis), לפי איזה עיקרון נודדים המקטעים, ולאיזה כיוון?","o":["מקטעים גדולים נודדים מהר יותר לכיוון הקתודה (השלילי) בגלל מטענם החיובי","מקטעים קטנים יותר נודדים מהר ורחוק יותר לכיוון האנודה (החיובי) כי שלד ה-DNA טעון שלילי","ההפרדה מבוססת רק על רצף הבסיסים ולא על הגודל","DNA נטול מטען ולכן נודד באקראי ללא קשר לשדה החשמלי"],"a":1,"e":"העיקרון: שלד הסוכר-פוספט של DNA טעון שלילית, ולכן בשדה חשמלי כל מקטעי ה-DNA נודדים לעבר הקוטב החיובי (האנודה). הג'ל פועל כמסננת מולקולרית: מקטעים קטנים יותר עוברים בקלות רבה יותר דרך נקבוביות הג'ל ולכן נודדים מהר ורחוק יותר, ומקטעים גדולים נשארים מאחור. ההפרדה היא לפי גודל. מדוע המסיחים שגויים: מקטעים גדולים אינם נודדים מהר לקתודה (גם הכיוון וגם יחס הגודל הפוכים; ל-DNA אין מטען חיובי); ההפרדה אינה לפי רצף הבסיסים אלא לפי גודל; ל-DNA יש מטען (שלילי) והוא אינו נודד באקראי. טיפ: 'קטן ומהיר אל הפלוס (אנודה)'."},
    {"topic":"Southern / Northern / Western blot","q":"חוקר רוצה לבדוק האם רמת ה-mRNA של גן מסוים עולה לאחר טיפול בהורמון. באיזו שיטת בלוט (blot) עליו להשתמש?","o":["Southern blot - מפריד DNA ומגלה אותו עם גשוש DNA","Northern blot - מפריד RNA ומגלה אותו עם גשוש (probe) חומצת גרעין משלים","Western blot - מפריד חלבונים ומגלה אותם עם נוגדנים","Eastern blot - מפריד ליפידים ומגלה אותם עם ציפוי כימי"],"a":1,"e":"העיקרון: Northern blot משמש לזיהוי ולכימות של RNA (כולל mRNA): ה-RNA מופרד בג'ל לפי גודל, מועבר לממברנה, ומזוהה באמצעות גשוש (probe) חומצת גרעין משלים מסומן. לכן זו השיטה הנכונה למדידת שינוי ברמת mRNA לאחר טיפול הורמונלי. מדוע המסיחים שגויים: Southern blot מיועד ל-DNA (וגשוש DNA); Western blot מיועד לחלבונים ומשתמש בנוגדנים; Eastern blot אינו השיטה לכימות mRNA. הבלבול בין סוגי הבלוט הוא טעות נפוצה. טיפ לזכירה: 'DNA = Southern, RNA = Northern, חלבון = Western' (ה-N של Northern = RNA, ה-N הצפוני)."},
    {"topic":"Western blot","q":"בניסוי Western blot, לאחר הפרדת חלבונים והעברתם לממברנה, כיצד מזוהה החלבון הספציפי שמעניין את החוקר?","o":["באמצעות גשוש DNA משלים שנקשר לחלבון","באמצעות נוגדן (antibody) ספציפי לחלבון, לרוב במערכת של נוגדן ראשוני ונוגדן משני מסומן","באמצעות אנזים הגבלה שחותך את החלבון באתר מסוים","באמצעות הכלאה לרצף RNA משלים על הממברנה"],"a":1,"e":"העיקרון: ב-Western blot, לאחר הפרדת החלבונים והעברתם לממברנה, החלבון הספציפי מזוהה באמצעות נוגדנים: נוגדן ראשוני (primary antibody) נקשר ספציפית לחלבון המטרה, ואחריו נוגדן משני (secondary) מסומן — באנזים (כגון HRP) או בפלואורופור — שנקשר לראשוני ומאפשר גילוי והגברת האות. מדוע המסיחים שגויים: גשוש DNA/RNA משלים מתאים ל-Southern/Northern (זיהוי חומצות גרעין), לא לחלבון; אנזים הגבלה חותך DNA ולא 'חותך חלבון באתר'; הכלאה לרצף RNA אינה מזהה חלבונים. טיפ: 'Western = נוגדנים' (חלבון מזוהה ע\"י אנטיבודי, לא ע\"י גשוש חומצת גרעין)."},
    {"topic":"ריצוף DNA","q":"בשיטת הריצוף של סנגר (Sanger sequencing) הקלאסית, מהו התפקיד של דידאוקסינוקלאוטידים (ddNTPs) בתגובה?","o":["הם מאיצים את פעולת הפולימראז ומאריכים את הגדיל ללא הגבלה","חוסר קבוצת 3'-OH בהם גורם לעצירת התארכות הגדיל בכל פעם שהם נכללים, ויוצר מקטעים באורכים שונים","הם חותכים את ה-DNA בכל מקום שבו מופיע בסיס מסוים","הם מסמנים רק את הפריימר בקצה 5' של הגדיל"],"a":1,"e":"העיקרון: בריצוף סנגר (Sanger sequencing), דידאוקסינוקלאוטידים (ddNTP) חסרים את קבוצת ה-3'-OH. כשהפולימראז משלב ddNTP, לא ניתן להוסיף נוקלאוטיד נוסף (אין 3'-OH לקשר הפוספודיאסטר הבא), ולכן ההתארכות נעצרת. כך נוצר אוסף מקטעים המסתיימים בכל מיקום אפשרי, ולפי אורכם (וזהות הבסיס הסופי המסומן) משחזרים את הרצף. מדוע המסיחים שגויים: ה-ddNTP אינם 'מאיצים' ומאריכים ללא הגבלה — דווקא ההפך, הם עוצרים; הם אינם 'חותכים' DNA כמו אנזים הגבלה; הם אינם 'מסמנים רק את הפריימר'. טיפ: 'dd = dead-end' — חוסר 3'-OH = עצירה אקראית מבוקרת."},
    {"topic":"CRISPR","q":"במערכת CRISPR-Cas9 לעריכת גנים, מהו תפקיד ה-RNA המנחה (guide RNA) ביחס לאנזים Cas9?","o":["ה-guide RNA חותך את ה-DNA, ו-Cas9 רק מזהה את הרצף","ה-guide RNA מכוון את Cas9 אל רצף DNA משלים ספציפי שבו Cas9 יוצר שבר דו-גדילי","ה-guide RNA משמש כתבנית לסינתזה של הגן החדש שיוחדר","ה-guide RNA מתרגם את ה-DNA לחלבון ה-Cas9"],"a":1,"e":"העיקרון: ב-CRISPR-Cas9, ה-RNA המנחה (guide RNA) מכיל רצף המשלים ל-DNA המטרה ובכך מכוון את אנזים Cas9 אל האתר הגנומי הספציפי (בכפוף גם לרצף PAM סמוך). Cas9 הוא נוקלאז (אנזים החותך DNA) היוצר באתר זה שבר דו-גדילי (double-strand break), שתיקונו ע\"י התא מאפשר עריכת הגן. מדוע המסיחים שגויים: התפקידים הפוכים — Cas9 הוא שחותך וה-gRNA הוא שמכוון, לא להפך; ה-gRNA אינו תבנית לסינתזת הגן החדש; ה-gRNA אינו 'מתרגם DNA לחלבון Cas9'. טיפ: 'gRNA = ה-GPS, Cas9 = המספריים' — האחד מכוון, השני חותך."},
    {"topic":"ביטוי חלבונים וקרינה פלואורסצנטית","q":"חוקר מחבר את הרצף המקודד ל-GFP לקצה של גן חלבון מטרה ומבטא את הקונסטרוקט בתאים חיים. מהי המטרה העיקרית של גישה זו?","o":["להגביר את קצב התרגום של חלבון המטרה פי כמה","לאפשר מעקב אחר מיקום ותנועת חלבון המטרה בתא חי באמצעות מיקרוסקופ פלואורסצנטי","לחתוך את חלבון המטרה לשני חלקים שווים","לשנות את רצף ה-DNA של הגן כך שיקודד חומצות אמינו אחרות"],"a":1,"e":"העיקרון: חיבור הרצף המקודד ל-GFP (Green Fluorescent Protein) כתג (fusion tag) לקצה גן חלבון מטרה יוצר חלבון היתוך פלואורסצנטי. כך ניתן לעקוב בתא חי אחר מיקומו, תנועתו ורמתו של חלבון המטרה באמצעות מיקרוסקופיה פלואורסצנטית, ללא צורך בקיבוע התא או בצביעה חיצונית. מדוע המסיחים שגויים: חיבור GFP אינו נועד להגביר את קצב התרגום של חלבון המטרה; הוא אינו 'חותך' את החלבון לשניים; הוא אינו משנה את רצף שאר הגן כך שיקודד חומצות אמינו אחרות — הוא רק מוסיף תג גלוי. טיפ: 'GFP = פנס מובנה' למעקב חי אחר חלבון המטרה."},
    {"topic":"מיקרוסקופיה פלואורסצנטית - מגבלות","q":"חוקר משתמש במיקרוסקופ פלואורסצנטי קונפוקלי כדי לבחון שני חלבונים המסומנים בפלואורופורים שונים בתוך תא. מהי מגבלה בסיסית של מיקרוסקופ אור (כולל פלואורסצנטי) הנובעת מאורך הגל של האור?","o":["לא ניתן לזהות יותר מפלואורופור אחד בו-זמנית בשום תנאי","כושר ההפרדה (resolution) מוגבל לכ-200 ננומטר, ולכן עצמים קרובים מכך אינם ניתנים להבחנה כנפרדים","המיקרוסקופ יכול לזהות רק חלבונים על פני התא ולא בתוכו","כל הסימון הפלואורסצנטי דוהה מיד ולכן אי אפשר לצלם תאים חיים"],"a":1,"e":"העיקרון: בשל גבול העקיפה (diffraction limit) התלוי באורך הגל של האור הנראה, כושר ההפרדה (resolution) של מיקרוסקופ אור (כולל פלואורסצנטי וקונפוקלי) מוגבל לכ-200 ננומטר בציר הצידי. שני עצמים הקרובים זה לזה יותר מכך ייראו כנקודה אחת מטושטשת, אלא אם נעשה שימוש בשיטות סופר-רזולוציה (כגון STORM/PALM/STED). מדוע המסיחים שגויים: ניתן בהחלט לזהות כמה פלואורופורים בו-זמנית בעזרת ערוצי צבע נפרדים; מיקרוסקופ פלואורסצנטי מדמה גם חלבונים בתוך התא ולא רק על פניו; לא 'כל' הסימון דוהה מיד — ניתן לצלם תאים חיים (אם כי דהיית פלואורסצנציה/photobleaching קיימת). טיפ: 'גבול ~200 nm' הוא המגבלה הפיזיקלית הבסיסית של מיקרוסקופ אור."},
    {"topic":"כרומטין — היסטון H1 וכרומטין","q":"איזו תכונה של זנבות ההיסטונים משתנה באצטילציה של ליזין וגורמת להתרופפות ה-DNA מהנוקלאוזום?","o":["נפח","מטען","סטויכיומטריה","גודל"],"a":1,"e":"אצטילציה מנטרלת את המטען החיובי של שייר הליזין, מחלישה את המשיכה האלקטרוסטטית בין הזנב להיסטון/DNA הטעון שלילית, ומרופפת את הכרומטין. ניתוח מסיחים: (א),(ד) שינוי הנפח/הגודל זניח ואינו המנגנון; (ג) הסטויכיומטריה של הנוקלאוזום אינה משתנה."},
    {"topic":"שעתוק - גורמי שעתוק כלליים","q":"למי יתחבר/חלק ממי הוא ה-TATA-box binding protein (TBP)?","o":["TFIID","TFIIH","TFIIB","TFIIE"],"a":0,"e":"TBP הוא תת-יחידה של פקטור השעתוק הכללי TFIID; הוא נקשר לתיבת ה-TATA ומניח את היסוד לבניית קומפלקס הקדם-אתחול. ניתוח מסיחים: (ב) TFIIH פותח את ה-DNA ומזרחן את ה-CTD בשלב מאוחר יותר; (ג) TFIIB מצטרף אחרי TBP ומכוון את הפולימראז; (ד) TFIIE מגייס את TFIIH — אף אחד מהם אינו מכיל את TBP."},
    {"topic":"ג'ל אלקטרופורזה","q":"חלבון A (1000 ח״א, מטען חיובי) וחלבון B (800 ח״א, נייטרלי) — מי ינוע רחוק יותר ב-SDS-PAGE?","o":["A — כי טעון חיובי","B — כי נייטרלי","B — כי קטן יותר","לא ניתן לקבוע"],"a":2,"e":"SDS מצפה את כל החלבונים במטען שלילי אחיד ומבטל את המטען המקורי, כך שההפרדה היא לפי גודל בלבד — החלבון הקטן יותר נע רחוק יותר. חלבון B (800 ח״א) קטן ולכן נע רחוק יותר. ניתוח מסיחים: (א) המטען המקורי אינו רלוונטי ב-SDS-PAGE; (ב) התוצאה נכונה אך מהנימוק השגוי (נייטרליות), בעוד הסיבה האמיתית היא הגודל; (ד) הנתונים מספיקים."},
    {"topic":"תיקון DNA — mismatch repair","q":"בסרטן מעי הגס יש פגם ב-MSH2. באיזה מנגנון תיקון מדובר?","o":["Mismatch repair","Non-homologous end joining","Homologous recombination","Excision repair"],"a":0,"e":"חלבוני MSH (כולל MSH2) הם רכיבי מערכת תיקון אי-ההתאמה (Mismatch Repair). פגם בהם גורם לתסמונת לינץ' (HNPCC) ולחוסר יציבות מיקרו-סטליטית בסרטן המעי. ניתוח מסיחים: (ב) NHEJ מאחה שברים דו-גדיליים; (ג) רקומבינציה הומולוגית מתקנת שברים דו-גדיליים בתבנית; (ד) Excision repair מתקן נזק בסיסים/נוקלאוטידים — אף לא מערב MSH2."},
    {"topic":"שכפול DNA — כיווניות","q":"מוטציה בטופואיזומראז 1 שמחליפה טירוזין לוואלין — מה ייפגע?","o":["קשירת ATP","שבירת קשר פוספודיאסטרי","יצירת קשר מימן","הסיבוב של הגדילים אחד ביחס לשני"],"a":1,"e":"טופואיזומראז I משתמש בטירוזין שבאתר הפעיל לתקיפה נוקלאופילית של שלד ה-DNA — יצירת ביניים קוולנטי פוספוטירוזין ושבירת קשר פוספודיאסטרי בגדיל אחד. החלפת הטירוזין מבטלת את יכולת השבירה/החיתוך. ניתוח מסיחים: (א) טופו I אינו תלוי ATP (בניגוד לטופו II); (ג) אינו עוסק ביצירת קשרי מימן; (ד) הסיבוב/הרפיית המתח הוא תוצאה של החיתוך — שנמנע כשאין טירוזין, אך הפגיעה הישירה היא בשבירת הקשר."},
    {"topic":"אנזימי הגבלה ושיבוט","q":"לאיזו משפחת חלבונים שייכים אנזימי הגבלה (רסטריקציה)?","o":["אקסונוקלאז","אנדונוקלאז","הליקאז","טופואיזומראז"],"a":1,"e":"אנזימי הגבלה הם אנדונוקלאזות — הם חותכים את ה-DNA באתרים פנימיים ספציפיים (רצפי זיהוי). ניתוח מסיחים: (א) אקסונוקלאז מסיר נוקלאוטידים מהקצוות; (ג) הליקאז מפריד גדילים; (ד) טופואיזומראז משנה טופולוגיה — אף אחד אינו חותך באתר פנימי ספציפי."},
    {"topic":"miRNA / RNAi","q":"מה יקרה אם יש התאמה לא שלמה בין miRNA ל-mRNA?","o":["ה-mRNA יעוכב (דיכוי תרגום)","ה-mRNA יפורק","ה-miRNA יעוכב","ה-miRNA יפורק"],"a":0,"e":"התאמה חלקית (האופיינית ל-miRNA בבעלי חיים) מובילה לדיכוי תרגום ולערעור יציבות ה-mRNA, בלי חיתוך ישיר. ניתוח מסיחים: (ב) פירוק/חיתוך ישיר מתרחש דווקא בהתאמה מלאה (מסלול siRNA); (ג),(ד) ה-miRNA הוא המנחה ואינו זה שמעוכב/מפורק כתוצאה מההתאמה."},
    {"topic":"אופרון לקטוז","q":"למה תגרום מוטציה באופרון הלקטוז שמונעת מהרפרסור להיקשר?","o":["ביטוי האופרון יפעל גם בהיעדר לקטוז","ביטוי האופרון לא יתבטא בהיעדר לקטוז","יצירת חלבון מוטנטי שלא מתפקד","לא יהיה תלוי ב-cAMP"],"a":0,"e":"אם הרפרסור אינו יכול להיקשר לאופרטור, אין דיכוי — האופרון מתבטא באופן קונסטיטוטיבי, גם בהיעדר לקטוז. ניתוח מסיחים: (ב) הפוך; (ג) מוטציה באתר הקישור אינה משנה את החלבונים המקודדים; (ד) הבקרה החיובית ע'י cAMP-CAP (תגובה לגלוקוז) נשמרת ואינה תלויה ברפרסור."},
    {"topic":"שעתוק - RNA פולימראזות","q":"מה תפקיד ה-CTD ב-RNA פולימראז II?","o":["נקשר אליו TBP/קושר TATA","אתר פעיל המחבר נוקלאוטידים","פיגום לגיוס פקטורי עיבוד רנ״א","מגן על הרנ״א שנוצר"],"a":2,"e":"הזנב הקרבוקסילי (CTD) של תת-היחידה הגדולה ב-Pol II משמש כפיגום: זרחונו לאורך השעתוק מגייס את מנגנוני העיבוד — הוספת כיפה, שחבור ופוליאדנילציה. ניתוח מסיחים: (א) קישור TATA הוא תפקיד TBP; (ב) האתר הפעיל הקטליטי נמצא בליבת האנזים, לא ב-CTD; (ד) הגנה על הרנ״א אינה תפקיד ה-CTD."},
    {"topic":"כרומטין — נוקלאוזום","q":"איזה דגם כרומטין מאפיין רצפים חוזרניים (כגון אלפא-סטלייט בצנטרומר)?","o":["Facultative euchromatin","Facultative heterochromatin","Constitutive euchromatin","Constitutive heterochromatin"],"a":3,"e":"רצפים חוזרניים בצנטרומר (אלפא-סטלייט) ארוזים כהטרוכרומטין קונסטיטוטיבי — דחוס ומושתק באופן קבוע בכל סוגי התאים. ניתוח מסיחים: (א),(ב) facultative משתנה בין תאים/שלבים — אינו מתאים לרצף מבני קבוע; (ג) 'constitutive euchromatin' אינו מונח עקבי — אאוכרומטין הוא פתוח ופעיל, לא מתאים לסטלייט."},
    {"topic":"שכפול DNA — נאמנות","q":"לאיזה מהאנזימים יש יכולת הגהה עצמית (proofreading)?","o":["RNA polymerase","DNA polymerase","לאף אחד","לשניהם"],"a":1,"e":"ל-DNA פולימראז יש פעילות אקסונוקלאז 3'→5' המאפשרת הגהה (הסרת נוקלאוטיד שגוי) ותורמת לנאמנות הגבוהה של השכפול. ניתוח מסיחים: (א) RNA פולימראז בעל נאמנות נמוכה יותר וללא מנגנון הגהה קלאסי; (ג) שגוי — ל-DNA פול יש; (ד) הייחוס לשניהם אינו מדויק לפי ההוראה הקלאסית."},
    {"topic":"אפיגנטיקה - מתילציה","q":"מה גורמת אצטילציה על היסטונים?","o":["מנטרלת מטען חיובי","מתילציה על היסטונים","מתילציה על ה-DNA","אצטילציה על ה-DNA"],"a":0,"e":"אצטילציה של שיירי ליזין מנטרלת את מטענם החיובי, מרופפת את אריזת הכרומטין ומקדמת ביטוי גנים. ניתוח מסיחים: (ב),(ג) מתילציה היא מודיפיקציה אחרת (לרוב מדכאת, על DNA/היסטונים) — לא תוצאה של אצטילציה; (ד) 'אצטילציה על DNA' אינו מנגנון קיים — האצטילציה היא על ההיסטונים."},
    {"topic":"CRISPR","q":"מהי מערכת ההגנה של חיידקים נגד בקטריופאג'ים שמשתמשת ב-RNA וחלבון כדי לחתוך DNA?","o":["אנזימי הגבלה","siRNA","miRNA","CRISPR-Cas9"],"a":3,"e":"CRISPR-Cas9 היא מערכת חיסון נרכש בחיידקים: RNA מנחה (gRNA) מכוון את חלבון Cas9 לחיתוך DNA זר (פאג') ברצף המשלים. ניתוח מסיחים: (א) אנזימי הגבלה חותכים DNA אך ללא RNA מנחה; (ב),(ג) siRNA/miRNA הם מנגנוני RNAi באיקריוטים, לא הגנת חיידקים."},
    {"topic":"שכפול DNA — פריימאז","q":"מה משותף לשכפול הגנום באאוקריוטים ובפרוקריוטים?","o":["התחלת שכפול מכמה origins","ברוב מחזור התא אין שכפול","פריימרים של RNA בתחילת השכפול","בעיה בשכפול קצוות הכרומוזומים"],"a":2,"e":"בשתי הממלכות השכפול מתחיל בפריימר RNA שמסונתז ע'י פרימאז, שאותו מאריך ה-DNA פולימראז. ניתוח מסיחים: (א) ריבוי origins אופייני לאיקריוטים; לפרוקריוטים origin בודד; (ב) אינו 'משותף' באופן מבחין; (ד) בעיית שכפול הקצוות קיימת רק בכרומוזומים לינאריים (איקריוטים), לא בכרומוזום מעגלי פרוקריוטי."},
    {"topic":"אפיגנטיקה - מתילציה","q":"מה עושים lncRNA בהחתמה גנומית?","o":["משמש כפיגום ומגייס חלבונים להשתקה","מגייסים חלבונים המשתיקים את האלל המוחתם בהטרוכרומטין קונסטיטוטיבי","מונעים קישור בין הריבוזום ל-mRNA","מפריעים למעבר RNA פולימראז"],"a":0,"e":"ב-lncRNA-ים מבוקרי החתמה (כמו Xist, Air, Kcnq1ot1) ה-RNA משמש כפיגום שמגייס קומפלקסים משנים-כרומטין להשתקת האלל המוחתם בציס. ניתוח מסיחים: (ב) ניסוח חלקי/לא-מדויק (החתמה אינה הטרוכרומטין קונסטיטוטיבי); (ג),(ד) אלו אינם מנגנוני ההחתמה הגנומית."},
    {"topic":"שעתוק - RNA פולימראזות","q":"את מי מסנתז RNA פולימראז III?","o":["tRNA","mRNA","lncRNA","miRNA"],"a":0,"e":"RNA פולימראז III מסנתז RNA-ים קצרים — tRNA, 5S rRNA ו-RNA-ים קטנים נוספים. ניתוח מסיחים: (ב) mRNA מסונתז ע'י Pol II; (ג) lncRNA לרוב ע'י Pol II; (ד) miRNA מתועתקים ע'י Pol II."},
    {"topic":"שכפול DNA — נאמנות","q":"מה ההשפעה של טאוטומרים על ה-DNA בשכפול?","o":["יצירת עיוות בהליקס","זיווג בסיסים שגוי","שבר חד-גדילי","שבר דו-גדילי"],"a":1,"e":"מעבר טאוטומרי (למשל אנול↔קטו) משנה זמנית את תכונות הזיווג של הבסיס וגורם לזיווג שגוי בעת השכפול — מקור למוטציות נקודתיות (טרנזיציות). ניתוח מסיחים: (א) אין עיוות מבני בהליקס; (ג),(ד) טאוטומריזציה אינה שוברת גדילים."},
    {"topic":"אנזימי הגבלה ושיבוט","q":"מה המטרה העיקרית של פורמלדהיד בניסוי ChIP?","o":["פירוק נוקלאוטידים","שבירת ה-DNA למקטעים בין הנוקלאוזומים","יצירת קשרים קוולנטיים בין DNA לחלבון","הכנה לפני חיתוך באנזימי הגבלה"],"a":2,"e":"פורמלדהיד יוצר קשרים קוולנטיים (cross-links) בין חלבונים ל-DNA, ומקבע את האינטראקציה כדי שניתן יהיה לשקע את הקומפלקס עם נוגדן (אימונופרסיפיטציה). ניתוח מסיחים: (א) אינו מפרק נוקלאוטידים; (ב) שבירת ה-DNA נעשית בסוניקציה/נוקלאז, לא בפורמלדהיד; (ד) אינו שלב הכנה לחיתוך רסטריקציה."},
    {"topic":"בקרת איכות - NMD","q":"באאוקריוטים, איזו תכונה קובעת את זמן מחצית החיים של ה-mRNA?","o":["קיצור זנב הפולי-A","הורדת ה-5' cap","עריכת האזור המקודד","הורדת אזור לא מתורגם"],"a":0,"e":"דה-אדנילציה (קיצור זנב הפולי-A) היא הצעד הקובע-קצב הראשון בפירוק ה-mRNA, ולכן אורך הזנב קובע במידה רבה את זמן מחצית החיים. ניתוח מסיחים: (ב) הסרת הכיפה (decapping) באה לרוב אחרי הדה-אדנילציה ומאיצה פירוק, אך אינה הקובעת הראשונית; (ג),(ד) אינם מנגנוני הקביעה של יציבות ה-mRNA."},
    {"topic":"אפיגנטיקה - מתילציה","q":"היכן בגנום נפוצות במיוחד מוטציות C>T כתוצאה מדיאמינציה?","o":["הטרוכרומטין","אאוכרומטין","באזורים שעברו מתילציות","באתרי קישור של פקטורי שעתוק"],"a":2,"e":"דיאמינציה של 5-מתיל-ציטוזין מניבה תימין, ולכן באזורים ממותלים (CpG) מצטברות טרנזיציות C>T בשכיחות גבוהה. ניתוח מסיחים: (א),(ב) רמת הדחיסה אינה הגורם הישיר; (ד) אתרי קישור אינם המוקד של דיאמינציית 5-מתיל-ציטוזין. הערה: באחזור נכתב 'T>C' — ככל הנראה היפוך שחזור; הכוונה ל-C>T."},
    {"topic":"שכפול DNA — פריימאז","q":"מה מבדיל את DNA פולימראז אלפא באאוקריוטים מפרימאז ב-E. coli?","o":["מסנתז גדיל DNA","מסנתז גדיל RNA","מסנתז גדיל RNA וגדיל DNA","מסנתז פריימר בלבד"],"a":2,"e":"קומפלקס פולימראז-אלפא/פרימאז מתחיל בסינתזת פריימר RNA קצר (ע'י הפרימאז) וממשיך בהוספת מקטע DNA קצר (ע'י פול-אלפא) — כלומר מסנתז גם RNA וגם DNA. פרימאז ב-E. coli מסנתז רק את פריימר ה-RNA. ניתוח מסיחים: (א) פרימאז אינו מסנתז DNA; (ב) מתאר רק את הפרימאז; (ד) 'פריימר בלבד' מתאר את פרימאז ה-E. coli, לא את פול-אלפא."},
    {"topic":"תרגום - אתחול אאוקריוטי","q":"מה קורה בזרחון eIF2?","o":["הגברת שעתוק","כיבוי/הפחתת שעתוק","הגברת תרגום","עיכוב תרגום"],"a":3,"e":"זרחון תת-יחידת eIF2α חוסם את חידוש GDP→GTP (ע'י eIF2B) ובכך מעכב את אתחול התרגום — מנגנון מרכזי בתגובת התא לעקה. ניתוח מסיחים: (א),(ב) eIF2 עוסק בתרגום, לא בשעתוק; (ג) הפוך — הזרחון מעכב, לא מגביר."},
    {"topic":"מיקרוסקופיה פלואורסצנטית - מגבלות","q":"לאיזה צורך עושים expansion microscopy?","o":["הגדלת יכולת ההפרדה","שמירה על הדגימה מפני פוטונים","עובי טוב יותר בדגימה","עומק חדירה לרקמה"],"a":0,"e":"במיקרוסקופיית הרחבה מטמיעים את הדגימה בפולימר תופח ומנפחים אותה פיזית, כך שמבנים קרובים מתרחקים זה מזה וניתן לפתור אותם מתחת לגבול העקיפה — שיפור יכולת ההפרדה האפקטיבית. ניתוח מסיחים: (ב),(ג),(ד) אינם מטרת השיטה."},
    {"topic":"שכפול DNA — ליגאז ומקטעי אוקזאקי","q":"כיצד פועל DNA ליגאז על מקטע אוקזאקי?","o":["מחבר קשרי מימן בין הקצוות","משתמש ב-ATP ליצירת קשר פוספודיאסטרי","יצירת קצוות דביקים","פעולת קינאז להוספת זרחה"],"a":1,"e":"DNA ליגאז סוגר את הניק בין מקטעי אוקזאקי ע'י יצירת קשר פוספודיאסטרי, בתהליך תלוי-אנרגיה (ATP באיקריוטים/T4). ניתוח מסיחים: (א) הליגאז יוצר קשר קוולנטי בשלד, לא קשרי מימן; (ג) יצירת קצוות דביקים היא פעולת אנזימי הגבלה; (ד) ליגאז אינו קינאז."},
    {"topic":"ריצוף DNA","q":"מה היתרון של Single-Cell RNA-seq לעומת RNA-seq רגיל (bulk)?","o":["מיון סוגי תאים לפי דפוסי ביטוי גנים","אפשר לרצף גם mRNA וגם non-coding","מידע על מיקום הרנ״א בתוך התא","רזולוציה גבוהה יותר ברמת האקסונים"],"a":0,"e":"ריצוף תא-בודד חושף את ההטרוגניות בין תאים ומאפשר למיין/לאפיין סוגי תאים לפי פרופיל הביטוי הייחודי לכל תא — מה ש-bulk ממצע ומסתיר. ניתוח מסיחים: (ב) נכון גם ל-bulk; (ג) מידע מרחבי מתקבל בטרנסקריפטומיקה מרחבית, לא ב-scRNA-seq רגיל; (ד) אינו ההבדל המהותי."},
    {"topic":"כרומטין — נוקלאוזום","q":"אילו חלבונים מרכיבים את ליבת הנוקלאוזום?","o":["1×H1, 2×H2, 2×H3, 2×H2","שילוב אחר","שילוב אחר","2×H2A, 2×H2B, 2×H3, 2×H4"],"a":3,"e":"ליבת הנוקלאוזום היא אוקטמר היסטונים — שניים מכל אחד: H2A, H2B, H3, H4. ה-H1 הוא היסטון מקשר (linker) שאינו חלק מהליבה. ניתוח מסיחים: (א),(ב),(ג) הרכבים שגויים/כוללים H1 בליבה; (ד) ההרכב הנכון של האוקטמר."},
    {"topic":"שעתוק - RNA פולימראזות","q":"איזה גן מתועתק ע'י RNA פולימראז III?","o":["18S rRNA","5S rRNA","16S rRNA","5.8S rRNA"],"a":1,"e":"RNA פולימראז III מתעתק tRNA, 5S rRNA ו-RNA-ים קטנים. מבין ה-rRNA, רק 5S מתועתק ע'י Pol III. ניתוח מסיחים: (א) 18S ו-(ד) 5.8S מתועתקים ע'י Pol I (כקדם-rRNA 45S); (ג) 16S הוא rRNA פרוקריוטי."},
    {"topic":"שעתוק - RNA פולימראזות","q":"מה מקור האנרגיה לשעתוק?","o":["GTP","ATP","ריבונוקלאוזיד-תלת-פוספט (NTP)","NADPH"],"a":2,"e":"בסינתזת RNA הריבונוקלאוזיד-תלת-פוספטים (ATP, GTP, CTP, UTP) משמשים גם כמצעים וגם כמקור אנרגיה — שחרור הפירופוספט (PPi) והידרוליזתו מניעים את ההארכה. ניתוח מסיחים: (א),(ב) רכיבים בודדים, לא התשובה הכללית; (ד) NADPH הוא נושא חיזור, לא מקור אנרגיה לשעתוק."},
    {"topic":"תיקון DNA — excision repair","q":"איזה אנזים קיים ב-NER אך לא ב-BER?","o":["נוקלאז","גליקוזילאז","פולימראז","הליקאז"],"a":3,"e":"תיקון כריתת נוקלאוטידים (NER) דורש הליקאזות (כמו XPB/XPD שב-TFIIH) לפתיחת ה-DNA סביב הנזק; תיקון כריתת בסיסים (BER) אינו דורש פתיחת סליל בהליקאז. ניתוח מסיחים: (ב) גליקוזילאז ייחודי דווקא ל-BER; (א),(ג) נוקלאז ופולימראז משמשים בשני המסלולים."},
    {"topic":"גורמי שעתוק ומגבירים","q":"מי מהבאים אינו נקשר ל-DNA?","o":["Helix-loop-helix","Leucine zipper","Zinc finger","Acidic domain"],"a":3,"e":"דומיין חומצי (acidic domain) הוא דומיין הפעלת-שעתוק שנקשר לחלבונים אחרים (מנגנון השעתוק), לא ל-DNA. ניתוח מסיחים: (א),(ב),(ג) helix-loop-helix, רוכסן לאוצין ואצבע אבץ הם מוטיבים קלאסיים לקשירת DNA."},
    {"topic":"כרומטין — היסטון H1 וכרומטין","q":"איזה זנב היסטון מכיל הכי הרבה מודיפיקציות שונות בקצה ה-N?","o":["H2A","H2B","H3","H4"],"a":2,"e":"זנב ה-N של H3 הוא העשיר ביותר במודיפיקציות פוסט-תרגומיות מגוונות (אצטילציות, מתילציות, זרחונים על שיירים רבים) — מרכזי ב'קוד ההיסטונים'. ניתוח מסיחים: (א),(ב),(ד) נושאים מודיפיקציות אך פחות מגוונות מאשר H3."},
    {"topic":"עיבוד RNA - שחבור חלופי","q":"חיידק מתרגם חלבון יחיד מגן יחיד, ואאוקריוט מספר חלבונים מגן יחיד. מה נכון?","o":["לריבוזום החיידקי פפטידיל-טרנספראז שונה","הריבוזום החיידקי שונה","לחיידק אין שחבור חלופי (alternative splicing)","חסר"],"a":2,"e":"היכולת להפיק כמה חלבונים מגן יחיד נובעת משחבור חלופי (alternative splicing) של ה-pre-mRNA — מנגנון אאוקריוטי; לחיידקים אין אינטרונים/שחבור ולכן גן→חלבון יחיד. ניתוח מסיחים: (א),(ב) הבדלי הריבוזום אינם מסבירים את ריבוי החלבונים; (ד) חסר."},
    {"topic":"שעתוק - פרוקריוטים מול אאוקריוטים","q":"איזו עדות מפריכה את 'הדוגמה המרכזית' (DNA→RNA→חלבון)?","o":["DNA פולימראז תלוי-DNA","RNA פולימראז","רוורס-טרנסקריפטאז","ריבוזום"],"a":2,"e":"רוורס-טרנסקריפטאז מסנתז DNA מתבנית RNA (RNA→DNA) — זרימת מידע 'אחורה' המפריכה את הגרסה החד-כיוונית הנוקשה של הדוגמה המרכזית. ניתוח מסיחים: (א),(ב),(ד) פועלים בכיוונים התואמים לדוגמה המרכזית (שכפול, שעתוק, תרגום)."},
    {"topic":"שכפול DNA — נאמנות","q":"שיבוט צפרדע ע'י החדרת גרעין מתא עור לביצית מנוטרלת-גרעין — מה הניסוי מוכיח?","o":["המידע ליצירת האורגניזם מצוי בחלבונים","ל-RNA יש יכולת קטליטית","חסר","תא עור ממוין מכיל את כל המידע ליצירת אורגניזם שלם"],"a":3,"e":"ניסוי גרדון מראה שגרעין של תא ממוין (עור) עדיין מכיל את כל המידע הגנטי הדרוש ליצירת אורגניזם שלם — כלומר ההתמיינות אינה כרוכה באובדן מידע גנטי. ניתוח מסיחים: (א) המידע ב-DNA שבגרעין, לא בחלבונים; (ב) אינו נושא הניסוי; (ג) חסר."},
    {"topic":"מיקרוסקופיה פלואורסצנטית - מגבלות","q":"איך מתאפשרת בחירת מישור במיקרוסקופ קונפוקלי בדגימה תלת-ממדית?","o":["פינהול (pinhole)","דה-קונבולוציה דיגיטלית","פוקוס ומישור","חסר"],"a":0,"e":"המיקרוסקופ הקונפוקלי משתמש בפינהול (חור-סיכה) שחוסם אור מחוץ-מוקד ומעביר רק את האור מהמישור המוקדי — וכך 'חותך' מישור אופטי דק בדגימה התלת-ממדית. ניתוח מסיחים: (ב) דה-קונבולוציה היא שיטה חישובית חלופית; (ג) ניסוח כללי; (ד) חסר."},
    {"topic":"Southern / Northern / Western blot","q":"באיזו שיטה תבדוק באיזה אזור במוח מתבטא lncRNA מסוים?","o":["FACS ואז Western blot","Affinity Chromatography","In situ hybridization","Microarray"],"a":2,"e":"In situ hybridization מאתרת RNA ספציפי בתוך רקמה שלמה בעזרת גשש משלים, ולכן מתאימה לזיהוי אזור הביטוי במוח. ניתוח מסיחים: (א) Western מזהה חלבונים, לא RNA, וללא הקשר מרחבי; (ב) כרומטוגרפיה אינה נותנת מידע מרחבי; (ד) Microarray מודד רמות ביטוי כלליות בלי לוקליזציה רקמתית."},
    {"topic":"שילוב - תרחיש מוטציה","q":"חוקרים יצרו מוטציות בתאים ואז זיהו פנוטיפים — איזו שיטה?","o":["Genetic screening","הורשה אפיגנטית","Position effect variegation","Chromatin remodeling"],"a":0,"e":"סריקה גנטית (genetic screening) — יצירת מוטציות אקראיות וזיהוי הפנוטיפים הנובעים — היא הגישה לקישור גנים לתפקודים. ניתוח מסיחים: (ב),(ג),(ד) תיאורי תופעות/מנגנונים, לא שיטת הסקר שתוארה."},
    {"topic":"עיבוד RNA - snRNP","q":"היכן נמצאים גופיפי קאחל (Cajal bodies)?","o":["מיטוכונדריה","גרעין","ER","ציטופלזמה"],"a":1,"e":"גופיפי קאחל הם מבנים תת-גרעיניים (בתוך הגרעין) המעורבים בהבשלה והרכבה של snRNP-ים וקומפלקסי RNA. ניתוח מסיחים: (א),(ג),(ד) מיקומים שגויים — הם גרעיניים."},
    {"topic":"שכפול DNA — גדיל מפגר","q":"מה קובע את אורך מקטעי אוקזאקי באאוקריוטים?","o":["ssDNA","dsDNA","נוקלאוזומים","מתילציות על ה-DNA"],"a":2,"e":"באאוקריוטים אורך מקטעי אוקזאקי (~150-200 נוקלאוטידים) תואם את מרווח הנוקלאוזומים — הנוקלאוזום מגביל ומתאם את הסינתזה על הגדיל המפגר. ניתוח מסיחים: (א),(ב),(ד) אינם קובעי האורך."},
    {"topic":"גורמי שעתוק ומגבירים","q":"גנים A ו-B על אותו כרומוזום ב-TADים שונים; C מגביר באותו TAD עם A. מה ייראה בתדירות גבוהה יותר ב-Hi-C?","o":["האינטראקציה C-A גדולה מ-C-B","C-A קטנה מ-C-B","תדירויות שוות","לא ניתן לדעת"],"a":0,"e":"TAD הוא תחום מבודד שבתוכו אינטראקציות מגע תכופות; מאחר ש-C ו-A באותו TAD, תדירות המגע C-A גבוהה מ-C-B (ב-TAD אחר, מופרד ע'י גבול). ניתוח מסיחים: (ב) הפוך; (ג),(ד) שגויים — הארגון ב-TADים צפוי וניתן למדידה."},
    {"topic":"CRISPR","q":"באיזו מערכת נשתמש כדי להשפיע על ביטוי גן בתא אאוקריוטי?","o":["T7 RNA פולימראז","CRISPR-Cas9 (עם מודיפיקציה, כגון dCas9)","I-SceI אנדונוקלאז","אנזים רסטריקציה"],"a":1,"e":"מערכת CRISPR מותאמת (dCas9 מאוחה למפעיל/מדכא — CRISPRa/CRISPRi) מאפשרת הכוונה ספציפית לרצף ובקרה על ביטוי הגן בתא אאוקריוטי. ניתוח מסיחים: (א) T7 פולימראז משמש לתעתוק in vitro; (ג),(ד) חיתוך DNA לא-ספציפי/באתרים קבועים, לא בקרת ביטוי מכוונת."},
    {"topic":"אפיגנטיקה - מתילציה","q":"מה מאפיין רצפים חוזרים (CA)n המשמשים כסמנים גנטיים?","o":["נדירים בגנום","עוברים מתילציות","C הופך ל-U","שינוי במספר החזרות (אורך המקטע)"],"a":3,"e":"מיקרו-סטליטים כמו (CA)n הם פולימורפיים באורכם — מספר החזרות משתנה בין פרטים, ולכן הם סמנים גנטיים שימושיים. ניתוח מסיחים: (א) הם נפוצים בגנום; (ב),(ג) אינם המאפיין הרלוונטי לשימוש כסמנים."},
    {"topic":"מיקרוסקופיה פלואורסצנטית - מגבלות","q":"מדוע במיקרוסקופ אור לא רואים שתי נקודות במרחק 150 ננומטר כנפרדות?","o":["אורך הגל של האור גדול מהמרחק בין הנקודות","אורך הגל קטן מ-150 ננומטר","העדשה רואה רק מעל 150 ננומטר","העדשה רואה רק 150 ננומטר בדיוק"],"a":0,"e":"גבול ההפרדה במיקרוסקופ אור (~λ/2) נקבע ע'י אורך הגל של האור הנראה (~400-700 ננומטר), הגדול בהרבה מ-150 ננומטר — ולכן שתי נקודות כה קרובות 'מתמזגות' (עקיפה). ניתוח מסיחים: (ב),(ג),(ד) טענות שגויות לגבי אורך הגל ויכולת העדשה."},
    {"topic":"שכפול DNA — כיווניות","q":"מה מאפיין מוצאי שכפול (origins) באאוקריוטים?","o":["לכל האורגניזמים אותם מוצאים","אין צורך במוצאים","כולם מתחילים בבת אחת","לא כל המוצאים פעילים בכל הכפלה"],"a":3,"e":"באאוקריוטים יש מוצאי שכפול רבים, אך לא כולם 'נורים' בכל מחזור — בחירת המוצאים גמישה ומשתנה. ניתוח מסיחים: (א) רצפי המוצאים אינם זהים בין אורגניזמים; (ב) המוצאים הכרחיים; (ג) המוצאים נורים בתזמונים שונים, לא בבת אחת."},
    {"topic":"מיקרוסקופיה פלואורסצנטית - מגבלות","q":"איזה אפקט אופטי מאפשר לראות תאים חיים (ללא קיבוע/צביעה)?","o":["הפרש פאזות (Phase contrast)","גבול הדיפרקציה","סופרפוזיציה","האצת פוטונים"],"a":0,"e":"מיקרוסקופ הפרש-פאזות (phase contrast) ממיר הבדלים זעירים במקדם השבירה (פאזה) לניגודיות נראית, ומאפשר לצפות בתאים חיים שקופים בלי צביעה. ניתוח מסיחים: (ב) גבול הדיפרקציה הוא מגבלה, לא שיטת ניגודיות; (ג),(ד) אינם רלוונטיים."},
    {"topic":"ביטוי חלבונים וקרינה פלואורסצנטית","q":"איזו שיטה אינה מאפשרת לראות אינטראקציה בין חלבונים?","o":["FRET","Co-IP","In situ hybridization","פלואורסצנס אניזוטרופי"],"a":2,"e":"In situ hybridization מאתרת חומצות גרעין (RNA/DNA) ברקמה — אינה בודקת אינטראקציות חלבון-חלבון. ניתוח מסיחים: (א) FRET, (ב) Co-IP ו-(ד) אניזוטרופיה פלואורסצנטית כולם משמשים לזיהוי אינטראקציות בין חלבונים."},
    {"topic":"שכפול DNA — נאמנות","q":"מולקולת DNA סומנה באיזוטופ ועברה 5 סבבי שכפול ללא איזוטופ — כמה גדילים מסומנים בסוף?","o":["2","4","16","32"],"a":0,"e":"שכפול שמרני-למחצה: שני הגדילים המקוריים המסומנים נשמרים לאורך כל הסבבים, כל אחד בנפרד בתוך מולקולה נפרדת — ולכן בכל שלב יש בדיוק 2 גדילים מסומנים. ניתוח מסיחים: (ב),(ג),(ד) מספרים גדלים מתעלמים מהשמירה השמרנית-למחצה של הגדילים המקוריים."},
    {"topic":"שעתוק - RNA פולימראזות","q":"מה ההבדל המהותי בין RNA פולימראז ל-DNA פולימראז?","o":["RNA פול מסנתז 3'→5'","RNA פול צורך ATP ו-DNA פול לא","DNA פול דורש פתיחת גדילים בעצמו","DNA פולימראז דורש פריימר ו-RNA פולימראז לא"],"a":3,"e":"RNA פולימראז יכול להתחיל סינתזה דה-נובו (בלי פריימר), בעוד DNA פולימראז דורש קצה 3'-OH של פריימר קיים. ניתוח מסיחים: (א) שניהם מסנתזים 5'→3'; (ב) שניהם משתמשים ב-NTP/dNTP; (ג) פתיחת הסליל נעשית ע'י הליקאז, לא ע'י הפולימראז."},
    {"topic":"בקרת איכות - NMD","q":"כיצד ניתן להפריד mRNA עכברי מ-mRNA חיידקי שהופקו יחד?","o":["צנטריפוגציה לפי משקל סגולי","אלקטרופורזה לפי אורך","מגנט (oligo-dT) הנקשר לזנב פולי-A הקיים באאוקריוטים בלבד","אלקטרופורזה לפי מטען"],"a":2,"e":"ל-mRNA האאוקריוטי (העכברי) יש זנב פולי-A שאין לחיידקי; לכד עם חרוזי oligo-dT מגנטיים מפריד אותו סלקטיבית. ניתוח מסיחים: (א),(ב),(ד) אינם מבחינים ספציפית בין מקור אאוקריוטי לחיידקי."},
    {"topic":"תרגום - ריבוזום ואתרי A/P/E","q":"מה יקרה לחומצות אמינו הידרופוביות כשהן יוצאות מהריבוזום בחלבון חדש?","o":["יתחברו ליוביקוויטין","יתחברו לשפרון מסוג HSP70","יעברו זרחון","יעברו ישירות לפרוטאזום"],"a":1,"e":"HSP70 נקשר לאזורים ההידרופוביים החשופים בשרשרת הנולדת, מונע אגרגציה ומסייע לקיפול תקין. ניתוח מסיחים: (א),(ד) חלבון נולד תקין אינו מנותב לפירוק; (ג) זרחון אינו התגובה למקטעים הידרופוביים."},
    {"topic":"תרגום - אמינואציל-tRNA סינתטאז","q":"כיצד aminoacyl-tRNA synthetase מוודא שהחומצה האמינית הנכונה הוטענה?","o":["לפי האפיניות לאנטי-קודון","אם חומצה אמינית שגויה נכנסת לכיס העריכה (editing) היא מוסרת מה-tRNA","אם החומצה מתאימה לכיס היא נשארת","לפי האפיניות לקודון"],"a":1,"e":"לאנזים אתר עריכה (proofreading): חומצת אמינו קטנה/שגויה שמתחמקת לאתר העריכה עוברת הידרוליזה ומוסרת מה-tRNA — 'סינון כפול' המבטיח נאמנות הטעינה. ניתוח מסיחים: (א),(ד) הזיהוי הוא של ה-tRNA והחומצה, לא לפי הקודון/אנטי-קודון בעת ההטענה; (ג) ניסוח חלקי שמתעלם מהעריכה."},
    {"topic":"מחזור התא","q":"מדוע חשוב שכרומטידות אחיות יוחזקו יחד ע'י קוהזין?","o":["שיגיעו לאותו תא בת","שייפרדו לתאי בת שונים באופן תקין","חלק מ-NHEJ","הכרחי למעבר G1→S"],"a":1,"e":"קוהזין מחזיק את הכרומטידות האחיות יחד עד אנאפאזה — מבטיח התמצאות דו-קוטבית (biorientation) על הציר והפרדה מדויקת של כל אחות לתא בת אחר. ניתוח מסיחים: (א) הפוך — הן הולכות לתאים שונים; (ג),(ד) אינם תפקיד הקוהזין כאן."},
    {"topic":"שעתוק - RNA פולימראזות","q":"באיזה חלבון משתמש HIV כדי לייצא מהגרעין RNA לא-משוחבר (עם אינטרונים)?","o":["Nef","Rev","Tat","Gag"],"a":1,"e":"Rev נקשר לאלמנט RRE שב-RNA הוויראלי ומתווך ייצוא של RNA לא-משוחבר/חלקית-משוחבר מהגרעין לציטופלזמה. ניתוח מסיחים: (א) Nef מורידה ויסות של קולטנים; (ג) Tat מגביר שעתוק; (ד) Gag הוא חלבון מבני."},
    {"topic":"תרגום - אתחול אאוקריוטי","q":"איזה פקטור איניציאציה מעורב בחיבור tRNA-Met לתת-היחידה הקטנה?","o":["eIF4E","eIF4G","eIF2","eIF3"],"a":2,"e":"eIF2-GTP נושא את Met-tRNAi ויוצר את הקומפלקס השלישוני המתחבר לתת-היחידה הקטנה (43S). ניתוח מסיחים: (א) eIF4E קושר את הכיפה; (ב) eIF4G מתאם; (ד) eIF3 מייצב את התת-יחידה הקטנה — אך נשיאת ה-Met-tRNA היא של eIF2."},
    {"topic":"שעתוק - RNA פולימראזות","q":"איזה חומר מעכב גדילה בחיידקים בלבד ולא בתאים אאוקריוטיים?","o":["Rifamycin","Actinomycin D","Puromycin","Anisomycin"],"a":0,"e":"ריפמיצין מעכב ספציפית את ה-RNA פולימראז החיידקי, ולכן סלקטיבי לחיידקים. ניתוח מסיחים: (ב) Actinomycin D נצמד ל-DNA ופוגע גם באאוקריוטים; (ג) Puromycin פוגע בתרגום בשני הסוגים; (ד) Anisomycin מעכב את הריבוזום האאוקריוטי 80S."},
    {"topic":"שעתוק - RNA פולימראזות","q":"איזו מולקולת rRNA אינה נמצאת באאוקריוטים?","o":["5.8S","16S","18S","28S"],"a":1,"e":"16S rRNA הוא רכיב תת-היחידה הקטנה של הריבוזום החיידקי (70S); באאוקריוטים תת-היחידה הקטנה מכילה 18S. ניתוח מסיחים: (א) 5.8S, (ג) 18S ו-(ד) 28S כולם rRNA אאוקריוטיים."}
  ],
  cell: [
    {"topic":"מבנה הקרום - אסימטריה ונזילות","q":"חוקרים סימנו את הפוספוליפיד פוספטידיל-סרין (phosphatidylserine) בקרום הפלזמה של תא חי ובריא. היכן צפויים למצוא אותו, ומה תפקיד האנזים האחראי על מיקומו?","o":["בעיקר בעלעל הציטוזולי (הפנימי), בשל פעילות פליפאזה (flippase) התלויה ב-ATP","בעיקר בעלעל החיצוני (האקסופלזמי), בשל פעילות סקראמבלאזה (scramblase) התלויה ב-ATP","מפוזר באופן סימטרי בשני העלעלים, בשל דיפוזיה רוחבית מהירה","בעיקר בעלעל החיצוני, בשל פעילות פליפאזה המעבירה פוספוליפידים החוצה"],"a":0,"e":"עיקרון מפתח: קרום הפלזמה אסימטרי — הרכב הפוספוליפידים בעלעל הציטוזולי שונה מזה שבעלעל האקסופלזמי. פוספטידיל-סרין (PS) ופוספטידיל-אתנול-אמין מרוכזים פנימה, ואת האסימטריה הזו יוצרת ומתחזקת פליפאזה (flippase) — אנזים תלוי-ATP שמעביר פוספוליפידים ספציפיים מהעלעל החיצוני לפנימי כנגד הנטייה. מסיח ב' שגוי: סקראמבלאזה אינה תלויה ב-ATP ופועלת דו-כיוונית כדי להשוות פיזור; הפעלתה דווקא מבטלת את האסימטריה. מסיח ג' שגוי: דיפוזיה רוחבית (לרוחב אותו עלעל) מהירה, אבל מעבר ספונטני בין העלעלים (flip-flop) איטי מאוד, ולכן האסימטריה יציבה. מסיח ד' הופך את כיוון הפליפאזה. טיפ לזכירה: חשיפת PS בעלעל החיצוני היא 'דגל' אכילה לאפופטוזיס — לכן בתא בריא הוא חייב להישאר פנימה."},
    {"topic":"מבנה הקרום - תפקיד הכולסטרול","q":"מהי השפעת הכולסטרול על נזילות דו-שכבת הפוספוליפידים בקרום של תא יונק בטמפרטורת הגוף?","o":["מקשיח את הדו-שכבה ומוריד נזילות, אך מונע מעבר חד למצב גבישי בקירור","מעלה באופן חד-משמעי את הנזילות בכל הטמפרטורות","אין לו השפעה על הנזילות אלא רק על החדירות למולקולות קטנות","מקטין את החדירות למים ולמולקולות קטנות מסיסות-מים, ובו-זמנית מעלה את הנזילות"],"a":0,"e":"עיקרון מפתח: כולסטרול הוא 'בולם נזילות' (fluidity buffer) דו-כיווני. קבוצת ההידרוקסיל שלו מתיישבת ליד ראשי הפוספוליפידים הקוטביים, והטבעת הסטרואידית הקשיחה נצמדת לשרשראות חומצות השומן. בטמפרטורת הגוף הוא מקשה על תנועת השרשראות ובכך מוריד נזילות; אך בטמפרטורות נמוכות הוא מפריד בין השרשראות ומונע אריזה צפופה, וכך מונע מעבר חד למצב גבישי-מוצק. מסיח ב' שגוי: ההשפעה תלוית-טמפרטורה ולא העלאה גורפת. מסיח ג' שגוי: לכולסטרול השפעה מהותית על נזילות, לא רק על חדירות. מסיח ד' נכון לגבי הקטנת חדירות למולקולות קטנות מסיסות-מים, אך טועה בכך שהוא טוען שבטמפ' הגוף הנזילות עולה. טיפ: זכור 'מתון לשני הכיוונים' — כולסטרול ממתן קיצוניות, ולכן מוריד נזילות בחום ומעלה בקור."},
    {"topic":"מבנה הקרום - חלבוני ממברנה","q":"חלבון ממברנה זוהה כבעל מקטע יחיד חוצה-קרום בצורת סליל אלפא, כאשר הקצה הקרבוקסילי (C) שלו ציטוזולי. כיצד ניתן לשחרר חלבון כזה מהקרום בלי לפרק את דו-שכבת השומנים?","o":["לא ניתן; נדרש דטרגנט להוצאת חלבון אינטגרלי בעל מקטע חוצה-קרום","באמצעות תמיסה בעלת כוח יוני גבוה בלבד (למשל ריכוז מלח גבוה)","באמצעות תמיסה בסיסית מאוד (pH גבוה) המנתקת קשרים מימניים","באמצעות פוספוליפאזה הפורקת את ראשי הפוספוליפידים בלבד"],"a":0,"e":"עיקרון מפתח: ההבחנה בין חלבון ממברנה אינטגרלי (integral) לפריפריאלי (peripheral). חלבון עם מקטע חוצה-קרום בצורת סליל אלפא הוא אינטגרלי — שאריותיו ההידרופוביות שקועות בליבת הדו-שכבה ומקיימות איתה אינטראקציות הידרופוביות. כדי לחלצו בלי לפרק את הקרום צריך דטרגנט, שמולקולותיו עוטפות את המקטעים ההידרופוביים ויוצרות מיצלות מסיסות. מסיח ב' שגוי: כוח יוני גבוה (מלח) משחרר רק חלבונים פריפריאליים הקשורים אלקטרוסטטית לפני השטח. מסיח ג' שגוי: שינוי pH קיצוני אף הוא משחרר רק פריפריאליים. מסיח ד' שגוי: פוספוליפאזה הורסת את הקרום עצמו ואינה השיטה המקובלת לבידוד החלבון. טיפ לזכירה: אינטגרלי = דטרגנט; פריפריאלי = מלח/pH."},
    {"topic":"מבנה הקרום - מעבר חומרים","q":"תעלת יונים מסוג מתח-תלויה (voltage-gated) לעומת משאבת יונים (pump): מהו ההבדל העקרוני ביניהן בהקשר של כיוון תנועת היונים?","o":["תעלה מאפשרת מעבר רק במורד מפל אלקטרוכימי, ואילו משאבה יכולה להעביר יונים נגד המפל תוך ניצול אנרגיה","תעלה מעבירה יונים נגד המפל, ומשאבה מעבירה רק במורד המפל","שתיהן מעבירות רק במורד המפל, אך תעלה מהירה יותר","שתיהן צורכות ATP, אך רק התעלה תלויה במתח"],"a":0,"e":"עיקרון מפתח: ההבדל הבסיסי בין טרנספורט סביל (תעלה) לפעיל (משאבה) נעוץ בכיוון ביחס למפל האלקטרוכימי. תעלה (channel) מאפשרת אך ורק מעבר במורד המפל — היונים זורמים לפי הפרש הריכוז והמטען, ללא השקעת אנרגיה, ובקצב מהיר מאוד. משאבה (pump, כגון ATPase) מבצעת טרנספורט פעיל ומסוגלת לדחוף יונים נגד המפל תוך ניצול אנרגיה (לרוב הידרוליזת ATP). מסיח ב' הופך את התפקידים. מסיח ג' שגוי: משאבה אינה מוגבלת לכיוון המורד — זו כל מהותה. מסיח ד' שגוי: תעלות אינן צורכות ATP כלל; רק המשאבה צורכת אנרגיה. טיפ: 'תעלה זורמת במדרון, משאבה עולה במעלה' — ורק עלייה במעלה דורשת דלק."},
    {"topic":"מבנה הקרום - נשאים מול תעלות","q":"מהי ההבחנה המהותית במנגנון הפעולה בין חלבון נשא (transporter/carrier) לבין תעלה (channel)?","o":["נשא עובר שינוי קונפורמציה הקושר את המומס וחושף אותו לסירוגין לכל צד, ואילו תעלה יוצרת נקב מימי המאפשר זרימה רציפה","נשא יוצר נקב מימי קבוע, ואילו תעלה עוברת שינוי קונפורמציה לכל מולקולה","נשא מעביר רק יונים, ותעלה מעבירה רק מולקולות לא-טעונות","שניהם בעלי קצב מעבר זהה לחלוטין למולקולה בשנייה"],"a":0,"e":"עיקרון מפתח: ההבחנה בין נשא (transporter/carrier) לתעלה (channel) היא במנגנון. נשא קושר את המומס באתר ספציפי, ואז עובר שינוי קונפורמציה שחושף את אתר הקישור לסירוגין לשני צידי הקרום ('מופנה-חוץ' מול 'מופנה-פנים'). מאחר שכל מולקולה דורשת מחזור קונפורמציוני, הקצב נמוך יחסית (מאות עד אלפי מולקולות בשנייה) וניתן לרוויה כמו אנזים. תעלה יוצרת נקב מימי המאפשר זרימה רציפה ומהירה (עד מיליוני יונים בשנייה). מסיח ב' הופך את ההגדרות. מסיח ג' שגוי: נשאים מעבירים גם מולקולות לא-טעונות (למשל גלוקוז דרך GLUT). מסיח ד' שגוי: הקצבים שונים מאוד. טיפ לזכירה: נשא 'מחבק ומסובב' מולקולה אחת בכל פעם; תעלה 'פותחת שער' לזרם — ולכן רק נשא רווי וניתן לדבר עליו ב-Km."},
    {"topic":"מיון חלבונים - פפטיד סיגנל ל-ER","q":"במהלך תרגום של חלבון מופרש, מתי ובאמצעות מי מזוהה פפטיד הסיגנל המכוון את הריבוזום אל קרום ה-ER המחוספס?","o":["במהלך התרגום (קו-טרנסלציוני), על-ידי חלקיק זיהוי הסיגנל (SRP) הקושר את הפפטיד וגורם להשהיית התרגום","לאחר השלמת התרגום (פוסט-טרנסלציוני) במלואו, על-ידי קולטן SRP בלבד","במהלך התרגום, על-ידי חלבוני TOM/TIM שבקרום ה-ER","לאחר התרגום, על-ידי רצף לוקליזציה גרעיני (NLS) המזוהה על-ידי אימפורטין"],"a":0,"e":"עיקרון מפתח: יבוא חלבונים מופרשים אל הרשתית האנדופלזמית (ER) הוא קו-טרנסלציוני — מתרחש תוך כדי התרגום. כשפפטיד הסיגנל ההידרופובי בקצה ה-N מבצבץ מהריבוזום, חלקיק זיהוי הסיגנל (SRP) קושר אותו ומשהה (מאט) את התרגום. SRP מוביל את כל הקומפלקס אל קולטן SRP בקרום ה-ER, שם הריבוזום נמסר לטרנסלוקון, ה-SRP משתחרר והתרגום מתחדש ישירות לתוך ה-ER. מסיח ב' שגוי: התהליך קו-טרנסלציוני (ולא פוסט) ומערב גם את SRP וגם את קולטנו. מסיח ג' שגוי: TOM/TIM שייכים ליבוא מיטוכונדריאלי. מסיח ד' שגוי: NLS ואימפורטין שייכים ליבוא גרעיני. טיפ: ER = SRP תוך כדי תרגום; מיטוכונדריה = TOM/TIM אחרי תרגום; גרעין = NLS/אימפורטין."},
    {"topic":"מיון חלבונים - יבוא למיטוכונדריה","q":"חלבון המיועד למטריקס המיטוכונדריאלי מקודד בגרעין ומתורגם בציטוזול. אילו תנאים נדרשים לכניסתו דרך קומפלקסי TOM ו-TIM?","o":["החלבון נכנס במצב לא-מקופל (פרוש), ונדרש מפל הפוטנציאל החשמלי על-פני הקרום הפנימי בנוסף ל-ATP","החלבון נכנס לאחר קיפול מלא, ונדרש רק ATP בציטוזול","החלבון נכנס בתוך שלפוחית מצופה COPII הנושאת אותו אל המטריקס","החלבון נכנס במצב מקופל, ונדרש רצף סיגנל פנימי המזוהה על-ידי SRP"],"a":0,"e":"עיקרון מפתח: יבוא למטריקס המיטוכונדריה הוא בעיקרו פוסט-טרנסלציוני, והחלבון חייב להיכנס במצב פרוס (unfolded). צ'אפרונים (chaperones, כגון Hsp70 ציטוזולי) מחזיקים את הקדם-חלבון רפוי כדי שיוכל להשחל דרך התעלות הצרות של TOM (קרום חיצוני) ו-TIM (קרום פנימי). המעבר אל המטריקס תלוי בשני מקורות אנרגיה: מפל הפוטנציאל החשמלי על-פני הקרום הפנימי, וכן Hsp70 מיטוכונדריאלי הפועל כ'מנוע' תלוי-ATP המושך את השרשרת פנימה. מסיח ב' שגוי: חלבון מקופל אינו יכול לעבור, ונדרש גם פוטנציאל הקרום. מסיח ג' שגוי: COPII שייך לתעבורת ER-גולג'י. מסיח ד' שגוי: SRP שייך למסלול ה-ER. טיפ: למיטוכונדריה נכנסים 'רזים ופרושים', בעוד שלגרעין אפשר להיכנס מקופל."},
    {"topic":"מיון חלבונים - UPR","q":"בתגובת החלבונים הלא-מקופלים (UPR) מופעלים מספר חיישנים בקרום ה-ER. מהו מנגנון הפעולה של החיישן IRE1 בעקבות הצטברות חלבונים לא-מקופלים בחלל ה-ER?","o":["IRE1 מתאגד (דימריזציה), מפעיל פעילות אנדוריבונוקלאז המבצעת שחבור (splicing) לא-קונבנציונלי של mRNA המקודד גורם שעתוק","IRE1 עובר ביקוע פרוטאוליטי המשחרר מקטע ציטוזולי שעובר לגרעין כגורם שעתוק","IRE1 מזרחן את eIF2 ובכך מעצור באופן כללי את התרגום בתא","IRE1 מפעיל קספאזות ומוביל ישירות לאפופטוזיס בתוך דקות"],"a":0,"e":"עיקרון מפתח: תגובת החלבונים הלא-מקופלים (UPR) מופעלת כשמצטברים חלבונים פגומים בחלל ה-ER, ופועלת דרך שלושה חיישנים נפרדים. IRE1 הוא חיישן בעל פעילות כפולה — קינאז ואנדוריבונוקלאז. עם הצטברות חלבונים לא-מקופלים הוא מתאגד (דימריזציה), עובר אוטו-זרחון, ואזור האנדוריבונוקלאז שלו מבצע שחבור (splicing) לא-קונבנציונלי של mRNA המקודד גורם שעתוק (XBP1 ביונקים, HAC1 בשמרים), שמפעיל גנים לשיקום ההומאוסטזיס. מסיח ב' מתאר את ATF6 (ביקוע פרוטאוליטי בגולג'י). מסיח ג' מתאר את PERK (זרחון eIF2alpha ועצירת תרגום כללית). מסיח ד' שגוי: UPR מנסה לתקן; אפופטוזיס מגיע רק בעקה ממושכת. טיפ: שלושה חיישנים — IRE1 (חותך mRNA), PERK (עוצר תרגום), ATF6 (נחתך והולך לגרעין)."},
    {"topic":"תעבורה ממברנלית - סוגי ציפוי","q":"באיזה סוג מעטה (coat) של שלפוחית מתווכת ההובלה מן הרשתית האנדופלזמית (ER) אל מתחם הגולג'י (קדמית-אנטרוגרדית), ובאיזה סוג מתווכת ההובלה ההפוכה מהגולג'י חזרה ל-ER?","o":["מ-ER לגולג'י: COPII; מהגולג'י ל-ER: COPI","מ-ER לגולג'י: COPI; מהגולג'י ל-ER: COPII","מ-ER לגולג'י: קלאתרין (clathrin); מהגולג'י ל-ER: COPI","מ-ER לגולג'י: COPII; מהגולג'י ל-ER: קלאתרין"],"a":0,"e":"עיקרון מפתח: התעבורה השלפוחיתית בין ER לגולג'י מתווכת על-ידי מעטפות חלבון ספציפיות לכיוון. שלפוחיות מצופות COPII מנצות מן ה-ER ונושאות מטען קדימה (אנטרוגרדית) אל הגולג'י. שלפוחיות מצופות COPI נוסעות אחורה (רטרוגרדית) — מהגולג'י חזרה ל-ER ובין ערימות הגולג'י, ובין השאר מחזירות חלבוני ER שנמלטו (מזוהים ברצף KDEL). מסיח ב' הופך בין השניים — זו הטעות הנפוצה ביותר. מסיחים ג' ו-ד' שגויים: קלאתרין (clathrin) פועל בקרום הפלזמה (אנדוציטוזה) וברשת ה-trans-גולג'י, לא בציר ER-גולג'י. טיפ לזכירה: 'COPII = II כמו 2 אותיות במילה Out (החוצה מה-ER, קדימה)'; COPI = חזרה ל-ER."},
    {"topic":"תעבורה ממברנלית - SNARE","q":"מהו תפקידם של חלבוני v-SNARE ו-t-SNARE בהיתוך שלפוחית עם קרום המטרה, וכיצד מתבצע מחזורם לשימוש חוזר?","o":["v-SNARE בשלפוחית ו-t-SNARE בקרום המטרה מתפתלים יחד למבנה מסולסל המקרב את הקרומים; לאחר ההיתוך NSF (עם SNAP) מפרק את הקומפלקס תוך הידרוליזת ATP","v-SNARE ו-t-SNARE מזהים את השלפוחית, ו-Rab מבצע את ההיתוך עצמו; הקומפלקס מתפרק ספונטנית","v-SNARE בקרום המטרה ו-t-SNARE בשלפוחית; הפירוק מתבצע על-ידי דינמין","ה-SNARE אחראים רק על הניצוץ הראשוני של השלפוחית, וההיתוך מבוצע על-ידי קלאתרין"],"a":0,"e":"עיקרון מפתח: היתוך שלפוחית עם קרום המטרה מתבצע על-ידי זוג חלבוני SNARE משלימים — v-SNARE על השלפוחית ו-t-SNARE על קרום המטרה. הם מתפתלים זה סביב זה לצרור של ארבעה סלילים (four-helix bundle) המקרב את שני הקרומים עד היתוך. הקומפלקס שנוצר יציב מאוד, ולכן כדי למחזר את ה-SNARE נדרש NSF (אנזים ATPase) בעזרת חלבוני SNAP, שמפרק אותו תוך הידרוליזת ATP. מסיח ב' שגוי: Rab ו-tethers אחראים לעגינה ולספציפיות הראשונית, אך ה-SNARE עצמם מבצעים את ההיתוך, והפירוק אינו ספונטני. מסיח ג' הופך את מיקום v/t-SNARE ומייחס פירוק לדינמין (שתפקידו לנתק שלפוחיות קלאתרין). מסיח ד' שגוי: קלאתרין הוא חלבון מעטה, לא מתווך היתוך. טיפ: v=vesicle, t=target; NSF 'מנתק' אותם לשימוש חוזר."},
    {"topic":"תעבורה ממברנלית - Rab ועגינה","q":"מהו התפקיד העיקרי של חלבוני Rab (GTPases קטנים) בתעבורה הממברנלית התוך-תאית?","o":["סימון זהות הקרום וגיוס חלבוני עגינה (tethering) ואפקטורים המבטיחים את ספציפיות העגינה של השלפוחית לקרום המטרה הנכון","יצירת המעטה הפיזי של השלפוחית המנצה מקרום התורם","ביצוע ההיתוך הסופי של דו-שכבות השומנים במקום ה-SNARE","ניתוק (fission) השלפוחית מקרום התורם בתום ההנצה"],"a":0,"e":"עיקרון מפתח: חלבוני Rab הם GTPases קטנים המשמשים כ'סמני זהות' לקרומים ולשלפוחיות. בצורתם הפעילה הקשורה ל-GTP הם מגייסים אפקטורים וחלבוני עגינה (tethering proteins) המבצעים את הזיהוי הראשוני בין השלפוחית הנכונה לקרום המטרה הנכון — וכך מבטיחים את ספציפיות התעבורה לפני שה-SNARE מבצעים את ההיתוך הסופי. מסיח ב' שגוי: יצירת המעטה הפיזי היא תפקיד חלבוני המעטה (COPI/COPII/clathrin) ו-GTPases מסוג Sar1/Arf. מסיח ג' שגוי: ההיתוך עצמו מבוצע על-ידי SNARE. מסיח ד' שגוי: ניתוק (fission) שלפוחיות קלאתרין מבוצע על-ידי דינמין. טיפ לזכירה: Rab = 'תג כתובת/מיקוד' שמכוון את החבילה; SNARE = 'הדבק' שמאחה; דינמין = 'מספריים' שמנתקות."},
    {"topic":"תעבורה ממברנלית - אנדוציטוזה ומיון","q":"קולטן ה-LDL נכנס לתא באנדוציטוזה מתווכת-קולטן בשלפוחיות מצופות קלאתרין ומגיע לאנדוזום מוקדם. מדוע הקולטן ממוחזר לקרום הפלזמה בעוד שה-LDL מנותב לליזוזום?","o":["ה-pH החומצי באנדוזום המוקדם משחרר את ה-LDL מהקולטן; הקולטן נאסף לאזור המוחזר לקרום, וה-LDL נשאר וממשיך לאנדוזום מאוחר וליזוזום","ה-pH הבסיסי באנדוזום מהדק את הקשירה; הקולטן מפורק והליגנד ממוחזר","הקולטן מנותב לליזוזום וה-LDL ממוחזר, משום שקולטנים מסומנים ביוביקוויטין לפירוק","הן הקולטן והן ה-LDL ממוחזרים יחד לקרום הפלזמה ללא הפרדה"],"a":0,"e":"עיקרון מפתח: באנדוציטוזה מתווכת-קולטן, ה-pH הוא ה'מתג' שמפריד בין קולטן לליגנד. קולטן ה-LDL ועמיתו ה-LDL נכנסים בשלפוחית מצופת קלאתרין ומגיעים לאנדוזום המוקדם, שם משאבות פרוטונים (V-ATPase) מחמצנות את החלל. ה-pH הנמוך משנה את קונפורמציית הקולטן ומשחרר ממנו את ה-LDL. הקולטן הפנוי נאסף לתת-מתחם הממוחזר (recycling) וחוזר לקרום הפלזמה לסבב נוסף, בעוד ה-LDL החופשי ממשיך לאנדוזום המאוחר ולליזוזום לפירוק. מסיח ב' שגוי: ה-pH חומצי (לא בסיסי) והוא משחרר ולא מהדק. מסיח ג' הופך את הגורלות — הקולטן ממוחזר, לא מפורק. מסיח ד' שגוי: יש הפרדה ברורה ביניהם. טיפ: 'חומצה מנתקת' — האנדוזום החומצי הוא תחנת המיון שמפרידה קולטן מליגנד."},
    {"topic":"תעבורה ממברנלית - מיון ליזוזומלי","q":"אנזימי הידרולאז ליזוזומליים ממוינים במסלול: ER, גולג'י ולבסוף ליזוזום. מהו האות המולקולרי המבטיח את ניתובם הנכון אל הליזוזום, והיכן הוא מתווסף?","o":["מנוז-6-פוספט (M6P), המתווסף בגולג'י ומזוהה על-ידי קולטן M6P ברשת ה-trans-גולג'י","רצף KDEL בקצה הקרבוקסילי, המתווסף ב-ER ומזהה אותם להחזרה","מנוז-6-פוספט, המתווסף ב-ER ומזוהה על-ידי SRP","יוביקוויטין, המתווסף בציטוזול ומכוון לפירוק בליזוזום"],"a":0,"e":"עיקרון מפתח: הידרולאזות ליזוזומליות מנותבות ליעדן באמצעות תווית מנוז-6-פוספט (M6P). בגולג'י (cis-גולג'י) מתבצע זרחון של שיירי מנוז על שרשרת ה-N-גליקן שלהן ליצירת M6P. ברשת ה-trans-גולג'י קולטני M6P קושרים אותן ומכניסים אותן לשלפוחיות מצופות קלאתרין שמועברות לאנדוזומים; ה-pH החומצי משחרר את האנזים מהקולטן, והקולטן ממוחזר. מסיח ב' שגוי: KDEL הוא אות להחזרה ל-ER, לא ניתוב לליזוזום. מסיח ג' שגוי בשני פרטים: M6P מתווסף בגולג'י (לא ER) ואינו מזוהה על-ידי SRP. מסיח ד' שגוי: יוביקוויטין מכוון לפרוטאזום או למסלולי ILV, לא לליזוזום בדרך זו. טיפ: M6P = 'בול דואר ליזוזומלי' שנדבק בגולג'י; KDEL = 'בול חזרה' ל-ER."},
    {"topic":"מיטוכונדריה והמרת אנרגיה","q":"בתהליך הזרחון החמצוני, מהו התפקיד הישיר של מפל האלקטרונים לאורך שרשרת מעבר האלקטרונים בממברנה הפנימית של המיטוכונדריה?","o":["לסנתז ATP באופן ישיר על ידי זרחון של ADP בקומפלקסים I, III ו-IV","לשאוב פרוטונים (H+) מהמטריקס אל המרחב הבין-ממברנלי וכך ליצור מפל אלקטרוכימי","להפחית את חמצן המולקולרי למים תוך שחרור ישיר של אנרגיה לסינתזת ATP במטריקס","להעביר פרוטונים מהמרחב הבין-ממברנלי אל המטריקס דרך ATP-סינתאז"],"a":1,"e":"עיקרון מפתח: שרשרת מעבר האלקטרונים (ETC) והזרחון החמצוני הם שני שלבים נפרדים פיזית — וזה לב מודל הכימיוסמוזה. קומפלקסים I, III ו-IV אינם מסנתזים ATP. תפקידם הישיר הוא לנצל את האנרגיה הנפלטת ממעבר האלקטרונים כדי לשאוב פרוטונים (H+) מהמטריקס אל המרחב הבין-ממברנלי, וליצור מפל אלקטרוכימי (כוח מניע פרוטוני). מסיח א' שגוי: אין זרחון ישיר של ADP בקומפלקסים; הסינתזה מתבצעת בנפרד על-ידי ATP-סינתאז. מסיח ג' שגוי: הפחתת חמצן למים (בקומפלקס IV) היא קולט האלקטרונים הסופי, אך אינה מסנתזת ATP ישירות. מסיח ד' הופך את כיוון זרימת הפרוטונים. טיפ: ETC 'שואב' פרוטונים החוצה ויוצר 'סוללה'; ATP-סינתאז 'פורק' את הסוללה כשהפרוטונים זורמים בחזרה."},
    {"topic":"מיטוכונדריה והמרת אנרגיה","q":"חוקרת בודקת מוטציה הפוגעת בייבוא חלבונים גרעיניים אל מטריקס המיטוכונדריה. אילו תכונות נדרשות מחלבון פרה-קורסור ומאיזה מצב קונפורמציוני כדי שייובא דרך קומפלקסי TOM ו-TIM23?","o":["החלבון חייב להיות מקופל לחלוטין (folded) ולשאת רצף איתות בקצה ה-C","החלבון נדרש במצב פרוס (unfolded) ונושא רצף איתות מטריקס בקצה ה-N, וייבואו תלוי בפוטנציאל הממברנה הפנימית ובמנוע התלוי-ATP (Hsp70 מיטוכונדריאלי)","החלבון מיובא במצב מקופל דרך נקבוביות גרעיניות תוך שימוש ב-GTP","החלבון מסונתז בתוך המטריקס על ידי ריבוזומים מיטוכונדריאליים ואינו זקוק לרצף איתות"],"a":1,"e":"עיקרון מפתח: רוב חלבוני המיטוכונדריה מקודדים בגרעין, מתורגמים בציטוזול, ומיובאים פוסט-טרנסלציונית במצב פרוס (unfolded). הקדם-חלבון נושא רצף איתות אמפיפתי בקצה ה-N. המעבר דרך TOM (קרום חיצוני) ו-TIM23 (קרום פנימי) אל המטריקס מונע משני גורמים: מפל הפוטנציאל החשמלי על-פני הקרום הפנימי, ו-Hsp70 מיטוכונדריאלי הפועל כמנוע תלוי-ATP המושך את השרשרת פנימה ('ratchet'). מסיח א' שגוי בכפליים: החלבון נכנס פרוס (לא מקופל) ורצף האיתות בקצה ה-N (לא C). מסיח ג' שגוי: יבוא דרך נקבוביות גרעיניות עם GTP שייך לגרעין. מסיח ד' שגוי: רק מיעוט החלבונים מתורגם בתוך המיטוכונדריה. טיפ: רצף N-טרמינלי + מצב פרוס + פוטנציאל קרום + Hsp70 = ארבעת תנאי היבוא."},
    {"topic":"מיטוכונדריה והמרת אנרגיה","q":"מהי הראיה המרכזית התומכת בתאוריה האנדוסימביוטית למוצא המיטוכונדריה לפי Alberts?","o":["המיטוכונדריה מכילה גנום DNA מעגלי משלה וריבוזומים הדומים לאלה של חיידקים, ומתחלקת בעצמה","כל חלבוני המיטוכונדריה מקודדים בגנום המיטוכונדריאלי באופן עצמאי מהגרעין","הממברנה החיצונית של המיטוכונדריה זהה בהרכבה לממברנה החיצונית של תאים אאוקריוטיים בלבד","המיטוכונדריה אינה מסוגלת להתחלק ונוצרת מחדש מקרום הרשתית האנדופלזמית בכל מחזור תא"],"a":0,"e":"עיקרון מפתח: התאוריה האנדוסימביוטית גורסת שהמיטוכונדריה מקורה בחיידק קדום שנבלע בתא אאוקריוטי. הראיות העיקריות: למיטוכונדריה גנום DNA משלה (לרוב מעגלי, דמוי-חיידק), מנגנון תרגום עצמאי עם ריבוזומים הדומים בגודלם וברגישותם לאנטיביוטיקה לאלה של חיידקים, והיא מתחלקת בעצמה בפיצול (ולא נוצרת מאברון אחר). מסיח ב' שגוי: רוב חלבוני המיטוכונדריה דווקא מקודדים בגרעין (הגנום המיטוכונדריאלי מקודד רק מעטים), כי לאורך האבולוציה רוב הגנים נדדו לגרעין. מסיח ג' שגוי לגבי דמיון הממברנה. מסיח ד' שגוי: המיטוכונדריה כן מתחלקת ואינה נוצרת מה-ER. טיפ לזכירה: 'DNA מעגלי + ריבוזומים דמויי-חיידק + התחלקות עצמית' = שלוש האצבעות המצביעות על מוצא חיידקי."},
    {"topic":"מיטוכונדריה והמרת אנרגיה","q":"בניסוי קלאסי מוסיפים למיטוכונדריה מבודדות חומר מנתק (uncoupler) כגון DNP (דיניטרופנול) המעביר פרוטונים דרך הממברנה הפנימית. מה תהיה התוצאה?","o":["סינתזת ATP תגבר כי מפל הפרוטונים יתחזק","מעבר האלקטרונים וצריכת החמצן ייפסקו מיד עקב חוסר ב-ADP","מעבר האלקטרונים וצריכת החמצן יימשכו ואף יגברו, אך סינתזת ATP תיפסק כי המפל האלקטרוכימי מתפוגג","הן מעבר האלקטרונים והן סינתזת ה-ATP ייפסקו, אך חום לא ישתחרר"],"a":2,"e":"עיקרון מפתח: מנתק (uncoupler) כמו DNP מנתק את הצימוד בין מעבר אלקטרונים לסינתזת ATP. הוא חומצה חלשה ליפופילית שמסיעה פרוטונים בחזרה דרך הממברנה הפנימית בעקיפת ATP-סינתאז, ובכך מפזר את המפל האלקטרוכימי. התוצאה: שרשרת מעבר האלקטרונים 'רצה חופשי' ואף מאיצה (כי הבקרה החוזרת של המפל הוסרה), צריכת החמצן עולה — אך סינתזת ה-ATP נפסקת, והאנרגיה מתבזבזת כחום. מסיח א' שגוי: המפל מתפוגג, לא מתחזק. מסיח ב' שגוי: ה-ETC ממשיכה דווקא ביתר שאת ואינה תלויה ב-ADP כאן. מסיח ד' שגוי: חום כן משתחרר (זו מהות התופעה). טיפ: 'מנתק = חור בסכר' — המים זורמים אך הטורבינה לא מסתובבת; זכור גם UCP1 ברקמת השומן החום שמייצר חום פיזיולוגית."},
    {"topic":"מיטוכונדריה והמרת אנרגיה","q":"מהי המשמעות של היות הממברנה המיטוכונדריאלית החיצונית עשירה בחלבון פורין (porin) לעומת הממברנה הפנימית?","o":["הממברנה החיצונית חדירה למולקולות קטנות (עד כ-5000 דלטון) בזכות הפורין, בעוד הפנימית אטומה ביותר ובררנית","הממברנה הפנימית חדירה לכל היונים בזכות הפורין, בעוד החיצונית אטומה","שתי הממברנות חדירות באופן זהה למולקולות גדולות","הפורין אחראי לשאיבת הפרוטונים ולכן הוא בממברנה הפנימית"],"a":0,"e":"עיקרון מפתח: לשתי ממברנות המיטוכונדריה תכונות חדירות הפוכות. הממברנה החיצונית עשירה בחלבון פורין (VDAC) — חלבון בטא-בָּרֶל היוצר תעלות רחבות שמאפשרות מעבר חופשי של מולקולות עד כ-5000 דלטון, ולכן הרכב המרחב הבין-ממברנלי דומה לציטוזול. הממברנה הפנימית, לעומת זאת, אטומה במיוחד ובררנית: היא חוסמת אפילו פרוטונים ויונים קטנים, ומעבר חומרים דרכה דורש נשאים ייעודיים. אטימות זו חיונית כדי לשמר את המפל האלקטרוכימי הדרוש לכימיוסמוזה. מסיח ב' הופך בין הממברנות. מסיח ג' שגוי: החדירות שונה לחלוטין. מסיח ד' שגוי: שאיבת הפרוטונים מבוצעת על-ידי קומפלקסי ה-ETC בממברנה הפנימית, לא על-ידי פורין. טיפ: חיצונית = 'מסננת רחבה' (פורין); פנימית = 'חומה אטומה' ששומרת על הסוללה."},
    {"topic":"איתות תאי","q":"קולטן מצומד-G (GPCR) מפעיל אדנילט-ציקלאז דרך חלבון Gs. בחולה עם רעלן הכולרה, תת-היחידה Gαs עוברת שינוי המונע את פעילות ה-GTPase שלה. מה התוצאה התאית הישירה?","o":["Gαs נשאר קשור ל-GDP ומעכב לצמיתות את אדנילט-ציקלאז, ורמת cAMP יורדת","Gαs נשאר פעיל (קשור GTP) ומפעיל לצמיתות את אדנילט-ציקלאז, ורמת cAMP עולה באופן בלתי מבוקר","הקולטן עצמו עובר אנדוציטוזה מיידית ופעילות האיתות פוסקת","פוספוליפאז C מופעל ורמת IP3 עולה ללא שינוי ב-cAMP"],"a":1,"e":"עיקרון מפתח: רעלן הכולרה משבית את 'מתג הכיבוי' של חלבון G מעורר. בדרך כלל Gαs מפעיל אדנילט-ציקלאז כשהוא קשור ל-GTP, ומכבה את עצמו על-ידי הידרוליזת ה-GTP ל-GDP (פעילות GTPase פנימית). הרעלן מבצע ADP-ריבוזילציה של Gαs ומשתק את פעילות ה-GTPase שלו, כך ש-Gαs נתקע במצב פעיל ומפעיל ברציפות את אדנילט-ציקלאז. רמת cAMP מרקיעה באופן בלתי מבוקר, מה שגורם בתאי המעי לזרימת יונים ומים החוצה (שלשול מימי חמור). מסיח א' הופך את התוצאה (cAMP עולה, לא יורד). מסיח ג' שגוי: אין אנדוציטוזה מיידית שמכבה. מסיח ד' שגוי: הציר הוא cAMP, לא PLC/IP3. טיפ לזכירה: כולרה 'תוקעת את הגז' של Gαs דולק; השוו לשעלת (pertussis) שמשתקת את Gαi המעכב."},
    {"topic":"איתות תאי","q":"בתא מסוים מופעל מסלול פוספוליפאז C-בטא (PLCβ) בעקבות הפעלת GPCR. אילו שני שליחים שניוניים נוצרים בעקבות הפיצול של PIP2, ומה תפקידם המיידי?","o":["cAMP ו-Ca2+; שניהם מפעילים ישירות את חלבון קינאז A","IP3 ו-DAG; IP3 משחרר Ca2+ ממאגרי הרשתית האנדופלזמית ו-DAG מפעיל יחד עם Ca2+ את חלבון קינאז C","cGMP ו-IP3; שניהם פותחים תעלות נתרן בממברנה","DAG ו-cAMP; DAG מפעיל את אדנילט-ציקלאז"],"a":1,"e":"עיקרון מפתח: הפעלת GPCR המצומד ל-Gq מובילה לפוספוליפאז C-בטא (PLCβ), שמפצל את הפוספוליפיד הממברנלי PIP2 לשני שליחים שניוניים. IP3 (אינוזיטול-1,4,5-טריספוספט) הוא מולקולה מסיסה שמתפזרת בציטוזול, נקשרת לתעלות-קולטן ברשתית האנדופלזמית ומשחררת ממנה Ca2+. DAG (דיאצילגליצרול) נשאר נעוץ בממברנה, ויחד עם ה-Ca2+ ששוחרר מפעיל את חלבון קינאז C (PKC). מסיח א' שגוי: cAMP נוצר ממסלול אחר (אדנילט-ציקלאז), לא מ-PIP2. מסיח ג' שגוי: cGMP אינו תוצר של PLC. מסיח ד' שגוי: DAG אינו מפעיל אדנילט-ציקלאז. טיפ לזכירה: 'PIP2 מתפצל ל-IP3 הנודד (משחרר סידן) ול-DAG הנשאר (מפעיל PKC)' — שניהם פועלים בשיתוף."},
    {"topic":"איתות תאי","q":"חוקר משווה את אופן ההעברה של אות דרך קולטן טירוזין קינאז (RTK) לעומת קולטן מצומד-G (GPCR). מהו ההבדל המבני-תפקודי המהותי באופן ההפעלה הראשוני של RTK?","o":["RTK מפעיל ישירות חלבון G הטרוטרימרי דרך החלפת GDP ב-GTP","קשירת הליגנד גורמת לדימריזציה של ה-RTK ולטרנס-אוטופוספורילציה הדדית של שיירי טירוזין בזנבות הציטוזוליים","RTK מפעיל ישירות אדנילט-ציקלאז ללא צורך בפוספורילציה","קשירת הליגנד ל-RTK פותחת תעלת יונים בממברנה ומאפשרת כניסת Ca2+"],"a":1,"e":"עיקרון מפתח: ההבדל היסודי בהפעלה הראשונית בין RTK ל-GPCR. בקולטן טירוזין קינאז (RTK), קשירת הליגנד מקרבת שני מונומרים ליצירת דימר, וכל יחידה מבצעת טרנס-אוטופוספורילציה — מזרחנת שיירי טירוזין על הזנב הציטוזולי של בת-זוגה. הטירוזינים המזורחנים הופכים לאתרי עגינה לחלבונים נושאי תחום SH2 (כמו Grb2), וכך מתחיל מפל האיתות. מסיח א' שגוי: זה תיאור GPCR (חלבון G הטרוטרימרי) — ב-RTK אין שלב כזה. מסיח ג' שגוי: RTK אינו מפעיל אדנילט-ציקלאז ישירות וכן דורש פוספורילציה. מסיח ד' שגוי: RTK אינו תעלת יונים. טיפ לזכירה: RTK = 'דימר + אוטו-פוספורילציה של טירוזינים'; GPCR = 'חלבון G + שליחים שניוניים'. שני עולמות נפרדים."},
    {"topic":"איתות תאי","q":"במסלול Ras/MAPK, מהו תפקידו של חלבון GEF (כגון Sos) לעומת חלבון GAP, ומדוע הם הפכיים בהשפעתם על Ras?","o":["GEF מזרז את החלפת GDP ב-GTP ובכך מפעיל את Ras, ואילו GAP מאיץ את הידרוליזת ה-GTP ובכך מכבה את Ras","GEF מאיץ את הידרוליזת ה-GTP ומכבה את Ras, ואילו GAP מחליף GDP ב-GTP ומפעיל אותו","שניהם מפעילים את Ras אך GEF פועל מהר יותר","GEF מפעיל את Ras על ידי פוספורילציה, ו-GAP מכבה אותו על ידי דה-פוספורילציה"],"a":0,"e":"עיקרון מפתח: Ras הוא GTPase קטן הפועל כמתג מולקולרי דו-מצבי — פעיל כשקשור ל-GTP, כבוי כשקשור ל-GDP. שני סוגי חלבונים מווסתים אותו בכיוונים הפוכים. GEF (Guanine nucleotide Exchange Factor, למשל Sos) מזרז את שחרור ה-GDP וקשירת GTP במקומו — ובכך מדליק את Ras. GAP (GTPase-Activating Protein) מאיץ את ההידרוליזה של GTP ל-GDP — ובכך מכבה את Ras. מסיח ב' הופך בין השניים. מסיח ג' שגוי: הם הפכיים, לא שניהם מפעילים. מסיח ד' שגוי: Ras אינו מווסת על-ידי פוספורילציה אלא על-ידי מצב הנוקלאוטיד. טיפ לזכירה: GEF = 'מדליק' (Exchange מכניס GTP טרי); GAP = 'מכבה' (מאיץ הידרוליזה). מוטציות אונקוגניות נפוצות ב-Ras פוגעות ב-GTPase ומשאירות אותו דלוק לצמיתות."},
    {"topic":"איתות תאי","q":"קולטן גרעיני לסטרואידים (למשל לקורטיזול) פועל באופן שונה מהותית מ-GPCR או RTK. מהי הסיבה לכך שהורמונים סטרואידים יכולים לפעול דרך קולטנים תוך-תאיים ולא דרך קולטני ממברנה?","o":["הם מולקולות טעונות גדולות שאינן יכולות לחצות את הממברנה ולכן זקוקות לקולטן ממברנלי","הם מולקולות קטנות והידרופוביות החוצות בקלות את הממברנה הפלסמטית ונקשרות לקולטן תוך-תאי המתפקד כגורם שעתוק","הם נקשרים תחילה לחלבון G ורק אז חודרים לגרעין","הם פועלים דרך שליחים שניוניים בלבד ולעולם אינם נכנסים לגרעין"],"a":1,"e":"עיקרון מפתח: ההבחנה בין הורמונים הידרופוביים (סטרואידים) לבין הידרופיליים נקבעת לפי יכולתם לחצות את הממברנה. הורמונים סטרואידים (וכן הורמוני בלוטת התריס, ויטמין D ורטינואידים) הם מולקולות קטנות והידרופוביות שחוצות בקלות את הדו-שכבה הליפידית בדיפוזיה. לכן אין להם צורך בקולטן ממברנלי — הם נקשרים לקולטן גרעיני תוך-תאי, וקומפלקס ההורמון-קולטן עצמו פועל כגורם שעתוק שמווסת ביטוי גנים. מסיח א' שגוי: סטרואידים אינם טעונים וכן חוצים את הממברנה. מסיח ג' שגוי: אינם פועלים דרך חלבון G. מסיח ד' שגוי: הם דווקא נכנסים לגרעין ושם פעולתם. טיפ: הידרופובי = קולטן פנימי + תגובה איטית (שינוי בתעתוק); הידרופילי = קולטן ממברנלי + תגובה מהירה."},
    {"topic":"איתות תאי","q":"במסלול PI3K/Akt, מהו התוצר הליפידי של אנזים PI3K המשמש כאתר עגינה בממברנה, וכיצד הוא מוביל להפעלת Akt (PKB)?","o":["PI3K מייצר IP3 המשחרר Ca2+, וה-Ca2+ מפעיל את Akt בציטוזול","PI3K מזרחן את PIP2 ל-PIP3 בממברנה, ו-PIP3 מגייס את Akt ואת PDK1 דרך תחום PH, מה שמאפשר את פוספורילציה והפעלת Akt","PI3K מפצל PIP2 ל-DAG ול-IP3 המפעילים יחד את Akt","PI3K מזרחן ישירות שיירי טירוזין על Akt בממברנה הפנימית של המיטוכונדריה"],"a":1,"e":"עיקרון מפתח: PI3K פועל על ליפידים, לא חולק אותם. הוא מזרחן את PIP2 בעמדה 3 של טבעת האינוזיטול ויוצר PIP3 בממברנה הפלסמטית. PIP3 משמש 'מצוף' עגינה לחלבונים נושאי תחום PH, ובהם Akt (PKB) והקינאז PDK1. גיוסם המשותף לאותו אזור ממברנלי מאפשר ל-PDK1 (ולקומפלקס mTORC2) לזרחן ולהפעיל את Akt, שמקדם הישרדות וגדילה. מסיח א' שגוי: PI3K אינו מייצר IP3. מסיח ג' שגוי: פיצול PIP2 ל-DAG ול-IP3 הוא תפקיד PLC — לא PI3K (זו הטעות הקריטית). מסיח ד' שגוי: PI3K מזרחן ליפיד, לא טירוזינים, ופועל בקרום הפלזמה. טיפ לזכירה: 'PI3K מזרחן (מוסיף פוספט ל-PIP2→PIP3); PLC מפצל (PIP2→IP3+DAG)' — שני אנזימים על אותו מצע אך פעולה הפוכה."},
    {"topic":"איתות תאי","q":"מהו המנגנון העיקרי שבו תאים מבצעים דה-סנסיטיזציה (desensitization) של GPCR בעקבות חשיפה ממושכת לליגנד?","o":["הגברת קצב הסינתזה של הקולטן והעלאת רגישותו","פוספורילציה של הקולטן על ידי קינאזות GRK, קשירת ארסטין (arrestin) שחוסמת את הקישור ל-G וכן מקדמת אנדוציטוזה של הקולטן","העלאת ריכוז ה-GTP בתא כדי לשמר את הקולטן פעיל","דה-פוספורילציה של חלבון G כדי להאיץ את האות"],"a":1,"e":"עיקרון מפתח: דה-סנסיטיזציה של GPCR מונעת תגובת-יתר בחשיפה ממושכת לליגנד, דרך מנגנון תלת-שלבי. ראשית, קינאזות ייעודיות (GRK) מזרחנות דווקא את הקולטן הפעיל (הקשור לליגנד). הזרחון יוצר אתר קישור לחלבון ארסטין (β-arrestin), שנקשר לקולטן וחוסם פיזית את האינטראקציה עם חלבון G — וכך מנתק את האות. בנוסף, ארסטין מקדם אנדוציטוזה של הקולטן (down-regulation, הורדה מפני השטח). מסיח א' שגוי: דה-סנסיטיזציה מורידה רגישות, לא מעלה. מסיח ג' שגוי: העלאת GTP אינה משמרת פעילות. מסיח ד' שגוי: דה-פוספורילציה של חלבון G אינו המנגנון. טיפ לזכירה: GRK 'מסמן' את הקולטן, ארסטין 'מכסה' אותו ומסיע אותו פנימה — 'תיוג, חסימה, הפנמה'."},
    {"topic":"איתות תאי","q":"בתא עם RTK פעיל, חלבון מתאם (adaptor) נושא תחומי SH2 ו-SH3 ממלא תפקיד מפתח בחיבור הקולטן ל-Ras. מהו רצף האירועים הנכון מהפעלת ה-RTK ועד הפעלת Ras?","o":["RTK מזורחן בטירוזין ← Grb2 (SH2) נקשר לטירוזין המזורחן ← Grb2 (SH3) מגייס את Sos ← Sos מפעיל את Ras על ידי החלפת GDP ב-GTP","RTK מפעיל חלבון G ← G מפעיל את Grb2 ← Grb2 הופך GTP ל-GDP על Ras","Ras מזרחן ישירות את ה-RTK ← RTK מגייס את Sos ← Sos מכבה את Ras","Sos נקשר ישירות לליגנד החיצוני ← Sos מפעיל את Grb2 ← Grb2 מפעיל את MAPK ללא מעורבות Ras"],"a":0,"e":"עיקרון מפתח: מפל ה-RTK ל-Ras עובר דרך חלבון מתאם (adaptor) רב-תחומי, Grb2. רצף האירועים: (1) קשירת ליגנד גורמת לדימריזציה ולאוטופוספורילציה של שיירי טירוזין ב-RTK; (2) תחום ה-SH2 של Grb2 נקשר לטירוזין המזורחן; (3) תחום ה-SH3 של Grb2 קושר את Sos (גורם GEF) ומגייס אותו לממברנה ליד Ras; (4) Sos מזרז החלפת GDP ב-GTP על Ras ומדליק אותו, מה שמתניע את מפל ה-MAPK (Raf→MEK→ERK). מסיח ב' שגוי: RTK אינו עובר דרך חלבון G, ו-Grb2 אינו GAP. מסיח ג' שגוי: Ras אינו מזרחן את ה-RTK. מסיח ד' שגוי: Sos אינו קושר ליגנד חיצוני ו-Ras חיוני. טיפ: SH2 'קורא' טירוזין-פוספט; SH3 'תופס' רצף עשיר-פרולין ב-Sos — שני התחומים מגשרים מהקולטן ל-Ras."},
    {"topic":"שלד התא","q":"חוקר עוקב אחר מיקרו-חוט אקטין בודד במצב 'יציבות' (steady state) שבו אורכו הכולל נשמר קבוע. הוא מבחין שמונומרים מצטרפים בקצה אחד ומשתחררים בקצב זהה מהקצה השני. כיצד נקרא תהליך זה ומה מאפשר אותו?","o":["טרדמילינג (treadmilling); הבדל ב-Cc (ריכוז קריטי) בין הקצה הפלוס לקצה המינוס הנובע מהידרוליזת ATP","חוסר יציבות דינמית (dynamic instability); מעבר פתאומי בין צמיחה לכיווץ עקב הידרוליזת GTP","טרדמילינג (treadmilling); ריכוז קריטי זהה בשני הקצוות והעדר הידרוליזת נוקלאוטיד","חוסר יציבות דינמית (dynamic instability); הבדל ב-Cc בין שני הקצוות הנובע מקשירת ATP"],"a":0,"e":"עיקרון מפתח: טרדמילינג (treadmilling, 'הליכון') הוא מצב יציב שבו הפילמנט שומר אורך קבוע למרות תחלופה מתמדת — מונומרים מצטרפים בקצה הפלוס ומשתחררים בקצב זהה בקצה המינוס. הוא מתאפשר כשהריכוז החופשי של מונומרים נמצא בין הריכוז הקריטי הנמוך (Cc) של הקצה הפלוס לבין ה-Cc הגבוה של קצה המינוס. הידרוליזת ה-ATP הקשור לאקטין היא שיוצרת את ההבדל ב-Cc בין הקצוות. מסיח ב' ו-ד' שגויים: 'חוסר יציבות דינמית' (מעברים פתאומיים בין צמיחה לכיווץ) אופייני למיקרו-צינוריות עם GTP, ומתבטא באורך משתנה — לא בזרימה יציבה. מסיח ג' שגוי: ללא הבדל ב-Cc וללא הידרוליזה אין טרדמילינג. טיפ לזכירה: טרדמילינג = 'הליכון' (אורך קבוע, חומר זורם); דינמית = 'יו-יו' (אורך קופץ)."},
    {"topic":"שלד התא","q":"מהו ההבדל המהותי בכיווניות התנועה בין משפחת הקינזינים הקונבנציונליים לבין הדינאין הציטופלזמטי לאורך מיקרו-צינורית?","o":["קינזין נע בדרך כלל לכיוון הקצה הפלוס ודינאין לכיוון הקצה המינוס","שניהם נעים לכיוון הקצה הפלוס, אך בקצבים שונים","קינזין נע לכיוון הקצה המינוס ודינאין לכיוון הקצה הפלוס","שניהם נעים לכיוון הקצה המינוס, אך קינזין מהיר יותר"],"a":0,"e":"עיקרון מפתח: שני המנועים הציטוסקלטליים העיקריים על מיקרו-צינוריות נעים בכיוונים מנוגדים. רוב הקינזינים הקונבנציונליים הם מנועים מכווני קצה-פלוס (plus-end directed) — הם מסיעים מטען מאזור הצנטרוזום אל הפריפריה (תעבורה אנטרוגרדית באקסון). הדינאין הציטופלזמטי הוא מנוע מכוון קצה-מינוס (minus-end directed) — הוא מסיע מטען מהפריפריה כלפי הצנטרוזום (תעבורה רטרוגרדית). מסיח ב' שגוי: הם נעים בכיוונים הפוכים. מסיח ג' הופך בין השניים. מסיח ד' שגוי: שניהם אינם נעים למינוס. טיפ לזכירה: 'קינזין הולך החוצה אל הפלוס; דינאין חוזר פנימה אל המינוס'. זכור שהקצה המינוס מעוגן בצנטרוזום, ולכן 'מינוס = מרכז'."},
    {"topic":"שלד התא","q":"בתסמונת קרטגנר (Kartagener) קיים פגם תורשתי בזרועות הדינאין הריסי (ciliary dynein). אילו תסמינים צפויים בעיקר כתוצאה ישירה מפגם זה?","o":["שיתוק ריסים ושוטונים: זיהומי דרכי נשימה חוזרים ואי-פוריות גברית","קושי בהתכווצות שריר השלד עקב פגיעה במיוזין","פגיעה בהובלה אקסונלית בנוירונים עקב חוסר קינזין","חוסר יכולת ליצור צנטרוזום פעיל בחלוקת התא"],"a":0,"e":"עיקרון מפתח: תסמונת קרטגנר (Kartagener) היא תת-סוג של דיסקינזיה ריסית ראשונית, הנובעת מפגם תורשתי בזרועות הדינאין הריסי (ciliary/axonemal dynein). הדינאין הריסי מניע את ההחלקה בין זוגות המיקרו-צינוריות באקסונמה (מבנה 9+2), ובכך מייצר את גל הכיפוף של הריס והשוטון. פגם בו משתק את התנועה: בריסי דרכי הנשימה מצטבר ריר ונגרמים זיהומים חוזרים (סינוסיטיס, ברונכיאקטזיות), ובשוטון הזרע נגרמת אי-פוריות גברית. מסיח ב' שגוי: מיוזין שייך לאקטין/שריר. מסיח ג' שגוי: קינזין ציטופלזמטי אינו הדינאין הריסי. מסיח ד' שגוי: הצנטרוזום אינו נפגע ישירות. טיפ לזכירה: בתסמונת קרטגנר מתלווה לרוב גם סיטוס אינברסוס (היפוך איברים), כי גם תנועת הריסים בעובר נפגעת."},
    {"topic":"שלד התא","q":"איזו מהטענות הבאות מבדילה נכון בין חוטי הביניים (intermediate filaments) לבין שני סוגי הסיבים האחרים בשלד התא?","o":["חוטי הביניים נטולי קוטביות מבנית, אינם קושרים נוקלאוטידים ואינם משמשים מסילה לחלבוני מנוע","חוטי הביניים בעלי קוטביות ברורה אך אינם קושרים נוקלאוטידים","חוטי הביניים קושרים GTP ועוברים חוסר יציבות דינמית כמו מיקרו-צינוריות","חוטי הביניים משמשים מסילה לקינזין אך לא לדינאין"],"a":0,"e":"עיקרון מפתח: חוטי הביניים (intermediate filaments) שונים מהותית משני סיבי השלד האחרים. תת-היחידות שלהם הן חלבונים מוארכים (דמויי-מוט) שנארזים בצורה אנטי-מקבילה (זנב-לזנב), ולכן הפילמנט חסר קוטביות — אין לו קצה-פלוס וקצה-מינוס. בנוסף, הם אינם קושרים נוקלאוטידים (לא ATP ולא GTP) ואינם משמשים כמסילה לחלבוני מנוע. תפקידם בעיקר מכני: מתן עמידות למתח ולכוחות מכניים (כמו קרטין בעור או למינים בגרעין). מסיח ב' שגוי: הם חסרי קוטביות. מסיח ג' שגוי: רק מיקרו-צינוריות קושרות GTP ועוברות חוסר יציבות דינמית. מסיח ד' שגוי: הם אינם מסילה לקינזין. טיפ לזכירה: אקטין=ATP, מיקרו-צינוריות=GTP, חוטי ביניים='שום נוקלאוטיד' — ולכן יציבים, סטטיים ומכניים."},
    {"topic":"מחזור התא","q":"מהו ההרכב המולקולרי של MPF (Maturation/M-phase Promoting Factor) ומה מפעיל אותו במעבר G2/M?","o":["M-ציקלין (cyclin B) הקשור ל-Cdk1, המופעל על ידי הסרת זרחות מעכבות בידי הפוספטאז Cdc25 וזרחה מפעילה בידי CAK","G1/S-ציקלין הקשור ל-Cdk2, המופעל על ידי APC/C","M-ציקלין הקשור ל-Cdk1, המופעל על ידי פירוקו בידי APC/C","S-ציקלין הקשור ל-Cdk4, המופעל על ידי p53"],"a":0,"e":"עיקרון מפתח: MPF (M-phase Promoting Factor) הוא ה'מנוע' שדוחף את התא ממופע G2 לתוך המיטוזה. הרכבו: M-ציקלין (cyclin B) הקשור ל-Cdk1 (קינאז תלוי-ציקלין). הקשירה לבדה אינה מספיקה — להפעלה צריך גם להסיר זרחות מעכבות (על שיירי Thr14/Tyr15) בידי הפוספטאז Cdc25, יחד עם זרחה מפעילה. מסיח ב' שגוי: G1/S-ציקלין ו-Cdk2 שייכים למעבר אחר, ו-APC/C אינו מפעיל את MPF. מסיח ג' שגוי: APC/C דווקא מפרק את M-ציקלין כדי לצאת מהמיטוזה — לא מפעיל. מסיח ד' שגוי: Cdk4 ו-p53 שייכים לבקרת G1. טיפ לזכירה: Cdc25 'מדליק' את MPF (מסיר בלמים); APC/C 'מכבה' אותו (מפרק את הציקלין). שים לב שיש לולאת היזון חיובי — MPF מפעיל את Cdc25 שמפעיל עוד MPF."},
    {"topic":"מחזור התא","q":"APC/C (Anaphase-Promoting Complex) מפעיל את המעבר ממטאפאזה לאנאפאזה. מהו המנגנון הישיר שבו הוא גורם להפרדת הכרומטידות?","o":["מסמן את securin לפירוק, וכך משחרר את separase שמבקע את הקוהזין המחבר בין הכרומטידות","מזרחן ישירות את הקוהזין וגורם לפירוקו","מפרק את ה-M-ציקלין וכך משחרר את separase","מסמן את separase לפירוק ובכך מאפשר ל-securin לפעול"],"a":0,"e":"עיקרון מפתח: APC/C (Anaphase-Promoting Complex) הוא ליגאז יוביקוויטין המניע את המעבר ממטאפאזה לאנאפאזה דרך שרשרת פירוק-מבוקרת. המנגנון הישיר: APC/C מסמן ביוביקוויטין את החלבון securin לפירוק בפרוטאזום. securin הוא מעכב טבעי של האנזים separase. עם פירוק securin, separase משתחרר, מבקע את תת-היחידה Scc1 של קומפלקס הקוהזין (cohesin) שמחבר בין הכרומטידות האחיות — וכך הן נפרדות לקטבים. מסיח ב' שגוי: APC/C אינו מזרחן את הקוהזין. מסיח ג' שגוי: אמנם APC/C מפרק גם M-ציקלין, אך זה לא המנגנון הישיר להפרדה. מסיח ד' הופך את הסדר. טיפ לזכירה: שרשרת השחרור 'APC/C ← מפרק securin ← משחרר separase ← חותך cohesin ← כרומטידות נפרדות'."},
    {"topic":"מחזור התא","q":"נקודת הביקורת של הכישור (spindle assembly checkpoint, SAC) מעכבת את המעבר לאנאפאזה עד שכל הקינטוכורים מחוברים כראוי. מהי המטרה הישירה של אות 'המתן' הזה?","o":["עיכוב הפעלת APC/C-Cdc20 כל עוד קיים קינטוכור לא מחובר","עיכוב הפעלת Cdc25 כדי למנוע כניסה למיטוזה","הפעלת p53 כדי לעצור את המעבר G1/S","עיכוב יצירת קומפלקס ציקלין-Cdk במעבר G2/M"],"a":0,"e":"עיקרון מפתח: נקודת ביקורת הכישור (Spindle Assembly Checkpoint, SAC) מוודאת שכל הכרומוזומים מחוברים נכון לכישור לפני שמתחילה האנאפאזה — וכך מונעת חלוקה כרומוזומלית שגויה. המטרה הישירה של אות ה'המתן': עיכוב הפעלת APC/C-Cdc20. כל קינטוכור שאינו מחובר כראוי לכישור משדר אות שמעכב את Cdc20; כל עוד APC/C-Cdc20 כבוי, securin אינו מתפרק, ולכן ההפרדה לאנאפאזה אינה מתחילה. מסיח ב' שגוי: Cdc25 פועל במעבר G2/M, לא כאן. מסיח ג' שגוי: p53 פועל ב-G1/S בתגובה לנזק DNA. מסיח ד' שגוי: SAC אינו מעכב את יצירת קומפלקס ציקלין-Cdk. טיפ לזכירה: SAC = 'בלם' שמחזיק את APC/C-Cdc20 כבוי עד שכל קינטוכור 'נתפס' — מספיק קינטוכור בודד לא מחובר כדי לעצור את כל החלוקה."},
    {"topic":"מחזור התא","q":"מהו ההבדל התפקודי המרכזי בין צנטרומר (centromere) לבין קינטוכור (kinetochore)?","o":["הצנטרומר הוא רצף DNA וכרומטין מיוחד בכרומוזום, והקינטוכור הוא מבנה החלבונים הנבנה עליו ומשמש כעיגון לחוטי הכישור","הצנטרומר הוא מבנה החלבונים הקושר את חוטי הכישור, והקינטוכור הוא רצף ה-DNA","הצנטרומר והקינטוכור הם שני שמות לאותו אברון המכיל זוג צנטריולים","הצנטרומר ממוקם בקטבי התא והקינטוכור במישור המשווה"],"a":0,"e":"עיקרון מפתח: יש להבחין בין שלושה מבנים שמתבלבלים בקלות. הצנטרומר (centromere) הוא אזור DNA/כרומטין ייחודי בכרומוזום, מסומן בווריאנט ההיסטון CENP-A. הקינטוכור (kinetochore) הוא קומפלקס חלבונים גדול שנבנה על הצנטרומר ומהווה את אתר העיגון של מיקרו-צינוריות הכישור. הצנטרוזום (centrosome), שמכיל זוג צנטריולים, הוא מרכז ארגון המיקרו-צינוריות בקטבי התא — מבנה נפרד לחלוטין. מסיח ב' הופך בין צנטרומר לקינטוכור. מסיח ג' שגוי: זה ערבוב עם הצנטרוזום, ושני המונחים אינם זהים. מסיח ד' שגוי במיקום. טיפ לזכירה: צנטרומֵר = DNA (אזור בכרומוזום); קינטוכור = החלבונים שנבנים עליו ותופסים את החוטים; צנטרוזום = הקוטב עם הצנטריולים."},
    {"topic":"מוות תאי","q":"מהי ההבחנה המדויקת בין קספאזות מתחילות (initiator) לקספאזות מבצעות (executioner) באפופטוזיס?","o":["קספאזות מתחילות (כגון 8 ו-9) מופעלות על ידי דימריזציה בקומפלקסי הפעלה ומבקעות ומפעילות את הקספאזות המבצעות (כגון 3 ו-7)","קספאזות מבצעות מפעילות את המתחילות באמצעות בקיעה הדדית","קספאזות מתחילות מבקעות ישירות את מצעי התא, והמבצעות רק מגבירות את האות","שני הסוגים מופעלים אך ורק על ידי שחרור ציטוכרום c מהמיטוכונדריה"],"a":0,"e":"עיקרון מפתח: קספאזות הן פרוטאזות המבצעות את האפופטוזיס במדורג, ומחולקות לשתי שכבות. קספאזות מתחילות (initiator, כמו 8 ו-9) מצויות כמונומרים לא-פעילים; הן מופעלות על-ידי דימריזציה כשהן מתקרבות בקומפלקס הפעלה ייעודי (DISC לקספאז-8 במסלול החיצוני, אפופטוזום לקספאז-9 במסלול הפנימי). לאחר מכן הן מבקעות ומפעילות את הקספאזות המבצעות (executioner, 3 ו-7), שמבקעות מאות מצעים בתא וגורמות לפירוקו. מסיח ב' הופך את הסדר (המתחילות מפעילות את המבצעות, לא להפך). מסיח ג' שגוי: המבצעות הן שמבקעות את המצעים. מסיח ד' שגוי: רק קספאז-9 תלוי בציטוכרום c; קספאז-8 מופעל ללא תלות בו. טיפ: 'מתחילה = הצתה (דימריזציה); מבצעת = ביצוע (בקיעת מצעים)' — מפל מגביר חד-כיווני."},
    {"topic":"מוות תאי","q":"באיזה מנגנון בדיוק מעורבים החלבונים Bax/Bak וחלבוני Bcl-2 במסלול האפופטוזיס הפנימי (מיטוכונדריאלי)?","o":["Bax/Bak יוצרים נקבוביות בקרום החיצוני של המיטוכונדריה ומשחררים ציטוכרום c, בעוד Bcl-2 (אנטי-אפופטוטי) מעכב אותם","Bax/Bak מעכבים שחרור ציטוכרום c, ו-Bcl-2 מקדם את שחרורו","Bax/Bak מפעילים ישירות את הקולטן Fas בקרום התא","Bcl-2 יוצר את הנקבוביות, ו-Bax/Bak מעכבים אותו"],"a":0,"e":"עיקרון מפתח: במסלול האפופטוזיס הפנימי (מיטוכונדריאלי), משפחת Bcl-2 מאזנת בין חברים פרו- לאנטי-אפופטוטיים. החברים הפרו-אפופטוטיים Bax ו-Bak מתאגדים בקרום החיצוני של המיטוכונדריה ויוצרים בו נקבוביות (MOMP — Mitochondrial Outer Membrane Permeabilization), שדרכן משתחרר ציטוכרום c לציטוזול. ציטוכרום c מרכיב את האפופטוזום ומפעיל את קספאז-9. החברים האנטי-אפופטוטיים Bcl-2 ו-Bcl-XL מעכבים את Bax/Bak ובכך בולמים את התהליך. מסיח ב' הופך את התפקידים. מסיח ג' שגוי: Bax/Bak שייכים למסלול הפנימי, לא מפעילים את Fas (שהוא מסלול חיצוני). מסיח ד' הופך לחלוטין — Bcl-2 מעכב, לא יוצר נקבים. טיפ לזכירה: Bax/Bak = 'מנקבים' (חיובי לאפופטוזיס); Bcl-2 = 'שומר' (מונע). היחס ביניהם קובע חיים או מוות."},
    {"topic":"מוות תאי","q":"תא חשוף לליגנד מוות (כגון Fas ligand) ומפעיל את המסלול החיצוני, אך ההפעלה הישירה של הקספאזות המבצעות אינה מספקת. מדוע בתאים מסוימים ('type II') האפופטוזיס עדיין תלוי במיטוכונדריה למרות הפעלה חיצונית?","o":["קספאז-8 מבקע את Bid ל-tBid, שמפעיל את Bax/Bak ומגביר את האות דרך המסלול הפנימי","הקולטן Fas מפעיל ישירות את קספאז-3 ללא צורך בקספאז-8","המסלול החיצוני מפעיל את APC/C שמוביל לשחרור ציטוכרום c","קספאז-9 מבקע את Fas ומפעיל את המסלול החיצוני"],"a":0,"e":"עיקרון מפתח: בתאי 'type II' המסלול החיצוני אינו מספיק לבדו, ונדרש 'מגבר' מיטוכונדריאלי — וזהו ה-crosstalk בין שני מסלולי האפופטוזיס. כשליגנד מוות (כמו Fas ligand) מפעיל את קספאז-8, כמות הקספאז-8 הפעיל קטנה מכדי להפעיל ישירות את הקספאזות המבצעות. במקום זאת, קספאז-8 מבקע את החלבון Bid לצורתו הפעילה tBid (truncated Bid). tBid עובר למיטוכונדריה ומפעיל את Bax/Bak, מגייס את המסלול הפנימי (שחרור ציטוכרום c) ומגביר את האות. מסיח ב' שגוי: Fas אינו מפעיל קספאז-3 ישירות בתאי type II. מסיח ג' שגוי: APC/C שייך למחזור התא, לא לאפופטוזיס. מסיח ד' הופך את הכיוון. טיפ לזכירה: tBid = 'הגשר' שמחבר חיצוני ← פנימי; type II תלוי במיטוכונדריה למרות שההצתה חיצונית."},
    {"topic":"צמתים תאיים ומטריקס","q":"בתאי אפיתל קיימים צמתים שונים. אילו צמתים אחראים בעיקר ליצירת מחסום שמונע מעבר מולקולות בין התאים (דליפה פראצלולרית) וגם שומרים על קוטביות התא?","o":["צמתים הדוקים (tight junctions)","דסמוזומים (desmosomes)","צמתי פער (gap junctions)","צמתי עיגון מסוג adherens"],"a":0,"e":"עיקרון מפתח: בין תאי אפיתל יש מגוון צמתים, וכל סוג ממלא תפקיד אחר. צמתים הדוקים (tight junctions) הם החוטמים את הרווח בין תאים סמוכים: רצועות של חלבוני קלאודין ואוקלודין יוצרות 'אטם' שחוסם מעבר פראצלולרי (בין-תאי) של מומסים, ובמקביל משמש 'גדר' שמפרידה בין הקרום האפיקלי לבזולטרלי ושומרת על קוטביות התא. מסיח ב' (דסמוזומים) ומסיח ד' (adherens) הם צמתי עיגון מכניים — מחברים תאים ומקנים חוזק, אך אינם אוטמים. מסיח ג' (צמתי פער) דווקא פותחים תקשורת — הם מאפשרים מעבר ישיר של מולקולות קטנות בין הציטופלזמות, ההפך מחסימה. טיפ לזכירה: tight = 'אוטם וגדר' (מחסום + קוטביות); gap = 'חלון פתוח' לתקשורת; דסמוזום/אדהרנס = 'דבק מכני'."},
    {"topic":"צמתים תאיים ומטריקס","q":"מהו ההבדל המבני-תפקודי המרכזי בין האינטגרינים (integrins) לבין הקדהרינים (cadherins) בהקשר של היצמדות תאית?","o":["אינטגרינים מתווכים בעיקר היצמדות תא-מטריקס (כגון לקולגן ולמינין) ופועלים כהטרודימרים תלויי קטיונים, ואילו קדהרינים מתווכים היצמדות תא-תא תלוית סידן","אינטגרינים מתווכים היצמדות תא-תא, וקדהרינים מתווכים היצמדות תא-מטריקס","שניהם מתווכים אך ורק היצמדות תא-תא, אך אינטגרינים תלויי סידן","אינטגרינים יוצרים את חוטי הקולגן עצמם, וקדהרינים יוצרים את הלמינה הבזלית"],"a":0,"e":"עיקרון מפתח: שני המשפחות העיקריות של קולטני היצמדות נבדלות במה שהן קושרות. אינטגרינים (integrins) הם קולטנים טרנס-ממברנליים הבנויים כהטרודימרים (תת-יחידת אלפא + בטא), שתפקידם בעיקר היצמדות תא-מטריקס — הם קושרים רכיבי מטריקס חוץ-תאי (קולגן, פיברונקטין, למינין) ומקשרים אותם פנימה לשלד האקטין; פעילותם תלויה בקטיונים דו-ערכיים. קדהרינים (cadherins) מתווכים היצמדות תא-תא הומופילית (קדהרין נקשר לקדהרין זהה בתא השכן), והיא תלויה ביוני סידן (Ca2+). מסיח ב' הופך בין השניים. מסיח ג' שגוי: רק קדהרינים תלויי-סידן ומתווכים תא-תא. מסיח ד' שגוי: אף אחד מהם אינו 'יוצר' קולגן או למינה. טיפ לזכירה: 'אינטגרין מחבר אל המטריקס (חוץ); קדהרין מחבר אל השכן (תא-תא), ושניהם אוהבים סידן/קטיון'."},
    {"topic":"מבנה הקרום - תפקיד הכולסטרול","q":"מה הכי נכון לגבי כולסטרול?","o":["מורכב רק מפחמנים ומימן","מוריד את חדירות הממברנה","לא עובר בקלות בין עלעלי הממברנה","יוצר קריסטליזציה בממברנה"],"a":1,"e":"כולסטרול ממלא את החללים בין זנבות הפוספוליפידים, מקשיח את האזור הסמוך לראשים ומוריד את חדירות הממברנה למולקולות קטנות מסיסות-מים. ניתוח מסיחים: (א) שגוי — לכולסטרול קבוצת הידרוקסיל (חמצן); (ג) דווקא מונע קריסטליזציה ושומר על נזילות בטמפ' נמוכה; (ד) הפוך — מונע גיבוש."},
    {"topic":"תעבורה ממברנלית - אנדוציטוזה ומיון","q":"מה יקרה אם דינמין (Dynamin) אינו פעיל באנדוציטוזה?","o":["לא תהיה הסרה של הציפוי","לא תהיה אקסוציטוזה בכלל","coated pits בלי איחוי","coated pits לא יתנתקו"],"a":3,"e":"דינמין מרכיב 'צווארון' GTPase סביב צוואר הבועית המצופה ומבצע את הביקוע (scission) — בלעדיו ה-coated pits אינם מתנתקים מהממברנה. ניתוח מסיחים: (א) הסרת הציפוי (uncoating) היא שלב נפרד, מאוחר יותר; (ב) דינמין אינו נדרש לאקסוציטוזה; (ג) הבעיה היא בהתנתקות, לא באיחוי."},
    {"topic":"מוות תאי","q":"מי אחראי על חדירות הממברנה החיצונית של המיטוכונדריה באפופטוזיס?","o":["חלבוני משפחת BCL-2 (Bax/Bak)","Apaf-1","קספאזות","קולטני המוות"],"a":0,"e":"חלבוני משפחת BCL-2 הפרו-אפופטוטיים (Bax/Bak) מחוררים את הממברנה החיצונית של המיטוכונדריה (MOMP) ומשחררים ציטוכרום c. ניתוח מסיחים: (ב) Apaf-1 מרכיב את האפופטוזום אחרי שחרור ציטוכרום c; (ג) קספאזות הן האפקטורים הפרוטאוליטיים במורד הזרם; (ד) קולטני המוות מתניעים את המסלול החיצוני, לא את חדירות המיטוכונדריה."},
    {"topic":"צמתים תאיים ומטריקס","q":"אילו תאים אחראים על יצירה והפרשה של מרכיבי המטריקס החוץ-תאי ברקמת החיבור?","o":["תאי אנדותל","תאי אפיתל","לימפוציטים","פיברובלסטים"],"a":3,"e":"פיברובלסטים הם תאי רקמת החיבור המייצרים ומפרישים את מרכיבי ה-ECM — קולגן, אלסטין, פיברונקטין ו-GAGs. ניתוח מסיחים: (א) אנדותל מרפד כלי דם; (ב) אפיתל יושב על למינה בזלית אך אינו יצרן ה-ECM של רקמת החיבור; (ג) לימפוציטים הם תאי מערכת חיסון."},
    {"topic":"מיון חלבונים - UPR","q":"הפעלת איזה חיישן UPR מתרחשת באמצעות פרוטאוליזה תוך-ממברנלית מבוקרת?","o":["IRE1","ATF6","PERK","XBP1"],"a":1,"e":"ATF6 נודד לגולגי שם פרוטאזות S1P/S2P חותכות אותו (Regulated Intramembrane Proteolysis); הקטע הציטוזולי המשוחרר נכנס לגרעין כפקטור שעתוק. ניתוח מסיחים: (א) IRE1 פועל כ-RNase (שחבור XBP1) ולא בפרוטאוליזה; (ג) PERK מזרחן את eIF2α; (ד) XBP1 הוא התוצר של שחבור IRE1, לא חיישן שעובר פרוטאוליזה."},
    {"topic":"שלד התא","q":"איזה חלבון שייך לסיבי הביניים בגרעין?","o":["לאמין","קרטין","וימנטין","נוירופילמנטים"],"a":0,"e":"לאמינים הם סיבי הביניים הגרעיניים — הם מרכיבים את הרשת התומכת מתחת לממברנה הגרעינית הפנימית (lamina). ניתוח מסיחים: (ב) קרטין באפיתל; (ג) וימנטין בתאי מזנכימה; (ד) נוירופילמנטים בנוירונים — כולם ציטופלזמיים."},
    {"topic":"מיון חלבונים - יבוא למיטוכונדריה","q":"מי מהגנים הבאים אינו מקודד ב-DNA מיטוכונדריאלי?","o":["tRNA","mRNA","rRNA","DNA polymerase"],"a":3,"e":"ה-mtDNA מקודד 13 חלבונים (mRNA), 22 tRNA ו-2 rRNA בלבד; ה-DNA פולימראז המיטוכונדריאלי (POLG) מקודד בגרעין ומיובא. ניתוח מסיחים: (א),(ב),(ג) כולם מקודדים ב-mtDNA; (ד) DNA פולימראז אינו."},
    {"topic":"מיון חלבונים - יבוא למיטוכונדריה","q":"למי יש DNA מיטוכונדריאלי שונה מהאחרים?","o":["לבת","לאם","לאב","לסבתא מצד האם"],"a":2,"e":"mtDNA עובר בתורשה אימהית בלבד. הבת, האם והסבתא מצד האם חולקים את אותו mtDNA (שושלת אימהית), בעוד לאב mtDNA שונה — שאינו מועבר לצאצאים. ניתוח מסיחים: (א),(ב),(ד) כולם באותה שושלת אימהית; (ג) האב חריג."},
    {"topic":"שלד התא","q":"איזה מבנה משמש כמרכז ארגון מיקרוטובולים (MTOC) בתא?","o":["צנטרוזום","סיליה","גמא-TuRC","קורטקס התא"],"a":0,"e":"הצנטרוזום (זוג צנטריולים + חומר פריצנטריולרי) הוא ה-MTOC הראשי בתא בעלי החיים, שממנו נוקלאים ומאורגנים המיקרוטובולים. ניתוח מסיחים: (ב) הסיליה צומחת מגוף בזלי; (ג) γ-TuRC הוא המתחם המנקלא בתוך הצנטרוזום — רכיב, לא ה'מבנה' המארגן; (ד) הקורטקס אינו MTOC."},
    {"topic":"מחזור התא","q":"מה גורם לאקטיבציה של Ran המשפיעה על הפעלת מיקרוטובולים במיטוזה?","o":["GTP","זרחון","דה-פוספורילציה","יוביקווינציה/הידרוליזה"],"a":0,"e":"Ran פעיל במצב הקשור-GTP (Ran-GTP), שריכוזו גבוה סביב הכרומוזומים (בזכות RCC1) ומשחרר גורמי הרכבת ציר ממעכביהם. ניתוח מסיחים: (ב),(ג) Ran אינו מווסת ע'י זרחון/דה-פוספורילציה; (ד) הידרוליזת ה-GTP דווקא מכבה את Ran."},
    {"topic":"צמתים תאיים ומטריקס","q":"אילו מולקולות יכולות לעבור ב-gap junction בין שני תאים סמוכים?","o":["חלבונים ו-RNA","יונים וחומצות אמינו","נוקלאוטידים ו-DNA","חד-סוכרים ורב-סוכרים"],"a":1,"e":"ערוצי gap junction (קונקסונים) מאפשרים מעבר מולקולות קטנות עד ~1 kDa — יונים, מטבוליטים קטנים, חומצות אמינו ושליחים משניים. ניתוח מסיחים: (א),(ג) חלבונים, RNA ו-DNA גדולים מדי; (ד) רב-סוכרים גדולים מדי לערוץ."},
    {"topic":"מבנה הקרום - תפקיד הכולסטרול","q":"מה לא נכון על ויטמין D?","o":["מיוצר מכולסטרול","חשיפה לאור יום מגבירה ייצורו","מעודד קליטת סידן באפיתל המעי","מעודד הפרשת סידן מהכליה"],"a":3,"e":"ויטמין D (דרך הצורה הפעילה קלציטריול) מעלה את ספיגת/ספיגה-חוזרת הסידן — הוא מעודד ספיגה חוזרת בכליה ולא הפרשתו. ניתוח מסיחים: (א) נכון — נגזר מ-7-דהידרוכולסטרול; (ב) נכון — UVB בעור; (ג) נכון — מגביר ספיגת סידן במעי; (ד) שגוי — ולכן זו התשובה הנכונה (מה ש'לא נכון')."},
    {"topic":"מחזור התא","q":"מתי MCM Helicase עובר אקטיבציה?","o":["S","G1","G2","טלופאזה"],"a":0,"e":"קומפלקס ה-MCM נטען על האוריג'ינים ב-G1 (רישוי), אך מופעל ('יורה') רק במעבר לשלב S — אז נפתח המזלג ומתחיל השכפול. ניתוח מסיחים: (ב) ב-G1 רק נטען, לא מופעל; (ג),(ד) השכפול כבר הסתיים."},
    {"topic":"שלד התא","q":"איזה מהחומרים מייצב את האקטין ומעודד את הפולימריזציה שלו?","o":["Phalloidin","ניקודאזול","Colchicine","Cytochalasin B"],"a":0,"e":"פאלואידין (מפטריית הכובע המוות) נקשר ל-F-אקטין, מייצב אותו ומונע דה-פולימריזציה. ניתוח מסיחים: (ב) ניקודאזול ו-(ג) קולכיצין פוגעים במיקרוטובולים, לא באקטין; (ד) ציטוכלסין B דווקא מפרק אקטין (חוסם את הקצה הגדל)."},
    {"topic":"איתות תאי","q":"איך משפיע IκB על ויסות ה-NFκB?","o":["מונע את כניסת NFκB לגרעין","מזרחן את NFκB","עושה דה-פוספורילציה ל-NFκB","עושה יוביקווינציה ל-NFκB ושולח לדגרדציה"],"a":0,"e":"IκB נקשר ל-NFκB בציטופלזמה ומסתיר את אות הכניסה הגרעיני שלו, ובכך כולא אותו מחוץ לגרעין. עם הפעלה, IκB מזורחן ומפורק — וה-NFκB משתחרר ונכנס לגרעין. ניתוח מסיחים: (ב),(ג) IκB אינו קינאז/פוספטאז; (ד) דווקא IκB עצמו עובר יוביקווינציה ופירוק, לא NFκB."},
    {"topic":"תעבורה ממברנלית - אנדוציטוזה ומיון","q":"איך ארסטין משפיע על מסלול האותות של GPCR?","o":["חסימת תנועה אופקית של חלבוני G","שיפור קישור חלבון G לקולטן","עיכוב פעילות חלבוני GRK","מעודד אנדוציטוזה ל-GPCR"],"a":3,"e":"לאחר שה-GRK מזרחן את הקולטן, β-ארסטין נקשר, מנתק את הצימוד לחלבון G (דה-סנסיטיזציה) ומגייס קלתרין לאנדוציטוזה של ה-GPCR. ניתוח מסיחים: (א) אינו חוסם תנועה אופקית; (ב) הפוך — מנתק קישור לחלבון G; (ג) ארסטין פועל אחרי ה-GRK, לא מעכב אותו."},
    {"topic":"מחזור התא","q":"מה יגרום MDM2 בבקרת מחזור התא?","o":["עיכוב עצירת מחזור התא ע'י יוביקווינציה של p53","מניעת מחזור התא ע'י פירוק p53","עיכוב p21","זרחון p21"],"a":0,"e":"MDM2 הוא יוביקווין-ליגאז שמסמן את p53 לפירוק בפרוטאזום; הורדת p53 מסירה את עצירת מחזור התא ומאפשרת התקדמות. ניתוח מסיחים: (ב) פירוק p53 דווקא מבטל עצירה (לא 'מונע מחזור'); (ג),(ד) ההשפעה על p21 עקיפה — דרך הורדת p53 (המשרן של p21), לא ישירה."},
    {"topic":"מבנה הקרום - חלבוני ממברנה","q":"לאן נקשר ספקטרין בתיווך מספר חלבונים בתא דם אדום?","o":["בצד הציטוזולי של ממברנת הפלסמה","בצד הלומינלי של הגולגי","בצד הציטוזולי של הגולגי","בצד החיצוני של ממברנת הפלסמה"],"a":0,"e":"ספקטרין יוצר רשת שלד-תאי בצד הציטוזולי (הפנימי) של קרום הפלסמה בכדורית האדומה, מעוגן דרך אנקירין ו-band 3/protein 4.1 — מה שמקנה לתא את גמישותו וצורתו. ניתוח מסיחים: (ב),(ג) אינו קשור לגולגי; (ד) הרשת פנימית (ציטוזולית), לא חיצונית."},
    {"topic":"מחזור התא","q":"באיזה שלב במחזור התא אין גרעין (או גרעינון)?","o":["G1","S","מטאפאזה (M)","כל השלבים חוץ מחלוקה"],"a":2,"e":"במהלך המיטוזה (כולל מטאפאזה) המעטפת הגרעינית מתפרקת והגרעינון מתפזר — ולכן אין גרעין מאורגן. ניתוח מסיחים: (א),(ב) ב-G1 ו-S הגרעין שלם; (ד) הפוך — דווקא רק בחלוקה (M) הגרעין נעלם."},
    {"topic":"מיקרוסקופיה פלואורסצנטית - מגבלות","q":"באיזה מיקרוסקופ נשתמש לרזולוציה גבוהה בתלת-ממד של טפיל מלריה הנפלט מתא דם אדום?","o":["מיקרוסקופ אור","מיקרוסקופ פלואורסצנטי","TEM (חודר)","SEM (סורק)"],"a":3,"e":"SEM (מיקרוסקופ אלקטרונים סורק) נותן תמונת פני-שטח תלת-ממדית ברזולוציה גבוהה — אידיאלי לאירוע משטחי כמו טפיל היוצא מהתא. ניתוח מסיחים: (א),(ב) רזולוציה מוגבלת בעקיפה; (ג) TEM נותן חתכים דקים דו-ממדיים של פנים התא."},
    {"topic":"שלד התא","q":"מה מאפיין intermediate filaments (סיבי ביניים)?","o":["תורמים לתנועה תאית","תורמים לפגוציטוזה","בתאים שונים מונומרים שונים","פגיעה במונומר → תסמונת קרטגנר"],"a":2,"e":"סיבי הביניים הם משפחה רקמה-ספציפית — מונומרים שונים בתאים שונים (קרטין באפיתל, וימנטין במזנכימה, נוירופילמנטים בנוירונים, למינים בגרעין). ניתוח מסיחים: (א),(ב) תנועה ופגוציטוזה תלויות אקטין/מיקרוטובולים; (ד) תסמונת קרטגנר נובעת מפגם בדינאין הריסי, לא בסיבי ביניים."},
    {"topic":"איתות תאי","q":"מה נכון לגבי קומפלקס mTOR?","o":["mTORC2 רגיש לרפמיצין","mTORC2 מכיל Rictor","mTORC1 מדכא ייצור ריבוזומים","mTORC1 מעוכב ע'י Rheb-GTP"],"a":1,"e":"mTORC2 מוגדר ע'י תת-היחידה Rictor (ו-mTORC1 ע'י Raptor). ניתוח מסיחים: (א) דווקא mTORC1 רגיש לרפמיצין; (ג) mTORC1 מקדם (לא מדכא) ביוגנזת ריבוזומים וסינתזת חלבון; (ד) Rheb-GTP מפעיל (לא מעכב) את mTORC1."},
    {"topic":"צמתים תאיים ומטריקס","q":"מה מאפיין תאי אפיתל?","o":["ניידים ברקמה","צמודים ויוצרים שכבה צפופה","מרווחים ולא מחוברים ב-ECM","מעט gap junction"],"a":1,"e":"תאי אפיתל צמודים זה לזה בצמתים הדוקים, חוצצים ואדהרנטיים ויוצרים שכבה רציפה וצפופה היושבת על למינה בזלית. ניתוח מסיחים: (א),(ג) מאפיינים תאי רקמת חיבור/מזנכימה; (ד) שגוי — לאפיתל יש gap junctions רבים לתקשורת."},
    {"topic":"צמתים תאיים ומטריקס","q":"איזו תכונה מאפיינת גליקוזאמינוגליקנים (GAGs)?","o":["הידרופיליים ולכן סופחים מים","פוליסכרידים מסועפים מאוד","טעונים חיובית","מבנים גלובולריים"],"a":0,"e":"GAGs טעונים שלילית בצפיפות (קרבוקסיל וסולפט), מאוד הידרופיליים וסופחים מים — יוצרים ג'ל עמיד-לחץ ב-ECM. ניתוח מסיחים: (ב) GAGs הם פוליסכרידים לא-מסועפים; (ג) טעונים שלילית, לא חיובית; (ד) מבנה מוארך, לא גלובולרי."},
    {"topic":"מחזור התא","q":"בהקשר סרטן in vitro — מהי המשמעות של contact inhibition?","o":["שני תאים נורמליים נוגעים זה בזה ומפסיקים להתחלק","שני תאים סרטניים נוגעים ומפסיקים","תא סרטני ובריא נוגעים והסרטני מפסיק","תא סרטני ובריא נוגעים והסרטני מת"],"a":0,"e":"עיכוב מגע: תאים נורמליים מפסיקים להתחלק כשהם נוגעים בשכניהם ומגיעים לצפיפות — תאים סרטניים מאבדים תכונה זו וממשיכים להתחלק (foci). ניתוח מסיחים: (ב),(ג),(ד) תיאורים שגויים — התכונה מאפיינת תאים נורמליים."},
    {"topic":"מוות תאי","q":"מהו סוג הגידול הנפוץ ביותר בבני אדם?","o":["Sarcoma","Melanoma","Carcinoma","Leukemia"],"a":2,"e":"קרצינומות (גידולים ממקור אפיתליאלי) הן הסוג השכיח ביותר — כ-80-90% מהסרטנים (שד, ריאה, מעי, ערמונית). ניתוח מסיחים: (א) סרקומה ממקור רקמת חיבור — נדירה יחסית; (ב) מלנומה ממלנוציטים; (ד) לוקמיה ממקור המטופויאטי — כולם נפוצים פחות מקרצינומה."},
    {"topic":"תעבורה ממברנלית - אנדוציטוזה ומיון","q":"מה יעודד תחלופה (turnover) של חלבונים ממברנליים?","o":["סימון ע'י יוביקוויטין","העלאת פרוטאוזומים","העלאת ליזוזומים","העלאת DUB"],"a":0,"e":"יוביקווינציה של חלבון ממברנלי מסמנת אותו לאינטרנליזציה (אנדוציטוזה) ולפירוק — מאיצה את התחלופה. ניתוח מסיחים: (ב) פרוטאוזום מפרק בעיקר חלבונים ציטוזוליים/ERAD; (ג) ליזוזום מפרק, אך הסימון היוזם הוא היוביקוויטין; (ד) DUB מסירים יוביקוויטין ודווקא מייצבים את החלבון."},
    {"topic":"איתות תאי","q":"מי אינו נקשר לפוספואינוזיטיד דרך דומיין PH?","o":["SOS","GRB2","IRS1","AKT"],"a":1,"e":"GRB2 הוא חלבון מתאם הבנוי מדומייני SH2 ו-SH3 (נקשר לפוספוטירוזין ולרצפים עתירי-פרולין), ואין לו דומיין PH. ניתוח מסיחים: (א) SOS, (ג) IRS1 ו-(ד) AKT כולם נושאים דומיין PH הנקשר לפוספואינוזיטידים בממברנה."},
    {"topic":"שלד התא","q":"מה לא נכון לגבי וזיקולות בציטוקינזה בצמח?","o":["מכילות פוליסכרידים","מכילות גליקופרוטאינים","תנועה על גבי אקטין","איחוי ממרכז התא"],"a":2,"e":"בציטוקינזה צמחית הוזיקולות נעות לאורך מיקרוטובולים (הפרגמופלסט), לא על אקטין, ומתאחות ממרכז התא החוצה ליצירת לוחית התא. ניתוח מסיחים: (א),(ב) הוזיקולות אכן מכילות פוליסכרידים וגליקופרוטאינים לדופן; (ד) נכון — האיחוי מתחיל במרכז; ולכן (ג) הוא הלא-נכון."},
    {"topic":"מחזור התא","q":"מה פעילות Ran-GTP במטאפאזה?","o":["פלמור מקומי של מיקרוטובולים","עיכוב ייבוא חלבונים","עיכוב ייצוא חלבונים","משהו עם סיבי אקטין"],"a":0,"e":"במיטוזה מפל Ran-GTP סביב הכרומוזומים משחרר גורמי הרכבת-ציר (SAFs) ממעכביהם ומקדם פלמור/נוקלאציה מקומית של מיקרוטובולים להרכבת ציר החלוקה. ניתוח מסיחים: (ב),(ג) ויסות ייבוא/ייצוא גרעיני הוא תפקיד Ran באינטרפאזה (כשיש מעטפת גרעינית); (ד) Ran אינו פועל על אקטין."},
    {"topic":"מחזור התא","q":"מה תפקיד p21?","o":["עיכוב p53","הפעלת Chk","עיכוב E2F","עיכוב קומפלקס ציקלין-CDK"],"a":3,"e":"p21 הוא מעכב CDK (CKI) — נקשר לקומפלקסי ציקלין-CDK ומעכב אותם, ובכך עוצר את מחזור התא (במורד הזרם של p53). ניתוח מסיחים: (א) הפוך — p53 משרן את p21; (ב) Chk פועל במעלה הזרם; (ג) עיכוב E2F נעשה ע'י Rb, לא ישירות ע'י p21."},
    {"topic":"שלד התא","q":"מהו שלב ה-lag בפלמור אקטין/מיקרוטובולים?","o":["חסר","הגעה ל-steady state","ה-nucleation","ה-treadmilling"],"a":2,"e":"שלב ה-lag (ההשהיה האיטית בתחילת הפלמור) מתאים לנוקלאציה — היווצרות גרעין ההתחלה האיטית; לאחריו מגיע שלב הארכה מהיר ואז שיווי משקל. ניתוח מסיחים: (ב) steady state הוא השלב המאוחר; (ד) treadmilling מתרחש בשיווי משקל; (א) חסר."},
    {"topic":"מבנה חלבונים וחומצות אמינו","q":"מהו המקור המקודד למבנה התלת-ממדי של חלבון?","o":["רצף חומצות האמינו","רצף ה-UTR ב-mRNA","ה-rRNA הבונה את הריבוזום","חסר"],"a":0,"e":"לפי עקרון אנפינסן, כל המידע לקיפול התלת-ממדי הסופי מקודד ברצף חומצות האמינו (המבנה הראשוני). ניתוח מסיחים: (ב) ה-UTR מווסת תרגום/יציבות, לא את הקיפול; (ג) ה-rRNA בונה את הריבוזום אך אינו קובע את מבנה החלבון; (ד) חסר."},
    {"topic":"שלד התא","q":"מיהו ה-MTOC העיקרי בתאים אנימליים?","o":["צנטרוזום","Gamma-TuRC","Spindle pole","ממברנת התא"],"a":0,"e":"הצנטרוזום הוא מרכז ארגון המיקרוטובולים הראשי בתא בעלי החיים. ניתוח מסיחים: (ב) γ-TuRC הוא המתחם המנקלא בתוך הצנטרוזום (רכיב); (ג) קוטב הציר נוצר מהצנטרוזומים במיטוזה; (ד) הממברנה אינה MTOC."},
    {"topic":"מבנה הקרום - אסימטריה ונזילות","q":"היכן יימצא הפוליפפטיד של חלבון מעוגן-GPI בקרום הפלזמה?","o":["מחוץ לתא (בצד החוץ-תאי)","בציטוזול","בליבה הליפידית ומחוץ לתא","בליבה הליפידית ובציטוזול"],"a":0,"e":"עוגן ה-GPI מחבר את החלבון לעלעל החיצוני של הממברנה, כך שכל חלק הפוליפפטיד פונה אל מחוץ לתא (הצד החוץ-תאי). ניתוח מסיחים: (ב),(ד) חלבון מעוגן-GPI אינו בציטוזול; (ג) הפוליפפטיד אינו טבול בליבה הליפידית — רק העוגן הליפידי."},
    {"topic":"איתות תאי","q":"מה מסמל המספר 3 בשם הקינאז PI3K?","o":["מספר קבוצות הפוספט שמוסיף","העמדה (הפחמן) על טבעת האינוזיטול שאותה הוא מזרחן","סדר הגילוי הכרונולוגי","מספר תתי-היחידות"],"a":1,"e":"PI3K מזרחן את קבוצת ההידרוקסיל בעמדה 3 של טבעת האינוזיטול (יוצר PIP3). ניתוח מסיחים: (א),(ג),(ד) פרשנויות שגויות של ה'3'."},
    {"topic":"איתות תאי","q":"כיצד פגם בדומיין ה-SH2 של STAT יפגע באיתות?","o":["לא יתאפשר קישור STAT לרצפטור וגם לא ל-STAT אחרים (דימריזציה)","קישור רק ל-STAT אחרים","קישור רק לרצפטור","אין מידע"],"a":0,"e":"דומיין ה-SH2 של STAT נקשר לפוספוטירוזין — גם זה שעל הרצפטור (לגיוס) וגם זה של ה-STAT השני (דימריזציה הדדית). פגם בו פוגע בשני הקישורים. ניתוח מסיחים: (ב),(ג) שניהם תלויים ב-SH2 ולכן ייפגעו; (ד) חסר."},
    {"topic":"איתות תאי","q":"מה תפקיד Axin במסלול Wnt/β-Catenin?","o":["Serine/Threonine Kinase","Tyrosine Kinase","Ubiquitin Ligase","Scaffold Protein"],"a":3,"e":"Axin הוא חלבון פיגום (scaffold) המרכיב את 'קומפלקס ההרס' (עם APC, GSK3β, CK1) המזרחן ומפרק את β-catenin בהיעדר Wnt. ניתוח מסיחים: (א),(ב) Axin אינו האנזים הקינאז (אלא מארגן אותם); (ג) הוא אינו היוביקווין-ליגאז עצמו."},
    {"topic":"מיון חלבונים - יבוא למיטוכונדריה","q":"כניסה לאיזה אברון מחייבת שני סיגנל-פפטידים שונים?","o":["ליזוזום","גרעין","Rough ER","כלורופלסט (הגעה לתילקואיד)"],"a":3,"e":"כדי להגיע לתילקואיד שבכלורופלסט נדרשים שני אותות עוקבים: אחד לייבוא לכלורופלסט (סטרומה) ולאחר ביקועו — אות שני להעברה אל ממברנת/לומן התילקואיד. ניתוח מסיחים: (א),(ב),(ג) דורשים אות יחיד."},
    {"topic":"מיון חלבונים - יבוא למיטוכונדריה","q":"מי מבני המשפחה נושא DNA מיטוכונדריאלי שונה מהשאר?","o":["האח","האב","האם","הבת"],"a":1,"e":"mtDNA עובר בתורשה אימהית בלבד; לכן האם, האח והבת חולקים את אותו mtDNA, ולאב mtDNA שונה (שאינו מועבר לצאצאים). ניתוח מסיחים: (א),(ג),(ד) באותה שושלת אימהית."},
    {"topic":"צימוד עירור-כיווץ בשריר השלד","q":"מה גורם לריגור מורטיס (קשיון) לאחר המוות?","o":["ריכוז סידן גבוה המונע ניתוק","חוסר פעילות ATPase במיוזין בגלל היעדר ATP","טיטין מעכב שחרור","המיוזין נקשר לאקטין בקשר קוולנטי"],"a":1,"e":"לאחר המוות אוזל ה-ATP; בלעדיו ראשי המיוזין אינם יכולים להתנתק מהאקטין (ניתוק הגשר דורש קשירת ATP) — והשריר נשאר נוקשה. ניתוח מסיחים: (א) אינו המנגנון; (ג) טיטין הוא אלמנט אלסטי; (ד) הקשר אקטין-מיוזין אינו קוולנטי."},
    {"topic":"שלד התא","q":"איזה חומר מעכב פולימריזציה של מיקרוטובולים ומשמש לבדיקת קריוטיפ?","o":["טקסול","קולכיצין","פאלואידין","ציטוכלסין B"],"a":1,"e":"קולכיצין מעכב פולימריזציה של מיקרוטובולים ועוצר תאים במטאפאזה — שם הכרומוזומים דחוסים ונראים בבירור לקריוטיפ. ניתוח מסיחים: (א) טקסול מייצב מיקרוטובולים (לא מעכב פולימריזציה); (ג),(ד) פאלואידין וציטוכלסין פועלים על אקטין."},
    {"topic":"שלד התא","q":"מה מאפיין קראטין?","o":["נמצא בעיקר בגרעין","מייצב אקסונים","מעניק חוזק מכני לאפידרמיס","נמצא בעיקר בשריר"],"a":2,"e":"קראטין הוא סיב ביניים בתאי אפיתל המעניק חוזק מכני לאפידרמיס (עור, שיער, ציפורניים). ניתוח מסיחים: (א) למינים בגרעין; (ב) נוירופילמנטים באקסונים; (ד) דסמין בשריר."},
    {"topic":"צמתים תאיים ומטריקס","q":"איזו צומת בין-תאית יוצרת רקמת אפיתל צפופה ומונעת מעבר חומרים בין התאים?","o":["Tight junction","Gap junction","Hemidesmosome","Desmosome"],"a":0,"e":"צמתים הדוקים (tight junctions) חוסמים את המרווח הפרא-תאי ויוצרים חיץ אטום שמונע מעבר חופשי של חומרים בין תאי האפיתל. ניתוח מסיחים: (ב) gap junction מחבר ציטופלזמות לתקשורת; (ג),(ד) hemidesmosome ו-desmosome מעגנים מכנית, לא אוטמים."},
    {"topic":"מיון חלבונים - פפטיד סיגנל ל-ER","q":"מהו האות העיקרי המכוון את הריבוזום/התרגום אל ה-ER?","o":["Signal peptide (ER signal sequence)","KDEL","Stop-translation sequence","N-אצטילציה"],"a":0,"e":"פפטיד-הסיגנל בקצה ה-N (ER signal sequence) מזוהה ע'י ה-SRP וגורם לעיגון הריבוזום על קרום ה-ER ולהתחלת הטרנסלוקציה. ניתוח מסיחים: (ב) KDEL הוא אות שימור בלומן ה-ER; (ג),(ד) אינם אותות מיקוד ל-ER."},
    {"topic":"מיון חלבונים - יבוא למיטוכונדריה","q":"מה תפקיד Pex5 במחזור החלבונים של הפרוקסיזום?","o":["לייצר ממברנות חדשות","לייבא חלבונים מהציטוזול אל מטריקס הפרוקסיזום","לסנתז חלבונים ממברנליים","לבצע מטבוליזם של ליפידים"],"a":1,"e":"Pex5 הוא קולטן ציטוזולי המזהה את אות PTS1, נושא את חלבון המטען (אף מקופל) אל הפרוקסיזום ומכניס אותו דרך טרנסלוקטור, ואז ממוחזר. ניתוח מסיחים: (א),(ג),(ד) אינם תפקיד Pex5."},
    {"topic":"תעבורה ממברנלית - סוגי ציפוי","q":"פגם גנטי שבו חלבוני הפרשה נשארים ב-ER מעיד על פגיעה ב:","o":["COPI","חיבור ל-SRP","תעלת Sec61","יצירת וזיקולות COPII"],"a":3,"e":"וזיקולות COPII מובילות חלבונים מה-ER אל הגולגי (anterograde); פגם בהיווצרותן יותיר את חלבוני ההפרשה תקועים ב-ER. ניתוח מסיחים: (א) COPI הוא רטרוגרדי (גולגי→ER); (ב),(ג) פגם בהם ימנע כניסה ל-ER מלכתחילה, לא הצטברות בתוכו."},
    {"topic":"מוות תאי","q":"במה שונה המסלול האפופטוטי האינטרינזי מהאקסטרינזי?","o":["שימוש בקולטני מוות","כולל שחרור ציטוכרום C מהמיטוכונדריה","אותות חוץ-תאיים בלבד","שימוש בקולטני TNF"],"a":1,"e":"המסלול האינטרינזי (המיטוכונדריאלי) מאופיין בחדירות הממברנה החיצונית ושחרור ציטוכרום C, שמרכיב את האפופטוזום ומפעיל קספאז-9. ניתוח מסיחים: (א),(ד) קולטני מוות (Fas/TNF) מאפיינים את המסלול האקסטרינזי; (ג) אינטרינזי מופעל ע'י אותות תוך-תאיים (נזק/עקה)."},
    {"topic":"מוות תאי","q":"מה צפוי בתא עם פגם המונע חשיפת פוספטידיל-סרין על הממברנה?","o":["התא יחיה זמן רב ולא יעבור אפופטוזה","התא האפופטוטי לא יזוהה ע'י מקרופאגים ולא ייבלע","נקרוזה תהפוך לצורת המוות העיקרית","פגם מיטוכונדריאלי שיגרום לנקרוזה משנית"],"a":1,"e":"חשיפת פוספטידיל-סרין על העלעל החיצוני היא אות ה'אכול אותי' לפינוי תאים אפופטוטיים; בהיעדרה מקרופאגים לא יזהו ולא יבלעו את התא. ניתוח מסיחים: (א) האפופטוזה עצמה אינה מעוכבת; (ג),(ד) אינם תוצאה ישירה של היעדר חשיפת PS."},
    {"topic":"מיון חלבונים - יבוא למיטוכונדריה","q":"מה תפקיד PINK1 ו-Parkin במיטופאגיה?","o":["PINK1 מגייס את Parkin ליוביקווינציה של חלבוני מיטוכונדריה","מגייסים הידרולאזות ליזוזומליות ישירות","פגיעה ביצירת פאגוזומים","אין מידע"],"a":0,"e":"במיטוכונדריה פגומה (איבוד פוטנציאל) PINK1 מצטבר על הקרום החיצוני, מגייס ומפעיל את Parkin (יוביקווין-ליגאז), שמיוביקוויטן חלבוני קרום — סימון לסילוק במיטופאגיה. ניתוח מסיחים: (ב),(ג) אינם תפקידם; (ד) חסר."},
    {"topic":"צמתים תאיים ומטריקס","q":"מוטציה בלמינין הפוגעת בפולימריזציה שלו — מה ההשפעה הישירה על הלמינה הבזאלית?","o":["פגיעה ביכולת לקשור מים","פגיעה ביכולת לעגן תאי אפיתל","הגברת קשיחות הרקמה","חיזוק האינטראקציה עם פיברונקטין"],"a":1,"e":"למינין הוא מרכיב מבני מרכזי בלמינה הבזאלית המעגן את תאי האפיתל (דרך אינטגרינים/דיסטרוגליקן); פגם בפולימריזציה שלו פוגע ישירות ביכולת העיגון. ניתוח מסיחים: (א) ספיחת מים אופיינית ל-GAGs; (ג),(ד) אינן תוצאה צפויה."},
    {"topic":"צמתים תאיים ומטריקס","q":"חוסר בקישוריות (cross-linking) של אלסטין — איזה אנזים חסר?","o":["הילורונאז","קולגנאז","פרוליל הידרוקסילאז","ליזיל אוקסידאז"],"a":3,"e":"ליזיל אוקסידאז יוצר את הקישורים הצולבים בין שיירי הליזין באלסטין (ובקולגן); חסרונו פוגע בקישוריות ובגמישות. ניתוח מסיחים: (א),(ב) אנזימי פירוק מטריקס; (ג) פרוליל-הידרוקסילאז מהדרוקסל פרולין בקולגן (לא קישור אלסטין)."}
  ],
  physio: [
    {"topic":"פוטנציאל מנוחה","q":"בנוירון במנוחה, פוטנציאל המנוחה של הממברנה (כ-70mV-) קרוב יותר לפוטנציאל שיווי המשקל של אשלגן (K+) מאשר לזה של נתרן (Na+). מהי הסיבה העיקרית לכך?","o":["הריכוז של אשלגן (K+) מחוץ לתא גבוה מזה של נתרן (Na+)","חדירות הממברנה במנוחה לאשלגן (K+) גבוהה בהרבה מהחדירות לנתרן (Na+)","משאבת הנתרן-אשלגן יוצרת מתח שלילי על ידי שאיבת אשלגן (K+) החוצה","פוטנציאל שיווי המשקל של נתרן (Na+) שלילי יותר מזה של אשלגן (K+)"],"a":1,"e":"פוטנציאל המנוחה נקבע לפי משוואת גולדמן: הממברנה נמשכת לעבר פוטנציאל שיווי המשקל של היון בעל החדירות הגבוהה ביותר. במנוחה תעלות הדלף לאשלגן (K+) פתוחות פי כמה עשרות מהחדירות לנתרן (Na+), ולכן Vm (כ-70mV-) קרוב ל-EK (כ-90mV-) ורחוק מ-ENa (כ-60mV+). מסיח א שגוי: דווקא הריכוז התוך-תאי של אשלגן גבוה, והמדרג אינו הגורם הישיר למשיכת המתח אלא החדירות. מסיח ג מגזים בתרומת המשאבה (Na+/K+-ATPase) שתורמת ישירות רק כ-mV אחדים אלקטרוגניים. מסיח ד הפוך: ENa חיובי ולא שלילי. טיפ לזכירה: 'הממברנה מקשיבה ליון שדלתו פתוחה' — חדירות, לא ריכוז, היא המכריעה."},
    {"topic":"משוואת נרנסט","q":"אם ריכוז האשלגן (K+) החוץ-תאי יוכפל פי 10 (מ-4 ל-40 mM) בעוד הריכוז התוך-תאי נשמר קבוע, כיצד ישתנה פוטנציאל שיווי המשקל של אשלגן (EK) בטמפרטורת הגוף?","o":["יעלה (יהפוך פחות שלילי) בכ-61mV","ירד (יהפוך שלילי יותר) בכ-61mV","יעלה (יהפוך פחות שלילי) בכ-2.3mV","לא ישתנה כי המשוואה תלויה רק בריכוז התוך-תאי"],"a":0,"e":"לפי משוואת נרנסט EK = 61 × log([K+]חוץ/[K+]פנים) בטמפ' הגוף. הכפלה פי 10 של הריכוז החוץ-תאי מוסיפה log(10)=1 ל-לוגריתם, כלומר +61mV. מאחר ש-EK שלילי, התוספת החיובית הופכת אותו פחות שלילי (עולה). מסיח ב הפוך בכיוון. מסיח ג מתעלם מכך שמדובר בהכפלה פי 10 (שמכניסה log שלם) ונותן ערך זעיר. מסיח ד שגוי: נרנסט תלוי ביחס הריכוזים בשני צידי הממברנה, לא רק בתוך-תאי. נקודת מפתח קלינית: עלייה ב-K+ חוץ-תאי (היפר-קלמיה) מדה-פולרת ומקרבת את הממברנה לסף — סכנת הפרעות קצב. זכור: כל שינוי פי 10 ביחס מזיז את הפוטנציאל ב-61mV."},
    {"topic":"פוטנציאל פעולה","q":"מהו האירוע היוני האחראי הישיר לשלב העלייה המהירה (דה-פולריזציה) של פוטנציאל הפעולה בנוירון?","o":["יציאה מהירה של אשלגן (K+) דרך תעלות תלויות-מתח","כניסה מהירה של נתרן (Na+) דרך תעלות תלויות-מתח","כניסה של כלוריד (Cl-) דרך תעלות תלויות-ליגנד","יציאה של נתרן (Na+) דרך משאבת הנתרן-אשלגן"],"a":1,"e":"שלב העלייה המהירה (דה-פולריזציה) נוצר מפתיחת שערי ההפעלה של תעלות הנתרן (Na+) תלויות-המתח: הגירוי מעל הסף פותח אותן, נתרן זורם פנימה לעבר ENa החיובי, וזה מזין מעגל משוב חיובי שמאיץ את הפתיחה. מסיח א שגוי: יציאת אשלגן (K+) אחראית לרה-פולריזציה (השלב היורד), לא לעלייה. מסיח ג שגוי: תעלות כלוריד תלויות-ליגנד אינן מעורבות בעלייה ולרוב נוגעות לעיכוב. מסיח ד שגוי: המשאבה אינה יוצרת את הזרם המהיר אלא שומרת מדרגים לאורך זמן. טיפ: 'נתרן עולה, אשלגן יורד' — נתרן בונה את ה-spike, אשלגן מכבה אותו."},
    {"topic":"פוטנציאל פעולה","q":"השלב היורד (רה-פולריזציה) של פוטנציאל הפעולה מתרחש בו-זמנית עם שני אירועים בתעלות תלויות-מתח. אילו?","o":["פתיחת שער ההפעלה של נתרן (Na+) ופתיחת תעלות אשלגן (K+)","אינאקטיבציה (סגירת שער) של תעלות נתרן (Na+) ופתיחה איטית של תעלות אשלגן (K+)","פתיחה של תעלות נתרן (Na+) וסגירה של תעלות אשלגן (K+)","פתיחת תעלות סידן (Ca2+) ואינאקטיבציה של תעלות אשלגן (K+)"],"a":1,"e":"הרה-פולריזציה (השלב היורד) משלבת שני אירועים בו-זמנית: שער ההשבתה (inactivation) של תעלת הנתרן (Na+) נסגר ומפסיק את זרם הנתרן פנימה, ובמקביל תעלות האשלגן (K+) תלויות-המתח, שנפתחות באיחור, מאפשרות יציאת אשלגן המחזירה את המתח לשלילי. מסיח א שגוי: שער ההפעלה של נתרן פתוח בשלב העלייה, לא היורד. מסיח ג שגוי: תעלות האשלגן נפתחות (לא נסגרות) בשלב זה. מסיח ד שגוי: סידן אינו מעורב ברה-פולריזציה של נוירון טיפוסי. נקודת מפתח: שתי תעלות שונות פועלות יחד — נתרן 'נכבה' ואשלגן 'נדלק' — ולכן המתח צולל חזרה ואף עובר היפר-פולריזציה קצרה."},
    {"topic":"תקופה רפרקטורית","q":"מהו ההסבר המולקולרי לתקופה הרפרקטורית המוחלטת (absolute refractory period)?","o":["כל תעלות האשלגן (K+) פתוחות ומונעות כל שינוי מתח","תעלות הנתרן (Na+) נמצאות במצב מושבת (inactivated) ואינן ניתנות לפתיחה חוזרת","משאבת הנתרן-אשלגן מושבתת זמנית","הממברנה היפר-פולרית מתחת לפוטנציאל המנוחה"],"a":1,"e":"בתקופה הרפרקטורית המוחלטת תעלות הנתרן (Na+) נמצאות במצב מושבת (inactivated): שער ההשבתה סגור ואינו ניתן לפתיחה חוזרת בכל עוצמת גירוי, עד שהממברנה תרה-פולרת ותאפס את השער. לכן לא ניתן ליצור פוטנציאל פעולה חדש כלל בתקופה זו. מסיח א שגוי: פתיחת אשלגן קשורה לרה-פולריזציה אך אינה ההסבר לרפרקטוריות המוחלטת. מסיח ג שגוי: המשאבה (Na+/K+-ATPase) פועלת ברקע ואינה הגורם. מסיח ד מתאר היפר-פולריזציה האופיינית לתקופה היחסית, לא למוחלטת. טיפ לזכירה: רפרקטוריות מוחלטת = 'מנעול נתרן' (inactivation gate) שאי אפשר לפתוח, ולכן היא מבטיחה חד-כיווניות והגבלת תדר."},
    {"topic":"תקופה רפרקטורית","q":"מה מבדיל את התקופה הרפרקטורית היחסית (relative) מהמוחלטת מבחינה מנגנונית?","o":["ביחסית כל תעלות הנתרן (Na+) מושבתות, ובמוחלטת חלקן זמינות","ביחסית חלק מתעלות הנתרן (Na+) כבר התאוששו אך זרם האשלגן (K+) עדיין מוגבר, ולכן דרוש גירוי חזק מהרגיל","ביחסית הממברנה דה-פולרית קבוע ולכן קל יותר לעורר","שתי התקופות זהות מנגנונית ונבדלות רק במשך"],"a":1,"e":"ההבדל המנגנוני: בתקופה היחסית חלק מתעלות הנתרן (Na+) כבר התאוששו מההשבתה וזמינות לפתיחה, אך זרם האשלגן (K+) עדיין מוגבר (היפר-פולריזציה ומוליכות גבוהה), ולכן נדרש גירוי חזק מהסף הרגיל כדי להגיע לפוטנציאל פעולה. מסיח א הפוך: ביחסית חלק כבר התאוששו, לא כולן מושבתות. מסיח ג שגוי: הממברנה היפר-פולרית (לא דה-פולרית), ולכן קשה יותר ולא קל יותר לעורר. מסיח ד שגוי: יש הבדל מנגנוני מהותי. נקודת מפתח: ביחסית הנוירון 'ניתן לעורר אך בקושי' — שילוב של נתרן זמין חלקית ואשלגן שעדיין יוצא הוא שמעלה את הסף האפקטיבי."},
    {"topic":"הולכה קפיצנית ומיאלין","q":"מדוע מיאלינציה מאיצה את מהירות הולכת פוטנציאל הפעולה לאורך האקסון?","o":["המיאלין מעלה את קיבול הממברנה ולכן מטעין אותה מהר יותר","המיאלין מקטין את קיבול הממברנה ומעלה את התנגדותה, כך שהזרם זורם רחוק יותר וקופץ בין מצרי רנבייה","המיאלין מגדיל את צפיפות תעלות הנתרן (Na+) לאורך כל האקסון","המיאלין מאט דליפת זרם אך מאיט גם את ההולכה לצורך דיוק"],"a":1,"e":"מיאלין מאיץ הולכה כי הוא מקטין את קיבול הממברנה (פחות מטען לטעון) ומעלה את התנגדותה (פחות דליפת זרם), כך שזרם הדה-פולריזציה זורם מרחק רב יותר תוך אובדן מועט וקופץ בין מצרי רנבייה — הולכה קפיצנית (saltatory). מסיח א הפוך: מיאלין מקטין קיבול, לא מעלה. מסיח ג שגוי: תעלות הנתרן (Na+) מרוכזות במצרי רנבייה דווקא, ולא לכל אורך האקסון. מסיח ד שגוי: מיאלין מאיץ ולא מאט. טיפ: דמיין כבל מבודד — הבידוד מצמצם 'נזילה' של מטען לסביבה, ולכן האות מגיע רחוק ומהר. שילוב של קוטר אקסון גדול ומיאלין נותן את ההולכה המהירה ביותר."},
    {"topic":"הולכה קפיצנית","q":"היכן מרוכזות תעלות הנתרן (Na+) תלויות-המתח באקסון מיאליני, ומה ההשלכה?","o":["מתחת לעטיפת המיאלין, ולכן הפוטנציאל מתחדש לכל אורך הסיב","במצרי רנבייה (nodes of Ranvier), ולכן הפוטנציאל מתחדש רק שם והולכה קפיצנית","באופן אחיד לאורך כל האקסון, ולכן ההולכה רציפה ומהירה","בגוף התא בלבד, ולכן ההולכה תלויה בסומה"],"a":1,"e":"באקסון מיאליני, תעלות הנתרן (Na+) תלויות-המתח מרוכזות בצפיפות גבוהה במצרי רנבייה (nodes of Ranvier) — אזורי הממברנה החשופים בין מקטעי המיאלין. שם בלבד הפוטנציאל מתחדש (regenerated), והזרם הפסיבי 'קופץ' ממצר למצר בהולכה קפיצנית מהירה וחסכונית באנרגיה. מסיח א שגוי: מתחת למיאלין אין כמעט תעלות, ושם אין התחדשות אלא הולכה פסיבית. מסיח ג שגוי: בסיב מיאליני ההולכה אינה רציפה אלא קופצנית. מסיח ד שגוי: התחדשות הפוטנציאל מתרחשת לאורך האקסון במצרים, לא בגוף התא. נקודת מפתח: מיאלין מבודד, ומצרי רנבייה הם 'תחנות הגברה' — זה מה שהופך את ההולכה למהירה."},
    {"topic":"נוזלי הגוף ואוסמולריות","q":"מטופל מקבל עירוי של תמיסת נתרן כלורי (NaCl) היפרטונית. מה תהיה ההשפעה המיידית על נפח התאים?","o":["התאים יתנפחו כי המים נכנסים אליהם","התאים יתכווצו כי המים יוצאים מהם אל הנוזל החוץ-תאי","נפח התאים לא ישתנה כי נתרן (Na+) נכנס לתאים בחופשיות","התאים יתכווצו כי נתרן (Na+) יוצא מהם יחד עם מים"],"a":1,"e":"תמיסת NaCl היפרטונית מעלה את האוסמולריות החוץ-תאית. לפי עיקרון האוסמוזה, מים זורמים מהאזור בעל האוסמולריות הנמוכה (תוך-תאי) אל הגבוה (חוץ-תאי), ולכן התאים מאבדים מים ומתכווצים. מסיח א הפוך: תאים מתנפחים בתמיסה היפוטונית, לא היפרטונית. מסיח ג שגוי: נתרן (Na+) אינו חוצה את הממברנה בחופשיות (הוא נשמר בעיקר מחוץ לתא ע\"י המשאבה), ולכן NaCl נשאר אוסמוטית פעיל מחוץ לתא. מסיח ד שגוי באותו טעם — נתרן אינו 'בורח' החוצה עם מים. טיפ לזכירה: 'מים רצים למלח' — המים נעים לעבר הריכוז המומס הגבוה, וכאן הוא מחוץ לתא, ולכן התא מצטמק."},
    {"topic":"חלוקת נוזלי הגוף","q":"איזה קטיון הוא הדומיננטי בקביעת האוסמולריות של הנוזל התוך-תאי, ואיזה דומיננטי בנוזל החוץ-תאי?","o":["נתרן (Na+) תוך-תאי; אשלגן (K+) חוץ-תאי","אשלגן (K+) תוך-תאי; נתרן (Na+) חוץ-תאי","סידן (Ca2+) תוך-תאי; כלוריד (Cl-) חוץ-תאי","כלוריד (Cl-) תוך-תאי; אשלגן (K+) חוץ-תאי"],"a":1,"e":"האשלגן (K+) הוא הקטיון הדומיננטי בנוזל התוך-תאי, והנתרן (Na+) הוא הקטיון הדומיננטי בנוזל החוץ-תאי. מדרגים אלה נשמרים על ידי משאבת הנתרן-אשלגן (Na+/K+-ATPase) המוציאה 3 נתרן ומכניסה 2 אשלגן, והם הבסיס לאוסמולריות התאית ולפוטנציאל הממברנה. מסיח א הפוך לחלוטין. מסיח ג שגוי: סידן (Ca2+) התוך-תאי החופשי דווקא נמוך מאוד (ננומולרי), והוא אינו קובע אוסמולריות; כלוריד דומיננטי חוץ-תאית אך כאניון. מסיח ד שגוי בשני הצדדים. נקודת מפתח לזכירה: 'אשלגן בבית, נתרן בחוץ' — והמשאבה היא ש'משלמת' ATP כדי לקיים את ההפרדה הזו ללא הרף."},
    {"topic":"העברה סינפטית","q":"פוטנציאל פוסט-סינפטי מעכב (IPSP) טיפוסי נוצר לרוב בעקבות פתיחת תעלות יוניות שגורמות ל:","o":["כניסת נתרן (Na+) ודה-פולריזציה של התא","כניסת כלוריד (Cl-) או יציאת אשלגן (K+), והיפר-פולריזציה/ייצוב מתחת לסף","כניסת סידן (Ca2+) ושחרור מוליך עצבי","סגירת תעלות אשלגן (K+) ודה-פולריזציה"],"a":1,"e":"פוטנציאל פוסט-סינפטי מעכב (IPSP) נוצר בדרך כלל מפתיחת תעלות כלוריד (Cl-) הגורמות לכניסת כלוריד, או מפתיחת תעלות אשלגן (K+) הגורמות ליציאת אשלגן. שני התהליכים הופכים את הממברנה לשלילית יותר (היפר-פולריזציה) או מייצבים אותה סביב פוטנציאל המנוחה, ומרחיקים אותה מהסף. מסיח א מתאר EPSP מעורר (כניסת נתרן ודה-פולריזציה), הפוך. מסיח ג מתאר אירוע פרה-סינפטי (כניסת סידן ושחרור מוליך), לא IPSP פוסט-סינפטי. מסיח ד הפוך: סגירת אשלגן דווקא מדה-פולרת. טיפ: עיכוב = 'להוריד את התא מתחת לסף' — או להכניס מטען שלילי (כלוריד) או להוציא מטען חיובי (אשלגן)."},
    {"topic":"העברה סינפטית","q":"מהו ההבדל העיקרי בין סיכום זמני (temporal summation) לסיכום מרחבי (spatial summation) של EPSPs?","o":["זמני = EPSPs ממספר סינפסות בו-זמנית; מרחבי = EPSPs מסינפסה אחת ברצף מהיר","זמני = EPSPs מסינפסה אחת המגיעים ברצף מהיר ומצטברים; מרחבי = EPSPs ממספר סינפסות בו-זמנית","זמני מתרחש רק באקסון; מרחבי רק בדנדריט","אין הבדל מנגנוני, רק מינוח"],"a":1,"e":"סיכום זמני (temporal) הוא הצטברות של EPSPs המגיעים מאותה סינפסה בזה אחר זה במהירות, לפני שהקודם דעך — חיבור בציר הזמן. סיכום מרחבי (spatial) הוא חיבור EPSPs המגיעים בו-זמנית ממספר סינפסות שונות על פני הנוירון. שניהם יכולים להביא את הממברנה לסף בגבעת האקסון וליצור פוטנציאל פעולה. מסיח א הפוך בין ההגדרות. מסיח ג שגוי: שני הסוגים מתרחשים בעיקר על הדנדריטים והסומה ומשתקפים בגבעת האקסון. מסיח ד שגוי: יש הבדל מנגנוני אמיתי. טיפ לזכירה: זמני = 'אותו פה צועק שוב ושוב מהר'; מרחבי = 'הרבה פיות צועקים יחד'. שניהם מסכמים אות עד החצייה את הסף."},
    {"topic":"תפקוד ממברנה","q":"חוקר חוסם את משאבת הנתרן-אשלגן (Na+/K+-ATPase) בנוירון בעזרת אובאין (ouabain). מה תהיה ההשפעה ארוכת-הטווח?","o":["פוטנציאל המנוחה יישאר זהה לחלוטין לאורך זמן","המדרגים היוניים יתפוגגו בהדרגה, נתרן (Na+) יצטבר תוך-תאית ופוטנציאל המנוחה יתפוגג (יהפוך פחות שלילי)","התא יהפוך מיד היפר-פולרי מאוד","תעלות הנתרן (Na+) תלויות-המתח ייפתחו לצמיתות"],"a":1,"e":"משאבת הנתרן-אשלגן (Na+/K+-ATPase) מקיימת את מדרגי הריכוז של נתרן (Na+) ואשלגן (K+). חסימתה באובאין גורמת בהדרגה להצטברות נתרן תוך-תאית ולאיבוד אשלגן; מדרגי הריכוז קורסים ופוטנציאל המנוחה מתפוגג (מתקרב לאפס, פחות שלילי). מסיח א שגוי: בלי המשאבה המדרגים אינם נשמרים לאורך זמן. מסיח ג שגוי: התא אינו הופך מיד היפר-פולרי — אובדן מדרג האשלגן דווקא מדה-פולר. מסיח ד שגוי: תעלות הנתרן תלויות-המתח אינן 'נפתחות לצמיתות'. נקודת מפתח: ההשפעה הדרגתית ולא מיידית, כי תרומת המשאבה הישירה למתח קטנה — הנזק האמיתי הוא קריסת המדרגים שעליהם נשען כל האיתות. זה גם הבסיס לפעולת דיגוקסין על שריר הלב."},
    {"topic":"פוטנציאל פעולה","q":"מדוע פוטנציאל הפעולה נע בכיוון אחד בלבד לאורך האקסון ואינו חוזר אחורה?","o":["בגלל שתעלות האשלגן (K+) פתוחות רק בקדמת הגל","משום שהאזור שזה עתה נורה נמצא בתקופה רפרקטורית עקב השבתת תעלות הנתרן (Na+)","בגלל שמשאבת הנתרן-אשלגן דוחפת את הגל קדימה","משום שהמיאלין קיים רק בכיוון אחד"],"a":1,"e":"פוטנציאל הפעולה נע חד-כיוונית כי האזור שזה עתה נורה נמצא בתקופה רפרקטורית: תעלות הנתרן (Na+) שלו במצב השבתה (inactivated) ואינן ניתנות לפתיחה מיידית. הזרם המקומי יכול לדה-פולר רק את האזור הקדמי שטרם נורה, ולכן ההולכה מתקדמת בכיוון אחד בלבד. מסיח א שגוי: תעלות אשלגן אינן הגורם לחד-כיווניות. מסיח ג שגוי: המשאבה אינה 'דוחפת' את הגל. מסיח ד שגוי: גם בסיב לא-מיאליני ההולכה חד-כיוונית, כך שמיאלין אינו ההסבר. טיפ לזכירה: 'מאחור נעול, מלפנים פתוח' — ההשבתה הזמנית של הנתרן מאחורי הגל היא שמונעת חזרה לאחור ומבטיחה התקדמות מסודרת לאורך האקסון."},
    {"topic":"צימוד עירור-כיווץ בשריר השלד","q":"במהלך צימוד עירור-כיווץ (excitation-contraction coupling) בשריר השלד, מהו האירוע המפעיל ישירות את שחרור הסידן מהרשתית הסרקופלזמית (sarcoplasmic reticulum)?","o":["כניסת סידן חוץ-תאי דרך תעלות סידן מסוג L בקנליקולי הרוחב, אשר מפעילה שחרור סידן מושרה-סידן","שינוי קונפורמציוני בקולטן הדיהידרופירידין (DHPR) בקנליקול הרוחב, המועבר מכנית לקולטן הריאנודין (RyR) ופותח אותו","קישור אצטילכולין לקולטן הריאנודין על קרום הרשתית הסרקופלזמית","עלייה בריכוז ה-IP3 התוך-תאי הפותחת תעלות סידן ברשתית הסרקופלזמית"],"a":1,"e":"בשריר השלד הצימוד מכני-ישיר: קולטן הדיהידרופירידין (DHPR) בקנליקול הרוחב משמש כחיישן מתח המצומד מכנית-פיזית לקולטן הריאנודין (RyR1) שעל הרשתית הסרקופלזמית (SR). דה-פולריזציה משנה את קונפורמציית ה-DHPR, וזה פותח ישירות את ה-RyR ומשחרר סידן — ללא צורך בכניסת סידן חוץ-תאי. מסיח א מתאר שחרור סידן מושרה-סידן (CICR), שאופייני לשריר הלב ולא לשלד. מסיח ג שגוי: אצטילכולין פועל בצומת העצבית-שרירית, לא על ה-RyR. מסיח ד שגוי: IP3 אינו המנגנון ב-SR של שריר השלד. נקודת מפתח: שלד = 'מתג מכני' (DHPR-RyR מחוברים), לב = 'סידן מדליק סידן'. זה ההבדל המהותי לזכור."},
    {"topic":"מודולציה של כוח - גיוס וסיכום","q":"אילו מהמנגנונים הבאים יגדיל את הכוח המופק על ידי שריר שלד שלם (whole muscle) בעת התכווצות?","o":["הארכת הסיב הרבה מעבר לאורך האופטימלי כדי להגדיל את ההיקף שעליו פועלים הגשרים","גיוס יחידות מוטוריות נוספות והעלאת תדירות הגירוי עד לסיכום זמני וטטנוס","הקטנת ריכוז הסידן הציטוזולי כדי להאריך את משך הגירוי הבודד","הגדלת ההפרש בין פוטנציאל הפעולה של תא העצב לפוטנציאל הפעולה של סיב השריר"],"a":1,"e":"כוח של שריר שלם מווסת בעיקר בשני מנגנונים: גיוס (recruitment) של יחידות מוטוריות נוספות, וסיכום זמני (temporal summation) על ידי העלאת תדירות הגירוי עד לטטנוס שבו הריכוזים הציטוזוליים של סידן נשארים גבוהים ומתח חופף נבנה. מסיח א שגוי: הארכת הסיב הרבה מעבר לאורך האופטימלי מקטינה את חפיפת האקטין-מיוזין (לפי יחס אורך-מתח) ומפחיתה כוח. מסיח ג שגוי: הקטנת סידן ציטוזולי מפחיתה הפעלת גשרים ומפחיתה כוח. מסיח ד שגוי ומבלבל — אין 'הפרש פוטנציאלים' שכזה שמגדיל כוח. טיפ לזכירה: יותר חיילים (גיוס) + ירי מהיר יותר (תדר/טטנוס) = יותר כוח. אורך אופטימלי הוא שיא הכוח, ולא קצוות העקומה."},
    {"topic":"סוגי סיבי שריר השלד","q":"סיבי שריר מסוג I (slow oxidative) בהשוואה לסיבים מסוג IIx (fast glycolytic) מאופיינים ב:","o":["פעילות ATPase מהירה של המיוזין, צפיפות נימים נמוכה ועמידות נמוכה לעייפות","תכולת מיוגלובין גבוהה, צפיפות מיטוכונדריה ונימים גבוהה ועמידות גבוהה לעייפות","קוטר סיב גדול, תכולת גליקוגן גבוהה והפקת כוח מקסימלית מהירה","הסתמכות בלעדית על גליקוליזה אנאירובית והפקת לקטט מוגברת"],"a":1,"e":"סיבי שריר מסוג I (איטיים-חמצוניים) עשירים במיוגלובין, בצפיפות מיטוכונדריה ובצפיפות נימים גבוהה, מסתמכים על מטבוליזם חמצני (אירובי) ולכן עמידים מאוד לעייפות — מתאימים לפעילות ממושכת ויציבה. מסיח א מתאר תכונות של סיבים מהירים (פעילות ATPase מהירה, מעט נימים, רגישות לעייפות) — הפוך. מסיח ג מתאר סיבי IIx מהירים (קוטר גדול, גליקוגן רב, כוח מהיר). מסיח ד מתאר סיבים גליקוליטיים אנאירוביים, שוב סוג מהיר. נקודת מפתח לזכירה: סוג I = 'אדום, איטי, עמיד' (מרתון); סוג IIx = 'לבן, מהיר, מתעייף' (ספרינט). הצבע נובע ממיוגלובין ומאספקת הדם הגבוהה בסיבים החמצניים."},
    {"topic":"הרפיית שריר ותפקיד ה-SR","q":"מטופל סובל ממוטציה הפוגעת בתפקוד משאבת ה-SERCA ברשתית הסרקופלזמית של שריר השלד. מה ההשפעה הצפויה ביותר?","o":["האטה בהרפיית השריר עקב פינוי איטי של סידן מהציטוזול חזרה לרשתית הסרקופלזמית","כשל מוחלט בהתחלת הכיווץ עקב חוסר יכולת לשחרר סידן מהרשתית הסרקופלזמית","האצת ההרפיה עקב הצטברות סידן מהירה יותר ברשתית הסרקופלזמית","ירידה בפוטנציאל הפעולה של סיב השריר עקב הפרעה בזרם הנתרן"],"a":0,"e":"משאבת ה-SERCA (Ca-ATPase) שואבת סידן מהציטוזול חזרה לרשתית הסרקופלזמית (SR), וכך מורידה את ריכוז הסידן ומאפשרת הרפיה. פגיעה בה תאט את פינוי הסידן ותפגע בהרפיה — הסידן נשאר גבוה זמן רב, הגשרים נשארים פעילים, וההתכווצות מתארכת. מסיח ב שגוי: הכיווץ מתחיל משחרור סידן דרך RyR ואינו תלוי ב-SERCA, ולכן ההתחלה לא תיכשל. מסיח ג הפוך: פגיעה ב-SERCA מאטה ולא מאיצה הרפיה. מסיח ד שגוי: SERCA אינו נוגע לזרם הנתרן או לפוטנציאל הפעולה. טיפ לזכירה: 'SERCA מכבה את האור' — בלעדיה הסידן לא מתפנה, השריר 'תקוע' בכיווץ, וההרפיה נמשכת. זה הבסיס לחלק מההפרעות עם נוקשות שרירית."},
    {"topic":"פוטנציאל הפעולה בקוצב SA","q":"מהו המנגנון העיקרי האחראי לדפולריזציה הספונטנית האיטית (phase 4) של תאי הקוצב בצומת הסינו-אטריאלי (SA node)?","o":["זרם פנימה מהיר של נתרן דרך תעלות נתרן מהירות תלויות-מתח","זרם פנימה איטי המכונה זרם המצחיק (funny current, If) הנישא בעיקר על ידי נתרן, יחד עם זרמי סידן","זרם החוצה של אשלגן דרך תעלות אשלגן מתקנות (delayed rectifier) הגובר עם הזמן","פתיחה ממושכת של תעלות סידן מסוג L היוצרת את הרמה (plateau)"],"a":1,"e":"תאי הקוצב בצומת הסינו-אטריאלי (SA node) חסרים פוטנציאל מנוחה יציב. הדפולריזציה הספונטנית האיטית (phase 4) נובעת בעיקר מזרם פנימה איטי המכונה 'הזרם המצחיק' (funny current, If) הנישא בעיקר ע\"י נתרן דרך תעלות HCN, בתוספת זרמי סידן ההולכים ומצטברים. כך המתח מטפס לאט עד הסף ויוצר פעימה חדשה. מסיח א שגוי: תעלות נתרן מהירות כמעט נעדרות בקוצב, ופאזה 0 שם נישאת בעיקר ע\"י סידן. מסיח ג שגוי: זרם אשלגן החוצה גורם לרה-פולריזציה, לא לדפולריזציה. מסיח ד מתאר plateau של שריר הלב המתכווץ, לא קוצב. טיפ: If = 'המנוע העצמי של הקוצב'; חוסמי If (כמו איוואברדין) מאטים קצב לב."},
    {"topic":"פוטנציאל הפעולה בשריר הלב המתכווץ","q":"בפוטנציאל הפעולה של תא שריר הלב החדרי (ventricular myocyte), מה אחראי לשלב הרמה הממושכת (plateau, phase 2)?","o":["איזון בין זרם פנימה של סידן דרך תעלות מסוג L לבין זרם החוצה של אשלגן","זרם פנימה מהיר של נתרן דרך תעלות נתרן מהירות","זרם החוצה מהיר של אשלגן דרך תעלות מתקנות מהירות בלבד","סגירה מוחלטת של כל תעלות היונים והפסקת כל זרם דרך הקרום"],"a":0,"e":"שלב הרמה (plateau, phase 2) בפוטנציאל הפעולה של תא שריר הלב החדרי נובע מאיזון בין זרם פנימה של סידן (Ca2+) דרך תעלות מסוג L לבין זרם החוצה של אשלגן (K+). האיזון הזה משמר דה-פולריזציה ממושכת, מאריך את התקופה הרפרקטורית ומונע טטנוס בלב. מסיח ב שגוי: זרם הנתרן המהיר אחראי לפאזה 0 (העלייה המהירה), לא לרמה. מסיח ג שגוי: זרם אשלגן בלבד היה גורם לרה-פולריזציה מהירה ולא לרמה ממושכת. מסיח ד שגוי: דווקא יש זרמים פעילים בשיווי משקל. נקודת מפתח: הסידן הנכנס בפלאטו גם מזין את ה-CICR לכיווץ, ולכן הפלאטו 'מחבר' בין החשמל לכוח — וזו הסיבה שהלב לא יכול להיכנס לטטנוס מסוכן."},
    {"topic":"צימוד עירור-כיווץ בשריר הלב","q":"מהו ההבדל המהותי בצימוד עירור-כיווץ בין שריר הלב לשריר השלד?","o":["בשריר הלב הכיווץ אינו תלוי כלל בסידן, בניגוד לשריר השלד","בשריר הלב נדרשת כניסת סידן חוץ-תאי דרך תעלות L הגורמת לשחרור סידן מושרה-סידן (CICR) מה-SR, בעוד בשריר השלד הצימוד מכני-ישיר","בשריר השלד נדרשת כניסת סידן חוץ-תאי, ואילו בשריר הלב הצימוד מכני בלבד","בשני סוגי השריר הסידן מגיע אך ורק מהמרחב החוץ-תאי ללא מעורבות ה-SR"],"a":1,"e":"בשריר הלב כניסת סידן (Ca2+) חוץ-תאי דרך תעלות מסוג L (בזמן הפלאטו) מהווה טריגר לשחרור סידן מושרה-סידן (CICR) מהרשתית הסרקופלזמית (SR) דרך RyR2. בשריר השלד, לעומת זאת, הצימוד מכני-ישיר בין DHPR ל-RyR1 ואינו דורש כניסת סידן חוץ-תאי. מסיח א שגוי: בשני סוגי השריר הכיווץ תלוי בסידן. מסיח ג הפוך: דווקא הלב תלוי בסידן חוץ-תאי, לא השלד. מסיח ד שגוי: בשני המקרים ה-SR הוא מקור עיקרי לסידן. נקודת מפתח קלינית: מכיוון שהלב תלוי בסידן חוץ-תאי, חוסמי תעלות סידן L מפחיתים כיווציות לב — בעוד בשריר השלד השפעתם זניחה. זכור: 'לב צריך סידן מבחוץ כדי לשחרר סידן מבפנים'."},
    {"topic":"חוק פרנק-סטרלינג","q":"על פי חוק פרנק-סטרלינג (Frank-Starling), עלייה בנפח הדם החוזר ללב (preload) במהלך הדיאסטולה תגרום ל:","o":["ירידה בנפח הפעימה עקב מתיחת יתר של סיבי שריר הלב","עלייה בנפח הפעימה (stroke volume) עקב מתיחה מוגברת של סיבי שריר הלב והגדלת כוח ההתכווצות","עלייה בקצב הלב בלבד ללא שינוי בנפח הפעימה","ירידה בכוח ההתכווצות עקב הפעלת מנגנון מעכב עצבי"],"a":1,"e":"חוק פרנק-סטרלינג קובע שעלייה ב-preload (נפח קצה-דיאסטולי, החזר ורידי גדול יותר) מותחת את סיבי שריר הלב לקראת אורכם האופטימלי, מגבירה את רגישות חלבוני הכיווץ לסידן ואת מספר הגשרים הפעילים, וכך מגדילה את כוח ההתכווצות ואת נפח הפעימה (stroke volume). מסיח א שגוי: בלב הבריא, בתחום הפיזיולוגי, מתיחה מוגברת מגבירה כוח ולא מפחיתה. מסיח ג שגוי: השינוי הוא בנפח הפעימה, לא רק בקצב. מסיח ד שגוי: זהו מנגנון פנימי (intrinsic) ולא עכבה עצבית. נקודת מפתח: 'מה שנכנס — יוצא' — הלב מתאים אוטומטית את הפלט להחזר הוורידי, וכך שני החדרים נשארים מסונכרנים בנפחיהם ללא תיווך עצבי."},
    {"topic":"תפוקת לב - חישוב","q":"מטופל בעל קצב לב של 70 פעימות לדקה, נפח קצה-דיאסטולי (EDV) של 130 מ\"ל ונפח קצה-סיסטולי (ESV) של 60 מ\"ל. מהי תפוקת הלב (cardiac output)?","o":["כ-4.2 ליטר לדקה","כ-4.9 ליטר לדקה","כ-9.1 ליטר לדקה","כ-5.6 ליטר לדקה"],"a":1,"e":"חישוב: נפח הפעימה (SV) = EDV מינוס ESV = 130 פחות 60 = 70 מ\"ל. תפוקת הלב (CO) = קצב לב כפול נפח פעימה = 70 כפול 70 = 4900 מ\"ל לדקה = כ-4.9 ליטר לדקה. מסיח 4.2 ל'/דקה נובע משימוש שגוי ב-ESV (60) כ-SV. מסיח 9.1 ל'/דקה נובע משימוש בטעות ב-EDV (130) במקום ב-SV. מסיח 5.6 ל'/דקה נובע מ-SV שגוי של 80. נקודת מפתח לזכירה: תמיד חשב קודם SV = EDV − ESV, ורק אז הכפל בקצב הלב. שגיאה נפוצה היא לדלג על חיסור ה-ESV ולהכפיל ישירות בנפח לא נכון. ערך תקין של CO במנוחה הוא כ-5 ליטר לדקה, מה שמתאים לתוצאה כאן."},
    {"topic":"לחץ דם והתנגדות היקפית","q":"על פי הקשר בין לחץ, זרימה והתנגדות במחזור הדם, אם ההתנגדות ההיקפית הכוללת (TPR) עולה פי שניים ותפוקת הלב נשארת קבועה, מה יקרה ללחץ הדם העורקי הממוצע (MAP)?","o":["יישאר ללא שינוי משום ש-MAP אינו תלוי בהתנגדות","יוכפל, משום ש-MAP שווה בקירוב למכפלת תפוקת הלב בהתנגדות ההיקפית","ירד בחצי, משום שהתנגדות גבוהה יותר מפחיתה את הלחץ","יעלה פי ארבעה עקב יחס ריבועי בין התנגדות ללחץ"],"a":1,"e":"הקשר ההמודינמי הבסיסי הוא MAP שווה בקירוב לתפוקת הלב (CO) כפול ההתנגדות ההיקפית הכוללת (TPR) — אנלוגי לחוק אוהם (לחץ = זרימה כפול התנגדות, V=IR). אם תפוקת הלב קבועה וה-TPR מוכפל, ה-MAP מוכפל גם הוא. מסיח א שגוי: MAP בהחלט תלוי בהתנגדות. מסיח ג הפוך: התנגדות גבוהה יותר מעלה לחץ, לא מורידה. מסיח ד שגוי: הקשר ליניארי (יחס ישר), לא ריבועי. נקודת מפתח לזכירה: MAP ≈ CO × TPR — שני 'ידיות' שולטות בלחץ הדם: כמה הלב שואב, וכמה הכלים מתנגדים. תרופות ליתר לחץ דם פועלות בדיוק על שני המשתנים האלה (הפחתת CO או הרחבת כלים)."},
    {"topic":"מחזור הלב - מנגנון מסתמים","q":"באיזה שלב של מחזור הלב נפתחים המסתמים הסמי-לונריים (aortic ו-pulmonary)?","o":["בתחילת ההתכווצות האיזו-וולומטרית (isovolumetric contraction), עם תחילת עליית הלחץ החדרי","כאשר הלחץ בחדרים עולה על הלחץ באבי העורקים ובעורק הריאה, בתחילת שלב הפליטה (ejection)","בתחילת ההרפיה האיזו-וולומטרית, כאשר הלחץ החדרי יורד","בשלב מילוי החדרים, כאשר הלחץ העלייתי גבוה מהלחץ החדרי"],"a":1,"e":"המסתמים הסמי-לונריים (אבי העורקים והריאתי) נפתחים כאשר הלחץ בחדרים עולה על הלחץ בעורקים הגדולים, מה שמסמן את תחילת שלב הפליטה (ejection). מסיח א שגוי: בהתכווצות האיזו-וולומטרית כל ארבעת המסתמים סגורים והלחץ עדיין לא הגיע ללחץ העורקי. מסיח ג שגוי: בתחילת ההרפיה האיזו-וולומטרית הלחץ החדרי יורד והמסתמים הסמי-לונריים נסגרים (לא נפתחים). מסיח ד שגוי: בשלב המילוי נפתחים המסתמים האטריו-ונטריקולריים (מיטרלי וטריקוספידלי), לא הסמי-לונריים. טיפ לזכירה: מסתם נפתח רק כשהלחץ 'במעלה הזרם' גבוה מ'במורד' — סמי-לונרי נפתח כשהחדר 'מנצח' את אבי העורקים בלחץ."},
    {"topic":"השריר החלק","q":"מהו המנגנון המרכזי המתחיל את התכווצות השריר החלק (smooth muscle), בשונה משריר השלד?","o":["קישור סידן לטרופונין C המזיז את הטרופומיוזין וחושף את אתרי הקישור על האקטין","קישור סידן לקלמודולין (calmodulin), שמפעיל את האנזים myosin light chain kinase וגורם לזרחון של שרשרת המיוזין הקלה","שחרור אצטילכולין הגורם ישירות להזזת המיוזין ללא מעורבות סידן","דה-פוספורילציה של שרשרת המיוזין הקלה על ידי קינאז תלוי-סידן"],"a":1,"e":"בשריר החלק אין טרופונין. הסידן (Ca2+) שנכנס נקשר לקלמודולין (calmodulin), והקומפלקס סידן-קלמודולין מפעיל את האנזים myosin light chain kinase (MLCK), המזרחן את שרשרת המיוזין הקלה ובכך מאפשר את פעילות הגשרים הצולבים והכיווץ. מסיח א מתאר את המנגנון בשריר השלד והלב (קישור סידן לטרופונין C), לא בשריר החלק. מסיח ג שגוי: אצטילכולין אינו מזיז מיוזין ישירות, וסידן הכרחי. מסיח ד הפוך: דה-פוספורילציה ע\"י MLCP (פוספטאז) גורמת להרפיה, לא לכיווץ. נקודת מפתח לזכירה: שריר חלק = 'סידן-קלמודולין-MLCK-זרחון מיוזין'; שלד/לב = 'סידן-טרופונין'. ההסתמכות על זרחון (ולא על טרופונין) מסבירה את הכיווץ האיטי והמתמשך של שריר חלק."},
    {"topic":"מערכת ההולכה בלב","q":"מה תפקידו העיקרי של העיכוב (delay) בהולכה דרך הצומת האטריו-ונטריקולרי (AV node)?","o":["להאיץ את ההולכה כדי שהחדרים והעליות יתכווצו בו-זמנית","לאפשר לעליות לסיים את התכווצותן ולמלא את החדרים לפני שהחדרים מתכווצים","למנוע לחלוטין כל הולכה חשמלית מהעליות לחדרים","לייצר את פוטנציאל הפעולה הראשוני המתחיל את פעימת הלב"],"a":1,"e":"ההולכה האיטית דרך הצומת האטריו-ונטריקולרי (AV node) יוצרת עיכוב (delay) המאפשר לעליות לסיים את התכווצותן ולמלא את החדרים בדם (ה-'atrial kick') לפני שהחדרים מתכווצים, ובכך ממטב את המילוי החדרי ואת נפח הפעימה. מסיח א הפוך: העיכוב מאט, לא מאיץ, ואינו גורם לכיווץ בו-זמני של עליות וחדרים. מסיח ג שגוי: ה-AV node מאט אך אינו חוסם הולכה תקינה (חסם מלא הוא מצב פתולוגי). מסיח ד שגוי: הקוצב הראשוני שמתחיל את הפעימה הוא ה-SA node, לא ה-AV. נקודת מפתח לזכירה: ה-AV הוא 'בלם תזמון' — הוא מוודא שהעליות 'גמרו לדחוף' לפני שהחדרים סוחטים, וזה מבטיח מילוי יעיל."},
    {"topic":"ויסות לחץ הדם - בארורצפטורים","q":"בעקבות ירידה פתאומית בלחץ הדם העורקי, כיצד יגיב הרפלקס הבארורצפטורי (baroreceptor reflex)?","o":["הגברת פעילות הפאראסימפתטית והאטת קצב הלב כדי לשמר אנרגיה","הפחתת קצב הירי מהבארורצפטורים, הגברת פעילות סימפתטית והפחתת פעילות פאראסימפתטית, מה שמעלה קצב לב, כיווציות והתנגדות היקפית","הגברת קצב הירי מהבארורצפטורים, הגורמת לכיווץ כלי דם ולעלייה בקצב הלב","אין שינוי משום שהבארורצפטורים מגיבים רק לעלייה בלחץ"],"a":1,"e":"ירידה בלחץ הדם העורקי מפחיתה את מתיחת הבארורצפטורים (בקשת אבי העורקים ובסינוס הקרוטידי) ואת קצב הירי העצבי שלהם. הפחתה זו מסירה את העיכוב ממרכזי הבקרה: עולה הפעילות הסימפתטית ופוחתת הפאראסימפתטית, ולכן עולים קצב הלב, הכיווציות, נפח הפעימה וההתנגדות ההיקפית — כדי להחזיר את הלחץ לנורמה. מסיח א שגוי: הגברה פאראסימפתטית הייתה מאטה את הלב ומחמירה את הירידה בלחץ. מסיח ג שגוי: קצב הירי פוחת (לא עולה) בירידת לחץ. מסיח ד שגוי: הבארורצפטורים מגיבים לשינויים בשני הכיוונים. נקודת מפתח לזכירה: פחות מתיחה = פחות 'בלם' פאראסימפתטי = יותר 'גז' סימפתטי. רפלקס מהיר ושלילי-משוב שמייצב לחץ דם רגע-אחר-רגע."},
    {"topic":"נשימה - הובלת חמצן ועקומת הדיסוציאציה","q":"חולה במחלקה לטיפול נמרץ מפתח חמצת נשימתית עם ירידה ב-pH הדמי, עלייה ב-PCO2 ועלייה בטמפרטורת הגוף עקב חום. כיצד ישפיעו שינויים אלו על עקומת הדיסוציאציה של ההמוגלובין-חמצן (oxyhemoglobin dissociation curve) ועל זמינות החמצן לרקמות?","o":["העקומה תוסט שמאלה, מה שמגביר את זיקת ההמוגלובין לחמצן ומקל על שחרור החמצן ברקמות","העקומה תוסט ימינה (אפקט בוהר - Bohr effect), מה שמקטין את זיקת ההמוגלובין לחמצן ומגביר את שחרור החמצן ברקמות","העקומה תוסט שמאלה, מה שמקטין את זיקת ההמוגלובין לחמצן ומגביר את שחרור החמצן ברקמות","העקומה לא תושפע מאחר ושינויי pH ו-PCO2 מקזזים זה את זה, ושחרור החמצן יישאר ללא שינוי"],"a":1,"e":"ירידה ב-pH, עלייה ב-PCO2 ועלייה בטמפרטורה — כולן מסיטות את עקומת הדיסוציאציה של ההמוגלובין-חמצן ימינה (אפקט בוהר, Bohr effect). הסטה ימינה משמעה ירידה בזיקת ההמוגלובין לחמצן (P50 עולה), כך שההמוגלובין משחרר חמצן ביתר קלות לרקמות הזקוקות לו — בדיוק מה שצריך ברקמה פעילה או חמצתית. מסיח א שגוי: הסטה שמאלה מעלה זיקה ומקשה על שחרור. מסיח ג שוגה בקישור: הסטה שמאלה אינה מקטינה זיקה. מסיח ד שגוי: השינויים מצטברים לאותו כיוון, לא מקזזים. נקודת מפתח לזכירה: 'חם, חמוץ ומלא CO2 — מוסר חמצן' — רקמה עמלה ומחממת מאותתת להמוגלובין לפרוק שם את החמצן. בלבול נפוץ: לזכור שימינה = פחות זיקה = יותר שחרור."},
    {"topic":"כליה - ספיגה חוזרת והפרשה","q":"חומר X מסונן בגלומרולוס, ובנוסף מופרש באופן פעיל בטובול. הקלירנס (clearance) שלו נמדד כגבוה מהקלירנס של אינולין (inulin) באותו אדם. מה ניתן להסיק לגבי הטיפול של הכליה בחומר X?","o":["החומר עובר ספיגה חוזרת נטו, מאחר וקלירנס גבוה מעיד על שמירת החומר בגוף","החומר עובר הפרשה נטו, מאחר וקלירנס הגבוה מקלירנס האינולין מעיד שכמות גדולה יותר מופרשת מזו שסוננה","הקלירנס הגבוה מעיד שהחומר אינו מסונן כלל בגלומרולוס אלא רק מופרש","קלירנס גבוה מאינולין בלתי אפשרי פיזיולוגית ומעיד על טעות מדידה"],"a":1,"e":"קלירנס האינולין (inulin) שווה ל-GFR, מאחר שאינולין רק מסונן בגלומרולוס ואינו נספג ואינו מופרש. חומר X שהקלירנס שלו גבוה מ-GFR חייב לעבור הפרשה טובולרית נטו — כלומר הטובול מוסיף אותו לשתן מעבר לכמות שסוננה (כמו PAH). מסיח א הפוך: קלירנס גבוה מעיד על סילוק מוגבר, לא על שמירה; ספיגה חוזרת נטו דווקא מורידה קלירנס מתחת ל-GFR. מסיח ג שגוי: החומר כן מסונן (הוא קטן דיו), בנוסף להפרשתו. מסיח ד שגוי: קלירנס גבוה מ-GFR אפשרי ושכיח (PAH). נקודת מפתח לזכירה: 'קלירנס > GFR ⟸ הפרשה'; 'קלירנס < GFR ⟸ ספיגה חוזרת'; 'קלירנס = GFR ⟸ רק סינון' (אינולין). זו אבן יסוד לחישובי תפקוד כלייתי."},
    {"topic":"אנדוקרינית - אינסולין וגלוקגון","q":"בצום, רמת הגלוקוז בדם נשמרת תקינה למרות היעדר צריכת מזון. אילו שינויים הורמונליים ומטבוליים אחראים בעיקר לשמירה על נורמוגליקמיה במצב זה?","o":["עלייה באינסולין (insulin) שמגרה גלוקונאוגנזה (gluconeogenesis) בכבד","ירידה ביחס אינסולין/גלוקגון, המגבירה גליקוגנוליזה (glycogenolysis) וגלוקונאוגנזה כבדית ומובילה לקטוגנזה","עלייה באינסולין במקביל לעלייה בגלוקגון, המגבירים יחד פירוק גליקוגן","ירידה בגלוקגון (glucagon) ועלייה באינסולין, המעודדות אגירת גלוקוז"],"a":1,"e":"בצום היחס אינסולין/גלוקגון יורד: האינסולין יורד והגלוקגון עולה. גלוקגון מגרה בכבד גליקוגנוליזה (glycogenolysis) בשלבים מוקדמים, ובצום ממושך גם גלוקונאוגנזה (gluconeogenesis), ומקדם קטוגנזה לאספקת אנרגיה חלופית למוח — וכך נשמרת נורמוגליקמיה. מסיח א שגוי: אינסולין הוא הורמון אנבולי ואינו 'מגרה גלוקונאוגנזה'; רמתו יורדת בצום. מסיח ג שגוי: אינסולין וגלוקגון נעים בכיוונים מנוגדים, ואינסולין דווקא מעכב פירוק גליקוגן. מסיח ד הפוך לחלוטין: בצום הגלוקגון עולה והאינסולין יורד, ואין אגירה. נקודת מפתח לזכירה: צום = 'דלק מהמאגרים' — גלוקגון 'פותח את הכספת' הכבדית, אינסולין (הורמון השובע) נסוג. היחס בין השניים, לא ערך מוחלט, הוא שמכריע."},
    {"topic":"כליה - מערכת רנין-אנגיוטנסין-אלדוסטרון","q":"חולה מקבל מעכב אנזים ההמרה של אנגיוטנסין (ACE inhibitor). מהי ההשפעה הצפויה על הטונוס של עורקיק היוצא (efferent arteriole) בגלומרולוס ועל ה-GFR, בהינתן שאנגיוטנסין II מכווץ באופן מועדף את העורקיק היוצא?","o":["העורקיק היוצא יתרחב, לחץ הסינון הגלומרולרי יירד וה-GFR ייטה לרדת","העורקיק היוצא יתכווץ יותר, לחץ הסינון יעלה וה-GFR יעלה","העורקיק הנכנס (afferent) יתכווץ והעורקיק היוצא יתרחב, ללא שינוי נטו ב-GFR","ה-GFR יעלה משמעותית מאחר ועיכוב אנגיוטנסין II מרחיב את שני העורקיקים באופן שווה"],"a":0,"e":"אנגיוטנסין II מכווץ באופן מועדף את העורקיק היוצא (efferent), ובכך שומר על הלחץ ההידרוסטטי הגלומרולרי ועל ה-GFR כשזרימת הדם הכלייתית יורדת. עיכוב יצירתו ב-ACE inhibitor מביא להרחבת העורקיק היוצא, לירידה בלחץ ההידרוסטטי הגלומרולרי ולירידה ב-GFR. מסיח ב הפוך: עיכוב אנגיוטנסין II מרחיב את היוצא, לא מכווץ אותו. מסיח ג שגוי: העורקיק הנכנס אינו מתכווץ כתוצאה מהתרופה. מסיח ד שגוי: ההשפעה אינה אחידה על שני העורקיקים, והתוצאה היא ירידת GFR. נקודת מפתח קלינית: בחולים עם היצרות דו-צדדית של עורקי הכליה, ACE inhibitor עלול להוריד GFR בחדות — כי הכליה הסתמכה על כיווץ העורקיק היוצא כדי לשמר סינון. 'אנגיוטנסין II מהדק את הברז ביציאה'."},
    {"topic":"נשימה - הובלת CO2","q":"כיצד מובל מרבית ה-CO2 המיוצר ברקמות בדם הוורידי אל הריאות, ומהו תפקיד אנזים האנהידרז הפחמני (carbonic anhydrase) בכדוריות הדם האדומות בתהליך זה?","o":["מרבית ה-CO2 מובל כ-CO2 מומס בפלזמה; האנהידרז הפחמני אינו מעורב בהובלה","מרבית ה-CO2 מובל כיון ביקרבונט (HCO3-); האנהידרז הפחמני בכדוריות מזרז הפיכת CO2 ומים לחומצה פחמתית המתפרקת ל-HCO3- ול-H+","מרבית ה-CO2 מובל קשור להמוגלובין כקרבמינו-המוגלובין; האנהידרז הפחמני מפרק קשר זה","מרבית ה-CO2 מובל כחומצה פחמתית (H2CO3) יציבה בפלזמה ללא צורך באנזים"],"a":1,"e":"כ-70% מה-CO2 מובל בדם בצורת יון ביקרבונט (HCO3-). אנזים האנהידרז הפחמני (carbonic anhydrase) בכדוריות הדם האדומות מזרז את הפיכת CO2 ומים לחומצה פחמתית (H2CO3), המתפרקת מיד ל-HCO3- ול-H+. ה-HCO3- יוצא מהכדורית לפלזמה בתמורה לכניסת כלוריד (chloride shift). כ-7% מובל מומס בפלזמה וכ-23% קשור כקרבמינו-המוגלובין. מסיח א ממעיט: רק חלק קטן מובל מומס. מסיח ג מנפח את חלק הקרבמינו (זו צורה משנית). מסיח ד שגוי: H2CO3 אינה יציבה ואינה הצורה העיקרית, והאנזים הכרחי. נקודת מפתח לזכירה: ביקרבונט הוא 'אוטובוס' עיקרי ל-CO2; האנהידרז הפחמני הוא ה'מאיץ' שהופך CO2 לצורה מסיסה זו, ו-chloride shift שומר על מאזן מטענים."},
    {"topic":"אנדוקרינית - בלוטת התריס","q":"חולה עם תת-פעילות ראשונית של בלוטת התריס (primary hypothyroidism) עקב הרס הבלוטה עצמה. מה צפוי להימצא בבדיקות הורמונליות בהתאם ללולאת המשוב של ציר היפותלמוס-יותרת המוח-תריס?","o":["T4 נמוך ו-TSH נמוך, מאחר וכל הציר מדוכא","T4 נמוך ו-TSH גבוה, מאחר וירידת הורמוני התריס מסירה את העכבה השלילית על הפרשת TSH","T4 גבוה ו-TSH נמוך, עקב משוב שלילי תקין","T4 תקין ו-TSH גבוה, מאחר והבלוטה מפצה במלואה"],"a":1,"e":"בתת-פעילות ראשונית של בלוטת התריס (primary hypothyroidism) הפגיעה היא בבלוטה עצמה, ולכן יורדים T4 ו-T3. ירידה זו מסירה את המשוב השלילי על ההיפותלמוס ויותרת המוח, ולכן הפרשת TSH (וגם TRH) עולה. הצירוף הקלאסי הוא T4 נמוך עם TSH גבוה. מסיח א מתאר מצב מרכזי (פגיעה ביותרת המוח), שבו ה-TSH נמוך/לא-מתאים — לא ראשוני. מסיח ג מתאר משוב תקין/יתר-פעילות (T4 גבוה, TSH נמוך), הפוך. מסיח ד שגוי: אם הבלוטה הרוסה, היא אינה 'מפצה במלואה'. נקודת מפתח לזכירה: בבעיה ראשונית, ההורמון ההיקפי וההורמון המעורר נעים בכיוונים מנוגדים (T4 ↓, TSH ↑). TSH הוא הבדיקה הרגישה ביותר לאיתור תת-פעילות ראשונית."},
    {"topic":"נשימה - ויסות נשימה","q":"אדם בריא נמצא בגובה רב, וה-PO2 העורקי שלו יורד. מהו החיישן העיקרי האחראי לגירוי האוורור (hyperventilation) בתגובה להיפוקסמיה זו, וכיצד הוא שונה מהחיישן המגיב בעיקר ל-CO2?","o":["הכימורצפטורים המרכזיים (central chemoreceptors) במוח מגיבים ישירות לירידת PO2","הכימורצפטורים ההיקפיים (peripheral chemoreceptors) בגופיפי התרדמה והאבי-עורקים מגיבים לירידת PO2; הכימורצפטורים המרכזיים מגיבים בעיקר לעלייה ב-PCO2/ירידת pH בנוזל המוח","הכימורצפטורים המרכזיים מגיבים ל-PO2 וההיקפיים מגיבים בלעדית ל-pH","שני סוגי הכימורצפטורים מגיבים באופן זהה לירידת PO2 ולעליית PCO2"],"a":1,"e":"בגובה רב ה-PO2 העורקי יורד (היפוקסמיה). החיישנים העיקריים שמגיבים לירידת PO2 הם הכימורצפטורים ההיקפיים (peripheral) בגופיפי התרדמה (carotid bodies) ובגופיפי אבי-העורקים — הם מגרים אוורור-יתר (hyperventilation). הכימורצפטורים המרכזיים (central) במוח אינם רגישים ל-PO2; הם מגיבים בעיקר לעליית PCO2 דרך שינוי ב-pH של נוזל המוח (CSF). מסיח א שגוי: המרכזיים אינם מגיבים ישירות ל-PO2. מסיח ג שגוי: ההיקפיים מגיבים גם ל-PO2, לא בלעדית ל-pH, והמרכזיים אינם חשי PO2. מסיח ד שגוי: התגובות אינן זהות. נקודת מפתח לזכירה: 'היקפיים = חיישני חמצן (O2)'; 'מרכזיים = חיישני CO2/pH'. בגובה, החמצן הנמוך מורגש דרך הגופיפים ההיקפיים."},
    {"topic":"כליה - ריכוז השתן ו-ADH","q":"לאחר שתיית כמות גדולה של מים, מהו רצף השינויים הפיזיולוגי שמוביל להפרשת שתן מדולל, וכיצד מעורב בכך ההורמון האנטי-דיורטי (ADH / vasopressin)?","o":["ירידת אוסמולליות הפלזמה מדכאת הפרשת ADH; ירידת ADH מקטינה את חדירות הצינורית המאספת למים, ומאפשרת הפרשת שתן מדולל","עלייה באוסמולליות הפלזמה מגבירה הפרשת ADH המוביל לשתן מדולל","ירידת אוסמולליות הפלזמה מגבירה הפרשת ADH, המגביר ספיגת מים בצינורית המאספת","ADH אינו משתנה; דילול השתן נובע אך ורק מעלייה ב-GFR"],"a":0,"e":"שתיית מים מדללת את הפלזמה ומורידה את אוסמולליותה. אוסמורצפטורים בהיפותלמוס חשים זאת ומדכאים את הפרשת ההורמון האנטי-דיורטי (ADH/vasopressin) מיותרת המוח האחורית. ירידת ה-ADH מקטינה את מספר תעלות המים (aquaporin-2) בצינורית המאספת, מפחיתה את חדירותה למים, ולכן נשמר נפח גדול של שתן מדולל. מסיח ב שגוי: ירידת אוסמולליות מדכאת ADH ואינה מובילה ישירות לשתן מדולל דרך עלייתו. מסיח ג הפוך: דילול מדכא ADH, לא מגביר; ADH גבוה דווקא היה מרכז שתן. מסיח ד שגוי: ADH הוא השחקן המרכזי, לא רק GFR. נקודת מפתח לזכירה: 'דילול ⟸ ADH יורד ⟸ aquaporin פחות ⟸ שתן מדולל ורב'. ADH הוא 'ברז המים' של הצינורית המאספת."},
    {"topic":"אנדוקרינית - אדרנל","q":"חולה מאובחן עם מחלת אדיסון (Addison's disease) - אי-ספיקה ראשונית של קליפת האדרנל. אילו שינויים במאזן הנתרן, האשלגן ולחץ הדם צפויים, בהתחשב במחסור באלדוסטרון (aldosterone)?","o":["אצירת נתרן, איבוד אשלגן ויתר לחץ דם, עקב עודף אלדוסטרון","איבוד נתרן, אצירת אשלגן ותת לחץ דם, עקב מחסור באלדוסטרון","אצירת נתרן ואשלגן יחד עם יתר לחץ דם","איבוד נתרן ואשלגן יחד עם לחץ דם תקין"],"a":1,"e":"אלדוסטרון מגרה בצינורית המאספת ספיגת נתרן (Na+, ועמו מים) והפרשת אשלגן (K+). במחלת אדיסון (אי-ספיקה ראשונית של קליפת האדרנל) מחסור באלדוסטרון גורם לאיבוד נתרן ומים (היפונתרמיה ותת לחץ דם, אף עד הלם) ולאצירת אשלגן (היפרקלמיה). מסיח א מתאר עודף אלדוסטרון (היפראלדוסטרוניזם/תסמונת קון), הפוך. מסיח ג שגוי: נתרן ואשלגן נעים בכיוונים מנוגדים תחת אלדוסטרון, ובאדיסון אין אצירת נתרן. מסיח ד שגוי: יש שינוי משמעותי בלחץ הדם (תת-לחץ). נקודת מפתח לזכירה: 'אין אלדוסטרון ⟸ מאבדים מלח ומים, אוצרים אשלגן' — היפונתרמיה, היפרקלמיה ותת-לחץ דם. באדיסון ראשונית יש גם עלייה ב-ACTH והיפר-פיגמנטציה, ומחסור בקורטיזול."},
    {"topic":"כליה - מאזן חומצה-בסיס","q":"חולה סוכרת מפתח חמצת קטוטית (diabetic ketoacidosis) עם ירידה חדה ב-pH הדם. כיצד מגיבות הריאות והכליות לפיצוי על החמצת המטבולית?","o":["הריאות מפחיתות אוורור לאצירת CO2, והכליות מפרישות פחות H+","הריאות מגבירות אוורור (תבנית קוסמאול) להורדת PCO2, והכליות מגבירות הפרשת H+ וייצור HCO3- חדש","הריאות מגבירות אוורור והכליות מפרישות יותר HCO3- בשתן","הריאות והכליות אינן מעורבות בפיצוי; הפיצוי נעשה רק בעצמות"],"a":1,"e":"בחמצת מטבולית (כמו חמצת קטוטית סוכרתית) הפיצוי הנשימתי מהיר: הגברת אוורור (נשימת קוסמאול, עמוקה ומהירה) מורידה את ה-PCO2 ומעלה את ה-pH לכיוון התקין. הפיצוי הכלייתי איטי יותר וכולל הגברת הפרשת H+ (כיוני אמוניום ופוספט) וייצור HCO3- חדש שמוחזר לדם. מסיח א הפוך לגמרי: בחמצת מגבירים אוורור (לא מפחיתים) ומפרישים יותר H+ (לא פחות). מסיח ג שגוי: בחמצת הכליות אוצרות HCO3- ולא מפרישות אותו לשתן. מסיח ד שגוי: הריאות והכליות הן עיקר הפיצוי, לא העצמות. נקודת מפתח לזכירה: 'חמצת ⟸ נושפים CO2 (חומצה) החוצה ומייצרים בסיס (HCO3-)'. הריאות מגיבות בדקות, הכליות בימים."},
    {"topic":"נשימה - אוורור ומכניקת נשימה","q":"במהלך שאיפה רגילה (inspiration) במנוחה, אילו שינויים מתרחשים בלחץ התוך-צדרי (intrapleural pressure) ובלחץ הנאדי (alveolar pressure), ומה מניע את זרימת האוויר לריאות?","o":["הלחץ התוך-צדרי נעשה פחות שלילי והלחץ הנאדי עולה מעל הלחץ האטמוספרי, מה שדוחף אוויר החוצה","הלחץ התוך-צדרי נעשה שלילי יותר והלחץ הנאדי יורד מתחת ללחץ האטמוספרי, מה שיוצר מפל לחצים המכניס אוויר","שני הלחצים עולים מעל הלחץ האטמוספרי בעת השאיפה","הלחץ הנאדי נשאר זהה ללחץ האטמוספרי לאורך כל מחזור הנשימה"],"a":1,"e":"בשאיפה (inspiration) התכווצות הסרעפת ושרירי הבין-צלעות החיצוניים מרחיבה את בית החזה, ולכן הלחץ התוך-צדרי (intrapleural) נעשה שלילי יותר (מ-כ-5- ל-כ-8- ס\"מ מים). התרחבות הריאות מורידה את הלחץ הנאדי (alveolar) מעט מתחת ללחץ האטמוספרי, ונוצר מפל לחצים המכניס אוויר פנימה. מסיח א הפוך: בשאיפה הלחץ התוך-צדרי שלילי יותר, והלחץ הנאדי יורד (לא עולה). מסיח ג שגוי: עליית שני הלחצים מעל האטמוספרי מאפיינת נשיפה כפויה. מסיח ד שגוי: הלחץ הנאדי משתנה במהלך המחזור (שווה לאטמוספרי רק בנקודות מנוחה). נקודת מפתח לזכירה: 'שאיפה = הכל נעשה יותר שלילי, והאוויר נשאב פנימה'. הלחץ התוך-צדרי תמיד שלילי כדי לשמור ריאה פתוחה."},
    {"topic":"כליה - סינון גלומרולרי GFR","q":"בחולה עם התייבשות קשה חלה ירידה חדה בלחץ הדם העורקי. מהו מנגנון הוויסות העצמי (autoregulation) הכלייתי שמנסה לשמור על GFR יציב, ומה קורה כאשר לחץ הדם יורד מתחת לטווח הוויסות העצמי?","o":["הוויסות העצמי שומר על GFR קבוע בכל טווח לחצי דם, ולכן GFR לעולם אינו יורד","במנגנון העורקיק הנכנס מתכווץ בעליית לחץ ומתרחב בירידת לחץ; מתחת לטווח הוויסות העצמי (כ-70 ממ\"כ) הוויסות נכשל וה-GFR יורד","הוויסות העצמי פועל רק על העורקיק היוצא; ירידת לחץ אינה משפיעה על GFR","הוויסות העצמי מגביר GFR ככל שלחץ הדם יורד, כפיצוי"],"a":1,"e":"הוויסות העצמי הכלייתי (autoregulation), דרך המנגנון המיוגני ומשוב טובולו-גלומרולרי, שומר על GFR וזרימת דם כלייתית יציבים יחסית בטווח לחץ עורקי של כ-70 עד 180 ממ\"כ — בעיקר על ידי כיווץ והרחבה של העורקיק הנכנס (afferent): התכווצות בעליית לחץ, התרחבות בירידת לחץ. כאשר לחץ הדם יורד מתחת לכ-70 ממ\"כ, הוויסות כבר אינו מסוגל לפצות וה-GFR יורד בחדות. מסיח א שגוי: ל-autoregulation יש גבולות, וה-GFR כן יורד מתחתם. מסיח ג שגוי: הוויסות פועל בעיקר על העורקיק הנכנס. מסיח ד הפוך: הוויסות אינו 'מגביר' GFR ככל שהלחץ יורד. נקודת מפתח לזכירה: הכליה מגינה על הסינון בטווח לחצים רחב, אך בהתייבשות קשה (לחץ מתחת לרצפה) — ההגנה נשברת ומתפתחת פגיעה כלייתית."},
    {"topic":"אנדוקרינית - ציר היפותלמוס-יותרת המוח","q":"חולה מקבל טיפול ממושך במינון גבוה של גלוקוקורטיקואידים (glucocorticoids) חיצוניים. מהי ההשפעה הצפויה על ציר היפותלמוס-יותרת המוח-אדרנל ועל קליפת האדרנל של החולה?","o":["עלייה בהפרשת CRH ו-ACTH, והיפרטרופיה של קליפת האדרנל","דיכוי הפרשת CRH ו-ACTH דרך משוב שלילי, וניוון (atrophy) של אזורי קליפת האדרנל המייצרים קורטיזול","עלייה בהפרשת ACTH בלבד ללא השפעה על האדרנל","היעדר השפעה על הציר, מאחר וגלוקוקורטיקואידים חיצוניים אינם משתתפים במשוב"],"a":1,"e":"גלוקוקורטיקואידים חיצוניים (glucocorticoids) במינון גבוה פועלים כמו קורטיזול אנדוגני ומפעילים משוב שלילי על ההיפותלמוס (דיכוי CRH) ועל יותרת המוח (דיכוי ACTH). ירידת ה-ACTH הממושכת גורמת לניוון (atrophy) של אזורי הזונה פסיקולטה והזונה רטיקולריס בקליפת האדרנל, המייצרים קורטיזול. מסיח א הפוך: המשוב מדכא CRH ו-ACTH ואינו מעלה אותם, ואין היפרטרופיה. מסיח ג שגוי: ה-ACTH יורד (לא עולה), ויש השפעה על האדרנל. מסיח ד שגוי: סטרואידים חיצוניים בהחלט משתתפים במשוב. נקודת מפתח קלינית: בגלל הניוון, הפסקה פתאומית של טיפול ממושך עלולה לגרום אי-ספיקת אדרנל חריפה — ולכן גומלים מסטרואידים בהדרגה (tapering). 'סטרואיד מבחוץ מרדים את הציר מבפנים'."},
    {"topic":"נשימה - חילופי גזים","q":"חולה מפתח בצקת ריאות עם הצטברות נוזל בממברנת חילופי הגזים, מה שמגדיל את מרחק הדיפוזיה בנאדיות. בהתחשב בחוק פיק לדיפוזיה (Fick's law), על העברת איזה גז תושפע ההיפוקסמיה בעיקר, ומדוע דווקא הוא ולא ה-CO2?","o":["העברת ה-CO2 תיפגע ראשונה מאחר וה-CO2 מתפזר לאט מ-O2","העברת ה-O2 תיפגע משמעותית יותר; ל-CO2 מקדם מסיסות/דיפוזיה גבוה פי כ-20 ולכן הוא ממשיך להתפזר ביעילות גם דרך מחסום מעובה","שני הגזים ייפגעו במידה זהה מאחר וגודל המולקולות זהה","אף גז לא יושפע מאחר ועיבוי הממברנה אינו משנה דיפוזיה"],"a":1,"e":"לפי חוק פיק לדיפוזיה, קצב המעבר יחסי הפוך לעובי הממברנה (מרחק הדיפוזיה) ויחסי למקדם הדיפוזיה/מסיסות של הגז. ל-CO2 מסיסות גבוהה בהרבה במים ומקדם דיפוזיה גבוה פי כ-20 מ-O2, ולכן הוא ממשיך להתפזר ביעילות גם דרך ממברנה מעובה (בצקת ריאות). ה-O2, בעל מסיסות נמוכה, רגיש הרבה יותר לעיבוי, ולכן בהפרעות דיפוזיה ההיפוקסמיה (חוסר חמצן) מקדימה את אצירת ה-CO2. מסיח א שגוי ומבטא בלבול: ה-CO2 דווקא 'מנצח' בדיפוזיה בזכות מסיסותו. מסיח ג שגוי: גודל המולקולה אינו הגורם המכריע — המסיסות היא. מסיח ד שגוי: עיבוי הממברנה בהחלט פוגע בדיפוזיה. נקודת מפתח לזכירה: 'בעיית דיפוזיה = בעיית חמצן ראשית'; ה-CO2 כמעט תמיד מצליח לצאת בזכות מסיסותו הגבוהה."},
    {"topic":"סוגי סיבי שריר השלד","q":"מה ההבדל בין שריר type I לשריר type IIb?","o":["העייפות איטית יותר ב-type II","סוג 2 נסמך על חמצון","סוג 1 מתכווץ חלש יותר/לאט יותר","סוג 2 יותר אירובי"],"a":2,"e":"סיב type I (איטי, חמצוני, עמיד בעייפות) מתכווץ לאט וחלש יחסית, בעוד type IIb (מהיר, גליקוליטי) מתכווץ חזק ומהר אך מתעייף מהר. ניתוח מסיחים: (א) הפוך — type II מתעייף מהר יותר; (ב),(ד) הפוך — type II גליקוליטי ואנאירובי יותר, type I הוא החמצוני/האירובי."},
    {"topic":"צימוד עירור-כיווץ בשריר השלד","q":"מה קורה מייד לאחר קישור אצטילכולין לרצפטור הניקוטיני על ממברנת שריר השלד?","o":["שחרור סידן ממאגרים","דה-פולריזציה בלוחית הקצה (End Plate Potential)","דה-פולריזציה ב-t-tubules","פירוק אצטילכולין"],"a":1,"e":"קישור ACh לרצפטור הניקוטיני פותח תעלה יונוטרופית, יוני נתרן נכנסים ונוצרת דה-פולריזציה מקומית — פוטנציאל לוחית הקצה (EPP). ניתוח מסיחים: (א) שחרור סידן מה-SR בא בהמשך השרשרת; (ג) הדה-פולריזציה ב-t-tubules מגיעה אחרי שה-EPP מצית פוטנציאל פעולה; (ד) פירוק ה-ACh ע'י אצטילכולין-אסטראז הוא שלב מאוחר וסיומי."},
    {"topic":"העברה סינפטית","q":"מה התפקיד של אסטרוציטים?","o":["ויסות אשלגן ופינוי נוירוטרנסמיטרים","משהו עם מיאלינציה","משהו של מערכת החיסון","העברת CSF"],"a":0,"e":"אסטרוציטים שומרים על הומאוסטזיס בסביבת הנוירונים — מווסתים את ריכוז האשלגן החוץ-תאי ומפנים נוירוטרנסמיטרים (כמו גלוטמט) מהמרווח הסינפטי. ניתוח מסיחים: (ב) מיאלינציה ב-CNS היא תפקיד אוליגודנדרוציטים; (ג) פעילות חיסונית/פאגוציטוזה היא תפקיד מיקרוגליה; (ד) ייצור CSF הוא תפקיד מקלעת הדמים (choroid plexus)."},
    {"topic":"מודולציה של כוח - גיוס וסיכום","q":"מתי השריר יפעיל הכי הרבה כוח?","o":["כשהסרקומרים הכי קצרים","כשהסרקומרים הכי ארוכים","כשהחפיפה בין אקטין למיוזין אופטימלית","כשהמתח הפסיבי מקסימלי"],"a":2,"e":"לפי עקומת אורך-מתח, הכוח הפעיל המרבי מושג באורך הסרקומר שבו החפיפה בין חוטי האקטין למיוזין אופטימלית — מספר מרבי של גשרי-רוחב פעילים. ניתוח מסיחים: (א),(ב) בקצוות (קצר/ארוך מדי) החפיפה ירודה והכוח יורד; (ד) מתח פסיבי מקסימלי אינו מתאר כוח פעיל מרבי."},
    {"topic":"הולכה קפיצנית ומיאלין","q":"מה מגדיר נכון את ההבדל העקרוני בין אוליגודנדרוציטים לתאי שוואן?","o":["אוליגודנדרוציטים עוטפים במיאלין אקסונים של מספר תאי עצב ב-CNS; תאי שוואן עוטפים אקסון בודד ב-PNS","אוליגודנדרוציטים בונים סינפסת עצב-שריר…","אוליגודנדרוציטים מרובי-גרעינים; תאי שוואן בעלי וזיקולות רבות","חסר"],"a":0,"e":"אוליגודנדרוציט יחיד (ב-CNS) שולח זרועות ועוטף במיאלין מקטעים של כמה אקסונים שונים; תא שוואן (ב-PNS) עוטף מקטע מיאלין יחיד של אקסון בודד. ניתוח מסיחים: (ב),(ג) שגויים עובדתית; (ד) חסר."},
    {"topic":"צימוד עירור-כיווץ בשריר השלד","q":"למה צריך את ה-t-tubules?","o":["להעביר את פוטנציאל הפעולה לעומק התא","ליצור תמיכה מבנית","לשמש מאגר סידן","משהו עם פ\"פ"],"a":0,"e":"ה-t-tubules הם הצטלקויות של קרום התא הנכנסות לעומק הסיב ומעבירות את פוטנציאל הפעולה פנימה — כך הדה-פולריזציה מגיעה בו-זמנית לכל המיופיברילים ומפעילה שחרור סידן אחיד מה-SR. ניתוח מסיחים: (ב) אינם אלמנט תומך מבני; (ג) מאגר הסידן הוא ה-SR, לא ה-t-tubules; (ד) שוחזר חלקית."},
    {"topic":"מבנה הקרום - אסימטריה ונזילות","q":"מה מעלה את נזילות (פלואידיות) הממברנה?","o":["כיפוף מחומצות שומן לא-רוויות ומבני ציטוסקלטון","חומצות שומן רוויות וכולסטרול בריכוז גבוה","חומצות שומן רוויות וירידה בטמפרטורה","כיפוף מחומצות שומן לא-רוויות ועלייה בטמפרטורה"],"a":3,"e":"קשרים כפולים בחומצות שומן לא-רוויות יוצרים 'כיפוף' שמונע אריזה צפופה, ועלייה בטמפרטורה מגבירה תנועה — שניהם מעלים נזילות. ניתוח מסיחים: (ב),(ג) חומצות שומן רוויות, כולסטרול (בטמפ' גבוהה) וטמפרטורה נמוכה דווקא מורידים נזילות; (א) מערב מבני ציטוסקלטון שאינם הגורם העיקרי לנזילות."},
    {"topic":"העברה סינפטית","q":"מה ההבדל בין סינפסה כימית לסינפסה חשמלית (gap junction)?","o":["החשמלית מקשרת בין הציטופלזמות של התאים והכימית לא","נגיעה של ממברנות","GAP מורכב מחלבון קונקסין","חסר"],"a":0,"e":"בסינפסה חשמלית ערוצי gap junction מחברים ישירות את הציטופלזמות של שני התאים ומאפשרים מעבר זרם מיידי; בסינפסה כימית אין רציפות ציטופלזמית — האות מועבר ע'י נוירוטרנסמיטר דרך המרווח. ניתוח מסיחים: (ב) ניסוח חלקי; (ג) נכון עובדתית (GAP בנוי מקונקסינים) אך אינו 'ההבדל' המבוקש; (ד) חסר."},
    {"topic":"מודולציה של כוח - גיוס וסיכום","q":"מה מאפשר חזרה למצב בסיס/שומר על הכוח הפסיבי בשריר?","o":["מתיחת טיטין","ה-cross bridge תמיד עובד","שימוש ב-ATP","רמות סידן גבוהות"],"a":0,"e":"טיטין הוא הקפיץ האלסטי שמספק את הכוח הפסיבי ומחזיר את הסרקומר לאורכו לאחר מתיחה — ללא צריכת אנרגיה. ניתוח מסיחים: (ב) גשרי-הרוחב פועלים בכיווץ אקטיבי, לא בשמירת מתח פסיבי; (ג) הכוח הפסיבי אינו תלוי ATP; (ד) רמות סידן גבוהות מפעילות כיווץ אקטיבי, לא מתח פסיבי."},
    {"topic":"פוטנציאל פעולה","q":"למה בפוטנציאל פעולה מתח הממברנה מתקרב לפוטנציאל נרנסט של נתרן?","o":["כי מתח הממברנה נוטה ליון בעל מספר התעלות הפתוחות הגדול ביותר — ובשיא הספייק רוב תעלות הנתרן פתוחות","יעברו מים בין התאים","מים לא יעברו","—"],"a":0,"e":"מתח הממברנה נקבע ע'י היון שלו החדירות (מספר התעלות הפתוחות) הגבוהה ביותר באותו רגע. בשלב העולה של פוטנציאל הפעולה נפתחות המוני תעלות נתרן, חדירות הנתרן מזנקת, ולכן Vm נדחף לכיוון פוטנציאל נרנסט של הנתרן (E_Na). ניתוח מסיחים: (ב),(ג) עוסקים במעבר מים — אינם רלוונטיים; (ד) ריק (שאריות שחזור)."},
    {"topic":"פוטנציאל פעולה","q":"מהו המשפט הנכון ביותר שמתאר מתח סף?","o":["היפוך מתח משלילי לחיובי","פתיחת תעלות נתרן שפותחות עוד תעלות נתרן","חסר","חסר"],"a":1,"e":"מתח הסף הוא הנקודה שבה פתיחת תעלות נתרן תלויות-מתח הופכת לתהליך מתחזק-עצמו (משוב חיובי): כניסת נתרן מדה-פולריזת ופותחת עוד תעלות נתרן, עד להצתת פוטנציאל פעולה 'הכל-או-כלום'. ניתוח מסיחים: (א) היפוך המתח לחיובי (overshoot) הוא תוצאה של חציית הסף, לא הגדרתו; (ג),(ד) חסרים בשחזור."},
    {"topic":"העברה סינפטית","q":"מה תהיה התוצאה הישירה של עיכוב אצטילכולין-אסטראז?","o":["שחרור מוגבר של סידן מהתא הפרה-סינפטי","משהו עם יוני אשלגן","רה-פולריזציה ממושכת של התא הפוסט-סינפטי","הארכה והגברה של האות הפוסט-סינפטי"],"a":3,"e":"אצטילכולין-אסטראז מפרק את ה-ACh במרווח; עיכובו גורם להצטברות ACh, להישארותו ארוכה יותר על הרצפטור, ולכן להארכה ולהגברה של האות (הדה-פולריזציה) בתא הפוסט-סינפטי. ניתוח מסיחים: (א) אינו משפיע ישירות על שחרור הסידן הפרה-סינפטי; (ב) ניסוח חלקי; (ג) התוצאה היא דה-פולריזציה ממושכת ולא רה-פולריזציה."},
    {"topic":"חלוקת נוזלי הגוף","q":"למה מניטול עוזר בטיפול בבצקת מוחית עם סיכון לשבץ?","o":["מפעיל תעלות נתרן-אשלגן","משמש אלקטרוליט אפקטיבי שמחזיר את המתח לדפנות הקפילרות","הוספתו לפלזמה מסייעת להוצאת נוזלים עודפים מרקמת המוח","הוספתו לרקמת המוח מסייעת לספיחת נוזלים מהתאים לפלזמה"],"a":2,"e":"מניטול הוא חומר אוסמוטי שאינו חוצה את מחסום הדם-מוח; הוספתו לפלזמה מעלה את האוסמולריות התוך-וסקולרית ו'מושכת' מים עודפים מרקמת המוח אל מחזור הדם — מפחית בצקת ולחץ תוך-גולגולתי. ניתוח מסיחים: (א) אינו מנגנון הפעולה; (ב) ניסוח שגוי; (ד) מניטול ניתן לפלזמה (תוך-ורידי), לא לרקמת המוח."},
    {"topic":"מבנה הקרום - מעבר חומרים","q":"איזה מהאברונים שומר באופן ישיר על רמת הסידן בציטוזול?","o":["גרעין התא","פרוטאוזום","sER (רשתית אנדופלזמטית חלקה)","ליזוזום"],"a":2,"e":"הרשתית האנדופלזמטית החלקה (sER; בשריר — ה-SR) היא מאגר הסידן התוך-תאי המרכזי, ומווסתת ישירות את ריכוז הסידן בציטוזול דרך משאבות SERCA ותעלות שחרור. ניתוח מסיחים: (א) הגרעין אינו מאגר סידן מווסת; (ב) הפרוטאוזום מפרק חלבונים; (ד) הליזוזום עוסק בפירוק, ותרומתו לאגירת סידן משנית."},
    {"topic":"פוטנציאל הפעולה בשריר הלב המתכווץ","q":"בהיפרקלמיה (K⁺ חוץ-תאי גבוה), מה יקרה בהתכווצות שריר הלב?","o":["היפרפולריזציה ולכן קושי לייצר פפ","דה-פולריזציה כך שקל יותר לייצר פפ בתחילה, אך רה-פולריזציה לא תקינה ולכן קושי לייצר פפ נוספים","ללא שינוי במתח","רה-פולריזציה מוגברת כך שיהיו יותר פפ"],"a":1,"e":"K⁺ חוץ-תאי גבוה מעלה (מדה-פולריז) את מתח המנוחה — בתחילה הסף נגיש יותר, אך הדה-פולריזציה המתמשכת מנטרלת תעלות נתרן ופוגעת בהולכה וברה-פולריזציה התקינה, ולכן קשה לייצר פוטנציאלי פעולה נוספים (סיכון להפרעות קצב). ניתוח מסיחים: (א) היפרקלמיה מדה-פולריזת, לא מהיפרפולריזת; (ג),(ד) שגויים — יש שינוי משמעותי במתח ופגיעה ביכולת הירי."},
    {"topic":"פוטנציאל מנוחה","q":"כיצד יושפע מתח הממברנה אם תעלות האשלגן ייסגרו בחסם מלאכותי?","o":["דה-פולריזציה","רה-פולריזציה","היפר-פולריזציה","לא ישתנה"],"a":0,"e":"מתח המנוחה קרוב לפוטנציאל נרנסט של האשלגן בזכות זרימת K⁺ החוצה דרך תעלות הדליפה. חסימת תעלות האשלגן מפחיתה את יציאת ה-K⁺, והמתח נע התרחק מ-E_K לכיוון חיובי יותר — דה-פולריזציה. ניתוח מסיחים: (ב),(ג) רה/היפר-פולריזציה הן בכיוון ההפוך; (ד) המתח כן ישתנה — האשלגן הוא הקובע העיקרי של מתח המנוחה."},
    {"topic":"נוזלי הגוף ואוסמולריות","q":"תא דם אדום הוכנס לתמיסה עם 0.3M אוריאה ו-0.1M NaCl — כיצד תוגדר התמיסה ביחס לסביבה החוץ-תאית?","o":["היפראוסמוטית והיפרטונית","היפראוסמוטית והיפוטונית","היפואוסמוטית והיפרטונית","היפואוסמוטית והיפוטונית"],"a":1,"e":"אוסמולריות: אוריאה 0.3 + NaCl 0.1M×2 = 0.2, סה״כ ~0.5 אוסמ'/ל' — גבוה מהפלזמה (~0.3) ⇒ היפראוסמוטית. טוניות: אוריאה חדירה (חוצה את הממברנה ולכן אינה 'אפקטיבית'), כך שרק ה-NaCl (0.2 אוסמ' אפקטיבי) נספר — נמוך מ-0.3 ⇒ היפוטונית. לכן התמיסה היפראוסמוטית אך היפוטונית, והתא יתנפח. ניתוח מסיחים: (א) שגוי בטוניות; (ג),(ד) שגויים באוסמולריות. הבחנה זו (אוסמולריות מול טוניות) היא לב השאלה."},
    {"topic":"העברה סינפטית","q":"מהי סינפסת עצב-שריר?","o":["סינפסה אדרנרגית","סינפסה כולינרגית","סינפסה חשמלית","כניסת קצה האקסון עד ל-t-tubule"],"a":1,"e":"הצומת העצבי-שרירי בשריר השלד הוא סינפסה כולינרגית — הנוירוטרנסמיטר הוא אצטילכולין הנקשר לרצפטור הניקוטיני על הסרקולמה. ניתוח מסיחים: (א) אדרנרגי שייך למערכת הסימפתטית; (ג) זו סינפסה כימית, לא חשמלית; (ד) תיאור שגוי של המבנה."},
    {"topic":"הולכה קפיצנית ומיאלין","q":"מעוררים אקסון במרחקים הולכים ומתרחקים — מה קורה?","o":["דעיכה כתלות במרחק, אם העירור תת-סיפי","דעיכה כתלות במרחק, אם העירור אינו תת-סיפי","חסר","חסר"],"a":0,"e":"גירוי תת-סיפי יוצר פוטנציאל מדורג פסיבי הדועך אקספוננציאלית עם המרחק (לפי קבוע המרחק). רק גירוי על-סיפי מצית פוטנציאל פעולה 'הכל-או-כלום' המתפשט ללא דעיכה. ניתוח מסיחים: (ב) על-סיפי דווקא אינו דועך; (ג),(ד) חסרים."},
    {"topic":"צימוד עירור-כיווץ בשריר השלד","q":"כיצד מוסבר החלק העולה בעקומת אורך-מתח בשריר שלד?","o":["האלמנטים האלסטיים נמתחים","ככל שהשריר נמתח יש יותר חפיפה אקטין-מיוזין עד לאורך אופטימלי","מגויסות עוד יחידות כיווץ","חסר"],"a":1,"e":"בחלק העולה של העקומה, מתיחה מאורך קצר מגדילה בהדרגה את החפיפה בין חוטי האקטין למיוזין (יותר גשרי-רוחב אפשריים) עד לאורך האופטימלי שבו הכוח מרבי. ניתוח מסיחים: (א) מתח אלסטי פסיבי שייך לחלק אחר של העקומה; (ג) גיוס יחידות הוא מודולציה נוירונית, לא מנגנון אורך-מתח; (ד) חסר."},
    {"topic":"צימוד עירור-כיווץ בשריר השלד","q":"לאן נקשר הסידן (בהפעלת כיווץ שריר השלד)?","o":["טרופונין C","תתי-היחידות של הטרופומיוזין","אקטין","מיוזין"],"a":0,"e":"הסידן נקשר לטרופונין C, גורם לשינוי קונפורמציה המזיז את הטרופומיוזין וחושף את אתרי הקישור על האקטין למיוזין. ניתוח מסיחים: (ב) הטרופומיוזין מוזז כתוצאה, אינו קושר את הסידן; (ג),(ד) אקטין ומיוזין אינם קושרי הסידן הרגולטורי."},
    {"topic":"הרפיית שריר ותפקיד ה-SR","q":"תא שריר שלד הוכנס לתמיסה ללא סידן וניתנו גירויים — מה נכון?","o":["מקור הסידן חוץ-תאי ולכן לא יתרחש כיווץ","סידן ייצא דרך RYR1 מה-SR","סידן ייצא דרך DHPR","חסר"],"a":1,"e":"בשריר השלד הסידן לכיווץ משוחרר מה-SR דרך RYR1 בצימוד מכני ל-DHPR — ולכן הכיווץ אינו תלוי בסידן חוץ-תאי ויתרחש גם בתמיסה נטולת סידן (בשונה משריר הלב). ניתוח מסיחים: (א) שגוי לשריר שלד; (ג) DHPR הוא החיישן הממברנלי המפעיל את RYR1, לא תעלת השחרור עצמה; (ד) חסר."},
    {"topic":"מודולציה של כוח - גיוס וסיכום","q":"מה מאפשר את המתיחה הפסיבית של הגיד?","o":["אקטין","מיוזין","קולגן ואלסטין","—"],"a":2,"e":"הגיד בנוי בעיקר מקולגן (חוזק מתיחה) ומאלסטין (גמישות), ושילובם מאפשר את התכונות המכניות והמתיחה הפסיבית. ניתוח מסיחים: (א),(ב) אקטין ומיוזין הם חלבוני הכיווץ בתוך תא השריר, לא רכיבי הגיד."},
    {"topic":"מבנה הקרום - מעבר חומרים","q":"מתי הדיפוזיה טובה יותר?","o":["הפרש ריכוזים גבוה, טמפ' גבוהה, צמיגות נמוכה","הפרש נמוך, טמפ' גבוהה, צמיגות נמוכה","הפרש נמוך, טמפ' נמוכה, צמיגות גבוהה","הפרש גבוה, טמפ' נמוכה, צמיגות גבוהה"],"a":0,"e":"לפי חוק פיק, קצב הדיפוזיה עולה עם הפרש הריכוזים והטמפרטורה (אנרגיה קינטית) ויורד עם הצמיגות (התנגדות התווך). השילוב האופטימלי: הפרש גבוה, טמפ' גבוהה, צמיגות נמוכה. ניתוח מסיחים: (ב),(ג),(ד) כוללים גורם אחד או יותר הפועל נגד הדיפוזיה."},
    {"topic":"מבנה הקרום - אסימטריה ונזילות","q":"מה בתאי אפיתל מאפשר העברה וקטוריאלית (חד-כיוונית)?","o":["תאים לא-פולריים","חלבונים ממברנליים מפוזרים אחיד","gap junctions","tight junctions"],"a":3,"e":"צמתים הדוקים (tight junctions) יוצרים 'גדר' המפרידה בין הדומיין האפיקלי לבזולטרלי ומונעת ערבוב חלבוני קרום ביניהם — וכך נשמרת קוטביות המאפשרת הובלה וקטוריאלית. ניתוח מסיחים: (א),(ב) דווקא היעדר קוטביות; (ג) gap junctions מחברים ציטופלזמות, לא יוצרים קוטביות."},
    {"topic":"הולכה קפיצנית ומיאלין","q":"כיצד תורמים יוני נתרן ליצירת פוטנציאל פעולה באקסון עטוף מיאלין?","o":["סביבה עשירת-נתרן חשובה ליצירת המיאלין","ריכוז נתרן גבוה מעודד מרווחים במיאלין","יותר נתרן עובר בדיפוזיה דרך המיאלין","נתרן הכרחי ליצירה מחדש של פוטנציאל פעולה במפרצי רנוויה"],"a":3,"e":"בהולכה קפיצנית פוטנציאל הפעולה 'מתחדש' רק במפרצי רנוויה — אזורים חשופים העשירים בתעלות נתרן תלויות-מתח; כניסת הנתרן שם מצמררת מחדש את הספייק לאורך האקסון. ניתוח מסיחים: (א),(ב),(ג) שגויים — המיאלין מבודד וחוסם זרמים, והנתרן אינו עובר דרכו."},
    {"topic":"מבנה הקרום - אסימטריה ונזילות","q":"איזו תכונה של הפוספוליפיד תורמת להיווצרות הדו-שכבה?","o":["הידרופיליות","הידרופוביות","אמפיפיליות","שומניות"],"a":2,"e":"הפוספוליפיד אמפיפילי — ראש קוטבי הידרופילי וזנבות הידרופוביים. בסביבה מימית הזנבות מתכנסים פנימה והראשים החוצה, וכך נוצרת ספונטנית דו-שכבה. ניתוח מסיחים: (א),(ב) כל אחת לבדה אינה מסבירה את הארגון; (ד) 'שומניות' אינה התכונה המדויקת."},
    {"topic":"מבנה הקרום - מעבר חומרים","q":"מה מתאר בקרה על מעבר דרך אקוופורינים בגוף האדם?","o":["סגירת תעלות ע'י קשירת ATP","שליטה על כמות התעלות בממברנה ע'י הורמון","פתיחת התעלות ע'י קשירת הורמון","סגירת התעלות ע'י קשירת ליגנד"],"a":1,"e":"בכליה, ADH (וזופרסין) מבקר את מספר תעלות ה-AQP2 בממברנה האפיקלית — מקדם הכנסתן (exocytosis) ובכך מגביר ספיגת מים. הבקרה היא על כמות התעלות. ניתוח מסיחים: (א),(ג),(ד) פתיחה/סגירה ישירה ע'י ATP/ליגנד אינה מנגנון הבקרה של אקוופורינים."},
    {"topic":"מבנה הקרום - נשאים מול תעלות","q":"מה מאפיין מעבר מולקולות בהובלה אקטיבית משנית?","o":["שתי מולקולות עוברות כל אחת נגד מפל הריכוז שלה","מולקולה אחת נצמדת למעבר של מולקולה אחרת העוברת לפי מפלה","שימוש ב-ATP להעברת מולקולה יחידה","שימוש ב-ATP להעברת 2 מולקולות לפי מפלן"],"a":1,"e":"בהובלה אקטיבית משנית, מפל הריכוז (האלקטרוכימי) של מולקולה אחת (לרוב נתרן) — שנשמר ע'י משאבה ראשונית — מנצל את מעברה 'במורד' כדי לגרור מולקולה שנייה 'במעלה' מפלה, ללא שימוש ישיר ב-ATP. ניתוח מסיחים: (ג) מתאר הובלה אקטיבית ראשונית (משאבה); (א),(ד) ניסוחים שגויים."},
    {"topic":"נוזלי הגוף ואוסמולריות","q":"מהו היון השכיח ביותר ב-ECF?","o":["נתרן","אשלגן","כלור","ביקרבונט"],"a":0,"e":"נתרן (Na⁺) הוא הקטיון השכיח ביותר בנוזל החוץ-תאי (~140 mM) וקובע במידה רבה את האוסמולריות שלו. ניתוח מסיחים: (ב) אשלגן הוא היון התוך-תאי השכיח; (ג),(ד) כלור וביקרבונט הם אניונים בריכוז נמוך יותר מהנתרן."},
    {"topic":"משוואת נרנסט","q":"מה יקרה לפוטנציאל שיווי המשקל של יון X כשהתא מעלה את מספר התעלות הפתוחות הסלקטיביות ל-X?","o":["פוטנציאל שיווי המשקל לא ישתנה, אך מתח הממברנה ישתנה","שניהם לא ישתנו","שניהם ישתנו","פוטנציאל שיווי המשקל ישתנה, אך מתח הממברנה לא"],"a":0,"e":"פוטנציאל שיווי המשקל (נרנסט) תלוי אך ורק ביחס ריכוזי היון משני צידי הממברנה — לא במספר התעלות. תוספת תעלות פתוחות ל-X מגדילה את חדירות X ומסיטה את מתח הממברנה לכיוון E_X. ניתוח מסיחים: (ב),(ג),(ד) מייחסים שינוי לפוטנציאל נרנסט — שאינו משתנה."},
    {"topic":"חלוקת נוזלי הגוף","q":"מהו יחס הלחץ הקולואיד-אוסמוטי (אונקוטי) בין הפלזמה לנוזל הבין-תאי (ISF)?","o":["בפלזמה גבוה יותר בגלל נוכחות חלבונים","בפלזמה נמוך יותר","שווה בשניהם","אין מידע"],"a":0,"e":"ריכוז החלבונים (אלבומין) בפלזמה גבוה בהרבה מאשר ב-ISF, ולכן הלחץ האונקוטי בפלזמה גבוה יותר — כוח המושך נוזל פנימה לקפילרה. ניתוח מסיחים: (ב),(ג) שגויים; (ד) חסר."},
    {"topic":"מבנה הקרום - אסימטריה ונזילות","q":"מי אחראי על הובלה וקטוריאלית באפיתל?","o":["Hemidesmosome","Tight junction","Gap junction","מיקרווילי"],"a":1,"e":"צמתים הדוקים מפרידים בין הדומיין האפיקלי לבזולטרלי ומונעים ערבוב חלבוני קרום ביניהם — וכך מאפשרים הובלה מכוונת (וקטוריאלית) של חומרים דרך האפיתל. ניתוח מסיחים: (א) hemidesmosome מעגן לבסיס; (ג) gap junction לתקשורת; (ד) מיקרווילי מגדילים שטח פנים אך אינם יוצרים את הקוטביות."},
    {"topic":"נוזלי הגוף ואוסמולריות","q":"איזו תמיסה תגרום לתא דם אדום להתפוצץ?","o":["איזו-אוסמוטית גלוקוז (300 mOsm)","היפר-אוסמוטית אוריאה (400 mOsm)","היפר-אוסמוטית NaCl (380 mOsm)","איזו-אוסמוטית NaCl (300 mOsm)"],"a":1,"e":"אוריאה חדירה לתא, ולכן אינה אוסמול אפקטיבי: גם בתמיסת אוריאה 400 mOsm אין כוח אוסמוטי אפקטיבי שמחזיק מים בחוץ, האוריאה והמים נכנסים והתא מתנפח עד לפיצוץ (התמיסה היפוטונית). ניתוח מסיחים: (ג) NaCl היפר-אוסמוטי מכווץ; (ד) NaCl איזוטוני — ללא שינוי; (א) גלוקוז איזו-אוסמוטי — קרוב לאיזוטוני."},
    {"topic":"צימוד עירור-כיווץ בשריר השלד","q":"מהו סדר הגודל של אורך סרקומר?","o":["ננומטרים","מיקרומטרים","סנטימטרים","מילימטרים"],"a":1,"e":"אורך הסרקומר הוא בסדר גודל של מיקרומטרים (~2-3 מיקרומטר באורך מנוחה). ניתוח מסיחים: (א) ננומטרים קטן מדי (סדר גודל של חלבונים בודדים); (ג),(ד) גדולים מדי (סדר גודל של השריר כולו)."},
    {"topic":"העברה סינפטית","q":"מה תפקיד הרצפטורים לנוירוטרנסמיטרים בצד הפוסט-סינפטי?","o":["לייצר פוטנציאל פעולה ישירות","לאפשר ספיגה חוזרת של הנוירוטרנסמיטר","לקשור את הליגנד ולקדם את התגובה הפוסט-סינפטית","לשמור על איזון יונים"],"a":2,"e":"הרצפטורים הפוסט-סינפטיים קושרים את הנוירוטרנסמיטר (הליגנד) ומתרגמים את הקישור לתגובה תאית — פתיחת תעלות (יונוטרופי) או הפעלת מסלול (מטבוטרופי) — כלומר העברת הסיגנל. ניתוח מסיחים: (א) הם יוצרים פוטנציאל מדורג, לא בהכרח פוטנציאל פעולה ישיר; (ב) הספיגה החוזרת היא תפקיד מובילים, לא הרצפטורים; (ד) אינו תפקידם העיקרי."},
    {"topic":"העברה סינפטית","q":"מה לא מתאר הולכה בין שני אקסונים המצומדים חשמלית?","o":["מעבר ישיר של זרם מאחד לשני","חיבור ע'י gap junctions","חיבור בעזרת קונקסינים","מעבר וזיקולות ישיר בין הסינפסות"],"a":3,"e":"בסינפסה חשמלית עובר זרם ישיר דרך ערוצי gap junction (קונקסינים) — אין שחרור/מעבר וזיקולות (זה מאפיין סינפסה כימית). ניתוח מסיחים: (א),(ב),(ג) מתארים נכון את ההולכה החשמלית."},
    {"topic":"הולכה קפיצנית ומיאלין","q":"מה נכון לגבי תאי גליה ב-CNS?","o":["מהווים עשירית מתאי המערכת","תאי שוואן הם הנפוצים ביותר ב-CNS","בעלי תפקיד חשוב בהולכת סיגנלים ובתפקוד מעגלים עצביים","אסטרוציטים קשורים רק למערכת החיסון"],"a":2,"e":"תאי הגליה תומכים באופן פעיל בהולכה ובתפקוד המעגלים העצביים — מיאלינציה, ויסות סביבת היונים והנוירוטרנסמיטרים, תמיכה מטבולית ועוד. ניתוח מסיחים: (א) הם כעשרות אחוזים (לא עשירית בלבד); (ב) תאי שוואן ב-PNS (ב-CNS אוליגודנדרוציטים); (ד) לאסטרוציטים תפקידים רבים מעבר לחיסון."},
    {"topic":"מודולציה של כוח - גיוס וסיכום","q":"מה מאפיין התכווצות שריר איזוטונית?","o":["מפעיל כוח אך אורכו אינו משתנה","מפעיל כוח קבוע וגם מתקצר","מתקצר ללא פיתוח כוח","שומר על אורכו ולא מפתח כוח"],"a":1,"e":"בכיווץ איזוטוני המתח (הכוח) נשאר קבוע והשריר מתקצר (תנועה כנגד עומס קבוע). ניתוח מסיחים: (א) מתאר כיווץ איזומטרי (אורך קבוע); (ג),(ד) שגויים — בכיווץ מתפתח כוח."},
    {"topic":"סוגי סיבי שריר השלד","q":"מהירות התקצרות שריר השלד תלויה ביחס ישר ב-?","o":["שטף הנתרן בדה-פולריזציה","שטף הסידן ב-T-tubules","שטף הסידן מה-SR","קצב פעילות ה-ATPase של ראשי המיוזין"],"a":3,"e":"מהירות ההתקצרות נקבעת בעיקר ע'י קצב מחזור גשרי-הרוחב — כלומר קצב פעילות ה-ATPase של המיוזין (הבסיס להבדל בין סיבים מהירים לאיטיים). ניתוח מסיחים: (א),(ב),(ג) שטפי יונים מתניעים את הכיווץ אך אינם הקובעים הישירים של מהירות ההתקצרות."}
  ]
};
